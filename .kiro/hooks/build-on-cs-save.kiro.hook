{
  "enabled": true,
  "name": "Build al guardar C#",
  "description": "Ejecuta dotnet build al guardar cualquier archivo .cs para detectar errores de compilación al instante",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.cs"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "dotnet build --no-restore -v quiet",
    "timeout": 60
  }
}