@page "/dev"
@model TalentManagement.Server.Pages.DevModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NovaHub — Selector de usuario dev</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 2rem; width: 360px; }
        .icon { font-size: 2.5rem; text-align: center; margin-bottom: .5rem; }
        h1 { font-size: 1.25rem; text-align: center; margin-bottom: .25rem; }
        p { font-size: .875rem; color: #94a3b8; text-align: center; margin-bottom: 1.5rem; }
        .users { display: flex; flex-direction: column; gap: .625rem; margin-bottom: 1.25rem; }
        .user-btn { display: flex; align-items: center; gap: .75rem; padding: .75rem 1rem; border-radius: 8px; border: 2px solid #334155; background: #0f172a; color: #e2e8f0; cursor: pointer; text-align: left; transition: border-color .15s; width: 100%; }
        .user-btn:hover, .user-btn.active { border-color: #6366f1; background: #1e1b4b; }
        .user-btn .emoji { font-size: 1.4rem; }
        .user-btn strong { display: block; font-size: .9rem; }
        .user-btn small { color: #94a3b8; font-size: .75rem; }
        .divider { display: flex; align-items: center; gap: .5rem; margin: 1rem 0; color: #475569; font-size: .75rem; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #334155; }
        .ms-btn { display: flex; align-items: center; justify-content: center; gap: .5rem; width: 100%; padding: .75rem; border-radius: 8px; border: 2px solid #334155; background: #0f172a; color: #e2e8f0; cursor: pointer; font-size: .9rem; transition: border-color .15s; }
        .ms-btn:hover { border-color: #0ea5e9; }
        .badge { display: inline-block; background: #6366f1; color: #fff; font-size: .65rem; padding: .1rem .4rem; border-radius: 999px; margin-left: .25rem; vertical-align: middle; }
    </style>
</head>
<body>
<div class="card">
    <div class="icon">🛠️</div>
    <h1>Modo desarrollo</h1>
    <p>Selecciona un usuario de prueba o usa tu cuenta de Microsoft.</p>

    <div class="users">
        @foreach (var u in Model.Users)
        {
            <form method="post" asp-page-handler="SetUser">
                <input type="hidden" name="email" value="@u.Email" />
                <button type="submit" class="user-btn @(Model.ActiveEmail == u.Email ? "active" : "")">
                    <span class="emoji">@u.Icon</span>
                    <span>
                        <strong>@u.Label @(Model.ActiveEmail == u.Email ? "" : "")</strong>
                        <small>@u.Email</small>
                    </span>
                    @if (Model.ActiveEmail == u.Email) { <span class="badge">activo</span> }
                </button>
            </form>
        }
    </div>

    <div class="divider">o</div>

    <form method="post" asp-page-handler="UseReal">
        <button type="submit" class="ms-btn">
            🏢 Usar cuenta de Microsoft (token real)
            @if (Model.ActiveEmail == null) { <span class="badge">activo</span> }
        </button>
    </form>
</div>
</body>
</html>
