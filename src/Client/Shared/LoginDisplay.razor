@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject AuthInfoService AuthInfo
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<AuthorizeView>
    <Authorized>
        <div class="topbar-user">
            <div class="avatar avatar-sm" style="background:#312e81;color:#a5b4fc;">
                @AuthInfo.Iniciales
            </div>
            <span class="topbar-user-name">@AuthInfo.Nombre</span>
            <button class="btn btn-ghost btn-sm" @onclick="LogoutLocal">Salir</button>
        </div>
    </Authorized>
    <NotAuthorized>
        <button class="btn btn-primary btn-sm" @onclick="Login">Iniciar sesion</button>
    </NotAuthorized>
</AuthorizeView>

@inject SignOutSessionStateManager SignOutManager

@code {
    private void Login() => Navigation.NavigateToLogin("authentication/login");
    private async Task LogoutLocal()
    {
        AuthInfo.Invalidar();
        await SignOutManager.SetSignOutState();
        Navigation.NavigateTo("authentication/logout");
    }

    protected override async Task OnInitializedAsync()
    {
        // Esperar a que el estado de autenticacion este listo
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            AuthInfo.Invalidar();
            await AuthInfo.LoadAsync();
            StateHasChanged();
        }
    }
}
