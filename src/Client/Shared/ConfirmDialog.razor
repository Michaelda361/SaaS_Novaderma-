@if (Visible)
{
    <div class="confirm-overlay" role="presentation">
        <div class="confirm-box" role="alertdialog" aria-modal="true" aria-labelledby="confirm-dialog-title" aria-describedby="confirm-dialog-desc">
            <div class="confirm-icon" aria-hidden="true">🗑️</div>
            <div class="confirm-title" id="confirm-dialog-title">@Title</div>
            <div class="confirm-msg" id="confirm-dialog-desc">@Message</div>
            <div class="confirm-actions">
                <button type="button" class="btn btn-ghost" @onclick="Cancel">Cancelar</button>
                <button type="button" class="btn btn-danger" @onclick="Confirm">Eliminar</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "¿Eliminar registro?";
    [Parameter] public string Message { get; set; } = "Esta acción no se puede deshacer.";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel()  => await OnCancel.InvokeAsync();
}
