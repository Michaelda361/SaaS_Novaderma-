@inject NotificacionesService Notificaciones
@inject NavigationManager Nav
@implements IDisposable

<div class="campana-wrapper" @onclick:stopPropagation>
    <button type="button"
            id="campana-notif-toggle"
            class="campana-btn @(abierto ? "campana-btn--active" : "")"
            @onclick="TogglePanel"
            title="Notificaciones"
            aria-label="Notificaciones"
            aria-expanded="@abierto"
            aria-controls="campana-notif-panel">
        <span aria-hidden="true">🔔</span>
        @if (Notificaciones.NoLeidas > 0)
        {
            <span class="campana-badge" aria-hidden="true">@(Notificaciones.NoLeidas > 9 ? "9+" : Notificaciones.NoLeidas.ToString())</span>
            <span class="sr-only">@Notificaciones.NoLeidas no leídas</span>
        }
    </button>

    @if (abierto)
    {
        <div id="campana-notif-panel" class="campana-panel" role="region" aria-labelledby="campana-notif-heading">
            <div class="campana-panel-header">
                <span class="font-medium text-sm" id="campana-notif-heading">Notificaciones</span>
                <div class="campana-header-actions">
                    @if (Notificaciones.Historial.Any(n => !n.Leida))
                    {
                        <button type="button" class="btn btn-ghost btn-sm btn-campana-compact"
                                @onclick="MarcarTodasLeidas">
                            Marcar leidas
                        </button>
                    }
                    @if (Notificaciones.Historial.Any())
                    {
                        <button type="button" class="btn btn-ghost btn-sm btn-icon btn-campana-compact"
                                @onclick="Limpiar" title="Limpiar notificaciones" aria-label="Limpiar notificaciones"><span aria-hidden="true">×</span></button>
                    }
                </div>
            </div>

            @if (!Notificaciones.Historial.Any())
            {
                <div class="campana-empty">
                    <span class="campana-empty-emoji" aria-hidden="true">🔔</span>
                    <p class="text-sm text-muted campana-empty-text">Sin notificaciones</p>
                </div>
            }
            else
            {
                <div class="campana-lista">
                    @foreach (var n in Notificaciones.Historial)
                    {
                        var notif = n;
                        <div class="campana-item @(!n.Leida ? "campana-item--nueva" : "")"
                             @onclick="() => AbrirNotificacion(notif)">
                            <div class="campana-item-icono" aria-hidden="true">@IconoPorTipo(n.Tipo)</div>
                            <div class="campana-item-body">
                                <div class="campana-item-titulo">@n.Titulo</div>
                                <div class="campana-item-cuerpo">@n.Cuerpo</div>
                                <div class="campana-item-fecha">@FormatFecha(n.Fecha)</div>
                            </div>
                            @if (!n.Leida)
                            {
                                <div class="campana-punto-nuevo" aria-hidden="true"></div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <div class="campana-overlay" @onclick="CerrarPanel" aria-hidden="true"></div>
    }
</div>

@code {
    private bool abierto = false;

    protected override void OnInitialized()
    {
        Notificaciones.OnCambio += OnNotificacionCambio;
    }

    private void OnNotificacionCambio() => InvokeAsync(StateHasChanged);

    private void TogglePanel() => abierto = !abierto;
    private void CerrarPanel() => abierto = false;

    private void MarcarTodasLeidas()
    {
        Notificaciones.MarcarTodasLeidas();
    }

    private void Limpiar()
    {
        Notificaciones.LimpiarHistorial();
        abierto = false;
    }

    private void AbrirNotificacion(NotificacionItem n)
    {
        Notificaciones.MarcarLeida(n.Id);
        abierto = false;
        if (!string.IsNullOrWhiteSpace(n.Url))
            Nav.NavigateTo(n.Url);
    }

    private static string IconoPorTipo(string tipo) => tipo switch
    {
        "solicitud_nueva"         => "📄",
        "solicitud_resuelta"      => "✅",
        "cuestionario_respondido" => "📝",
        "certificado_emitido"     => "🏆",
        "inscripcion_creada"      => "📚",
        "capacitacion_publicada"  => "🎓",
        _                         => "🔔"
    };

    private static string FormatFecha(DateTime fecha)
    {
        var diff = DateTime.Now - fecha;
        if (diff.TotalMinutes < 1) return "Ahora";
        if (diff.TotalMinutes < 60) return $"Hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"Hace {(int)diff.TotalHours} h";
        return fecha.ToString("dd/MM HH:mm");
    }

    public void Dispose()
    {
        Notificaciones.OnCambio -= OnNotificacionCambio;
    }
}
