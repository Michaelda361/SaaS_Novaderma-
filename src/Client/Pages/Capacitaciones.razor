                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("descargarArchivo", base64, "historial_completo_capacitaciones.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
