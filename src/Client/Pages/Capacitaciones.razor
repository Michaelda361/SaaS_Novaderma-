@page "/capacitaciones"
@attribute [PageTitle("Capacitaciones")]
@attribute [Authorize]
@inject CapacitacionApiService ApiService
@inject AreaApiService AreaService
@inject ColaboradorApiService ColaboradorService
@inject InscripcionApiService InscripcionService
@inject CuestionarioApiService CuestionarioService
@inject AuthInfoService AuthInfo
@inject NavigationManager Nav
@inject NotificacionesService Notificaciones
@inject IJSRuntime JS
@implements IAsyncDisposable
<Toast @ref="toast" />
<ConfirmDialog Visible="confirmVisible"
               Message="¿Seguro que deseas eliminar esta capacitación? Esta acción no se puede deshacer."
               OnConfirm="ConfirmarEliminar"
               OnCancel="() => confirmVisible = false" />

<div class="page-header">
    <div>
        <h2 class="page-title">Capacitaciones</h2>
        <p class="page-subtitle">
            @if (PuedeGestionar) { <span>Gestiona y realiza seguimiento de las capacitaciones</span> }
            else { <span>Capacitaciones disponibles para ti</span> }
        </p>
    </div>
    @if (PuedeGestionar && tabActiva == "capacitaciones")
    {
        <button class="btn btn-primary btn-sm" @onclick="AbrirModal">+ Nueva capacitación</button>
    }
</div>

@if (PuedeGestionar)
{
    <div class="admin-tabs">
        <button class="admin-tab @(tabActiva == "capacitaciones" ? "admin-tab--active" : "")"
                @onclick='() => tabActiva = "capacitaciones"'>
            📚 Capacitaciones
            @if (capacitaciones is not null)
            {
                <span class="admin-tab-count">@capacitaciones.Count</span>
            }
        </button>
        <button class="admin-tab @(tabActiva == "historial" ? "admin-tab--active" : "")"
                @onclick='() => { tabActiva = "historial"; _ = CargarHistorial(); }'>
            📋 Historial
        </button>
    </div>
}

@if (tabActiva == "historial" && PuedeGestionar)
{
    @if (cargandoHistorial)
    {
        <div class="loading"><div class="spinner"></div> Cargando historial...</div>
    }
    else if (!historialItems.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h3>Sin historial</h3>
            <p>Ningún colaborador ha completado capacitaciones aún.</p>
        </div>
    }
    else
    {
        <style>
            .historial-split-container {
                display: flex;
                gap: 1.25rem;
                align-items: stretch;
                margin-top: 1rem;
            }

            @@media (max-width: 992px) {
                .historial-split-container {
                    flex-direction: column;
                }
            }

            .historial-sidebar {
                flex: 0 0 340px;
                background: var(--surface, #ffffff);
                border: 1px solid var(--border, #e2e8f0);
                border-radius: var(--radius, 8px);
                display: flex;
                flex-direction: column;
                height: 620px;
            }

            .historial-sidebar-header {
                padding: 0.75rem 1rem;
                border-bottom: 1px solid var(--border, #e2e8f0);
                background: var(--bg, #f8fafc);
                display: flex;
                flex-direction: column;
                gap: 0.5rem;
            }

            .historial-collaborator-list {
                flex: 1;
                overflow-y: auto;
                background: var(--surface, #ffffff);
            }

            .collaborator-item-btn {
                width: 100%;
                text-align: left;
                padding: 0.75rem 1rem;
                border: none;
                background: none;
                border-bottom: 1px solid var(--border, #f1f5f9);
                display: flex;
                align-items: center;
                justify-content: space-between;
                cursor: pointer;
                transition: all 0.15s ease-in-out;
                border-left: 4px solid transparent;
            }

            .collaborator-item-btn:hover {
                background-color: var(--border, #f1f5f9);
                opacity: 0.95;
            }

            .collaborator-item-btn--active {
                background-color: rgba(34, 110, 253, 0.05) !important;
                border-left-color: var(--primary, #0d6efd);
            }

            .collaborator-item-info {
                display: flex;
                flex-direction: column;
                gap: 0.2rem;
                min-width: 0;
                flex: 1;
                margin-right: 0.5rem;
            }

            .collaborator-item-name {
                font-weight: 600;
                color: var(--text, #1e293b);
                font-size: 0.875rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .collaborator-item-sub {
                font-size: 0.75rem;
                color: var(--text-muted, #64748b);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .collaborator-badge-count {
                background: var(--border, #e2e8f0);
                color: var(--text-muted, #475569);
                font-size: 0.7rem;
                font-weight: 700;
                padding: 0.15rem 0.5rem;
                border-radius: 12px;
                white-space: nowrap;
            }

            .collaborator-item-btn--active .collaborator-badge-count {
                background: var(--primary, #0d6efd);
                color: #ffffff;
            }

            .historial-detail-panel {
                flex: 1;
                display: flex;
                flex-direction: column;
                gap: 1rem;
                min-width: 0;
            }

            .detail-colab-card {
                background: var(--surface, #ffffff);
                border: 1px solid var(--border, #e2e8f0);
                border-radius: var(--radius, 8px);
                padding: 1rem 1.25rem;
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .detail-colab-avatar {
                width: 44px;
                height: 44px;
                background: rgba(34, 110, 253, 0.1);
                color: var(--primary, #0d6efd);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.1rem;
                font-weight: 700;
            }

            .detail-colab-meta {
                display: flex;
                flex-direction: column;
                gap: 0.15rem;
                min-width: 0;
            }

            .detail-colab-name {
                font-size: 1.05rem;
                font-weight: 700;
                color: var(--text, #1e293b);
                margin: 0;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .detail-colab-subtitle {
                font-size: 0.75rem;
                color: var(--text-muted, #64748b);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .detail-stats {
                display: flex;
                gap: 1rem;
                margin-left: auto;
            }

            .detail-stat-item {
                display: flex;
                flex-direction: column;
                align-items: center;
                background: var(--bg, #f8fafc);
                padding: 0.35rem 0.75rem;
                border-radius: 6px;
                border: 1px solid var(--border, #e2e8f0);
            }

            .detail-stat-val {
                font-size: 0.95rem;
                font-weight: 700;
            }

            .detail-stat-lbl {
                font-size: 0.65rem;
                color: var(--text-muted, #64748b);
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }
        </style>

        <div class="historial-split-container">
            <!-- Sidebar: Lista de Colaboradores -->
            <div class="historial-sidebar">
                <div class="historial-sidebar-header">
                    <div class="search-input-wrap" style="width: 100%;">
                        <span class="search-icon">🔍</span>
                        <input type="search" placeholder="Buscar colaborador..."
                               @bind="BusquedaHistorial" @bind:event="oninput" style="width: 100%;" />
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; color: var(--text-muted);">
                        <span>Colaboradores: <strong>@ColaboradoresFiltrados.Count()</strong></span>
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="ExportarTodoCsv" style="padding: 0.2rem 0.5rem; font-size: 0.7rem; border-radius: 4px; display: flex; align-items: center; gap: 0.25rem;">
                            📥 Exportar Todo
                        </button>
                    </div>
                </div>

                <div class="historial-collaborator-list">
                    @if (!ColaboradoresFiltrados.Any())
                    {
                        <div style="padding: 2rem; text-align: center; color: var(--text-muted); font-size: 0.85rem;">
                            No se encontraron colaboradores.
                        </div>
                    }
                    else
                    {
                        @foreach (var c in ColaboradoresFiltrados)
                        {
                            var col = c;
                            var activeClass = ColaboradorSeleccionado?.Id == col.Id ? "collaborator-item-btn--active" : "";
                            <button type="button" class="collaborator-item-btn @activeClass" @onclick="() => SeleccionarColaborador(col.Id)">
                                <div class="collaborator-item-info">
                                    <span class="collaborator-item-name">@col.Nombre</span>
                                    <span class="collaborator-item-sub">@col.Area · @col.Cargo</span>
                                </div>
                                <span class="collaborator-badge-count">@col.Items.Count</span>
                            </button>
                        }
                    }
                </div>
            </div>

            <!-- Detail Panel: Historial del Colaborador Seleccionado -->
            <div class="historial-detail-panel">
                @if (ColaboradorSeleccionado is null)
                {
                    <div class="card" style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 400px; margin: 0;">
                        <span style="font-size: 3rem;">👥</span>
                        <h3 style="margin-top: 1rem; color: var(--text);">Selecciona un Colaborador</h3>
                        <p class="text-sm text-muted">Elige un colaborador de la lista para ver su historial completo de capacitaciones.</p>
                    </div>
                }
                else
                {
                    <!-- Resumen del Colaborador -->
                    <div class="detail-colab-card">
                        <div class="detail-colab-avatar">
                            @ObtenerIniciales(ColaboradorSeleccionado.Nombre)
                        </div>
                        <div class="detail-colab-meta">
                            <h3 class="detail-colab-name">@ColaboradorSeleccionado.Nombre</h3>
                            <span class="detail-colab-subtitle">@ColaboradorSeleccionado.Email · @ColaboradorSeleccionado.Area (<strong>@ColaboradorSeleccionado.Cargo</strong>)</span>
                        </div>
                        <div class="detail-stats">
                            <div class="detail-stat-item">
                                <span class="detail-stat-val text-success">@ColaboradorSeleccionado.Items.Count(h => h.Resultado?.Aprobado == true)</span>
                                <span class="detail-stat-lbl">Aprobadas</span>
                            </div>
                            <div class="detail-stat-item">
                                <span class="detail-stat-val text-danger">@ColaboradorSeleccionado.Items.Count(h => h.Resultado is not null && !h.Resultado.Aprobado)</span>
                                <span class="detail-stat-lbl">No Aprobadas</span>
                            </div>
                            <div class="detail-stat-item">
                                <span class="detail-stat-val text-muted">@ColaboradorSeleccionado.Items.Count(h => h.Resultado is null)</span>
                                <span class="detail-stat-lbl">Pendientes</span>
                            </div>
                        </div>
                    </div>

                    <!-- Tabla de Capacitaciones del Colaborador -->
                    <div class="card" style="margin: 0; flex: 1; display: flex; flex-direction: column; overflow: hidden;">
                        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
                            <span class="card-title">Historial de Capacitaciones</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ExportarColaboradorCsv" style="padding: 0.35rem 0.75rem; font-size: 0.75rem; border-radius: 6px; display: flex; align-items: center; gap: 0.25rem;">
                                📥 Exportar Excel/CSV
                            </button>
                        </div>
                        <div class="table-wrapper" style="flex: 1; overflow-y: auto;">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Capacitación</th>
                                        <th>Fecha Inscripción</th>
                                        <th>Fecha Finalización</th>
                                        <th>Calificación</th>
                                        <th>Resultado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in ColaboradorSeleccionadoItemsPagina)
                                    {
                                        <tr>
                                            <td>
                                                <div class="font-medium">@h.Inscripcion.CapacitacionNombre</div>
                                            </td>
                                            <td class="text-sm text-muted">@h.Inscripcion.FechaInscripcion.ToString("dd/MM/yyyy")</td>
                                            <td class="text-sm">
                                                @(h.Inscripcion.FechaFinalizacion?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")
                                            </td>
                                            <td class="text-sm font-medium">
                                                @if (h.Inscripcion.Calificacion.HasValue)
                                                {
                                                    <div class="@(h.Inscripcion.Calificacion >= 7 ? "text-success" : "text-danger")">
                                                        @h.Inscripcion.Calificacion.Value.ToString("0.##")
                                                    </div>
                                                    @if (h.Resultado is not null)
                                                    {
                                                        <div class="text-xs text-muted" style="font-weight:normal;">
                                                            Eval: @h.Resultado.Correctas/@h.Resultado.TotalPreguntas
                                                        </div>
                                                    }
                                                }
                                                else if (h.Resultado is not null)
                                                {
                                                    @($"{h.Resultado.Correctas} / {h.Resultado.TotalPreguntas}")
                                                }
                                                else
                                                {
                                                    <span>—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (h.Resultado is null)
                                                { <span class="badge badge-gray">Pendiente</span> }
                                                else if (h.Resultado.Aprobado)
                                                { <span class="badge badge-success">✅ Aprobado</span> }
                                                else
                                                { <span class="badge badge-danger">❌ No aprobado</span> }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="pagination" style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.75rem 1rem;border-top:1px solid var(--border);">
                            <div class="text-sm text-muted">Página @paginaDetalleHistorial de @TotalPaginasDetalle</div>
                            <div>
                                <button class="btn btn-sm btn-secondary" disabled="@(!CanPrevDetalle)" @onclick="IrPaginaAnteriorDetalle">Anterior</button>
                                <button class="btn btn-sm btn-secondary" disabled="@(!CanNextDetalle)" @onclick="IrPaginaSiguienteDetalle">Siguiente</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@if (tabActiva == "capacitaciones")
{
<div class="card">
    <div class="card-header">
        <span class="card-title">Capacitaciones</span>
    </div>

    <div class="filter-bar">
        <div class="search-input-wrap">
            <span class="search-icon">🔍</span>
            <input type="search" placeholder="Buscar capacitación..."
                   @bind="busqueda" @bind:event="oninput" />
        </div>
        @if (!string.IsNullOrEmpty(busqueda))
        {
            <span class="text-sm text-muted">@Filtradas.Count resultado(s)</span>
        }
    </div>

    @if (cargando)
    {
        <div class="loading"><div class="spinner"></div> Cargando...</div>
    }
    else if (capacitaciones is null || capacitaciones.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">📚</div>
            <h3>Sin capacitaciones</h3>
            <p>@(PuedeGestionar ? "Crea la primera capacitación para comenzar." : "No hay capacitaciones disponibles aún.")</p>
        </div>
    }
    else if (Filtradas.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">🔍</div>
            <h3>Sin resultados</h3>
            <p>No hay capacitaciones que coincidan con los filtros.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th>Duración</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Inscritos</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Filtradas)
                    {
                        var estado = EstadoCapacitacion(c);
                        <tr>
                            <td>
                                <div class="font-medium">@c.Nombre</div>
                                @if (!string.IsNullOrEmpty(c.Descripcion))
                                {
                                    <div class="text-sm text-muted truncate" style="max-width:200px">@c.Descripcion</div>
                                }
                            </td>
                            <td><span class="badge @estado.Clase">@estado.Texto</span></td>
                            <td><span class="badge badge-info">@c.DuracionHoras h</span></td>
                            <td class="text-sm">@c.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td class="text-sm">@c.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge badge-gray">@c.TotalInscritos</span></td>
                            <td>
                                <div class="flex gap-2">
                                    <button class="btn btn-ghost btn-sm btn-icon"
                                            @onclick="() => VerDetalle(c.Id)" title="Ver detalle">👁️</button>
                                    @if (PuedeGestionar)
                                    {
                                        <button class="btn btn-ghost btn-sm btn-icon"
                                                @onclick="() => AbrirEditar(c)" title="Editar">✏️</button>
                                        <button class="btn btn-danger btn-sm btn-icon"
                                                @onclick="() => PedirConfirmacion(c.Id)" title="Eliminar">🗑️</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
}

@* Sección de capacitaciones completadas — solo para colaboradores *@
@if (AuthInfo.EsSoloColaborador && capacitacionesCompletadas.Any())
{
    <div style="margin-top:1.5rem;">
        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.75rem;">
            <span style="font-size:1.1rem;">🎓</span>
            <span class="font-medium">Completadas (@capacitacionesCompletadas.Count)</span>
            <span class="text-sm text-muted">— capacitaciones que ya completaste</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:.5rem;">
            @foreach (var c in (capacitaciones ?? []).Where(c => capacitacionesCompletadas.Contains(c.Id)))
            {
                var cap = c;
                <div style="display:flex;align-items:center;gap:.875rem;padding:.75rem 1rem;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);opacity:.75;">
                    <span style="font-size:1.25rem;">✅</span>
                    <div style="flex:1;min-width:0;">
                        <span class="font-medium text-sm">@c.Nombre</span>
                        @if (!string.IsNullOrEmpty(c.Descripcion))
                        {
                            <span class="text-xs text-muted" style="margin-left:.5rem;">@c.Descripcion</span>
                        }
                    </div>
                    <span class="badge badge-success" style="font-size:.7rem;">Completada</span>
                    <button class="btn btn-ghost btn-sm btn-icon"
                            @onclick="@(() => Nav.NavigateTo($"/capacitaciones/{cap.Id}"))"
                            title="Ver detalle">👁️</button>
                </div>
            }
        </div>
    </div>
}

@if (mostrarModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editandoId.HasValue ? "Editar capacitación" : "Nueva capacitación")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <EditForm Model="form" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Nombre *</label>
                            <InputText @bind-Value="form.Nombre" placeholder="Nombre de la capacitación" />
                            <ValidationMessage For="() => form.Nombre" class="validation-message" />
                        </div>
                        <div class="form-group full">
                            <label>Descripción</label>
                            <InputTextArea @bind-Value="form.Descripcion" rows="2" placeholder="Descripción..." />
                        </div>
                        <div class="form-group">
                            <label>Duración (horas)</label>
                            <InputNumber @bind-Value="form.DuracionHoras" min="1" />
                            <ValidationMessage For="() => form.DuracionHoras" class="validation-message" />
                        </div>
                        <div class="form-group">
                            <label>Fecha límite *</label>
                            <InputDate @bind-Value="form.FechaFin" />
                            <ValidationMessage For="() => form.FechaFin" class="validation-message" />
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private bool PuedeGestionar => AuthInfo.EsJefe || AuthInfo.EsAdmin;

    private List<CapacitacionDto>? capacitaciones;
    private List<AreaDto> areas = [];
    private List<ColaboradorDto> colaboradores = [];
    private bool cargando = true;
    private bool mostrarModal = false;
    private bool guardando = false;
    private int? editandoId = null;
    private string busqueda = string.Empty;
    private string filtroTipo = string.Empty;
    private string tipoAsignacion = "general";
    private bool confirmVisible = false;
    private int eliminandoId;
    private Toast toast = default!;
    private CreateCapacitacionDto form = new();

    // Pestañas
    private string tabActiva = "capacitaciones";

    // Historial
    private record HistorialItem(InscripcionDto Inscripcion, ResultadoCuestionarioDto? Resultado);
    private record ColaboradorHistorial(int Id, string Nombre, string Email, string Area, string Cargo, List<HistorialItem> Items);
    private List<HistorialItem> historialItems = [];
    private bool cargandoHistorial = false;
    private string busquedaHistorial = string.Empty;
    private int? colaboradorSeleccionadoId = null;
    private HashSet<int> capacitacionesCompletadas = [];

    private string BusquedaHistorial
    {
        get => busquedaHistorial;
        set
        {
            if (busquedaHistorial == value) return;
            busquedaHistorial = value;
        }
    }

    private List<ColaboradorHistorial> ColaboradoresHistorial
    {
        get
        {
            if (historialItems == null || !historialItems.Any()) return [];
            
            return historialItems
                .GroupBy(h => h.Inscripcion.ColaboradorId)
                .Select(g => {
                    var primerItem = g.First().Inscripcion;
                    return new ColaboradorHistorial(
                        primerItem.ColaboradorId,
                        primerItem.ColaboradorNombre,
                        primerItem.ColaboradorEmail,
                        primerItem.ColaboradorArea,
                        primerItem.ColaboradorCargo,
                        g.ToList()
                    );
                })
                .OrderBy(c => c.Nombre)
                .ToList();
        }
    }

    private IEnumerable<ColaboradorHistorial> ColaboradoresFiltrados =>
        string.IsNullOrWhiteSpace(busquedaHistorial)
            ? ColaboradoresHistorial
            : ColaboradoresHistorial.Where(c =>
                c.Nombre.Contains(busquedaHistorial, StringComparison.OrdinalIgnoreCase) ||
                c.Area.Contains(busquedaHistorial, StringComparison.OrdinalIgnoreCase) ||
                c.Cargo.Contains(busquedaHistorial, StringComparison.OrdinalIgnoreCase));

    private ColaboradorHistorial? ColaboradorSeleccionado
    {
        get
        {
            if (colaboradorSeleccionadoId.HasValue)
            {
                var sel = ColaboradoresHistorial.FirstOrDefault(c => c.Id == colaboradorSeleccionadoId.Value);
                if (sel is not null) return sel;
            }
            
            var primero = ColaboradoresFiltrados.FirstOrDefault();
            if (primero is not null)
            {
                colaboradorSeleccionadoId = primero.Id;
                return primero;
            }
            
            return null;
        }
    }

    private int paginaDetalleHistorial = 1;
    private const int DetalleHistorialPaginaSize = 10;

    private IEnumerable<HistorialItem> ColaboradorSeleccionadoItemsPagina =>
        ColaboradorSeleccionado?.Items
            .Skip((paginaDetalleHistorial - 1) * DetalleHistorialPaginaSize)
            .Take(DetalleHistorialPaginaSize) ?? [];

    private int TotalPaginasDetalle =>
        ColaboradorSeleccionado is null
            ? 1
            : Math.Max(1, (int)Math.Ceiling(ColaboradorSeleccionado.Items.Count / (double)DetalleHistorialPaginaSize));

    private bool CanPrevDetalle => paginaDetalleHistorial > 1;
    private bool CanNextDetalle => paginaDetalleHistorial < TotalPaginasDetalle;

    private void IrPaginaAnteriorDetalle() => paginaDetalleHistorial = Math.Max(1, paginaDetalleHistorial - 1);
    private void IrPaginaSiguienteDetalle() => paginaDetalleHistorial = Math.Min(TotalPaginasDetalle, paginaDetalleHistorial + 1);

    private void SeleccionarColaborador(int id)
    {
        if (colaboradorSeleccionadoId != id)
        {
            colaboradorSeleccionadoId = id;
            paginaDetalleHistorial = 1;
        }
    }

    private static string ObtenerIniciales(string nombreCompleto)
    {
        if (string.IsNullOrWhiteSpace(nombreCompleto)) return "?";
        var partes = nombreCompleto.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length >= 2)
            return $"{partes[0][0]}{partes[1][0]}".ToUpper();
        return partes[0][0].ToString().ToUpper();
    }

