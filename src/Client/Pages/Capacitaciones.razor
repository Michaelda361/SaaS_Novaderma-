@page "/capacitaciones"
@attribute [PageTitle("Capacitaciones")]
@attribute [Authorize]
@inject CapacitacionApiService ApiService
@inject AreaApiService AreaService
@inject ColaboradorApiService ColaboradorService
@inject InscripcionApiService InscripcionService
@inject CuestionarioApiService CuestionarioService
@inject AuthInfoService AuthInfo
@inject NavigationManager Nav
@inject NotificacionesService Notificaciones
@implements IAsyncDisposable
<Toast @ref="toast" />
<ConfirmDialog Visible="confirmVisible"
               Message="¿Seguro que deseas eliminar esta capacitación? Esta acción no se puede deshacer."
               OnConfirm="ConfirmarEliminar"
               OnCancel="() => confirmVisible = false" />

<div class="page-header">
    <div>
        <h2 class="page-title">Capacitaciones</h2>
        <p class="page-subtitle">
            @if (PuedeGestionar) { <span>Gestiona y realiza seguimiento de las capacitaciones</span> }
            else { <span>Capacitaciones disponibles para ti</span> }
        </p>
    </div>
    @if (PuedeGestionar && tabActiva == "capacitaciones")
    {
        <button class="btn btn-primary btn-sm" @onclick="AbrirModal">+ Nueva capacitación</button>
    }
</div>

@if (PuedeGestionar)
{
    <div class="admin-tabs">
        <button class="admin-tab @(tabActiva == "capacitaciones" ? "admin-tab--active" : "")"
                @onclick='() => tabActiva = "capacitaciones"'>
            📚 Capacitaciones
            @if (capacitaciones is not null)
            {
                <span class="admin-tab-count">@capacitaciones.Count</span>
            }
        </button>
        <button class="admin-tab @(tabActiva == "historial" ? "admin-tab--active" : "")"
                @onclick='() => { tabActiva = "historial"; _ = CargarHistorial(); }'>
            📋 Historial
        </button>
    </div>
}

@if (tabActiva == "historial" && PuedeGestionar)
{
    @if (cargandoHistorial)
    {
        <div class="loading"><div class="spinner"></div> Cargando historial...</div>
    }
    else if (!historialItems.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h3>Sin historial</h3>
            <p>Ningún colaborador ha completado capacitaciones aún.</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="filter-bar">
                <div class="search-input-wrap">
                    <span class="search-icon">🔍</span>
                    <input type="search" placeholder="Buscar colaborador o capacitación..."
                           @bind="BusquedaHistorial" @bind:event="oninput" />
                </div>
                <span class="text-sm text-muted">@HistorialFiltrado.Count() registro(s)</span>
            </div>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Colaborador</th>
                            <th>Área</th>
                            <th>Capacitación</th>
                            <th>Inscripción</th>
                            <th>Fecha de Finalización</th>
                            <th>Calificación</th>
                            <th>Resultado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in HistorialPagina)
                        {
                            <tr>
                                <td class="font-medium">@h.Inscripcion.ColaboradorNombre</td>
                                <td class="text-sm text-muted">@h.Inscripcion.ColaboradorArea</td>
                                <td class="text-sm">@h.Inscripcion.CapacitacionNombre</td>
                                <td class="text-sm text-muted">@h.Inscripcion.FechaInscripcion.ToString("dd/MM/yyyy")</td>
                                <td class="text-sm">
                                    @(h.Inscripcion.FechaFinalizacion?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")
                                </td>
                                <td class="text-sm font-medium">
                                    @if (h.Resultado is not null)
                                    {
                                        @($"{h.Resultado.Correctas} / {h.Resultado.TotalPreguntas}")
                                    }
                                    else
                                    {
                                        @(h.Inscripcion.Calificacion.HasValue ? h.Inscripcion.Calificacion.Value.ToString("0.##") : "—")
                                    }
                                </td>
                                <td>
                                    @if (h.Resultado is null)
                                    { <span class="badge badge-gray">Pendiente</span> }
                                    else if (h.Resultado.Aprobado)
                                    { <span class="badge badge-success">✅ Aprobado</span> }
                                    else
                                    { <span class="badge badge-danger">❌ No aprobado</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="pagination" style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;padding:.75rem 1rem;border-top:1px solid var(--border);">
                <div class="text-sm text-muted">Página @paginaHistorial de @TotalPaginas</div>
                <div>
                    <button class="btn btn-sm btn-secondary" disabled="@(!CanPrevHistorial)" @onclick="IrPaginaAnterior">Anterior</button>
                    <button class="btn btn-sm btn-secondary" disabled="@(!CanNextHistorial)" @onclick="IrPaginaSiguiente">Siguiente</button>
                </div>
            </div>
            <div class="text-sm text-muted" style="padding:.75rem 1rem;border-top:1px solid var(--border);">
                @historialItems.Count(h => h.Resultado?.Aprobado == true) aprobado(s) ·
                @historialItems.Count(h => h.Resultado is not null && !h.Resultado.Aprobado) no aprobado(s) ·
                @historialItems.Count(h => h.Resultado is null) pendiente(s)
            </div>
        </div>
    }
}

@if (tabActiva == "capacitaciones")
{
<div class="card">
    <div class="card-header">
        <span class="card-title">Capacitaciones</span>
    </div>

    <div class="filter-bar">
        <div class="search-input-wrap">
            <span class="search-icon">🔍</span>
            <input type="search" placeholder="Buscar capacitación..."
                   @bind="busqueda" @bind:event="oninput" />
        </div>
        <select @bind="filtroTipo" style="min-width:140px">
            <option value="">Todos</option>
            <option value="General">General</option>
            <option value="Área">Por área</option>
            <option value="Colaborador">Por colaborador</option>
        </select>
        @if (!string.IsNullOrEmpty(busqueda) || !string.IsNullOrEmpty(filtroTipo))
        {
            <span class="text-sm text-muted">@Filtradas.Count resultado(s)</span>
        }
    </div>

    @if (cargando)
    {
        <div class="loading"><div class="spinner"></div> Cargando...</div>
    }
    else if (capacitaciones is null || capacitaciones.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">📚</div>
            <h3>Sin capacitaciones</h3>
            <p>@(PuedeGestionar ? "Crea la primera capacitación para comenzar." : "No hay capacitaciones disponibles aún.")</p>
        </div>
    }
    else if (Filtradas.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">🔍</div>
            <h3>Sin resultados</h3>
            <p>No hay capacitaciones que coincidan con los filtros.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Estado</th>
                        <th>Asignación</th>
                        <th>Duración</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Inscritos</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Filtradas)
                    {
                        var estado = EstadoCapacitacion(c);
                        <tr>
                            <td>
                                <div class="font-medium">@c.Nombre</div>
                                @if (!string.IsNullOrEmpty(c.Descripcion))
                                {
                                    <div class="text-sm text-muted truncate" style="max-width:200px">@c.Descripcion</div>
                                }
                            </td>
                            <td><span class="badge @estado.Clase">@estado.Texto</span></td>
                            <td>
                                @if (c.AreaId.HasValue)
                                {
                                    <span class="badge badge-info">🏢 @c.AreaNombre</span>
                                }
                                else if (c.ColaboradorId.HasValue)
                                {
                                    <span class="badge badge-warning">👤 @c.ColaboradorNombre</span>
                                }
                                else
                                {
                                    <span class="badge badge-gray">General</span>
                                }
                            </td>
                            <td><span class="badge badge-info">@c.DuracionHoras h</span></td>
                            <td class="text-sm">@c.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td class="text-sm">@c.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge badge-gray">@c.TotalInscritos</span></td>
                            <td>
                                <div class="flex gap-2">
                                    <button class="btn btn-ghost btn-sm btn-icon"
                                            @onclick="() => VerDetalle(c.Id)" title="Ver detalle">👁️</button>
                                    @if (PuedeGestionar)
                                    {
                                        <button class="btn btn-ghost btn-sm btn-icon"
                                                @onclick="() => AbrirEditar(c)" title="Editar">✏️</button>
                                        <button class="btn btn-danger btn-sm btn-icon"
                                                @onclick="() => PedirConfirmacion(c.Id)" title="Eliminar">🗑️</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
}

@* Sección de capacitaciones completadas — solo para colaboradores *@
@if (AuthInfo.EsSoloColaborador && capacitacionesCompletadas.Any())
{
    <div style="margin-top:1.5rem;">
        <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.75rem;">
            <span style="font-size:1.1rem;">🎓</span>
            <span class="font-medium">Completadas (@capacitacionesCompletadas.Count)</span>
            <span class="text-sm text-muted">— capacitaciones que ya completaste</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:.5rem;">
            @foreach (var c in (capacitaciones ?? []).Where(c => capacitacionesCompletadas.Contains(c.Id)))
            {
                var cap = c;
                <div style="display:flex;align-items:center;gap:.875rem;padding:.75rem 1rem;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);opacity:.75;">
                    <span style="font-size:1.25rem;">✅</span>
                    <div style="flex:1;min-width:0;">
                        <span class="font-medium text-sm">@c.Nombre</span>
                        @if (!string.IsNullOrEmpty(c.Descripcion))
                        {
                            <span class="text-xs text-muted" style="margin-left:.5rem;">@c.Descripcion</span>
                        }
                    </div>
                    <span class="badge badge-success" style="font-size:.7rem;">Completada</span>
                    <button class="btn btn-ghost btn-sm btn-icon"
                            @onclick="@(() => Nav.NavigateTo($"/capacitaciones/{cap.Id}"))"
                            title="Ver detalle">👁️</button>
                </div>
            }
        </div>
    </div>
}

@if (mostrarModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editandoId.HasValue ? "Editar capacitación" : "Nueva capacitación")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <EditForm Model="form" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-grid">
                        <div class="form-group full">
                            <label>Nombre *</label>
                            <InputText @bind-Value="form.Nombre" placeholder="Nombre de la capacitación" />
                            <ValidationMessage For="() => form.Nombre" class="validation-message" />
                        </div>
                        <div class="form-group full">
                            <label>Descripción</label>
                            <InputTextArea @bind-Value="form.Descripcion" rows="2" placeholder="Descripción..." />
                        </div>
                        <div class="form-group">
                            <label>Duración (horas)</label>
                            <InputNumber @bind-Value="form.DuracionHoras" />
                            <ValidationMessage For="() => form.DuracionHoras" class="validation-message" />
                        </div>
                        <div class="form-group">
                            <label>Fecha límite *</label>
                            <InputDate @bind-Value="form.FechaFin" />
                            <ValidationMessage For="() => form.FechaFin" class="validation-message" />
                        </div>
                        <div class="form-group full">
                            <label>Asignar a</label>
                            <select @bind="tipoAsignacion" class="form-select">
                                <option value="general">General (todos)</option>
                                <option value="area">Área específica</option>
                                <option value="colaborador">Colaborador específico</option>
                            </select>
                        </div>
                        @if (tipoAsignacion == "area")
                        {
                            <div class="form-group full">
                                <label>Área</label>
                                <select @bind="form.AreaId" class="form-select">
                                    <option value="">-- Seleccionar área --</option>
                                    @foreach (var a in areas)
                                    {
                                        <option value="@a.Id">@a.Nombre</option>
                                    }
                                </select>
                            </div>
                        }
                        else if (tipoAsignacion == "colaborador")
                        {
                            <div class="form-group full">
                                <label>Colaborador</label>
                                <select @bind="form.ColaboradorId" class="form-select">
                                    <option value="">-- Seleccionar colaborador --</option>
                                    @foreach (var col in colaboradores)
                                    {
                                        <option value="@col.Id">@col.Nombre @col.Apellido — @ColaboradorGeneroUi.Etiqueta(col.Genero) · @col.AreaNombre</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private bool PuedeGestionar => AuthInfo.EsJefe || AuthInfo.EsAdmin;

    private List<CapacitacionDto>? capacitaciones;
    private List<AreaDto> areas = [];
    private List<ColaboradorDto> colaboradores = [];
    private bool cargando = true;
    private bool mostrarModal = false;
    private bool guardando = false;
    private int? editandoId = null;
    private string busqueda = string.Empty;
    private string filtroTipo = string.Empty;
    private string tipoAsignacion = "general";
    private bool confirmVisible = false;
    private int eliminandoId;
    private Toast toast = default!;
    private CreateCapacitacionDto form = new();

    // Pestañas
    private string tabActiva = "capacitaciones";

    // Historial
    private record HistorialItem(InscripcionDto Inscripcion, ResultadoCuestionarioDto? Resultado);
    private List<HistorialItem> historialItems = [];
    private bool cargandoHistorial = false;
    private bool historialCargado = false;
    private string busquedaHistorial = string.Empty;
    private int paginaHistorial = 1;
    private const int HistorialPaginaSize = 10;

    // Capacitaciones completadas por el colaborador (excluidas de la lista activa)
    private HashSet<int> capacitacionesCompletadas = [];

    private string BusquedaHistorial
    {
        get => busquedaHistorial;
        set
        {
            if (busquedaHistorial == value) return;
            busquedaHistorial = value;
            paginaHistorial = 1;
        }
    }

    private IEnumerable<HistorialItem> HistorialFiltrado =>
        string.IsNullOrWhiteSpace(busquedaHistorial)
            ? historialItems
            : historialItems.Where(h =>
                h.Inscripcion.ColaboradorNombre.Contains(busquedaHistorial, StringComparison.OrdinalIgnoreCase) ||
                h.Inscripcion.CapacitacionNombre.Contains(busquedaHistorial, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<HistorialItem> HistorialPagina =>
        HistorialFiltrado
            .Skip((paginaHistorial - 1) * HistorialPaginaSize)
            .Take(HistorialPaginaSize);

    private int TotalPaginas => Math.Max(1, (int)Math.Ceiling(HistorialFiltrado.Count() / (double)HistorialPaginaSize));
    private bool CanPrevHistorial => paginaHistorial > 1;
    private bool CanNextHistorial => paginaHistorial < TotalPaginas;

    private void IrPaginaAnterior() => paginaHistorial = Math.Max(1, paginaHistorial - 1);
    private void IrPaginaSiguiente() => paginaHistorial = Math.Min(TotalPaginas, paginaHistorial + 1);

    private List<CapacitacionDto> Filtradas
    {
        get
        {
            var lista = capacitaciones ?? [];
            // Colaboradores ven: generales, las de su área, o las asignadas a ellos
            if (AuthInfo.EsSoloColaborador)
            {
                lista = lista.Where(c =>
                    c.Publicada && !c.Finalizada && (
                    c.TipoAsignacion == "General" ||
                    (c.AreaId.HasValue && c.AreaId == AuthInfo.AreaId) ||
                    (c.ColaboradorId.HasValue && c.ColaboradorId == AuthInfo.ColaboradorId))).ToList();

                // Excluir las que ya aprobó — pasan al historial
                lista = lista.Where(c => !capacitacionesCompletadas.Contains(c.Id)).ToList();
            }

            lista = lista.Where(c => !c.Finalizada).ToList();

            if (!string.IsNullOrWhiteSpace(busqueda))
                lista = lista.Where(c => c.Nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase)).ToList();
            if (!string.IsNullOrWhiteSpace(filtroTipo))
                lista = lista.Where(c => c.TipoAsignacion == filtroTipo).ToList();
            return lista;
        }
    }

    private static (string Texto, string Clase) EstadoCapacitacion(CapacitacionDto c)
    {
        if (c.Finalizada) return ("Finalizada", "badge-gray");
        var hoy = DateTime.Today;
        if (c.FechaFin < hoy)    return ("Finalizada", "badge-gray");
        if (c.FechaInicio > hoy) return ("Próxima",    "badge-info");
        return ("En curso", "badge-success");
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthInfo.LoadAsync();
        if (PuedeGestionar)
        {
            await Task.WhenAll(Cargar(), CargarSelectores());
            // La conexión ya fue iniciada por MainLayout — solo nos unimos al grupo
            for (int i = 0; i < 10; i++) { if (Notificaciones.Conectado) break; await Task.Delay(200); }
            await Notificaciones.UnirseGrupoAdminAsync();
            Notificaciones.OnCuestionarioRespondido += OnCuestionarioRespondidoHistorial;
        }
        else
            await Task.WhenAll(Cargar(), CargarCompletadas());
    }

    protected override void OnInitialized()
    {
        // Escuchar cambios de navegacion para recargar aprobadas cuando el colaborador vuelve
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (AuthInfo.EsSoloColaborador && AuthInfo.ColaboradorId.HasValue)
            InvokeAsync(async () => { await CargarCompletadas(); StateHasChanged(); });
    }

    private void OnCuestionarioRespondidoHistorial(TalentManagement.Shared.DTOs.Cuestionarios.CuestionarioRespondidoDto n)
    {
        // Invalidar caché del historial para que se recargue con el nuevo resultado
        historialCargado = false;
        // Si el admin está viendo el historial, recargarlo automáticamente
        if (tabActiva == "historial")
            InvokeAsync(async () => { await CargarHistorial(); StateHasChanged(); });
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Notificaciones.OnCuestionarioRespondido -= OnCuestionarioRespondidoHistorial;
    }

    private void VerDetalle(int id) => Nav.NavigateTo($"/capacitaciones/{id}");

    private async Task Cargar()
    {
        cargando = true;
        capacitaciones = await ApiService.GetAllAsync();
        cargando = false;
    }

    private async Task CargarCompletadas()
    {
        if (!AuthInfo.ColaboradorId.HasValue) return;
        try
        {
            // Una sola llamada al servidor en lugar de N+1 requests
            var ids = await CuestionarioService.GetCapacitacionesAprobadasAsync(AuthInfo.ColaboradorId.Value);
            capacitacionesCompletadas = ids.ToHashSet();
        }
        catch { }
    }

    private async Task CargarSelectores()
    {
        areas = await AreaService.GetAllAsync() ?? [];
        colaboradores = await ColaboradorService.GetAllAsync() ?? [];
    }

    private void AbrirModal()
    {
        form = new CreateCapacitacionDto { FechaInicio = DateTime.Today, FechaFin = DateTime.Today.AddDays(1) };
        tipoAsignacion = "general";
        editandoId = null;
        mostrarModal = true;
    }

    private void AbrirEditar(CapacitacionDto c)
    {
        form = new CreateCapacitacionDto
        {
            Nombre = c.Nombre,
            Descripcion = c.Descripcion,
            DuracionHoras = c.DuracionHoras,
            FechaInicio = c.FechaInicio,
            FechaFin = c.FechaFin,
            AreaId = c.AreaId,
            ColaboradorId = c.ColaboradorId,
            EmiteCertificado = c.EmiteCertificado,
            NombreCertificado = c.NombreCertificado
        };
        tipoAsignacion = c.AreaId.HasValue ? "area" : c.ColaboradorId.HasValue ? "colaborador" : "general";
        editandoId = c.Id;
        mostrarModal = true;
    }

    private void CerrarModal() => mostrarModal = false;

    private async Task Guardar()
    {
        if (tipoAsignacion != "area") form.AreaId = null;
        if (tipoAsignacion != "colaborador") form.ColaboradorId = null;

        if (form.DuracionHoras <= 0)
        {
            await toast.Show("La duración de la capacitación debe ser mayor a cero.", "error");
            return;
        }

        // Validar fecha límite no anterior a fecha inicio
        var fechaInicioValidacion = editandoId.HasValue 
            ? (capacitaciones?.FirstOrDefault(c => c.Id == editandoId.Value)?.FechaInicio ?? DateTime.Today) 
            : DateTime.Today;

        if (form.FechaFin.Date < fechaInicioValidacion.Date)
        {
            await toast.Show("La fecha límite no puede ser anterior a la fecha de inicio.", "error");
            return;
        }

        guardando = true;
        bool ok = editandoId.HasValue
            ? await ApiService.UpdateAsync(editandoId.Value, form) is not null
            : await ApiService.CreateAsync(form) is not null;
        guardando = false;

        if (ok) { CerrarModal(); await Cargar(); await toast.Show(editandoId.HasValue ? "Capacitación actualizada." : "Capacitación creada."); }
        else await toast.Show("Error al guardar o validar en servidor.", "error");
    }

    private void PedirConfirmacion(int id) { eliminandoId = id; confirmVisible = true; }

    private async Task ConfirmarEliminar()
    {
        confirmVisible = false;
        if (await ApiService.DeleteAsync(eliminandoId)) { await Cargar(); await toast.Show("Capacitación eliminada."); }
        else await toast.Show("No se pudo eliminar.", "error");
    }

    private async Task CargarHistorial()
    {
        cargandoHistorial = true;
        StateHasChanged();

        try
        {
            // Una sola llamada al servidor - 3 queries planas en lugar de N*M requests
            var filas = await InscripcionService.GetHistorialCompletoAsync();
            historialItems = filas
                .Select(f => new HistorialItem(f.Inscripcion, f.Resultado))
                .Where(h => h.Inscripcion.FechaFinalizacion.HasValue)
                .OrderByDescending(h => h.Inscripcion.FechaFinalizacion)
                .ThenByDescending(h => h.Inscripcion.FechaInscripcion)
                .ToList();
            paginaHistorial = 1;
        }
        catch { historialItems = []; }

        cargandoHistorial = false;
        historialCargado = true;
        StateHasChanged();
    }
}
