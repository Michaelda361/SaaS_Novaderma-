    private List<CapacitacionDto> Filtradas
    {
        get
        {
            var lista = capacitaciones ?? [];
            // Colaboradores ven: generales, las de su área, o las asignadas a ellos
            if (AuthInfo.EsSoloColaborador)
            {
                lista = lista.Where(c =>
                    c.Publicada && !c.Finalizada && (
                    c.TipoAsignacion == "General" ||
                    (c.AreaId.HasValue && c.AreaId == AuthInfo.AreaId) ||
                    (c.ColaboradorId.HasValue && c.ColaboradorId == AuthInfo.ColaboradorId))).ToList();

                // Excluir las que ya aprobó — pasan al historial
                lista = lista.Where(c => !capacitacionesCompletadas.Contains(c.Id)).ToList();
            }

            lista = lista.Where(c => !c.Finalizada).ToList();

            if (!string.IsNullOrWhiteSpace(busqueda))
                lista = lista.Where(c => c.Nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase)).ToList();
            if (!string.IsNullOrWhiteSpace(filtroTipo))
                lista = lista.Where(c => c.TipoAsignacion == filtroTipo).ToList();
            return lista;
        }
    }

    private static (string Texto, string Clase) EstadoCapacitacion(CapacitacionDto c)
    {
        if (c.Finalizada) return ("Finalizada", "badge-gray");
        var hoy = DateTime.Today;
        if (c.FechaFin < hoy)    return ("Finalizada", "badge-gray");
        if (c.FechaInicio > hoy) return ("Próxima",    "badge-info");
        return ("En curso", "badge-success");
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthInfo.LoadAsync();
        if (PuedeGestionar)
        {
            await Task.WhenAll(Cargar(), CargarSelectores());
            // La conexión ya fue iniciada por MainLayout — solo nos unimos al grupo
            for (int i = 0; i < 10; i++) { if (Notificaciones.Conectado) break; await Task.Delay(200); }
            await Notificaciones.UnirseGrupoAdminAsync();
            Notificaciones.OnCuestionarioRespondido += OnCuestionarioRespondidoHistorial;
        }
        else
            await Task.WhenAll(Cargar(), CargarCompletadas());
    }

    protected override void OnInitialized()
    {
        // Escuchar cambios de navegacion para recargar aprobadas cuando el colaborador vuelve
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (AuthInfo.EsSoloColaborador && AuthInfo.ColaboradorId.HasValue)
            InvokeAsync(async () => { await CargarCompletadas(); StateHasChanged(); });
    }

    private void OnCuestionarioRespondidoHistorial(TalentManagement.Shared.DTOs.Cuestionarios.CuestionarioRespondidoDto n)
    {
        // Invalidar caché del historial para que se recargue con el nuevo resultado
        // historialCargado eliminado
        // Si el admin está viendo el historial, recargarlo automáticamente
        if (tabActiva == "historial")
            InvokeAsync(async () => { await CargarHistorial(); StateHasChanged(); });
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Notificaciones.OnCuestionarioRespondido -= OnCuestionarioRespondidoHistorial;
    }

