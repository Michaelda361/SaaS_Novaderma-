    private string? expandedVersionChanges = null;

    private List<DiffField> GetVersionDiffs(string version)
    {
        var list = new List<DiffField>();
        var sol = GetSolicitudForVersion(version);
        if (sol == null) return list;

        try
        {
            DocumentoControlDto? orig = null;
            if (!string.IsNullOrEmpty(sol.DatosOriginales))
            {
                orig = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.DocumentoControlDto>(sol.DatosOriginales, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }

            UpdateDocumentoControlDto? prop = null;
            if (!string.IsNullOrEmpty(sol.DatosPropuestos))
            {
                prop = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.UpdateDocumentoControlDto>(sol.DatosPropuestos, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }

            if (orig != null && prop != null)
            {
                void CheckChange(string fieldName, string? oVal, string? pVal)
                {
                    oVal = oVal?.Trim() ?? string.Empty;
                    pVal = pVal?.Trim() ?? string.Empty;
                    if (oVal != pVal)
                    {
                        list.Add(new DiffField 
                        { 
                            Name = fieldName, 
                            OriginalValue = string.IsNullOrWhiteSpace(oVal) ? "—" : oVal, 
                            ProposedValue = string.IsNullOrWhiteSpace(pVal) ? "—" : pVal 
                        });
                    }
                }

                CheckChange("Código", orig.Codigo, prop.Codigo);
                CheckChange("Nombre", orig.Nombre, prop.Nombre);
                CheckChange("Proceso responsable", orig.ProcesoResponsable, prop.ProcesoResponsable);
                CheckChange("Versión", orig.Version, prop.Version);
                CheckChange("Fecha documento", orig.FechaDocumento.ToLocalTime().ToString("d"), prop.FechaDocumento.ToLocalTime().ToString("d"));
                CheckChange("OneDrive URL", orig.OneDriveUrl, prop.OneDriveUrl);
                CheckChange("Nombre de archivo", orig.ArchivoNombre, prop.ArchivoNombre);
                CheckChange("Uso", orig.Uso, prop.Uso);
                CheckChange("Tiempo de retención", orig.TiempoRetencion, prop.TiempoRetencion);
                CheckChange("Protección", orig.Proteccion, prop.Proteccion);
                CheckChange("Recuperación", orig.Recuperacion, prop.Recuperacion);
                CheckChange("Disposición final", orig.DisposicionFinal, prop.DisposicionFinal);

                var origArea = areas.FirstOrDefault(a => a.Id == orig.AreaId)?.Nombre ?? "—";
                var propArea = areas.FirstOrDefault(a => a.Id == prop.AreaId)?.Nombre ?? "—";
                CheckChange("Área", origArea, propArea);

                var origKeys = orig.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                var propKeys = prop.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                var allKeys = origKeys.Union(propKeys).Distinct();

                foreach (var key in allKeys)
                {
                    orig.CamposPersonalizados.TryGetValue(key, out var origVal);
                    prop.CamposPersonalizados.TryGetValue(key, out var propVal);
                    CheckChange(key, origVal, propVal);
                }
            }
        }
        catch {}

        return list;
    }

    private SolicitudCambioDocumentoControlDto? GetSolicitudForVersion(string version)
    {
        if (documentoSolicitudes == null) return null;
        return documentoSolicitudes.FirstOrDefault(s => {
            if (string.IsNullOrEmpty(s.DatosPropuestos)) return false;
            try {
                var prop = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.UpdateDocumentoControlDto>(s.DatosPropuestos, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                return prop?.Version == version;
            } catch {
                return false;
            }
        });
    }

