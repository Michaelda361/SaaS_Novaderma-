    private async Task RechazarSolicitud()
    {
        if (solicitudSeleccionada is null)
        {
            return;
        }

        processingSolicitud = true;
        try
        {
            var response = await ControlDocumentalApi.RechazarSolicitudCambioAsync(solicitudSeleccionada.Id, rechazoForm);
            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                await toast.Show("No tienes permisos para rechazar esta solicitud.", "warning");
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                await toast.Show("Solicitud rechazada correctamente.", "success");
                showRejectModal = false;
                await LoadPendingSolicitudesAsync();
                return;
            }

            var message = await response.Content.ReadAsStringAsync();
            await toast.Show(string.IsNullOrWhiteSpace(message) ? "No se pudo rechazar la solicitud." : message, "error");
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al rechazar la solicitud: {ex.Message}", "error");
        }
        finally
        {
            processingSolicitud = false;
        }
    }

