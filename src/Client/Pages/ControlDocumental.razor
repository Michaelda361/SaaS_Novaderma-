@page "/control-documental"
@attribute [PageTitle("Control Documental")]
@attribute [Authorize]
@using System.Net
@using System.Net.Http.Headers
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using TalentManagement.Shared.DTOs.ControlDocumental
@using TalentManagement.Shared.DTOs.Colaboradores
@inject ControlDocumentalApiService ControlDocumentalApi
@inject ColaboradorApiService ColaboradorApi
@inject AreaApiService AreaApi
@inject AuthInfoService AuthInfo
@inject IJSRuntime JS
@inject NavigationManager Navigation

<Toast @ref="toast" />

<div class="page-header">
    <div>
        <h2 class="page-title">Control Documental</h2>
        <p class="page-subtitle">Registra, busca y audita documentos OneDrive con listados maestros.</p>
    </div>
    <div class="page-actions">
        @if (AuthInfo.EsAdmin || AuthInfo.EsJefe)
        {
            <button class="btn btn-ghost" @onclick="AbrirNuevoListado">
                + Nuevo listado maestro
            </button>
            <button class="btn btn-ghost" @onclick="AbrirEditarListado" disabled="@(!selectedListadoId.HasValue)">
                ✏️ Editar listado
            </button>
            <button class="btn btn-ghost" @onclick="ToggleImportInstructions">
                Importar listado
            </button>
            @if (AuthInfo.EsAdmin)
            {
                <button class="btn btn-ghost" @onclick="AbrirPermisos">
                    🔒 Gestionar permisos
                </button>
            }
            <button class="btn btn-ghost" @onclick="TogglePendingRequests">
                📝 Solicitudes pendientes (@pendingSolicitudes.Count)
            </button>
            <button class="btn btn-danger" @onclick="EliminarListadoSeleccionado" disabled="@(!selectedListadoId.HasValue)">
                🗑️ Eliminar listado
            </button>
        }
        <button class="btn btn-ghost" @onclick="ExportListado" disabled="@(!selectedListadoId.HasValue)">
            ⬇️ Exportar listado
        </button>
        @if (AuthInfo.EsAdmin || AuthInfo.EsJefe)
        {
            <button class="btn btn-primary" @onclick="AbrirNuevoDocumento" disabled="@(!selectedListadoId.HasValue)">
                + Nuevo documento
            </button>
        }
    </div>
</div>

@if (showImportInstructions)
{
    <div class="card" style="margin-bottom:1rem; padding:1rem; background:#f8f9fa; border:1px solid #dde1e6;">
        <h3>Manual de importación</h3>
        <p>El archivo <strong>.xlsx</strong> puede tener cualquier nombre de hoja. El sistema detecta los datos por encabezados.</p>
        <ul>
            <li>Hoja de metadatos: filas con <strong>Nombre</strong> y <strong>Descripción</strong>.</li>
            <li>Hoja de campos: columnas <strong>CampoClave</strong>, <strong>Nombre</strong>, <strong>Tipo</strong>, <strong>Requerido</strong>, <strong>Opciones</strong>, <strong>Orden</strong>.</li>
            <li>Hoja de documentos: columnas <strong>Codigo</strong>, <strong>Nombre</strong>, <strong>ProcesoResponsable</strong> o <strong>Lugar de archivo</strong>, <strong>Version</strong>, <strong>Estado</strong>.</li>
        </ul>
        <p>Si falta el nombre del listado, se usará el nombre del archivo. Las columnas adicionales se ignoran.</p>
        <label class="btn btn-secondary" style="position:relative; overflow:hidden; cursor:pointer;">
            Seleccionar archivo
            <InputFile OnChange="OnArchivoListadoSeleccionado" accept=".xlsx" style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0; cursor:pointer;" />
        </label>
    </div>
}

<div class="card" style="margin-bottom:1rem;">
    <div class="filter-bar">
        <select class="form-control" @bind="selectedListadoId" @bind:after="OnSelectedListadoChanged">
            <option value="">Selecciona un listado maestro</option>
            @foreach (var listado in listados)
            {
                <option value="@listado.Id">@listado.Nombre</option>
            }
        </select>
        <select class="form-control" @bind="selectedAreaId" @bind:after="Filtrar">
            <option value="0">Todas las áreas</option>
            @foreach (var area in areas)
            {
                <option value="@area.Id">@area.Nombre</option>
            }
        </select>
        <input type="text" class="form-control" placeholder="Buscar por nombre, código o proceso" @bind="filterBusqueda" @bind:after="Filtrar" />
        <input type="text" class="form-control" placeholder="Código" @bind="filterCodigo" @bind:after="Filtrar" />
        <input type="text" class="form-control" placeholder="Proceso responsable" @bind="filterProceso" @bind:after="Filtrar" />
        <input type="text" class="form-control" placeholder="Estado" @bind="filterEstado" @bind:after="Filtrar" />
    </div>
</div>

@if (AuthInfo.EsAdmin || AuthInfo.EsJefe)
{
    <div class="card" style="margin-bottom:1rem;">
        <div class="section-header" style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1rem;">
            <div>
                <h3 style="margin:0;">Solicitudes de cambio pendientes (@pendingSolicitudes.Count)</h3>
                <p style="margin:0.25rem 0 0; color:var(--text-muted);">Revisa y resuelve los cambios solicitados por colaboradores.</p>
            </div>
            <button class="btn btn-secondary" @onclick="TogglePendingRequests">
                @(showPendingRequests ? "Ocultar" : "Mostrar")
            </button>
        </div>

        @if (!showPendingRequests)
        {
            <div class="empty-state">
                <div class="empty-state-icon">👁️</div>
                <h3>Panel de solicitudes oculto</h3>
                <p>Pulsa "Mostrar" para revisar las solicitudes de cambio pendientes.</p>
            </div>
        }
        else if (loadingSolicitudes)
        {
            <div class="loading"><div class="spinner"></div> Cargando solicitudes...</div>
        }
        else if (!pendingSolicitudes.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">✅</div>
                <h3>No hay solicitudes pendientes</h3>
                <p>Las solicitudes de cambio aparecerán aquí cuando los colaboradores las envíen.</p>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Documento</th>
                            <th>Código</th>
                            <th>Solicitante</th>
                            <th>Fecha</th>
                            <th>Comentario</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var solicitud in pendingSolicitudes)
                        {
                            <tr>
                                <td>@solicitud.DocumentoControlNombre</td>
                                <td>@solicitud.DocumentoControlCodigo</td>
                                <td>@solicitud.SolicitanteNombre</td>
                                <td>@solicitud.FechaCreacion.ToLocalTime():g</td>
                                <td>@solicitud.ComentarioSolicitud</td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn btn-success btn-sm" @onclick="() => AprobarSolicitud(solicitud.Id)">Aprobar</button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => AbrirRechazarSolicitud(solicitud)">Rechazar</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding:0; border:none;">
                                    <details style="padding:0.75rem 1rem; background:var(--surface-muted); border-top:1px solid var(--surface-border);">
                                        <summary style="cursor:pointer; font-weight:600;">Ver datos propuestos</summary>
                                        <pre style="white-space:pre-wrap; word-break:break-word; margin-top:0.75rem;">@GetFormattedJson(solicitud.DatosPropuestos)</pre>
                                    </details>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

<div class="card">
    @if (loading)
    {
        <div class="loading"><div class="spinner"></div> Cargando...</div>
    }
    else if (!selectedListadoId.HasValue)
    {
        <div class="empty-state">
            <div class="empty-state-icon">📌</div>
            <h3>Selecciona un listado maestro</h3>
            <p>Elige un listado maestro para ver los documentos asociados.</p>
        </div>
    }
    else if (!documentos.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📄</div>
            <h3>No hay documentos</h3>
            <p>No se encontraron documentos para este listado con los filtros actuales.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        @foreach (var campo in listadoCampos.OrderBy(c => c.Orden))
                        {
                            <th>@campo.Nombre</th>
                        }
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in documentos)
                    {
                        <tr>
                            @foreach (var campo in listadoCampos.OrderBy(c => c.Orden))
                            {
                                <td>
                                    @if (campo.CampoClave == "OneDriveUrl")
                                    {
                                        <a href="@item.OneDriveUrl" target="_blank" rel="noopener noreferrer" style="color: var(--color-primary); text-decoration: underline; display: inline-flex; align-items: center; gap: 0.25rem;">
                                            🔗 @(string.IsNullOrWhiteSpace(item.ArchivoNombre) ? "Ver archivo" : item.ArchivoNombre)
                                        </a>
                                    }
                                    else if (campo.CampoClave == "Estado")
                                    {
                                        <span class="badge @GetEstadoClass(item.Estado)">@item.Estado</span>
                                    }
                                    else
                                    {
                                        @GetValorDynamic(item, campo.CampoClave)
                                    }
                                </td>
                            }
                            <td>
                                <div class="flex gap-1">
                                    <button class="btn btn-ghost btn-sm" @onclick="() => EditarDocumento(item.Id)">✏️ @(AuthInfo.EsSoloColaborador ? "Actualizar" : "Editar")</button>
                                    <button class="btn btn-ghost btn-sm" @onclick="() => VerAuditoria(item.Id)">🕘 Auditoría</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editing ? (AuthInfo.EsSoloColaborador ? "Actualizar documento" : "Editar documento") : "Nuevo documento")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="form" OnValidSubmit="GuardarDocumento">
                    <DataAnnotationsValidator />
                    <div class="form-row">
                        <div class="form-group">
                            <label>Listado maestro *</label>
                            <InputSelect class="form-control" @bind-Value="form.ListadoMaestroId" disabled="@(editing && !(AuthInfo.EsAdmin || AuthInfo.EsJefe))">
                                <option value="">Selecciona un listado maestro</option>
                                @foreach (var listado in listados)
                                {
                                    <option value="@listado.Id">@listado.Nombre</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => form.ListadoMaestroId" />
                        </div>
                        <div class="form-group">
                            <label>@GetCampoLabel("Codigo", "Código") *</label>
                            <InputText class="form-control" @bind-Value="form.Codigo" />
                            <ValidationMessage For="() => form.Codigo" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>@GetCampoLabel("Nombre", "Nombre") *</label>
                            <InputText class="form-control" @bind-Value="form.Nombre" />
                            <ValidationMessage For="() => form.Nombre" />
                        </div>
                        <div class="form-group">
                            <label>@GetCampoLabel("ProcesoResponsable", "Proceso responsable") *</label>
                            <InputText class="form-control" @bind-Value="form.ProcesoResponsable" />
                            <ValidationMessage For="() => form.ProcesoResponsable" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>@GetCampoLabel("Version", "Versión")</label>
                            <InputText class="form-control" @bind-Value="form.Version" />
                        </div>
                        <div class="form-group">
                            <label>@GetCampoLabel("FechaDocumento", "Fecha de documento") *</label>
                            <InputDate class="form-control" @bind-Value="form.FechaDocumento" />
                            <ValidationMessage For="() => form.FechaDocumento" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>@GetCampoLabel("OneDriveUrl", "Archivo OneDrive") *</label>
                        <div class="one-drive-row">
                            <InputText class="form-control" @bind-Value="form.OneDriveUrl" placeholder="URL de OneDrive" />
                            <button type="button" class="btn btn-ghost" @onclick="() => showOneDriveBrowser = true">Buscar OneDrive</button>
                        </div>
                        <ValidationMessage For="() => form.OneDriveUrl" />
                        @if (!string.IsNullOrWhiteSpace(form.ArchivoNombre))
                        {
                            <small class="text-muted">Archivo seleccionado: @form.ArchivoNombre</small>
                        }
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>@GetCampoLabel("Estado", "Estado") *</label>
                            <InputSelect class="form-control" @bind-Value="form.Estado">
                                <option value="">Selecciona estado...</option>
                                <option value="Borrador">Borrador</option>
                                <option value="Revision">Revisión</option>
                                <option value="Aprobado">Aprobado</option>
                                <option value="Publicado">Publicado</option>
                            </InputSelect>
                            <ValidationMessage For="() => form.Estado" />
                        </div>
                        <div class="form-group">
                            <label>Área (opcional)</label>
                            <InputSelect class="form-control" @bind-Value="form.AreaId">
                                <option value="">Sin área específica</option>
                                @foreach (var area in areas)
                                {
                                    <option value="@area.Id">@area.Nombre</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    @if (listadoCampos.Any(c => !c.EsPredeterminado))
                    {
                        <div class="form-group">
                            <h4>Campos adicionales</h4>
                            @foreach (var campo in listadoCampos.Where(c => !c.EsPredeterminado))
                            {
                                <div class="form-group">
                                    <label>@campo.Nombre@if (campo.Requerido) { <span class="text-danger">*</span> }</label>
                                    @if (campo.Tipo == "Lista")
                                    {
                                        <select class="form-control" value="@form.CamposPersonalizados[campo.CampoClave]" @onchange="@(e => form.CamposPersonalizados[campo.CampoClave] = e.Value?.ToString())">
                                            <option value="">Selecciona...</option>
                                            @foreach (var opcion in campo.Opciones?.Split(',').Select(o => o.Trim()).Where(o => !string.IsNullOrWhiteSpace(o)) ?? Enumerable.Empty<string>())
                                            {
                                                <option value="@opcion">@opcion</option>
                                            }
                                        </select>
                                    }
                                    else if (campo.Tipo == "Fecha")
                                    {
                                        <input type="date" class="form-control" value="@form.CamposPersonalizados[campo.CampoClave]" @onchange="@(e => form.CamposPersonalizados[campo.CampoClave] = e.Value?.ToString())" />
                                    }
                                    else if (campo.Tipo == "Numero")
                                    {
                                        <input type="number" class="form-control" value="@form.CamposPersonalizados[campo.CampoClave]" @onchange="@(e => form.CamposPersonalizados[campo.CampoClave] = e.Value?.ToString())" />
                                    }
                                    else
                                    {
                                        <input type="text" class="form-control" value="@form.CamposPersonalizados[campo.CampoClave]" @onchange="@(e => form.CamposPersonalizados[campo.CampoClave] = e.Value?.ToString())" />
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div class="form-group">
                        <label>Comentario de cambio</label>
                        <InputTextArea class="form-control" @bind-Value="form.ComentarioCambio" Rows="3" />
                    </div>
                    <div class="form-group">
                        <label>Observaciones</label>
                        <InputTextArea class="form-control" @bind-Value="form.Observaciones" Rows="3" />
                    </div>
                    @if (editing && AuthInfo.EsSoloColaborador)
                    {
                        <div class="alert alert-info" style="margin-bottom:1rem;">
                            Esta actualización se registrará como una solicitud de cambio pendiente. Un jefe o administrador deberá aprobarla antes de que se aplique al documento.
                        </div>
                    }
                    <div class="modal-footer">
                        <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@guardando">@(guardando ? (editing ? "Actualizando..." : "Guardando...") : (editing ? (AuthInfo.EsSoloColaborador ? "Actualizar" : "Guardar") : "Guardar"))</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (showListadoModal)
{
    <div class="modal-backdrop" @onclick="CerrarListadoModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editingListado ? "Editar listado maestro" : "Nuevo listado maestro")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarListadoModal">✕</button>
            </div>
            <div class="modal-body">
                <EditForm Model="listadoForm" OnValidSubmit="CrearListado">
                    <DataAnnotationsValidator />
                    <div class="form-group">
                        <label>Nombre *</label>
                        <InputText class="form-control" @bind-Value="listadoForm.Nombre" />
                        <ValidationMessage For="() => listadoForm.Nombre" />
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <InputTextArea class="form-control" @bind-Value="listadoForm.Descripcion" Rows="3" />
                    </div>
                    <div class="form-group">
                        <label>Campos configurables</label>
                        <div class="template-documents">
                            @if (!listadoForm.Campos.Any())
                            {
                                <div class="text-muted" style="margin-bottom:.5rem;">No hay campos configurados. Agrega uno para definir los parámetros del listado.</div>
                            }
                            @foreach (var campo in listadoForm.Campos.OrderBy(c => c.Orden))
                            {
                                <div class="template-document">
                                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.5rem;">
                                        <div>
                                            <strong>@campo.CampoClave</strong>
                                            @if (campo.EsPredeterminado)
                                            {
                                                <span class="badge badge-gray" style="margin-left:.5rem">Predeterminado</span>
                                            }
                                        </div>
                                        @if (!campo.EsPredeterminado)
                                        {
                                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => EliminarCampoPlantilla(campo.CampoClave)">Eliminar</button>
                                        }
                                    </div>
                                    <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(120px, 1fr));gap:.5rem;margin-bottom:.5rem;">
                                        <div>
                                            <label>Etiqueta</label>
                                            <InputText class="form-control" @bind-Value="campo.Nombre" />
                                        </div>
                                        <div>
                                            <label>Tipo</label>
                                            <InputSelect class="form-control" @bind-Value="campo.Tipo">
                                                <option value="Texto">Texto</option>
                                                <option value="Numero">Número</option>
                                                <option value="Fecha">Fecha</option>
                                                <option value="Lista">Lista</option>
                                            </InputSelect>
                                        </div>
                                        <div>
                                            <label>Requerido</label>
                                            <div style="display:flex;align-items:center;gap:.25rem;height:38px;">
                                                <InputCheckbox @bind-Value="campo.Requerido" style="width:auto;" />
                                                <span>Sí</span>
                                            </div>
                                        </div>
                                        <div>
                                            <label>Orden</label>
                                            <InputNumber class="form-control" @bind-Value="campo.Orden" />
                                        </div>
                                    </div>
                                    @if (campo.Tipo == "Lista")
                                    {
                                        <div style="margin-bottom:.5rem;">
                                            <label>Opciones (separadas por coma)</label>
                                            <InputText class="form-control" @bind-Value="campo.Opciones" />
                                        </div>
                                    }
                                </div>
                            }
                            <button type="button" class="btn btn-ghost btn-sm" @onclick="AgregarCampoPlantilla">Agregar campo personalizado</button>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-ghost" @onclick="CerrarListadoModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@guardandoListado">@(guardandoListado ? "Guardando..." : (editingListado ? "Guardar cambios" : "Crear listado"))</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (showPermisosModal)
{
    <div class="modal-backdrop" @onclick="CerrarPermisosModal">
        <div class="modal large" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Permisos de acceso</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarPermisosModal">✕</button>
            </div>
            <div class="modal-body">
                @if (permisosLoading)
                {
                    <div class="loading"><div class="spinner"></div> Cargando permisos...</div>
                }
                else
                {
                    <div class="section-header" style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1rem;">
                        <div>
                            <h3 style="margin:0;">Permisos del listado</h3>
                            <p style="margin:0.25rem 0 0; color:var(--text-muted);">Define quién puede ver, editar y aprobar cambios en este listado.</p>
                        </div>
                        <button class="btn btn-primary" @onclick="AgregarPermiso">+ Agregar colaborador</button>
                    </div>

                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Colaborador</th>
                                    <th>Email</th>
                                    <th style="text-align:center;">Ver</th>
                                    <th style="text-align:center;">Editar</th>
                                    <th style="text-align:center;">Aprobar</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (permiso, index) in listadoPermisos.Select((p, i) => (p, i)))
                                {
                                    <tr>
                                        <td>@permiso.ColaboradorNombre</td>
                                        <td>@permiso.ColaboradorEmail</td>
                                        <td style="text-align:center;">
                                            <input type="checkbox" checked="@permiso.PuedeVer" @onchange="(ChangeEventArgs e) => { permiso.PuedeVer = (bool)e.Value!; MarcarCambioPermisos(); }" />
                                        </td>
                                        <td style="text-align:center;">
                                            <input type="checkbox" checked="@permiso.PuedeEditar" @onchange="(ChangeEventArgs e) => { permiso.PuedeEditar = (bool)e.Value!; MarcarCambioPermisos(); }" />
                                        </td>
                                        <td style="text-align:center;">
                                            <input type="checkbox" checked="@permiso.PuedeAprobar" @onchange="(ChangeEventArgs e) => { permiso.PuedeAprobar = (bool)e.Value!; MarcarCambioPermisos(); }" />
                                        </td>
                                        <td>
                                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarPermiso(index)">Eliminar</button>
                                        </td>
                                    </tr>
                                }
                                @foreach (var (nuevoPermiso, index) in nuevosPermisosListado.Select((p, i) => (p, i)))
                                {
                                    <tr style="background:var(--surface-muted);">
                                        <td>
                                            <select class="form-control" value="@nuevoPermiso.ColaboradorId" @onchange="@( (ChangeEventArgs e) => { if (int.TryParse(e.Value?.ToString(), out var value)) { nuevoPermiso.ColaboradorId = value; } MarcarCambioPermisos(); } )">
                                                <option value="0">Selecciona colaborador</option>
                                                @foreach (var colab in colaboradores)
                                                {
                                                    <option value="@colab.Id">@colab.Nombre @colab.Apellido</option>
                                                }
                                            </select>
                                        </td>
                                        <td>@(colaboradores.FirstOrDefault(c => c.Id == nuevoPermiso.ColaboradorId)?.Email ?? "—")</td>
                                        <td style="text-align:center;">
                                            <input type="checkbox" checked="@nuevoPermiso.PuedeVer" @onchange="(ChangeEventArgs e) => { nuevoPermiso.PuedeVer = (bool)e.Value!; MarcarCambioPermisos(); }" />
                                        </td>
                                        <td style="text-align:center;">
                                            <input type="checkbox" checked="@nuevoPermiso.PuedeEditar" @onchange="(ChangeEventArgs e) => { nuevoPermiso.PuedeEditar = (bool)e.Value!; MarcarCambioPermisos(); }" />
                                        </td>
                                        <td style="text-align:center;">
                                            <input type="checkbox" checked="@nuevoPermiso.PuedeAprobar" @onchange="(ChangeEventArgs e) => { nuevoPermiso.PuedeAprobar = (bool)e.Value!; MarcarCambioPermisos(); }" />
                                        </td>
                                        <td>
                                            <button class="btn btn-secondary btn-sm" @onclick="() => EliminarPermisoNuevo(index)">Cancelar</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CerrarPermisosModal">Cerrar</button>
                <button class="btn btn-primary" @onclick="GuardarPermisosListado" disabled="@(permisosGuardando || !tieneCambiosPermisos)">@(permisosGuardando ? "Guardando..." : "Guardar cambios")</button>
            </div>
        </div>
    </div>
}

@if (showAuditModal)
{
    <div class="modal-backdrop" @onclick="CerrarAuditoriaModal">
        <div class="modal large" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Historial de auditoría</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarAuditoriaModal">✕</button>
            </div>
            <div class="modal-body">
                @if (historial is null || !historial.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🕘</div>
                        <h3>Sin historial</h3>
                        <p>Aún no hay registros de auditoría para este documento.</p>
                    </div>
                }
                else
                {
                    @if (auditDocumentDetail is null)
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">⚠️</div>
                            <h3>Error al cargar el documento</h3>
                            <p>No se pudo cargar la versión actual del documento para mostrar el historial.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-wrapper" style="margin-bottom:1.5rem;">
                            <table>
                                <thead>
                                    <tr>
                                        <th colspan="@(listadoCampos.Count + 1)" style="text-align:center;font-weight:700;background:var(--surface-hover);">Versión actual</th>
                                    </tr>
                                    <tr>
                                        <th>Listado maestro</th>
                                        @foreach (var campo in listadoCampos.OrderBy(c => c.Orden))
                                        {
                                            <th>@campo.Nombre</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Listado maestro")</td>
                                        @foreach (var campo in listadoCampos.OrderBy(c => c.Orden))
                                        {
                                            <td>
                                                @if (campo.CampoClave == "OneDriveUrl")
                                                {
                                                    <a href="@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "OneDrive URL")" target="_blank" rel="noopener noreferrer" style="color: var(--color-primary); text-decoration: underline;">
                                                        🔗 @(string.IsNullOrWhiteSpace(GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Archivo")) ? "Ver archivo" : GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Archivo"))
                                                    </a>
                                                }
                                                else if (campo.CampoClave == "Estado")
                                                {
                                                    <span class="badge @GetEstadoClass(GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Estado") ?? "")">
                                                        @GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Estado")
                                                    </span>
                                                }
                                                else
                                                {
                                                    @GetSnapshotValueForCampo(BuildSnapshot(auditDocumentDetail), campo.CampoClave)
                                                }
                                            </td>
                                        }
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div style="margin-bottom:.75rem;">
                            <h4>Versiones anteriores</h4>
                        </div>

                        @if (!versionesAnteriores.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-state-icon">🕘</div>
                                <h3>Sin versiones anteriores</h3>
                                <p>Aún no hay registros de versiones anteriores para este documento.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-wrapper">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Fecha / Usuario</th>
                                            <th>Acción</th>
                                            <th>Listado maestro</th>
                                            @foreach (var campo in listadoCampos.OrderBy(c => c.Orden))
                                            {
                                                <th>@campo.Nombre</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var version in versionesAnteriores)
                                        {
                                            <tr>
                                                <td>@version.Descripcion</td>
                                                <td>@version.Titulo</td>
                                                <td>@GetSnapshotValue(version.Campos, "Listado maestro")</td>
                                                @foreach (var campo in listadoCampos.OrderBy(c => c.Orden))
                                                {
                                                    <td>
                                                        @if (campo.CampoClave == "OneDriveUrl")
                                                        {
                                                            <a href="@GetSnapshotValue(version.Campos, "OneDrive URL")" target="_blank" rel="noopener noreferrer" style="color: var(--color-primary); text-decoration: underline;">
                                                                🔗 @(string.IsNullOrWhiteSpace(GetSnapshotValue(version.Campos, "Archivo")) ? "Ver archivo" : GetSnapshotValue(version.Campos, "Archivo"))
                                                            </a>
                                                        }
                                                        else if (campo.CampoClave == "Estado")
                                                        {
                                                            <span class="badge @GetEstadoClass(GetSnapshotValue(version.Campos, "Estado") ?? "")">
                                                                @GetSnapshotValue(version.Campos, "Estado")
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            @GetSnapshotValueForCampo(version.Campos, campo.CampoClave)
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CerrarAuditoriaModal">Cerrar</button>
            </div>
        </div>
    </div>
}

@if (showRejectModal)
{
    <div class="modal-backdrop" @onclick="() => showRejectModal = false">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Rechazar solicitud de cambio</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => showRejectModal = false">✕</button>
