    private void AbrirAprobarSolicitud(SolicitudCambioDocumentoControlDto solicitud)
    {
        solicitudSeleccionada = solicitud;
        approvalComments = string.Empty;
        showApproveModal = true;
    }

    private async Task ConfirmarAprobacion()
    {
        if (solicitudSeleccionada is null) return;

        processingSolicitud = true;
        try
        {
            var response = await ControlDocumentalApi.AprobarSolicitudCambioAsync(
                solicitudSeleccionada.Id,
                new TalentManagement.Shared.DTOs.ControlDocumental.AprobarSolicitudCambioDto { Comentarios = approvalComments });

            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                await toast.Show("No tienes permisos para aprobar esta solicitud.", "warning");
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                await toast.Show("Solicitud aprobada y publicada correctamente.", "success");
                showApproveModal = false;
                showSolicitudDetalleModal = false;
                await LoadPendingSolicitudesAsync();
                await Filtrar();
                return;
            }

            var message = await response.Content.ReadAsStringAsync();
            await toast.Show(string.IsNullOrWhiteSpace(message) ? "No se pudo aprobar la solicitud." : message, "error");
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al aprobar la solicitud: {ex.Message}", "error");
        }
        finally
        {
            processingSolicitud = false;
        }
    }

    private DocumentoControlDetalleDto? originalDocParaDiff;
    private List<DiffField> currentDiffs = new();

    private async Task AbrirSolicitudDetalles(SolicitudCambioDocumentoControlDto solicitud)
    {
        selectedSolicitudDetalle = solicitud;
        showDiff = false;
        approvalComments = string.Empty;
        currentDiffs.Clear();

        try
        {
            originalDocParaDiff = null;
            if (!string.IsNullOrEmpty(solicitud.DatosOriginales))
            {
                try
                {
                    var origDto = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.DocumentoControlDto>(solicitud.DatosOriginales, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (origDto != null)
                    {
                        originalDocParaDiff = new DocumentoControlDetalleDto
                        {
                            Id = origDto.Id,
                            ListadoMaestroId = origDto.ListadoMaestroId,
                            ListadoMaestroNombre = origDto.ListadoMaestroNombre,
                            Codigo = origDto.Codigo,
                            Nombre = origDto.Nombre,
                            ProcesoResponsable = origDto.ProcesoResponsable,
                            Version = origDto.Version,
                            FechaDocumento = origDto.FechaDocumento,
                            OneDriveUrl = origDto.OneDriveUrl,
                            Estado = origDto.Estado,
                            AreaId = origDto.AreaId,
                            AreaNombre = origDto.AreaNombre,
                            Uso = origDto.Uso,
                            TiempoRetencion = origDto.TiempoRetencion,
                            Proteccion = origDto.Proteccion,
                            Recuperacion = origDto.Recuperacion,
                            DisposicionFinal = origDto.DisposicionFinal,
                            Observaciones = origDto.Observaciones,
                            ComentarioCambio = origDto.ComentarioCambio,
                            ArchivoNombre = origDto.ArchivoNombre,
                            CamposPersonalizados = origDto.CamposPersonalizados ?? new Dictionary<string, string?>(),
                            DocumentoOriginalId = origDto.DocumentoOriginalId,
                            SolicitanteId = origDto.SolicitanteId,
                            SolicitanteNombre = origDto.SolicitanteNombre,
                            EditorId = origDto.EditorId,
                            EditorNombre = origDto.EditorNombre,
                            AprobadorId = origDto.AprobadorId,
                            AprobadorNombre = origDto.AprobadorNombre,
                            FechaPublicacion = origDto.FechaPublicacion,
                            MotivoCambio = origDto.MotivoCambio,
                            DescripcionDetallada = origDto.DescripcionDetallada
                        };
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error deserializing original snapshot: {ex.Message}");
                }
            }

            if (originalDocParaDiff == null)
            {
                originalDocParaDiff = await ControlDocumentalApi.GetDocumentoAsync(solicitud.DocumentoControlId);
            }

            if (originalDocParaDiff != null && !string.IsNullOrEmpty(solicitud.DatosPropuestos))
            {
                var propuesta = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.UpdateDocumentoControlDto>(solicitud.DatosPropuestos, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (propuesta != null)
                {
                    AddDiffIfChanged("Código", originalDocParaDiff.Codigo, propuesta.Codigo);
                    AddDiffIfChanged("Nombre", originalDocParaDiff.Nombre, propuesta.Nombre);
                    AddDiffIfChanged("Proceso responsable", originalDocParaDiff.ProcesoResponsable, propuesta.ProcesoResponsable);
                    AddDiffIfChanged("Versión", originalDocParaDiff.Version, propuesta.Version);
                    AddDiffIfChanged("Fecha documento", originalDocParaDiff.FechaDocumento.ToLocalTime().ToString("d"), propuesta.FechaDocumento.ToLocalTime().ToString("d"));
                    AddDiffIfChanged("OneDrive URL", originalDocParaDiff.OneDriveUrl, propuesta.OneDriveUrl);
                    AddDiffIfChanged("Nombre de archivo", originalDocParaDiff.ArchivoNombre ?? "—", propuesta.ArchivoNombre ?? "—");
                    AddDiffIfChanged("Uso", originalDocParaDiff.Uso ?? "—", propuesta.Uso ?? "—");
                    AddDiffIfChanged("Tiempo de retención", originalDocParaDiff.TiempoRetencion ?? "—", propuesta.TiempoRetencion ?? "—");
                    AddDiffIfChanged("Protección", originalDocParaDiff.Proteccion ?? "—", propuesta.Proteccion ?? "—");
                    AddDiffIfChanged("Recuperación", originalDocParaDiff.Recuperacion ?? "—", propuesta.Recuperacion ?? "—");
                    AddDiffIfChanged("Disposición final", originalDocParaDiff.DisposicionFinal ?? "—", propuesta.DisposicionFinal ?? "—");

                    var origArea = areas.FirstOrDefault(a => a.Id == originalDocParaDiff.AreaId)?.Nombre ?? "—";
                    var propArea = areas.FirstOrDefault(a => a.Id == propuesta.AreaId)?.Nombre ?? "—";
                    AddDiffIfChanged("Área", origArea, propArea);

                    var origKeys = originalDocParaDiff.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                    var propKeys = propuesta.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                    var allKeys = origKeys.Union(propKeys).Distinct();

                    foreach (var key in allKeys)
                    {
                        originalDocParaDiff.CamposPersonalizados.TryGetValue(key, out var origVal);
                        propuesta.CamposPersonalizados.TryGetValue(key, out var propVal);
                        AddDiffIfChanged(key, origVal ?? "—", propVal ?? "—");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar detalles de la propuesta: {ex.Message}", "error");
        }

        showSolicitudDetalleModal = true;
    }

    private void AddDiffIfChanged(string fieldName, string origVal, string propVal)
    {
        var cleanOrig = origVal?.Trim() ?? string.Empty;
        var cleanProp = propVal?.Trim() ?? string.Empty;
        if (cleanOrig != cleanProp)
        {
            currentDiffs.Add(new DiffField
            {
                Name = fieldName,
                OriginalValue = string.IsNullOrWhiteSpace(cleanOrig) ? "—" : cleanOrig,
                ProposedValue = string.IsNullOrWhiteSpace(cleanProp) ? "—" : cleanProp
            });
        }
    }

    private List<TimelineEvent> BuildTimeline()
    {
        var events = new List<TimelineEvent>();

        var baseDoc = historial.OrderBy(d => d.Id).FirstOrDefault();
        if (baseDoc != null)
        {
            events.Add(new TimelineEvent
            {
                Tipo = "Creacion",
                SolicitudId = 0,
                Titulo = "📄 Documento Creado",
                Fecha = baseDoc.FechaDocumento,
                Usuario = baseDoc.SolicitanteNombre ?? baseDoc.EditorNombre ?? "Sistema",
                BadgeClass = "badge-success",
                Icon = "📄",
                SortOrder = 1,
                Codigo = baseDoc.Codigo,
                Nombre = baseDoc.Nombre,
                Version = baseDoc.Version,
                Area = baseDoc.AreaNombre ?? "—"
            });
        }

        foreach (var sol in documentoSolicitudes.OrderBy(s => s.FechaCreacion))
        {
            DocumentoControlDto? origDoc = null;
            if (!string.IsNullOrEmpty(sol.DatosOriginales))
            {
                try
                {
                    origDoc = System.Text.Json.JsonSerializer.Deserialize<DocumentoControlDto>(sol.DatosOriginales, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }
                catch {}
            }
            if (origDoc != null && string.IsNullOrEmpty(origDoc.AreaNombre) && origDoc.AreaId.HasValue)
            {
                origDoc.AreaNombre = areas.FirstOrDefault(a => a.Id == origDoc.AreaId.Value)?.Nombre;
            }

            events.Add(new TimelineEvent
            {
                Tipo = "Solicitud",
                SolicitudId = sol.Id,
                Titulo = "📝 Elaborado y/o cambiado",
                Fecha = sol.FechaCreacion,
                Usuario = sol.SolicitanteNombre ?? "Colaborador",
                BadgeClass = "badge-warning",
                Icon = "📝",
                SortOrder = 2,
                Motivo = !string.IsNullOrWhiteSpace(sol.MotivoCambio) ? sol.MotivoCambio : (sol.ComentarioSolicitud ?? "—"),
                Observaciones = !string.IsNullOrWhiteSpace(sol.DescripcionDetallada) ? sol.DescripcionDetallada : "Ninguna",
                SnapshotOriginal = origDoc
            });

            if (sol.FechaEdicion.HasValue)
            {
                List<DiffField> diffList = new();
                if (origDoc != null && !string.IsNullOrEmpty(sol.DatosPropuestos))
                {
                    try
                    {
                        var propDoc = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.UpdateDocumentoControlDto>(sol.DatosPropuestos, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                        if (propDoc != null)
                        {
                            void CheckChange(string fieldName, string? oVal, string? pVal)
                            {
                                oVal = oVal?.Trim() ?? string.Empty;
                                pVal = pVal?.Trim() ?? string.Empty;
                                if (oVal != pVal)
                                {
                                    diffList.Add(new DiffField 
                                    { 
                                        Name = fieldName, 
                                        OriginalValue = string.IsNullOrWhiteSpace(oVal) ? "—" : oVal, 
                                        ProposedValue = string.IsNullOrWhiteSpace(pVal) ? "—" : pVal 
                                    });
                                }
                            }

                            CheckChange("Código", origDoc.Codigo, propDoc.Codigo);
                            CheckChange("Nombre", origDoc.Nombre, propDoc.Nombre);
                            CheckChange("Proceso responsable", origDoc.ProcesoResponsable, propDoc.ProcesoResponsable);
                            CheckChange("Versión", origDoc.Version, propDoc.Version);
                            CheckChange("Fecha documento", origDoc.FechaDocumento.ToLocalTime().ToString("d"), propDoc.FechaDocumento.ToLocalTime().ToString("d"));
                            CheckChange("OneDrive URL", origDoc.OneDriveUrl, propDoc.OneDriveUrl);
                            CheckChange("Nombre de archivo", origDoc.ArchivoNombre, propDoc.ArchivoNombre);
                            CheckChange("Uso", origDoc.Uso, propDoc.Uso);
                            CheckChange("Tiempo de retención", origDoc.TiempoRetencion, propDoc.TiempoRetencion);
                            CheckChange("Protección", origDoc.Proteccion, propDoc.Proteccion);
                            CheckChange("Recuperación", origDoc.Recuperacion, propDoc.Recuperacion);
                            CheckChange("Disposición final", origDoc.DisposicionFinal, propDoc.DisposicionFinal);

                            var origArea = areas.FirstOrDefault(a => a.Id == origDoc.AreaId)?.Nombre ?? "—";
                            var propArea = areas.FirstOrDefault(a => a.Id == propDoc.AreaId)?.Nombre ?? "—";
                            CheckChange("Área", origArea, propArea);

                            var origKeys = origDoc.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                            var propKeys = propDoc.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                            var allKeys = origKeys.Union(propKeys).Distinct();

                            foreach (var key in allKeys)
                            {
                                origDoc.CamposPersonalizados.TryGetValue(key, out var origVal);
                                propDoc.CamposPersonalizados.TryGetValue(key, out var propVal);
                                CheckChange(key, origVal, propVal);
                            }
                        }
                    }
                    catch {}
                }

                events.Add(new TimelineEvent
                {
                    Tipo = "Edicion",
                    SolicitudId = sol.Id,
                    Titulo = "✏️ Verificado",
                    Fecha = sol.FechaEdicion.Value,
                    Usuario = !string.IsNullOrWhiteSpace(sol.EditorNombre) ? sol.EditorNombre : (!string.IsNullOrWhiteSpace(sol.SolicitanteNombre) ? sol.SolicitanteNombre : "Editor"),
                    BadgeClass = "badge-info",
                    Icon = "✏️",
                    SortOrder = 3,
                    Estado = GetEstadoPropuestaLabel(sol.EstadoPropuesta),
                    Cambios = diffList
                });
            }

            if (sol.FechaResolucion.HasValue)
            {
                bool esAprobada = sol.EstadoPropuesta == "Aprobada" || sol.EstadoPropuesta == "Publicada";
                
                string approverName = "Aprobador";
                if (!string.IsNullOrWhiteSpace(sol.AprobadorNombre))
                {
                    approverName = sol.AprobadorNombre;
                }
                else if (!string.IsNullOrWhiteSpace(sol.EditorNombre))
                {
                    approverName = sol.EditorNombre;
                }
                else if (sol.AprobadorId.HasValue && sol.AprobadorId == sol.SolicitanteId && !string.IsNullOrWhiteSpace(sol.SolicitanteNombre))
                {
                    approverName = sol.SolicitanteNombre;
                }

                events.Add(new TimelineEvent
                {
                    Tipo = "Aprobacion",
                    SolicitudId = sol.Id,
                    Titulo = esAprobada ? "✅ Cambio Aprobado" : "❌ Cambio Rechazado",
                    Fecha = sol.FechaResolucion.Value,
                    Usuario = approverName,
                    BadgeClass = esAprobada ? "badge-success" : "badge-danger",
                    Icon = esAprobada ? "✅" : "❌",
                    SortOrder = 4,
                    Comentarios = !string.IsNullOrWhiteSpace(sol.ComentarioResolucion) ? sol.ComentarioResolucion : "Sin comentarios"
                });
            }
        }

        return events.OrderBy(e => e.Fecha).ThenBy(e => e.SortOrder).ToList();
    }

    private List<IGrouping<int, TimelineEvent>> GetTimelineGroups()
    {
        var allEvents = BuildTimeline();
        return allEvents
            .GroupBy(e => e.SolicitudId)
            .OrderByDescending(g => g.Max(e => e.Fecha))
            .ToList();
    }

