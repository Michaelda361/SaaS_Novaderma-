    private List<DocumentVersionSnapshot> BuildVersionHistory(
        DocumentoControlDetalleDto? detalle,
        List<DocumentoControlDto> versions)
    {
        if (versions is null || !versions.Any())
            return new List<DocumentVersionSnapshot>();

        var list = new List<DocumentVersionSnapshot>();
        var relevantVersions = versions
            .Where(v => v.Estado == "Vigente" || v.Estado == "Histórica")
            .OrderByDescending(v => v.Estado == "Vigente") // Vigente comes first
            .ThenByDescending(v => v.Id)                   // Then descending chronological order of clones
            .ToList();

        foreach (var doc in relevantVersions)
        {
            var campos = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase)
            {
                ["Listado maestro"] = doc.ListadoMaestroNombre,
                ["Código"] = doc.Codigo,
                ["Nombre"] = doc.Nombre,
                ["Proceso responsable"] = doc.ProcesoResponsable,
                ["Versión"] = doc.Version,
                ["Fecha documento"] = doc.FechaDocumento.ToString("d"),
                ["Ubicación"] = null,
                ["OneDrive URL"] = doc.OneDriveUrl,
                ["OneDrive Item ID"] = null,
                ["Archivo"] = doc.ArchivoNombre,
                ["Uso"] = doc.Uso,
                ["Tiempo de retención"] = doc.TiempoRetencion,
                ["Protección"] = doc.Proteccion,
                ["Recuperación"] = doc.Recuperacion,
                ["Disposición final"] = doc.DisposicionFinal,
                ["Estado"] = doc.Estado,
                ["Observaciones"] = doc.Observaciones,
                ["Comentario de cambio"] = doc.ComentarioCambio,
                ["Área"] = doc.AreaNombre
            };

            if (doc.CamposPersonalizados != null)
            {
                foreach (var campo in doc.CamposPersonalizados)
                {
                    if (!campos.ContainsKey(campo.Key))
                    {
                        campos[campo.Key] = campo.Value;
                    }
                }
                if (doc.CamposPersonalizados.TryGetValue("Ubicación", out var ubicacion))
                {
                    campos["Ubicación"] = ubicacion;
                }
            }

            var autor = doc.EditorNombre ?? doc.SolicitanteNombre ?? doc.AprobadorNombre ?? "Sistema";
            var fecha = doc.FechaPublicacion?.ToLocalTime().ToString("g") ?? doc.FechaDocumento.ToLocalTime().ToString("g");
            var desc = $"{autor} · {fecha}";

            var titulo = $"Versión {doc.Version}";
            if (!string.IsNullOrWhiteSpace(doc.Estado))
            {
                titulo += $" ({doc.Estado})";
            }
            if (!string.IsNullOrWhiteSpace(doc.MotivoCambio))
            {
                titulo += $" - {doc.MotivoCambio}";
            }

            list.Add(new DocumentVersionSnapshot(titulo, desc, campos));
        }

        return list;
    }

