@page "/control-documental"
@attribute [PageTitle("Control Documental")]
@attribute [Authorize]
@using System.Net
@inject ControlDocumentalApiService ControlDocumentalApi
@inject AreaApiService AreaApi
@inject AuthInfoService AuthInfo

<Toast @ref="toast" />

<div class="page-header">
    <div>
        <h2 class="page-title">Control Documental</h2>
        <p class="page-subtitle">Registra, busca y audita documentos OneDrive con listados maestros.</p>
    </div>
    <div class="page-actions">
        @if (AuthInfo.EsAdmin || AuthInfo.EsJefe)
        {
            <button class="btn btn-secondary" @onclick="AbrirNuevoListado">
                + Nuevo listado maestro
            </button>
            <button class="btn btn-secondary" @onclick="AbrirEditarListado" disabled="@(!selectedListadoId.HasValue)">
                ✏️ Editar listado
            </button>
        }
        <button class="btn btn-primary" @onclick="AbrirNuevoDocumento" disabled="@(!selectedListadoId.HasValue)">
            + Nuevo documento
        </button>
    </div>
</div>

<div class="card" style="margin-bottom:1rem;">
    <div class="filter-bar">
        <select class="form-control" @bind="selectedListadoId" @bind:after="OnSelectedListadoChanged">
            <option value="">Selecciona un listado maestro</option>
            @foreach (var listado in listados)
            {
                <option value="@listado.Id">@listado.Nombre</option>
            }
        </select>
        <select class="form-control" @bind="selectedAreaId" @bind:after="Filtrar">
            <option value="0">Todas las áreas</option>
            @foreach (var area in areas)
            {
                <option value="@area.Id">@area.Nombre</option>
            }
        </select>
        <input type="text" class="form-control" placeholder="Buscar por nombre, código o proceso" @bind="filterBusqueda" @bind:after="Filtrar" />
        <input type="text" class="form-control" placeholder="Código" @bind="filterCodigo" @bind:after="Filtrar" />
        <input type="text" class="form-control" placeholder="Proceso responsable" @bind="filterProceso" @bind:after="Filtrar" />
        <input type="text" class="form-control" placeholder="Estado" @bind="filterEstado" @bind:after="Filtrar" />
    </div>
</div>

<div class="card">
    @if (loading)
    {
        <div class="loading"><div class="spinner"></div> Cargando...</div>
    }
    else if (!selectedListadoId.HasValue)
    {
        <div class="empty-state">
            <div class="empty-state-icon">📌</div>
            <h3>Selecciona un listado maestro</h3>
            <p>Elige un listado maestro para ver los documentos asociados.</p>
        </div>
    }
    else if (!documentos.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">📄</div>
            <h3>No hay documentos</h3>
            <p>No se encontraron documentos para este listado con los filtros actuales.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Proceso</th>
                        <th>Versión</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th>Área</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in documentos)
                    {
                        <tr>
                            <td>@item.Codigo</td>
                            <td>@item.Nombre</td>
                            <td>@item.ProcesoResponsable</td>
                            <td>@item.Version</td>
                            <td>@item.FechaDocumento.ToString("yyyy-MM-dd")</td>
                            <td><span class="badge @GetEstadoClass(item.Estado)">@item.Estado</span></td>
                            <td>@(item.AreaNombre ?? "—")</td>
                                <td style="display:flex;gap:.25rem;flex-wrap:wrap;">
                                <button class="btn btn-sm btn-secondary" @onclick="() => EditarDocumento(item.Id)">@(AuthInfo.EsSoloColaborador ? "Actualizar" : "Editar")</button>
                                <button class="btn btn-sm btn-info" @onclick="() => VerAuditoria(item.Id)">Auditoría</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
                <div class="modal-header">
                <h3>@(editing ? (AuthInfo.EsSoloColaborador ? "Actualizar documento" : "Editar documento") : "Nuevo documento")</h3>
                <button class="modal-close" @onclick="CerrarModal">×</button>
            </div>
            <div class="modal-body">
                <EditForm Model="form" OnValidSubmit="GuardarDocumento">
                    <DataAnnotationsValidator />
                    <div class="form-row">
                        <div class="form-group">
                            <label>Listado maestro *</label>
                            <InputSelect class="form-control" @bind-Value="form.ListadoMaestroId" disabled="@(editing && !(AuthInfo.EsAdmin || AuthInfo.EsJefe))">
                                <option value="">Selecciona un listado maestro</option>
                                @foreach (var listado in listados)
                                {
                                    <option value="@listado.Id">@listado.Nombre</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => form.ListadoMaestroId" />
                        </div>
                        <div class="form-group">
                            <label>@GetCampoLabel("Codigo", "Código") *</label>
                            <InputText class="form-control" @bind-Value="form.Codigo" />
                            <ValidationMessage For="() => form.Codigo" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>@GetCampoLabel("Nombre", "Nombre") *</label>
                            <InputText class="form-control" @bind-Value="form.Nombre" />
                            <ValidationMessage For="() => form.Nombre" />
                        </div>
                        <div class="form-group">
                            <label>@GetCampoLabel("ProcesoResponsable", "Proceso responsable") *</label>
                            <InputText class="form-control" @bind-Value="form.ProcesoResponsable" />
                            <ValidationMessage For="() => form.ProcesoResponsable" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>@GetCampoLabel("Version", "Versión")</label>
                            <InputText class="form-control" @bind-Value="form.Version" />
                        </div>
                        <div class="form-group">
                            <label>@GetCampoLabel("FechaDocumento", "Fecha de documento") *</label>
                            <InputDate class="form-control" @bind-Value="form.FechaDocumento" />
                            <ValidationMessage For="() => form.FechaDocumento" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>@GetCampoLabel("OneDriveUrl", "Archivo OneDrive") *</label>
                        <div class="one-drive-row">
                            <InputText class="form-control" @bind-Value="form.OneDriveUrl" placeholder="URL de OneDrive" />
                            <button type="button" class="btn btn-secondary" @onclick="() => showOneDriveBrowser = true">Buscar OneDrive</button>
                        </div>
                        <ValidationMessage For="() => form.OneDriveUrl" />
                        @if (!string.IsNullOrWhiteSpace(form.ArchivoNombre))
                        {
                            <small class="text-muted">Archivo seleccionado: @form.ArchivoNombre</small>
                        }
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>@GetCampoLabel("Estado", "Estado") *</label>
                            <InputSelect class="form-control" @bind-Value="form.Estado">
                                <option value="">Selecciona estado...</option>
                                <option value="Borrador">Borrador</option>
                                <option value="Revision">Revisión</option>
                                <option value="Aprobado">Aprobado</option>
                                <option value="Publicado">Publicado</option>
                            </InputSelect>
                            <ValidationMessage For="() => form.Estado" />
                        </div>
                        <div class="form-group">
                            <label>Área (opcional)</label>
                            <InputSelect class="form-control" @bind-Value="form.AreaId">
                                <option value="">Sin área específica</option>
                                @foreach (var area in areas)
                                {
                                    <option value="@area.Id">@area.Nombre</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    @if (listadoCampos.Any(c => !c.EsPredeterminado))
                    {
                        <div class="form-group">
                            <h4>Campos adicionales</h4>
                            @foreach (var campo in listadoCampos.Where(c => !c.EsPredeterminado))
                            {
                                <div class="form-group">
                                    <label>@campo.Nombre@if (campo.Requerido) { <span class="text-danger">*</span> }</label>
                                    @if (campo.Tipo == "Lista")
                                    {
                                        <InputSelect class="form-control" @bind-Value="form.CamposPersonalizados[campo.CampoClave]">
                                            <option value="">Selecciona...</option>
                                            @foreach (var opcion in campo.Opciones?.Split(',').Select(o => o.Trim()).Where(o => !string.IsNullOrWhiteSpace(o)) ?? Enumerable.Empty<string>())
                                            {
                                                <option value="@opcion">@opcion</option>
                                            }
                                        </InputSelect>
                                    }
                                    else if (campo.Tipo == "Fecha")
                                    {
                                        <InputText type="date" class="form-control" @bind-Value="form.CamposPersonalizados[campo.CampoClave]" />
                                    }
                                    else if (campo.Tipo == "Numero")
                                    {
                                        <InputText type="number" class="form-control" @bind-Value="form.CamposPersonalizados[campo.CampoClave]" />
                                    }
                                    else
                                    {
                                        <InputText class="form-control" @bind-Value="form.CamposPersonalizados[campo.CampoClave]" />
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div class="form-group">
                        <label>Comentario de cambio</label>
                        <InputTextArea class="form-control" @bind-Value="form.ComentarioCambio" Rows="3" />
                    </div>
                    <div class="form-group">
                        <label>Observaciones</label>
                        <InputTextArea class="form-control" @bind-Value="form.Observaciones" Rows="3" />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@guardando">@(guardando ? (editing ? "Actualizando..." : "Guardando...") : (editing ? (AuthInfo.EsSoloColaborador ? "Actualizar" : "Guardar") : "Guardar"))</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (showListadoModal)
{
    <div class="modal-overlay" @onclick="CerrarListadoModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@(editingListado ? "Editar listado maestro" : "Nuevo listado maestro")</h3>
                <button class="modal-close" @onclick="CerrarListadoModal">×</button>
            </div>
            <div class="modal-body">
                <EditForm Model="listadoForm" OnValidSubmit="CrearListado">
                    <DataAnnotationsValidator />
                    <div class="form-group">
                        <label>Nombre *</label>
                        <InputText class="form-control" @bind-Value="listadoForm.Nombre" />
                        <ValidationMessage For="() => listadoForm.Nombre" />
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <InputTextArea class="form-control" @bind-Value="listadoForm.Descripcion" Rows="3" />
                    </div>
                    <div class="form-group">
                        <label>Campos configurables</label>
                        <div class="template-documents">
                            @if (!listadoForm.Campos.Any())
                            {
                                <div class="text-muted mb-2">No hay campos configurados. Agrega uno para definir los parámetros del listado.</div>
                            }
                            @foreach (var campo in listadoForm.Campos.OrderBy(c => c.Orden))
                            {
                                <div class="template-document mb-3 p-3 border rounded">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <strong>@campo.CampoClave</strong>
                                            @if (campo.EsPredeterminado)
                                            {
                                                <span class="badge badge-secondary ml-2">Predeterminado</span>
                                            }
                                        </div>
                                        @if (!campo.EsPredeterminado)
                                        {
                                            <button type="button" class="btn btn-sm btn-danger" @onclick="() => EliminarCampoPlantilla(campo.CampoClave)">Eliminar</button>
                                        }
                                    </div>
                                    <div class="row gx-2">
                                        <div class="col-12 col-md-5 mb-2">
                                            <label>Etiqueta</label>
                                            <InputText class="form-control" @bind-Value="campo.Nombre" />
                                        </div>
                                        <div class="col-12 col-md-3 mb-2">
                                            <label>Tipo</label>
                                            <InputSelect class="form-control" @bind-Value="campo.Tipo">
                                                <option value="Texto">Texto</option>
                                                <option value="Numero">Número</option>
                                                <option value="Fecha">Fecha</option>
                                                <option value="Lista">Lista</option>
                                            </InputSelect>
                                        </div>
                                        <div class="col-12 col-md-2 mb-2">
                                            <label>Requerido</label>
                                            <div class="form-check">
                                                <InputCheckbox class="form-check-input" @bind-Value="campo.Requerido" />
                                                <label class="form-check-label">Sí</label>
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-2 mb-2">
                                            <label>Orden</label>
                                            <InputNumber class="form-control" @bind-Value="campo.Orden" />
                                        </div>
                                    </div>
                                    @if (campo.Tipo == "Lista")
                                    {
                                        <div class="mb-2">
                                            <label>Opciones (separadas por coma)</label>
                                            <InputText class="form-control" @bind-Value="campo.Opciones" />
                                        </div>
                                    }
                                </div>
                            }
                            <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AgregarCampoPlantilla">Agregar campo personalizado</button>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarListadoModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary" disabled="@guardandoListado">@(guardandoListado ? "Guardando..." : (editingListado ? "Guardar cambios" : "Crear listado"))</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (showAuditModal)
{
    <div class="modal-overlay" @onclick="CerrarAuditoriaModal">
        <div class="modal large" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Historial de auditoría</h3>
                <button class="modal-close" @onclick="CerrarAuditoriaModal">×</button>
            </div>
            <div class="modal-body">
                @if (historial is null || !historial.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">🕘</div>
                        <h3>Sin historial</h3>
                        <p>Aún no hay registros de auditoría para este documento.</p>
                    </div>
                }
                else
                {
                    @if (auditDocumentDetail is null)
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">⚠️</div>
                            <h3>Error al cargar el documento</h3>
                            <p>No se pudo cargar la versión actual del documento para mostrar el historial.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive mb-4">
                            <table class="table table-bordered table-striped">
                                <thead class="table-light">
                                    <tr>
                                        <th colspan="18">Versión actual</th>
                                    </tr>
                                    <tr>
                                        <th>Listado maestro</th>
                                        <th>Código</th>
                                        <th>Nombre</th>
                                        <th>Proceso responsable</th>
                                        <th>Versión</th>
                                        <th>Fecha documento</th>
                                        <th>Ubicación</th>
                                        <th>OneDrive URL</th>
                                        <th>OneDrive Item ID</th>
                                        <th>Archivo</th>
                                        <th>Uso</th>
                                        <th>Tiempo retención</th>
                                        <th>Protección</th>
                                        <th>Recuperación</th>
                                        <th>Disposición final</th>
                                        <th>Estado</th>
                                        <th>Área</th>
                                        <th>Observaciones</th>
                                        <th>Comentario</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Listado maestro")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Código")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Nombre")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Proceso responsable")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Versión")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Fecha documento")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Ubicación")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "OneDrive URL")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "OneDrive Item ID")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Archivo")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Uso")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Tiempo de retención")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Protección")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Recuperación")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Disposición final")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Estado")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Área")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Observaciones")</td>
                                        <td>@GetSnapshotValue(BuildSnapshot(auditDocumentDetail), "Comentario de cambio")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="mb-3">
                            <h4>Versiones anteriores</h4>
                        </div>

                        @if (!versionesAnteriores.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-state-icon">🕘</div>
                                <h3>Sin versiones anteriores</h3>
                                <p>Aún no hay registros de versiones anteriores para este documento.</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Fecha / Usuario</th>
                                            <th>Acción</th>
                                            <th>Listado maestro</th>
                                            <th>Código</th>
                                            <th>Nombre</th>
                                            <th>Proceso responsable</th>
                                            <th>Versión</th>
                                            <th>Fecha documento</th>
                                            <th>Ubicación</th>
                                            <th>OneDrive Item ID</th>
                                            <th>Archivo</th>
                                            <th>Uso</th>
                                            <th>Tiempo retención</th>
                                            <th>Protección</th>
                                            <th>Recuperación</th>
                                            <th>Disposición final</th>
                                            <th>Estado</th>
                                            <th>Área</th>
                                            <th>Observaciones</th>
                                            <th>Comentario</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var version in versionesAnteriores)
                                        {
                                            <tr>
                                                <td>@version.Descripcion</td>
                                                <td>@version.Titulo</td>
                                                <td>@GetSnapshotValue(version.Campos, "Listado maestro")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Código")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Nombre")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Proceso responsable")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Versión")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Fecha documento")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Ubicación")</td>
                                                <td>@GetSnapshotValue(version.Campos, "OneDrive Item ID")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Archivo")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Uso")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Tiempo de retención")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Protección")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Recuperación")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Disposición final")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Estado")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Área")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Observaciones")</td>
                                                <td>@GetSnapshotValue(version.Campos, "Comentario de cambio")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CerrarAuditoriaModal">Cerrar</button>
            </div>
        </div>
    </div>
}

<OneDriveBrowser Visible="showOneDriveBrowser"
                 OnSeleccionado="OnArchivoOneDriveSeleccionado"
                 OnCancelado="() => showOneDriveBrowser = false" />

@code {
    private Toast toast = null!;
    private bool loading = true;
    private bool editing = false;
    private bool showModal = false;
    private bool showListadoModal = false;
    private bool showAuditModal = false;
    private bool guardando = false;
    private bool guardandoListado = false;
    private bool showOneDriveBrowser = false;
    private bool editingListado = false;

    private int? selectedListadoId;
    private int? selectedAreaId;
    private string filterBusqueda = string.Empty;
    private string filterCodigo = string.Empty;
    private string filterProceso = string.Empty;
    private string filterEstado = string.Empty;

    private CreateDocumentoControlDto form = new();
    private CreateListadoMaestroDto listadoForm = new();
    private int? editingId;
    private List<DocumentoControlCampoDto> listadoCampos = [];

    private List<ListadoMaestroDto> listados = [];
    private List<DocumentoControlDto> documentos = [];
    private List<AreaDto> areas = [];
    private List<AuditLogDto> historial = [];
    private DocumentoControlDetalleDto? auditDocumentDetail;
    private List<DocumentVersionSnapshot> versionesAnteriores = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthInfo.LoadAsync();
            areas = await AreaApi.GetAllAsync() ?? [];
            listados = await ControlDocumentalApi.GetListadosMaestrosAsync() ?? [];
            selectedListadoId = listados.FirstOrDefault()?.Id;
            if (selectedListadoId.HasValue)
            {
                await LoadListadoCamposAsync(selectedListadoId.Value);
            }
            await Filtrar();
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar datos: {ex.Message}", "error");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Filtrar()
    {
        loading = true;
        if (!selectedListadoId.HasValue)
        {
            documentos = [];
            loading = false;
            return;
        }

        documentos = await ControlDocumentalApi.GetDocumentosAsync(
            selectedListadoId.Value,
            selectedAreaId > 0 ? selectedAreaId : null,
            string.IsNullOrWhiteSpace(filterBusqueda) ? null : filterBusqueda,
            string.IsNullOrWhiteSpace(filterCodigo) ? null : filterCodigo,
            string.IsNullOrWhiteSpace(filterProceso) ? null : filterProceso,
            string.IsNullOrWhiteSpace(filterEstado) ? null : filterEstado);
        loading = false;
    }

    private async Task OnSelectedListadoChanged()
    {
