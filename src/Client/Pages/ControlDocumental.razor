    private async Task LoadListadoCamposAsync(int listadoId)
    {
        var listado = await ControlDocumentalApi.GetListadoMaestroAsync(listadoId);
        listadoCampos = listado is null
            ? GetDefaultCampoPlantilla()
            : listado.Campos.Any()
                ? listado.Campos.OrderBy(c => c.Orden).ToList()
                : GetDefaultCampoPlantilla();
    }

    private void InitializeCamposPersonalizados()
    {
        if (form.CamposPersonalizados is null)
            form.CamposPersonalizados = new Dictionary<string, string?>();

        foreach (var campo in listadoCampos.Where(c => !c.EsPredeterminado))
        {
            if (!form.CamposPersonalizados.ContainsKey(campo.CampoClave))
            {
                form.CamposPersonalizados[campo.CampoClave] = null;
            }
        }
    }

