                        }
                        else
                        {
                            <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem; background: var(--surface-card);">
                                <thead>
                                    <tr style="background: var(--surface-muted); border-bottom: 1px solid var(--surface-border);">
                                        <th style="padding: 0.5rem; text-align: left; width: 30%; font-weight:600;">Campo modificado</th>
                                        <th style="padding: 0.5rem; text-align: left; width: 35%; font-weight:600;">Valor anterior (Antes)</th>
                                        <th style="padding: 0.5rem; text-align: left; width: 35%; font-weight:600;">Valor nuevo (Después)</th>
                                    </tr>
