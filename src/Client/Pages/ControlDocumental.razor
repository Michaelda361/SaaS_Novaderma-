    {
        get => _searchText;
        set
        {
            if (_searchText != value)
            {
                _searchText = value;
                currentPage = 1;
            }
        }
    }

    private CreateDocumentoControlDto form = new();
    private CreateListadoMaestroDto listadoForm = new();
    private int? editingId;
    private int? editingSolicitudId;
    private List<DocumentoControlCampoDto> listadoCampos = [];
    private bool importingListado = false;
    private bool showImportInstructions = false;

    private List<ListadoMaestroDto> listados = [];
    private List<DocumentoControlDto> documentos = [];
    private List<AreaDto> areas = [];
    private List<ListadoMaestroPermisoDto> listadoPermisos = [];
    private List<ListadoMaestroPermisoUpdateDto> nuevosPermisosListado = [];
    private List<ColaboradorDto> colaboradores = [];
    private List<SolicitudCambioDocumentoControlDto> documentoSolicitudes = [];
    private List<SolicitudCambioDocumentoControlDto> pendingSolicitudes = [];
    private bool loadingSolicitudes = false;
    private bool showPendingRequests = false;
    private bool showRejectModal = false;
    private bool showSolicitudDetalleModal = false;
    private SolicitudCambioDocumentoControlDto? selectedSolicitudDetalle = null;
    private bool showDiff = false;
    private string approvalComments = string.Empty;
    private bool showApproveModal = false;
    private SolicitudCambioDocumentoControlDto? solicitudSeleccionada = null;
    private RechazarSolicitudCambioDto rechazoForm = new();
    private bool processingSolicitud = false;
    
    private bool showSolicitudCambioModal = false;
    private DocumentoControlDetalleDto? documentoParaSolicitud = null;
    private string solicitudMotivo = string.Empty;
    private string solicitudObservaciones = string.Empty;
    private bool guardandoSolicitudCambio = false;
    private List<DocumentoControlDto> historial = [];
    private DocumentoControlDto? vigenteDoc;
    private List<DocumentoControlDto> sortedHistorial = [];
    private DocumentoControlDetalleDto? auditDocumentDetail;
    private List<DocumentVersionSnapshot> versionesAnteriores = [];

    private async Task AbrirPermisos()
    {
        if (!selectedListadoId.HasValue)
            return;

        permisosLoading = true;
        try
        {
            listadoPermisos = await ControlDocumentalApi.GetListadoPermisosAsync(selectedListadoId.Value);
            nuevosPermisosListado = [];
            tieneCambiosPermisos = false;
            showPermisosModal = true;
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar permisos: {ex.Message}", "error");
        }
        finally
        {
            permisosLoading = false;
        }
    }

    private void CerrarPermisosModal()
    {
        showPermisosModal = false;
        tieneCambiosPermisos = false;
    }

    private async Task GuardarPermisosListado()
    {
        if (!selectedListadoId.HasValue)
            return;

        permisosGuardando = true;
        try
        {
            var todosLosPermisos = listadoPermisos
                .Select(p => new ListadoMaestroPermisoUpdateDto
                {
                    ColaboradorId = p.ColaboradorId,
                    PuedeVer = p.PuedeVer,
                    PuedeEditar = p.PuedeEditar,
                    PuedeAprobar = p.PuedeAprobar
                })
                .Concat(nuevosPermisosListado.Where(p => p.ColaboradorId > 0))
                .GroupBy(p => p.ColaboradorId)
                .Select(g => g.Last())
                .ToList();

            var response = await ControlDocumentalApi.UpdateListadoPermisosAsync(selectedListadoId.Value, todosLosPermisos);
            if (response.IsSuccessStatusCode)
            {
                await toast.Show("Permisos guardados correctamente.", "success");
                showPermisosModal = false;
                await AbrirPermisos();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                await toast.Show($"Error al guardar permisos: {content}", "error");
            }
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al guardar permisos: {ex.Message}", "error");
        }
        finally
        {
            permisosGuardando = false;
        }
    }

    private void AgregarPermiso()
    {
        nuevosPermisosListado.Add(new ListadoMaestroPermisoUpdateDto
        {
            ColaboradorId = 0,
            PuedeVer = false,
            PuedeEditar = false,
            PuedeAprobar = false
        });
        tieneCambiosPermisos = true;
    }

    private void EliminarPermiso(int index)
    {
        if (index >= 0 && index < listadoPermisos.Count)
        {
            listadoPermisos.RemoveAt(index);
            tieneCambiosPermisos = true;
        }
    }

    private void EliminarPermisoNuevo(int index)
    {
        if (index >= 0 && index < nuevosPermisosListado.Count)
        {
            nuevosPermisosListado.RemoveAt(index);
            tieneCambiosPermisos = nuevosPermisosListado.Any();
        }
    }

    private void MarcarCambioPermisos()
    {
        tieneCambiosPermisos = true;
    }

    private async Task VerAuditoria(int id)
    {
        auditDocumentDetail = await ControlDocumentalApi.GetDocumentoAsync(id);
        historial = await ControlDocumentalApi.GetHistorialAsync(id);
        documentoSolicitudes = await ControlDocumentalApi.GetSolicitudesPorDocumentoAsync(id);
        versionesAnteriores = BuildVersionHistory(auditDocumentDetail, historial);

        vigenteDoc = historial?.FirstOrDefault(h => h.Estado == "Vigente") ?? (auditDocumentDetail != null ? new DocumentoControlDto {
            Nombre = auditDocumentDetail.Nombre,
            Codigo = auditDocumentDetail.Codigo,
            Version = auditDocumentDetail.Version,
            Estado = auditDocumentDetail.Estado,
            FechaPublicacion = auditDocumentDetail.FechaPublicacion,
            FechaDocumento = auditDocumentDetail.FechaDocumento,
            SolicitanteNombre = auditDocumentDetail.SolicitanteNombre,
            EditorNombre = auditDocumentDetail.EditorNombre,
            AprobadorNombre = auditDocumentDetail.AprobadorNombre,
            MotivoCambio = auditDocumentDetail.MotivoCambio,
            ComentarioCambio = auditDocumentDetail.ComentarioCambio
        } : null);

        sortedHistorial = historial?
            .OrderByDescending(h => h.Estado == "Vigente") // Vigente always first
            .ThenByDescending(h => {
                if (System.Version.TryParse(h.Version, out var v)) return v;
                return new System.Version(0, 0);
            })
            .ThenByDescending(h => h.FechaPublicacion ?? h.FechaDocumento)
            .ToList() ?? new List<DocumentoControlDto>();

        showAuditModal = true;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthInfo.LoadAsync();
            areas = await AreaApi.GetAllAsync() ?? [];
            colaboradores = await ColaboradorApi.GetAllAsync() ?? [];
            listados = await ControlDocumentalApi.GetListadosMaestrosAsync() ?? [];

            // Cargar listado seleccionado desde localStorage si está disponible
            var storedVal = await JS.InvokeAsync<string>("localStorage.getItem", "novahub_selected_listado_id");
            if (int.TryParse(storedVal, out var storedId) && listados.Any(l => l.Id == storedId))
            {
                selectedListadoId = storedId;
            }
            else
            {
                selectedListadoId = listados.FirstOrDefault()?.Id;
            }

            if (selectedListadoId.HasValue)
            {
                await LoadListadoCamposAsync(selectedListadoId.Value);
            }
            await Filtrar();
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar datos: {ex.Message}", "error");
        }
        finally
        {
            loading = false;
        }

        if (AuthInfo.EsAdmin || AuthInfo.EsJefe)
        {
            await LoadPendingSolicitudesAsync();
            // Unirse al grupo de admins para notificaciones en tiempo real
            await Notificaciones.UnirseGrupoAdminAsync();
            Notificaciones.OnNuevaSolicitudCambio += OnNuevaSolicitudCambio;
        }
    }

    private async Task OnListadoChanged(ChangeEventArgs e)
    {
        searchText = string.Empty;
        currentPage = 1;
        var val = e.Value?.ToString();
        if (int.TryParse(val, out var id))
        {
            selectedListadoId = id;
            try
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "novahub_selected_listado_id", id.ToString());
            }
            catch { }
            await LoadListadoCamposAsync(id);
        }
        else
        {
            selectedListadoId = null;
            try
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "novahub_selected_listado_id");
            }
            catch { }
            listadoCampos = [];
            documentos = [];
        }
        await Filtrar();
    }

    private async Task Filtrar()
    {
        loading = true;
        if (!selectedListadoId.HasValue)
        {
            documentos = [];
            loading = false;
            return;
        }

        documentos = await ControlDocumentalApi.GetDocumentosAsync(
            selectedListadoId.Value,
            null,
            null,
            null,
            null,
            null);
        loading = false;
    }

    private async Task LoadPendingSolicitudesAsync()
    {
        loadingSolicitudes = true;
        try
        {
            pendingSolicitudes = await ControlDocumentalApi.GetSolicitudesPendientesAsync() ?? [];
        }
        catch (Exception ex)
        {
            await toast.Show($"No se pudieron cargar las solicitudes de cambio: {ex.Message}", "error");
            pendingSolicitudes = [];
        }
        finally
        {
            loadingSolicitudes = false;
        }
    }

    public void Dispose()
    {
        try
        {
            Notificaciones.OnNuevaSolicitudCambio -= OnNuevaSolicitudCambio;
            _ = Notificaciones.SalirGrupoAdminAsync();
        }
        catch { }
    }

    private async Task AprobarSolicitud(int solicitudId)
    {
        var sol = pendingSolicitudes.FirstOrDefault(s => s.Id == solicitudId);
        if (sol != null)
        {
            AbrirAprobarSolicitud(sol);
        }
        else
        {
            await toast.Show("No se encontró la solicitud especificada.", "error");
        }
    }

    private void AbrirAprobarSolicitud(SolicitudCambioDocumentoControlDto solicitud)
    {
        solicitudSeleccionada = solicitud;
        approvalComments = string.Empty;
        showApproveModal = true;
    }

    private async Task ConfirmarAprobacion()
    {
        if (solicitudSeleccionada is null) return;

        processingSolicitud = true;
        try
        {
            var response = await ControlDocumentalApi.AprobarSolicitudCambioAsync(
                solicitudSeleccionada.Id,
                new TalentManagement.Shared.DTOs.ControlDocumental.AprobarSolicitudCambioDto { Comentarios = approvalComments });

            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                await toast.Show("No tienes permisos para aprobar esta solicitud.", "warning");
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                await toast.Show("Solicitud aprobada y publicada correctamente.", "success");
                showApproveModal = false;
                showSolicitudDetalleModal = false;
                await LoadPendingSolicitudesAsync();
                await Filtrar();
                return;
            }

            var message = await response.Content.ReadAsStringAsync();
            await toast.Show(string.IsNullOrWhiteSpace(message) ? "No se pudo aprobar la solicitud." : message, "error");
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al aprobar la solicitud: {ex.Message}", "error");
        }
        finally
        {
            processingSolicitud = false;
        }
    }

    private DocumentoControlDetalleDto? originalDocParaDiff;
    private List<DiffField> currentDiffs = new();

    private async Task AbrirSolicitudDetalles(SolicitudCambioDocumentoControlDto solicitud)
    {
        selectedSolicitudDetalle = solicitud;
        showDiff = false;
        approvalComments = string.Empty;
        currentDiffs.Clear();

        try
        {
            originalDocParaDiff = null;
            if (!string.IsNullOrEmpty(solicitud.DatosOriginales))
            {
                try
                {
                    var origDto = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.DocumentoControlDto>(solicitud.DatosOriginales, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (origDto != null)
                    {
                        originalDocParaDiff = new DocumentoControlDetalleDto
                        {
                            Id = origDto.Id,
                            ListadoMaestroId = origDto.ListadoMaestroId,
                            ListadoMaestroNombre = origDto.ListadoMaestroNombre,
                            Codigo = origDto.Codigo,
                            Nombre = origDto.Nombre,
                            ProcesoResponsable = origDto.ProcesoResponsable,
                            Version = origDto.Version,
                            FechaDocumento = origDto.FechaDocumento,
                            OneDriveUrl = origDto.OneDriveUrl,
                            Estado = origDto.Estado,
                            AreaId = origDto.AreaId,
                            AreaNombre = origDto.AreaNombre,
                            Uso = origDto.Uso,
                            TiempoRetencion = origDto.TiempoRetencion,
                            Proteccion = origDto.Proteccion,
                            Recuperacion = origDto.Recuperacion,
                            DisposicionFinal = origDto.DisposicionFinal,
                            Observaciones = origDto.Observaciones,
                            ComentarioCambio = origDto.ComentarioCambio,
                            ArchivoNombre = origDto.ArchivoNombre,
                            CamposPersonalizados = origDto.CamposPersonalizados ?? new Dictionary<string, string?>(),
                            DocumentoOriginalId = origDto.DocumentoOriginalId,
                            SolicitanteId = origDto.SolicitanteId,
                            SolicitanteNombre = origDto.SolicitanteNombre,
                            EditorId = origDto.EditorId,
                            EditorNombre = origDto.EditorNombre,
                            AprobadorId = origDto.AprobadorId,
                            AprobadorNombre = origDto.AprobadorNombre,
                            FechaPublicacion = origDto.FechaPublicacion,
                            MotivoCambio = origDto.MotivoCambio,
                            DescripcionDetallada = origDto.DescripcionDetallada
                        };
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error deserializing original snapshot: {ex.Message}");
                }
            }

            if (originalDocParaDiff == null)
            {
                originalDocParaDiff = await ControlDocumentalApi.GetDocumentoAsync(solicitud.DocumentoControlId);
            }

            if (originalDocParaDiff != null && !string.IsNullOrEmpty(solicitud.DatosPropuestos))
            {
                var propuesta = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.UpdateDocumentoControlDto>(solicitud.DatosPropuestos, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (propuesta != null)
                {
                    AddDiffIfChanged("Código", originalDocParaDiff.Codigo, propuesta.Codigo);
                    AddDiffIfChanged("Nombre", originalDocParaDiff.Nombre, propuesta.Nombre);
                    AddDiffIfChanged("Proceso responsable", originalDocParaDiff.ProcesoResponsable, propuesta.ProcesoResponsable);
                    AddDiffIfChanged("Versión", originalDocParaDiff.Version, propuesta.Version);
                    AddDiffIfChanged("Fecha documento", originalDocParaDiff.FechaDocumento.ToLocalTime().ToString("d"), propuesta.FechaDocumento.ToLocalTime().ToString("d"));
                    AddDiffIfChanged("OneDrive URL", originalDocParaDiff.OneDriveUrl, propuesta.OneDriveUrl);
                    AddDiffIfChanged("Nombre de archivo", originalDocParaDiff.ArchivoNombre ?? "—", propuesta.ArchivoNombre ?? "—");
                    AddDiffIfChanged("Uso", originalDocParaDiff.Uso ?? "—", propuesta.Uso ?? "—");
                    AddDiffIfChanged("Tiempo de retención", originalDocParaDiff.TiempoRetencion ?? "—", propuesta.TiempoRetencion ?? "—");
                    AddDiffIfChanged("Protección", originalDocParaDiff.Proteccion ?? "—", propuesta.Proteccion ?? "—");
                    AddDiffIfChanged("Recuperación", originalDocParaDiff.Recuperacion ?? "—", propuesta.Recuperacion ?? "—");
                    AddDiffIfChanged("Disposición final", originalDocParaDiff.DisposicionFinal ?? "—", propuesta.DisposicionFinal ?? "—");

                    var origArea = areas.FirstOrDefault(a => a.Id == originalDocParaDiff.AreaId)?.Nombre ?? "—";
                    var propArea = areas.FirstOrDefault(a => a.Id == propuesta.AreaId)?.Nombre ?? "—";
                    AddDiffIfChanged("Área", origArea, propArea);

                    var origKeys = originalDocParaDiff.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                    var propKeys = propuesta.CamposPersonalizados?.Keys ?? Enumerable.Empty<string>();
                    var allKeys = origKeys.Union(propKeys).Distinct();

                    foreach (var key in allKeys)
                    {
                        originalDocParaDiff.CamposPersonalizados.TryGetValue(key, out var origVal);
                        propuesta.CamposPersonalizados.TryGetValue(key, out var propVal);
                        AddDiffIfChanged(key, origVal ?? "—", propVal ?? "—");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar detalles de la propuesta: {ex.Message}", "error");
        }

        showSolicitudDetalleModal = true;
    }

    private void AddDiffIfChanged(string fieldName, string origVal, string propVal)
    {
        var cleanOrig = origVal?.Trim() ?? string.Empty;
        var cleanProp = propVal?.Trim() ?? string.Empty;
        if (cleanOrig != cleanProp)
        {
            currentDiffs.Add(new DiffField
            {
                Name = fieldName,
                OriginalValue = string.IsNullOrWhiteSpace(cleanOrig) ? "—" : cleanOrig,
                ProposedValue = string.IsNullOrWhiteSpace(cleanProp) ? "—" : cleanProp
            });
        }
    }

    private List<TimelineEvent> BuildTimeline()
    {
        var events = new List<TimelineEvent>();

        var baseDoc = historial.OrderBy(d => d.Id).FirstOrDefault();
        if (baseDoc != null)
        {
            events.Add(new TimelineEvent
            {
                Tipo = "Creacion",
                Titulo = "Creación del documento",
                Fecha = baseDoc.FechaDocumento,
                Usuario = baseDoc.SolicitanteNombre ?? baseDoc.EditorNombre ?? "Sistema",
                Detalle1 = "Documento inicializado",
                BadgeClass = "badge-success",
                Icon = "🆕",
                SortOrder = 1
            });
        }

        foreach (var sol in documentoSolicitudes.OrderBy(s => s.FechaCreacion))
        {
            events.Add(new TimelineEvent
            {
                Tipo = "Solicitud",
                Titulo = "Solicitud de Cambio",
                Fecha = sol.FechaCreacion,
                Usuario = sol.SolicitanteNombre ?? "Colaborador",
                Detalle1 = $"Motivo: {(!string.IsNullOrWhiteSpace(sol.MotivoCambio) ? sol.MotivoCambio : sol.ComentarioSolicitud)}",
                Detalle2 = !string.IsNullOrWhiteSpace(sol.DescripcionDetallada) ? $"Observaciones: {sol.DescripcionDetallada}" : string.Empty,
                BadgeClass = "badge-warning",
                Icon = "📝",
                SortOrder = 2
            });

            // Document before the change request (Snapshot)
            if (!string.IsNullOrEmpty(sol.DatosOriginales))
            {
                try
                {
                    var orig = System.Text.Json.JsonSerializer.Deserialize<TalentManagement.Shared.DTOs.ControlDocumental.DocumentoControlDto>(sol.DatosOriginales, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (orig != null)
                    {
                        events.Add(new TimelineEvent
                        {
                            Tipo = "SnapshotOriginal",
                            Titulo = "Documento antes de la solicitud",
                            Fecha = sol.FechaCreacion,
                            Usuario = sol.SolicitanteNombre ?? "Colaborador",
                            Detalle1 = $"Código: {orig.Codigo} | Versión: {orig.Version} | Estado: {orig.Estado}",
                            Detalle2 = $"Nombre: {orig.Nombre} | Proceso: {orig.ProcesoResponsable}",
                            BadgeClass = "badge-gray",
                            Icon = "📄",
                            SortOrder = 3
                        });
                    }
                }
                catch {}
            }

            if (sol.FechaRevision.HasValue)
            {
                events.Add(new TimelineEvent
                {
                    Tipo = "Revision",
                    Titulo = "Ingreso a Revisión",
                    Fecha = sol.FechaRevision.Value,
                    Usuario = sol.RevisorNombre ?? "Revisor",
                    Detalle1 = !string.IsNullOrWhiteSpace(sol.ObservacionesRevision) ? $"Observaciones de revisión: {sol.ObservacionesRevision}" : "Revisión iniciada",
                    BadgeClass = "badge-info",
                    Icon = "🔍",
                    SortOrder = 4
                });
            }

            if (sol.FechaEdicion.HasValue)
            {
                events.Add(new TimelineEvent
                {
                    Tipo = "Edicion",
                    Titulo = "Edición de borrador",
                    Fecha = sol.FechaEdicion.Value,
                    Usuario = sol.EditorNombre ?? sol.SolicitanteNombre ?? "Editor",
                    Detalle1 = "Modificación de metadatos y borrador guardado",
                    BadgeClass = "badge-primary",
                    Icon = "✏️",
                    SortOrder = 5
                });
            }

            if (sol.FechaResolucion.HasValue)
            {
                bool esAprobada = sol.EstadoPropuesta == "Aprobada" || sol.EstadoPropuesta == "Publicada";
                events.Add(new TimelineEvent
                {
                    Tipo = "Resolucion",
                    Titulo = esAprobada ? "Aprobación de solicitud" : "Rechazo de solicitud",
                    Fecha = sol.FechaResolucion.Value,
                    Usuario = sol.AprobadorNombre ?? "Aprobador",
                    Detalle1 = !string.IsNullOrWhiteSpace(sol.ComentarioResolucion) ? $"Comentarios: {sol.ComentarioResolucion}" : string.Empty,
                    BadgeClass = esAprobada ? "badge-success" : "badge-danger",
                    Icon = esAprobada ? "✅" : "❌",
                    SortOrder = 6
                });

                if (esAprobada)
                {
                    var versionDoc = historial.FirstOrDefault(d => d.Id == sol.BorradorDocumentoId || (d.DocumentoOriginalId == sol.DocumentoControlId && d.FechaPublicacion >= sol.FechaResolucion.Value.AddSeconds(-5) && d.FechaPublicacion <= sol.FechaResolucion.Value.AddSeconds(5)));
                    string versionStr = versionDoc?.Version ?? "Nueva versión";
                    
                    events.Add(new TimelineEvent
                    {
                        Tipo = "Publicacion",
                        Titulo = "Publicación de Nueva Versión",
                        Fecha = sol.FechaResolucion.Value,
                        Usuario = sol.AprobadorNombre ?? "Sistema",
                        Detalle1 = $"Nueva versión vigente: Versión {versionStr}",
                        BadgeClass = "badge-success",
                        Icon = "📢",
                        SortOrder = 7
                    });
                }
            }
        }

        return events.OrderBy(e => e.Fecha).ThenBy(e => e.SortOrder).ToList();
    }

