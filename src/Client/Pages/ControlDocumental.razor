    private bool IsValidUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;
        return Uri.TryCreate(value, UriKind.Absolute, out var uriResult) 
               && (uriResult.Scheme == Uri.UriSchemeHttp || uriResult.Scheme == Uri.UriSchemeHttps);
    }

    private IEnumerable<DocumentoControlDto> GetFilteredDocumentos()
    {
        IEnumerable<DocumentoControlDto> query = documentos;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var searchTrimmed = searchText.Trim();
            query = query.Where(item =>
                (item.Nombre != null && item.Nombre.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.Codigo != null && item.Codigo.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.Version != null && item.Version.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.Estado != null && item.Estado.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.ProcesoResponsable != null && item.ProcesoResponsable.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.OneDriveUrl != null && item.OneDriveUrl.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.ArchivoNombre != null && item.ArchivoNombre.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.Uso != null && item.Uso.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.TiempoRetencion != null && item.TiempoRetencion.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.Proteccion != null && item.Proteccion.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.Recuperacion != null && item.Recuperacion.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.DisposicionFinal != null && item.DisposicionFinal.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.Observaciones != null && item.Observaciones.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)) ||
                (item.CamposPersonalizados != null && item.CamposPersonalizados.Values.Any(v => v != null && v.Contains(searchTrimmed, StringComparison.OrdinalIgnoreCase)))
            );
        }

        return query
            .OrderByDescending(item => item.FechaPublicacion ?? item.FechaDocumento)
            .ThenByDescending(item => item.Id);
    }

    private async Task LoadListadoCamposAsync(int listadoId)
    {
        var listado = await ControlDocumentalApi.GetListadoMaestroAsync(listadoId);
        listadoCampos = listado is null
            ? new List<DocumentoControlCampoDto>()
            : listado.Campos.OrderBy(c => c.Orden).ToList();
    }

    private void InitializeCamposPersonalizados()
    {
        if (form.CamposPersonalizados is null)
            form.CamposPersonalizados = new Dictionary<string, string?>();

        foreach (var campo in listadoCampos.Where(c => !c.EsPredeterminado))
        {
            if (!form.CamposPersonalizados.ContainsKey(campo.CampoClave))
            {
                form.CamposPersonalizados[campo.CampoClave] = null;
            }
        }
    }

