    private async Task GuardarDocumento()
    {
        guardando = true;
        try
        {
            if (editingId.HasValue)
            {
                var updateDto = new UpdateDocumentoControlDto
                {
                    ListadoMaestroId = form.ListadoMaestroId,
                    Codigo = form.Codigo,
                    Nombre = form.Nombre,
                    ProcesoResponsable = form.ProcesoResponsable,
                    Version = form.Version,
                    FechaDocumento = form.FechaDocumento,
                    OneDriveUrl = form.OneDriveUrl,
                    OneDriveItemId = form.OneDriveItemId,
                    ArchivoNombre = form.ArchivoNombre,
                    Uso = form.Uso,
                    TiempoRetencion = form.TiempoRetencion,
                    Proteccion = form.Proteccion,
                    Recuperacion = form.Recuperacion,
                    DisposicionFinal = form.DisposicionFinal,
                    Estado = form.Estado,
                    Observaciones = form.Observaciones,
                    ComentarioCambio = form.ComentarioCambio,
                    AreaId = form.AreaId,
                    CamposPersonalizados = form.CamposPersonalizados
                };

                HttpResponseMessage response;
                if (editingSolicitudId.HasValue)
                {
                    response = await ControlDocumentalApi.UpdateBorradorDocumentoAsync(editingSolicitudId.Value, updateDto);
                }
                else
                {
                    response = await ControlDocumentalApi.UpdateDocumentoAsync(editingId.Value, updateDto);
                }

                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para reasignar el listado maestro o actualizar este documento.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    var message = await response.Content.ReadAsStringAsync();
                    await toast.Show(string.IsNullOrWhiteSpace(message)
                        ? "No se pudo procesar la solicitud."
                        : message,
                        "error");
                    return;
                }

                if (response.StatusCode == HttpStatusCode.Created)
                {
                    await toast.Show("Solicitud de cambio enviada para revisión.", "success");
                }
                else
                {
                    await toast.Show("Documento actualizado correctamente.", "success");
                }
            }
            else
            {
                var createDto = new CreateDocumentoControlDto
                {
                    ListadoMaestroId = form.ListadoMaestroId,
                    Codigo = form.Codigo,
                    Nombre = form.Nombre,
                    ProcesoResponsable = form.ProcesoResponsable,
                    Version = form.Version,
                    FechaDocumento = form.FechaDocumento,
                    OneDriveUrl = form.OneDriveUrl,
                    OneDriveItemId = form.OneDriveItemId,
                    ArchivoNombre = form.ArchivoNombre,
                    Uso = form.Uso,
                    TiempoRetencion = form.TiempoRetencion,
                    Proteccion = form.Proteccion,
                    Recuperacion = form.Recuperacion,
                    DisposicionFinal = form.DisposicionFinal,
                    Estado = form.Estado,
                    Observaciones = form.Observaciones,
                    ComentarioCambio = form.ComentarioCambio,
                    AreaId = form.AreaId,
                    CamposPersonalizados = form.CamposPersonalizados
                };
                var response = await ControlDocumentalApi.CreateDocumentoAsync(createDto);
                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para crear documentos en este listado.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    await toast.Show("No se pudo crear el documento.", "error");
                    return;
                }

                await toast.Show("Documento creado correctamente.");
            }

            showModal = false;
            await Filtrar();
        }
        finally
        {
            guardando = false;
        }
    }

