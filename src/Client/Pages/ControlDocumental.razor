            <div class="modal-body">
                <EditForm Model="rechazoForm" OnValidSubmit="RechazarSolicitud">
                    <DataAnnotationsValidator />
                    <div class="form-group">
                        <label>Motivo de rechazo *</label>
                        <InputTextArea class="form-control" @bind-Value="rechazoForm.MotivoRechazo" Rows="4" />
                        <ValidationMessage For="() => rechazoForm.MotivoRechazo" />
