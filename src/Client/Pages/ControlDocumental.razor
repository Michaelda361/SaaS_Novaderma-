    private async Task AbrirEditarListado()
    {
        if (!selectedListadoId.HasValue) return;
        var listado = await ControlDocumentalApi.GetListadoMaestroAsync(selectedListadoId.Value);
        if (listado is null)
        {
            await toast.Show("No se pudo cargar la configuración del listado.", "error");
            return;
        }

        editingListado = true;
        listadoForm = new CreateListadoMaestroDto
        {
            Nombre = listado.Nombre,
            Descripcion = listado.Descripcion,
            Campos = listado.Campos.Any() ? listado.Campos.OrderBy(c => c.Orden).ToList() : GetDefaultCampoPlantilla()
        };
        showListadoModal = true;
    }

    private async Task CrearListado()
    {
        guardandoListado = true;
        try
        {
            if (editingListado)
            {
                if (!selectedListadoId.HasValue) return;
                var response = await ControlDocumentalApi.UpdateListadoMaestroAsync(selectedListadoId.Value, listadoForm);
                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para editar este listado maestro.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    await toast.Show("No se pudo actualizar el listado maestro.", "error");
                    return;
                }

                var local = listados.FirstOrDefault(l => l.Id == selectedListadoId.Value);
                if (local is not null)
                {
                    local.Nombre = listadoForm.Nombre;
                    local.Descripcion = listadoForm.Descripcion;
                }
                await toast.Show("Listado maestro actualizado correctamente.");
            }
            else
            {
                var response = await ControlDocumentalApi.CreateListadoMaestroAsync(listadoForm);
                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para crear un listado maestro.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    await toast.Show("No se pudo crear el listado maestro.", "error");
                    return;
                }

                var created = await response.Content.ReadFromJsonAsync<ListadoMaestroDto>(new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (created is null)
                {
                    await toast.Show("No se pudo crear el listado maestro.", "error");
                    return;
                }

                listados.Add(created);
                selectedListadoId = created.Id;
                await toast.Show("Listado maestro creado correctamente.");
            }

            listadoForm = new CreateListadoMaestroDto();
            showListadoModal = false;
            await Filtrar();
        }
        finally
        {
            guardandoListado = false;
        }
    }

    private async Task VerAuditoria(int id)
    {
        auditDocumentDetail = await ControlDocumentalApi.GetDocumentoAsync(id);
        historial = await ControlDocumentalApi.GetHistorialAsync(id);
        versionesAnteriores = BuildVersionHistory(auditDocumentDetail, historial);
        showAuditModal = true;
    }

    private List<DocumentVersionSnapshot> BuildVersionHistory(
        DocumentoControlDetalleDto? detalle,
        List<AuditLogDto> logs)
    {
        if (detalle is null || logs is null || !logs.Any())
            return new List<DocumentVersionSnapshot>();

        var snapshot = BuildSnapshot(detalle);
        var versiones = new List<DocumentVersionSnapshot>();

        foreach (var log in logs.OrderByDescending(l => l.FechaHora))
        {
            if (string.IsNullOrWhiteSpace(log.CamposModificados))
                continue;

            var cambios = ParseCamposModificados(log.CamposModificados);
            var anterior = snapshot.ToDictionary(k => k.Key, v => v.Value, StringComparer.OrdinalIgnoreCase);

            foreach (var cambio in cambios)
            {
                var label = GetFieldLabel(cambio.Key);
                anterior[label] = FormatFieldValue(cambio.Key, cambio.Value.Antes);
            }

            versiones.Add(new DocumentVersionSnapshot(
                log.Accion,
                $"{log.ColaboradorNombre} · {log.FechaHora.ToLocalTime():g}",
                anterior));

            snapshot = anterior;
        }

        return versiones;
    }

    private static Dictionary<string, string?> BuildSnapshot(DocumentoControlDetalleDto detalle)
    {
        var snapshot = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase)
        {
            ["Listado maestro"] = detalle.ListadoMaestroNombre,
            ["Código"] = detalle.Codigo,
            ["Nombre"] = detalle.Nombre,
            ["Proceso responsable"] = detalle.ProcesoResponsable,
            ["Versión"] = detalle.Version,
            ["Fecha documento"] = detalle.FechaDocumento.ToString("d"),
            ["Ubicación"] = null,
            ["OneDrive URL"] = detalle.OneDriveUrl,
            ["OneDrive Item ID"] = detalle.OneDriveItemId,
            ["Archivo"] = detalle.ArchivoNombre,
            ["Uso"] = detalle.Uso,
            ["Tiempo de retención"] = detalle.TiempoRetencion,
            ["Protección"] = detalle.Proteccion,
            ["Recuperación"] = detalle.Recuperacion,
            ["Disposición final"] = detalle.DisposicionFinal,
            ["Estado"] = detalle.Estado,
            ["Observaciones"] = detalle.Observaciones,
            ["Comentario de cambio"] = detalle.ComentarioCambio,
            ["Área"] = detalle.AreaNombre,
            ["Descripción de listado"] = detalle.ListadoMaestroDescripcion
        };

        if (detalle.CamposPersonalizados != null)
        {
            foreach (var campo in detalle.CamposPersonalizados)
            {
                if (!snapshot.ContainsKey(campo.Key))
                {
                    snapshot[campo.Key] = campo.Value;
                }
            }

            if (detalle.CamposPersonalizados.TryGetValue("Ubicación", out var ubicacion))
            {
                snapshot["Ubicación"] = ubicacion;
            }
        }

        return snapshot;
    }

    private string GetFieldLabel(string propertyName) => propertyName switch
    {
        "ListadoMaestroId" => "Listado maestro",
        "AreaId" => "Área",
        "OneDriveUrl" => "OneDrive URL",
        "OneDriveItemId" => "OneDrive Item ID",
        "ArchivoNombre" => "Archivo",
        "TiempoRetencion" => "Tiempo de retención",
        "DisposicionFinal" => "Disposición final",
        "ComentarioCambio" => "Comentario de cambio",
        "FechaDocumento" => "Fecha documento",
        "Ubicacion" => "Ubicación",
        _ => propertyName
    };

    private string? FormatFieldValue(string propertyName, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return value;

        return propertyName switch
        {
            "ListadoMaestroId" when int.TryParse(value, out var listadoId) => GetListadoNombre(listadoId),
            "AreaId" when int.TryParse(value, out var areaId) => GetAreaNombre(areaId),
            "FechaDocumento" when DateTime.TryParse(value, out var fecha) => fecha.ToString("d"),
            _ => value
        };
    }

    private string GetListadoNombre(int listadoId) => listados.FirstOrDefault(l => l.Id == listadoId)?.Nombre ?? $"#{listadoId}";

    private string GetAreaNombre(int areaId) => areas.FirstOrDefault(a => a.Id == areaId)?.Nombre ?? $"#{areaId}";

    private static string? GetSnapshotValue(Dictionary<string, string?> campos, string clave) =>
        campos.TryGetValue(clave, out var valor) ? valor : string.Empty;

    private record DocumentVersionSnapshot(string Titulo, string Descripcion, Dictionary<string, string?> Campos);

    private static Dictionary<string, (string Antes, string Despues)> ParseCamposModificados(string cambiosJson)
    {
        if (string.IsNullOrWhiteSpace(cambiosJson))
            return new Dictionary<string, (string Antes, string Despues)>();

        try
        {
            var document = System.Text.Json.JsonDocument.Parse(cambiosJson);
            var parsed = new Dictionary<string, (string Antes, string Despues)>(StringComparer.OrdinalIgnoreCase);

            foreach (var property in document.RootElement.EnumerateObject())
            {
                if (property.Value.ValueKind == System.Text.Json.JsonValueKind.Object)
                {
                    var antes = property.Value.TryGetProperty("de", out var antesElement)
                        ? antesElement.GetString() ?? string.Empty
                        : string.Empty;

                    var despues = property.Value.TryGetProperty("a", out var despuesElement)
                        ? despuesElement.GetString() ?? string.Empty
                        : string.Empty;

                    parsed[property.Name] = (antes, despues);
                }
                else
                {
                    parsed[property.Name] = (property.Value.ToString() ?? string.Empty, string.Empty);
                }
            }

            return parsed;
        }
        catch
        {
            return new Dictionary<string, (string Antes, string Despues)>();
        }
    }

