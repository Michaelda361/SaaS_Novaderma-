            if (pendingSolicitudes == null) return Enumerable.Empty<SolicitudCambioDocumentoControlDto>();
            
            return pendingSolicitudes
                .Where(s => s.EstadoPropuesta == "PendienteRevision" || s.EstadoPropuesta == "EnEdicion" || s.EstadoPropuesta == "PendienteAprobacion")
