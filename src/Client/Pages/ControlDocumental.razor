                        @if (diffs == null || !diffs.Any())
                        {
                            <div style="text-align: center; color: var(--text-muted); font-size: 0.9rem; padding: 0.5rem;">
                                No se encontraron diferencias registradas (puede ser la versión inicial o metadatos idénticos).
