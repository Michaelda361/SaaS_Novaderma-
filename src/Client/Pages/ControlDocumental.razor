    private async Task EnviarSolicitudCambio()
    {
        if (documentoParaSolicitud is null || string.IsNullOrWhiteSpace(solicitudMotivo))
        {
            await toast.Show("Por favor completa el motivo de la solicitud.", "warning");
            return;
        }

        guardandoSolicitudCambio = true;
        try
        {
            // Crear un DTO con los datos actuales del documento como "propuesta"
            // El motivo va en el campo ComentarioCambio
            var updateDto = new UpdateDocumentoControlDto
            {
                ListadoMaestroId = documentoParaSolicitud.ListadoMaestroId,
                Codigo = documentoParaSolicitud.Codigo,
                Nombre = documentoParaSolicitud.Nombre,
                ProcesoResponsable = documentoParaSolicitud.ProcesoResponsable,
                Version = documentoParaSolicitud.Version,
                FechaDocumento = documentoParaSolicitud.FechaDocumento,
                OneDriveUrl = documentoParaSolicitud.OneDriveUrl,
                OneDriveItemId = documentoParaSolicitud.OneDriveItemId,
                ArchivoNombre = documentoParaSolicitud.ArchivoNombre,
                Uso = documentoParaSolicitud.Uso,
                TiempoRetencion = documentoParaSolicitud.TiempoRetencion,
                Proteccion = documentoParaSolicitud.Proteccion,
                Recuperacion = documentoParaSolicitud.Recuperacion,
                DisposicionFinal = documentoParaSolicitud.DisposicionFinal,
                Estado = documentoParaSolicitud.Estado,
                Observaciones = documentoParaSolicitud.Observaciones,
                ComentarioCambio = solicitudMotivo + (string.IsNullOrWhiteSpace(solicitudObservaciones) ? "" : $"\n\nObservaciones adicionales: {solicitudObservaciones}"),
                AreaId = documentoParaSolicitud.AreaId,
                CamposPersonalizados = documentoParaSolicitud.CamposPersonalizados ?? new Dictionary<string, string?>()
            };

            // Enviar la solicitud - el servidor retornará 201 (Created) indicando que creó una solicitud de cambio
            var response = await ControlDocumentalApi.UpdateDocumentoAsync(documentoParaSolicitud.Id, updateDto);

            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                await toast.Show("No tienes permisos para enviar solicitudes de cambio.", "warning");
                return;
            }

            if (response.StatusCode == HttpStatusCode.Created)
            {
                await toast.Show("Solicitud de cambio enviada correctamente. Un administrador o jefe la revisará y editará el documento según tu solicitud.", "success");
                CerrarSolicitudCambioModal();
                await LoadPendingSolicitudesAsync();
                await Filtrar();
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                await toast.Show(string.IsNullOrWhiteSpace(message) ? "No se pudo enviar la solicitud." : message, "error");
                return;
            }

            await toast.Show("Solicitud enviada correctamente.", "success");
            CerrarSolicitudCambioModal();
            await LoadPendingSolicitudesAsync();
            await Filtrar();
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al enviar la solicitud: {ex.Message}", "error");
        }
        finally
        {
            guardandoSolicitudCambio = false;
        }
    }

    private string GetFormattedJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return "No hay datos propuestos.";

        try
        {
            using var document = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(document.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

