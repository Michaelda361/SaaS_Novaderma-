    private async Task OnArchivoListadoSeleccionado(InputFileChangeEventArgs e)
    {
        importingListado = true;

        try
        {
            var file = e.File;
            if (file is null)
            {
                return;
            }

            await using var stream = file.OpenReadStream(maxAllowedSize: 10_485_760);
            using var content = new MultipartFormDataContent();
            using var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new MediaTypeHeaderValue("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            content.Add(streamContent, "file", file.Name);

            var response = await ControlDocumentalApi.ImportListadoAsync(content);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                await toast.Show($"Error importando listado: {error}", "error");
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<ListadoMaestroDto>(JsonOptions);
            if (created is not null)
            {
                listados = await ControlDocumentalApi.GetListadosMaestrosAsync() ?? [];
                selectedListadoId = created.Id;
                try
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "novahub_selected_listado_id", created.Id.ToString());
                }
                catch { }
                await toast.Show("Listado importado correctamente.");
                await LoadListadoCamposAsync(created.Id);
                await Filtrar();
            }
        }
        catch (Exception ex)
        {
            await toast.Show($"Error importando listado: {ex.Message}", "error");
        }
        finally
        {
            importingListado = false;
        }
    }

    private async Task EliminarListadoSeleccionado()
    {
        if (!selectedListadoId.HasValue)
        {
            return;
        }

        var confirm = await JS.InvokeAsync<bool>("confirm", "¿Estás seguro de que deseas eliminar este listado maestro? Esta acción ocultará el listado y sus documentos.");
        if (!confirm)
        {
            return;
        }

        var response = await ControlDocumentalApi.DeleteListadoMaestroAsync(selectedListadoId.Value);
        if (response.StatusCode == HttpStatusCode.Forbidden)
        {
            await toast.Show("No tiene permisos para eliminar este listado maestro.", "warning");
            return;
        }

        if (response.StatusCode == HttpStatusCode.NotFound)
        {
            await toast.Show("Listado maestro no encontrado.", "error");
            return;
        }

        if (!response.IsSuccessStatusCode)
        {
            await toast.Show("No se pudo eliminar el listado maestro.", "error");
            return;
        }

        var removed = listados.FirstOrDefault(l => l.Id == selectedListadoId.Value);
        if (removed is not null)
        {
            listados.Remove(removed);
        }

        selectedListadoId = listados.FirstOrDefault()?.Id;
        if (selectedListadoId.HasValue)
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "novahub_selected_listado_id", selectedListadoId.Value.ToString());
            }
            catch { }
            await LoadListadoCamposAsync(selectedListadoId.Value);
        }
        else
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "novahub_selected_listado_id");
            }
            catch { }
            listadoCampos = GetDefaultCampoPlantilla();
            documentos = [];
        }

        await Filtrar();
        await toast.Show("Listado maestro eliminado correctamente.");
    }

