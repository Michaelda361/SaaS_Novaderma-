            </div>

            @if (!isVigente)
            {
                <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--surface-border); display: flex; justify-content: flex-end; align-items: center;">
                    @if (GetSolicitudForVersion(doc.Version) != null)
                    {
                        <button class="btn btn-secondary btn-sm" @onclick="() => expandedVersionChanges = (expandedVersionChanges == doc.Version ? null : doc.Version)">
                            @(expandedVersionChanges == doc.Version ? "Ocultar cambios" : "📊 Comparar cambios con versión anterior")
