                SolicitanteNombre = auditDocumentDetail.SolicitanteNombre,
                EditorId = auditDocumentDetail.EditorId,
                EditorNombre = auditDocumentDetail.EditorNombre,
                AprobadorId = auditDocumentDetail.AprobadorId,
                AprobadorNombre = auditDocumentDetail.AprobadorNombre,
                FechaPublicacion = auditDocumentDetail.FechaPublicacion,
                MotivoCambio = auditDocumentDetail.MotivoCambio,
                DescripcionDetallada = auditDocumentDetail.DescripcionDetallada
            };
        }
        else
        {
            vigenteDoc = historial?
                .Where(h => h.Estado == "Vigente")
                .OrderByDescending(h => {
                    var vStr = h.Version ?? "0.0";
                    if (!vStr.Contains(".")) vStr += ".0";
                    if (System.Version.TryParse(vStr, out var v)) return v;
                    return new System.Version(0, 0);
                })
                .ThenByDescending(h => h.FechaPublicacion ?? h.FechaDocumento)
                .FirstOrDefault() ?? (auditDocumentDetail != null ? new DocumentoControlDto {
                    Id = auditDocumentDetail.Id,
                    ListadoMaestroId = auditDocumentDetail.ListadoMaestroId,
                    ListadoMaestroNombre = auditDocumentDetail.ListadoMaestroNombre,
                    Codigo = auditDocumentDetail.Codigo,
                    Nombre = auditDocumentDetail.Nombre,
                    ProcesoResponsable = auditDocumentDetail.ProcesoResponsable,
                    Version = auditDocumentDetail.Version,
                    FechaDocumento = auditDocumentDetail.FechaDocumento,
                    OneDriveUrl = auditDocumentDetail.OneDriveUrl,
                    Estado = auditDocumentDetail.Estado,
                    AreaId = auditDocumentDetail.AreaId,
                    AreaNombre = auditDocumentDetail.AreaNombre,
                    Uso = auditDocumentDetail.Uso,
                    TiempoRetencion = auditDocumentDetail.TiempoRetencion,
                    Proteccion = auditDocumentDetail.Proteccion,
                    Recuperacion = auditDocumentDetail.Recuperacion,
                    DisposicionFinal = auditDocumentDetail.DisposicionFinal,
                    Observaciones = auditDocumentDetail.Observaciones,
                    ComentarioCambio = auditDocumentDetail.ComentarioCambio,
                    ArchivoNombre = auditDocumentDetail.ArchivoNombre,
                    CamposPersonalizados = auditDocumentDetail.CamposPersonalizados,
                    DocumentoOriginalId = auditDocumentDetail.DocumentoOriginalId,
                    SolicitanteId = auditDocumentDetail.SolicitanteId,
                    SolicitanteNombre = auditDocumentDetail.SolicitanteNombre,
                    EditorId = auditDocumentDetail.EditorId,
                    EditorNombre = auditDocumentDetail.EditorNombre,
                    AprobadorId = auditDocumentDetail.AprobadorId,
                    AprobadorNombre = auditDocumentDetail.AprobadorNombre,
                    FechaPublicacion = auditDocumentDetail.FechaPublicacion,
                    MotivoCambio = auditDocumentDetail.MotivoCambio,
                    DescripcionDetallada = auditDocumentDetail.DescripcionDetallada
                } : null);
        }

        sortedHistorial = historial?
            .OrderByDescending(h => h.Estado == "Vigente") // Vigente always first
            .ThenByDescending(h => {
                var vStr = h.Version ?? "0.0";
                if (!vStr.Contains(".")) vStr += ".0";
                if (System.Version.TryParse(vStr, out var v)) return v;
                return new System.Version(0, 0);
            })
            .ThenByDescending(h => h.FechaPublicacion ?? h.FechaDocumento)
            .ToList() ?? new List<DocumentoControlDto>();

        showAuditModal = true;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthInfo.LoadAsync();
            areas = await AreaApi.GetAllAsync() ?? [];
            colaboradores = await ColaboradorApi.GetAllAsync() ?? [];
            listados = await ControlDocumentalApi.GetListadosMaestrosAsync() ?? [];

            // Cargar preferencia de vista desde localStorage
            try
            {
                var storedMode = await JS.InvokeAsync<string>("localStorage.getItem", "novahub_document_view_mode");
                if (!string.IsNullOrEmpty(storedMode) && (storedMode == "comfortable" || storedMode == "compact" || storedMode == "grid"))
                {
                    viewMode = storedMode;
                    compactMode = (viewMode == "compact");
                }
                else
                {
                    var storedCompact = await JS.InvokeAsync<string>("localStorage.getItem", "novahub_compact_mode");
                    if (bool.TryParse(storedCompact, out var isCompact))
                    {
                        compactMode = isCompact;
                        viewMode = isCompact ? "compact" : "comfortable";
                    }
                }
            }
            catch { }

            // Cargar listado seleccionado desde localStorage si está disponible
            var storedVal = await JS.InvokeAsync<string>("localStorage.getItem", "novahub_selected_listado_id");
            if (int.TryParse(storedVal, out var storedId) && listados.Any(l => l.Id == storedId))
            {
                selectedListadoId = storedId;
            }
            else
            {
                selectedListadoId = listados.FirstOrDefault()?.Id;
            }

            if (selectedListadoId.HasValue)
            {
                await LoadListadoCamposAsync(selectedListadoId.Value);
            }
            await Filtrar();
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar datos: {ex.Message}", "error");
        }
        finally
        {
            loading = false;
        }

        if (AuthInfo.EsAdmin || AuthInfo.EsJefe)
        {
            await LoadPendingSolicitudesAsync();
            // Unirse al grupo de admins para notificaciones en tiempo real
            await Notificaciones.UnirseGrupoAdminAsync();
            Notificaciones.OnNuevaSolicitudCambio += OnNuevaSolicitudCambio;
        }
    }

    private async Task OnListadoChanged(ChangeEventArgs e)
    {
        searchText = string.Empty;
        currentPage = 1;
        var val = e.Value?.ToString();
        if (int.TryParse(val, out var id))
        {
            selectedListadoId = id;
            try
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "novahub_selected_listado_id", id.ToString());
            }
            catch { }
            await LoadListadoCamposAsync(id);
        }
        else
        {
            selectedListadoId = null;
            try
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "novahub_selected_listado_id");
            }
            catch { }
            listadoCampos = [];
            documentos = [];
        }
        await Filtrar();
    }

    private async Task ChangeViewMode(string mode)
    {
        viewMode = mode;
        compactMode = (mode == "compact");
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "novahub_document_view_mode", mode);
            await JS.InvokeVoidAsync("localStorage.setItem", "novahub_compact_mode", compactMode.ToString().ToLowerInvariant());
