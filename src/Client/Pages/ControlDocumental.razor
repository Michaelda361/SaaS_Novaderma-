<OneDriveBrowser Visible="showOneDriveBrowser"
                 OnSeleccionado="OnArchivoOneDriveSeleccionado"
                 OnCancelado="() => showOneDriveBrowser = false" />

@code {
    private Toast toast = null!;
    private bool loading = true;
    private bool editing = false;
    private bool showModal = false;
    private bool showListadoModal = false;
    private bool showAuditModal = false;
    private bool showPermisosModal = false;
    private bool permisosLoading = false;
    private bool permisosGuardando = false;
    private bool tieneCambiosPermisos = false;
    private bool guardando = false;
    private bool guardandoListado = false;
    private bool showOneDriveBrowser = false;
    private bool editingListado = false;

    private int? selectedListadoId;
    private int? selectedAreaId;
    private string filterBusqueda = string.Empty;
    private string filterCodigo = string.Empty;
    private string filterProceso = string.Empty;
    private string filterEstado = string.Empty;

    private CreateDocumentoControlDto form = new();
    private CreateListadoMaestroDto listadoForm = new();
    private int? editingId;
    private List<DocumentoControlCampoDto> listadoCampos = [];
    private bool importingListado = false;
    private bool showImportInstructions = false;

    private List<ListadoMaestroDto> listados = [];
    private List<DocumentoControlDto> documentos = [];
    private List<AreaDto> areas = [];
    private List<ListadoMaestroPermisoDto> listadoPermisos = [];
    private List<ListadoMaestroPermisoUpdateDto> nuevosPermisosListado = [];
    private List<ColaboradorDto> colaboradores = [];
    private List<SolicitudCambioDocumentoControlDto> documentoSolicitudes = [];
    private List<SolicitudCambioDocumentoControlDto> pendingSolicitudes = [];
    private bool loadingSolicitudes = false;
    private bool showPendingRequests = true;
    private bool showRejectModal = false;
    private SolicitudCambioDocumentoControlDto? solicitudSeleccionada = null;
    private RechazarSolicitudCambioDto rechazoForm = new();
    private bool processingSolicitud = false;
    private List<AuditLogDto> historial = [];
    private DocumentoControlDetalleDto? auditDocumentDetail;
    private List<DocumentVersionSnapshot> versionesAnteriores = [];

    private async Task AbrirPermisos()
    {
        if (!selectedListadoId.HasValue)
            return;

        permisosLoading = true;
        try
        {
            listadoPermisos = await ControlDocumentalApi.GetListadoPermisosAsync(selectedListadoId.Value);
            nuevosPermisosListado = [];
            tieneCambiosPermisos = false;
            showPermisosModal = true;
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar permisos: {ex.Message}", "error");
        }
        finally
        {
            permisosLoading = false;
        }
    }

    private void CerrarPermisosModal()
    {
        showPermisosModal = false;
        tieneCambiosPermisos = false;
    }

    private async Task GuardarPermisosListado()
    {
        if (!selectedListadoId.HasValue)
            return;

        permisosGuardando = true;
        try
        {
            var todosLosPermisos = listadoPermisos
                .Select(p => new ListadoMaestroPermisoUpdateDto
                {
                    ColaboradorId = p.ColaboradorId,
                    PuedeVer = p.PuedeVer,
                    PuedeEditar = p.PuedeEditar,
                    PuedeAprobar = p.PuedeAprobar
                })
                .Concat(nuevosPermisosListado.Where(p => p.ColaboradorId > 0))
                .GroupBy(p => p.ColaboradorId)
                .Select(g => g.Last())
                .ToList();

            var response = await ControlDocumentalApi.UpdateListadoPermisosAsync(selectedListadoId.Value, todosLosPermisos);
            if (response.IsSuccessStatusCode)
            {
                await toast.Show("Permisos guardados correctamente.", "success");
                showPermisosModal = false;
                await AbrirPermisos();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                await toast.Show($"Error al guardar permisos: {content}", "error");
            }
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al guardar permisos: {ex.Message}", "error");
        }
        finally
        {
            permisosGuardando = false;
        }
    }

    private void AgregarPermiso()
    {
        nuevosPermisosListado.Add(new ListadoMaestroPermisoUpdateDto
        {
            ColaboradorId = 0,
            PuedeVer = false,
            PuedeEditar = false,
            PuedeAprobar = false
        });
        tieneCambiosPermisos = true;
    }

    private void EliminarPermiso(int index)
    {
        if (index >= 0 && index < listadoPermisos.Count)
        {
            listadoPermisos.RemoveAt(index);
            tieneCambiosPermisos = true;
        }
    }

    private void EliminarPermisoNuevo(int index)
    {
        if (index >= 0 && index < nuevosPermisosListado.Count)
        {
            nuevosPermisosListado.RemoveAt(index);
            tieneCambiosPermisos = nuevosPermisosListado.Any();
        }
    }

    private void MarcarCambioPermisos()
    {
        tieneCambiosPermisos = true;
    }

    private async Task VerAuditoria(int id)
    {
        auditDocumentDetail = await ControlDocumentalApi.GetDocumentoAsync(id);
        historial = await ControlDocumentalApi.GetHistorialAsync(id);
        documentoSolicitudes = await ControlDocumentalApi.GetSolicitudesPorDocumentoAsync(id);
        versionesAnteriores = BuildVersionHistory(auditDocumentDetail, historial);
        showAuditModal = true;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthInfo.LoadAsync();
            areas = await AreaApi.GetAllAsync() ?? [];
            colaboradores = await ColaboradorApi.GetAllAsync() ?? [];
            listados = await ControlDocumentalApi.GetListadosMaestrosAsync() ?? [];
            selectedListadoId = listados.FirstOrDefault()?.Id;
            if (selectedListadoId.HasValue)
            {
                await LoadListadoCamposAsync(selectedListadoId.Value);
            }
            await Filtrar();
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al cargar datos: {ex.Message}", "error");
        }
        finally
        {
            loading = false;
        }

        if (AuthInfo.EsAdmin || AuthInfo.EsJefe)
        {
            await LoadPendingSolicitudesAsync();
        }
    }

    private async Task Filtrar()
    {
        loading = true;
        if (!selectedListadoId.HasValue)
        {
            documentos = [];
            loading = false;
            return;
        }

        documentos = await ControlDocumentalApi.GetDocumentosAsync(
            selectedListadoId.Value,
            selectedAreaId > 0 ? selectedAreaId : null,
            string.IsNullOrWhiteSpace(filterBusqueda) ? null : filterBusqueda,
            string.IsNullOrWhiteSpace(filterCodigo) ? null : filterCodigo,
            string.IsNullOrWhiteSpace(filterProceso) ? null : filterProceso,
            string.IsNullOrWhiteSpace(filterEstado) ? null : filterEstado);
        loading = false;
    }

    private async Task LoadPendingSolicitudesAsync()
    {
        loadingSolicitudes = true;
        try
        {
            pendingSolicitudes = await ControlDocumentalApi.GetSolicitudesPendientesAsync() ?? [];
        }
        catch (Exception ex)
        {
            await toast.Show($"No se pudieron cargar las solicitudes de cambio: {ex.Message}", "error");
            pendingSolicitudes = [];
        }
        finally
        {
            loadingSolicitudes = false;
        }
    }

    private async Task AprobarSolicitud(int solicitudId)
    {
        processingSolicitud = true;
        try
        {
            var response = await ControlDocumentalApi.AprobarSolicitudCambioAsync(solicitudId);
            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                await toast.Show("No tienes permisos para aprobar esta solicitud.", "warning");
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                await toast.Show("Solicitud aprobada correctamente.", "success");
                await LoadPendingSolicitudesAsync();
                await Filtrar();
                return;
            }

            var message = await response.Content.ReadAsStringAsync();
            await toast.Show(string.IsNullOrWhiteSpace(message) ? "No se pudo aprobar la solicitud." : message, "error");
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al aprobar la solicitud: {ex.Message}", "error");
        }
        finally
        {
            processingSolicitud = false;
        }
    }

    private void AbrirRechazarSolicitud(SolicitudCambioDocumentoControlDto solicitud)
    {
        solicitudSeleccionada = solicitud;
        rechazoForm = new RechazarSolicitudCambioDto();
        showRejectModal = true;
    }

    private async Task RechazarSolicitud()
    {
        if (solicitudSeleccionada is null)
        {
            return;
        }

        processingSolicitud = true;
        try
        {
            var response = await ControlDocumentalApi.RechazarSolicitudCambioAsync(solicitudSeleccionada.Id, rechazoForm);
            if (response.StatusCode == HttpStatusCode.Forbidden)
            {
                await toast.Show("No tienes permisos para rechazar esta solicitud.", "warning");
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                await toast.Show("Solicitud rechazada correctamente.", "success");
                showRejectModal = false;
                await LoadPendingSolicitudesAsync();
                return;
            }

            var message = await response.Content.ReadAsStringAsync();
            await toast.Show(string.IsNullOrWhiteSpace(message) ? "No se pudo rechazar la solicitud." : message, "error");
        }
        catch (Exception ex)
        {
            await toast.Show($"Error al rechazar la solicitud: {ex.Message}", "error");
        }
        finally
        {
            processingSolicitud = false;
        }
    }

    private void TogglePendingRequests() => showPendingRequests = !showPendingRequests;

    private string GetFormattedJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return "No hay datos propuestos.";

        try
        {
            using var document = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(document.RootElement, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

    private async Task OnSelectedListadoChanged()
    {
        if (selectedListadoId.HasValue)
        {
            await LoadListadoCamposAsync(selectedListadoId.Value);
        }
        await Filtrar();
    }

    private async Task AbrirNuevoDocumento()
    {
        editing = false;
        editingId = null;
        if (selectedListadoId.HasValue)
        {
            await LoadListadoCamposAsync(selectedListadoId.Value);
        }
        form = new CreateDocumentoControlDto
        {
            ListadoMaestroId = selectedListadoId ?? 0,
            Version = "1.0",
            FechaDocumento = DateTime.Today,
            Estado = "Borrador",
            CamposPersonalizados = new Dictionary<string, string?>()
        };
        InitializeCamposPersonalizados();
        showModal = true;
    }

    private async Task EditarDocumento(int id)
    {
        var detail = await ControlDocumentalApi.GetDocumentoAsync(id);
        if (detail is null)
        {
            await toast.Show("No se pudo cargar el documento.", "error");
            return;
        }

        await LoadListadoCamposAsync(detail.ListadoMaestroId);

        editing = true;
        editingId = id;
        form = new CreateDocumentoControlDto
        {
            ListadoMaestroId = detail.ListadoMaestroId,
            Codigo = detail.Codigo,
            Nombre = detail.Nombre,
            ProcesoResponsable = detail.ProcesoResponsable,
            Version = detail.Version,
            FechaDocumento = detail.FechaDocumento,
            OneDriveUrl = detail.OneDriveUrl,
            OneDriveItemId = detail.OneDriveItemId,
            ArchivoNombre = detail.ArchivoNombre,
            Uso = detail.Uso,
            TiempoRetencion = detail.TiempoRetencion,
            Proteccion = detail.Proteccion,
            Recuperacion = detail.Recuperacion,
            DisposicionFinal = detail.DisposicionFinal,
            Estado = detail.Estado,
            Observaciones = detail.Observaciones,
            ComentarioCambio = detail.ComentarioCambio,
            AreaId = detail.AreaId,
            CamposPersonalizados = detail.CamposPersonalizados ?? new Dictionary<string, string?>()
        };
        InitializeCamposPersonalizados();
        showModal = true;
    }

    private async Task GuardarDocumento()
    {
        guardando = true;
        try
        {
            if (editingId.HasValue)
            {
                var updateDto = new UpdateDocumentoControlDto
                {
                    ListadoMaestroId = form.ListadoMaestroId,
                    Codigo = form.Codigo,
                    Nombre = form.Nombre,
                    ProcesoResponsable = form.ProcesoResponsable,
                    Version = form.Version,
                    FechaDocumento = form.FechaDocumento,
                    OneDriveUrl = form.OneDriveUrl,
                    OneDriveItemId = form.OneDriveItemId,
                    ArchivoNombre = form.ArchivoNombre,
                    Uso = form.Uso,
                    TiempoRetencion = form.TiempoRetencion,
                    Proteccion = form.Proteccion,
                    Recuperacion = form.Recuperacion,
                    DisposicionFinal = form.DisposicionFinal,
                    Estado = form.Estado,
                    Observaciones = form.Observaciones,
                    ComentarioCambio = form.ComentarioCambio,
                    AreaId = form.AreaId,
                    CamposPersonalizados = form.CamposPersonalizados
                };
                var response = await ControlDocumentalApi.UpdateDocumentoAsync(editingId.Value, updateDto);
                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para reasignar el listado maestro o actualizar este documento.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    await toast.Show("No se pudo actualizar el documento.", "error");
                    return;
                }

                await toast.Show(AuthInfo.EsSoloColaborador
                    ? "Solicitud de cambio enviada para revisión."
                    : "Documento actualizado correctamente.");
            }
            else
            {
                var createDto = new CreateDocumentoControlDto
                {
                    ListadoMaestroId = form.ListadoMaestroId,
                    Codigo = form.Codigo,
                    Nombre = form.Nombre,
                    ProcesoResponsable = form.ProcesoResponsable,
                    Version = form.Version,
                    FechaDocumento = form.FechaDocumento,
                    OneDriveUrl = form.OneDriveUrl,
                    OneDriveItemId = form.OneDriveItemId,
                    ArchivoNombre = form.ArchivoNombre,
                    Uso = form.Uso,
                    TiempoRetencion = form.TiempoRetencion,
                    Proteccion = form.Proteccion,
                    Recuperacion = form.Recuperacion,
                    DisposicionFinal = form.DisposicionFinal,
                    Estado = form.Estado,
                    Observaciones = form.Observaciones,
                    ComentarioCambio = form.ComentarioCambio,
                    AreaId = form.AreaId,
                    CamposPersonalizados = form.CamposPersonalizados
                };
                var response = await ControlDocumentalApi.CreateDocumentoAsync(createDto);
                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para crear documentos en este listado.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    await toast.Show("No se pudo crear el documento.", "error");
                    return;
                }

                await toast.Show("Documento creado correctamente.");
            }

            showModal = false;
            await Filtrar();
        }
        finally
        {
            guardando = false;
        }
    }

    private void AbrirNuevoListado()
    {
        editingListado = false;
        listadoForm = new CreateListadoMaestroDto
        {
            Campos = GetDefaultCampoPlantilla()
        };
        showListadoModal = true;
    }

    private async Task AbrirEditarListado()
    {
        if (!selectedListadoId.HasValue) return;
        var listado = await ControlDocumentalApi.GetListadoMaestroAsync(selectedListadoId.Value);
        if (listado is null)
        {
            await toast.Show("No se pudo cargar la configuración del listado.", "error");
            return;
        }

        editingListado = true;
        listadoForm = new CreateListadoMaestroDto
        {
            Nombre = listado.Nombre,
            Descripcion = listado.Descripcion,
            Campos = listado.Campos.Any() ? listado.Campos.OrderBy(c => c.Orden).ToList() : GetDefaultCampoPlantilla()
        };
        showListadoModal = true;
    }

    private async Task CrearListado()
    {
        guardandoListado = true;
        try
        {
            if (editingListado)
            {
                if (!selectedListadoId.HasValue) return;
                var response = await ControlDocumentalApi.UpdateListadoMaestroAsync(selectedListadoId.Value, listadoForm);
                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para editar este listado maestro.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    await toast.Show("No se pudo actualizar el listado maestro.", "error");
                    return;
                }

                var local = listados.FirstOrDefault(l => l.Id == selectedListadoId.Value);
                if (local is not null)
                {
                    local.Nombre = listadoForm.Nombre;
                    local.Descripcion = listadoForm.Descripcion;
                }
                await toast.Show("Listado maestro actualizado correctamente.");
            }
            else
            {
                var response = await ControlDocumentalApi.CreateListadoMaestroAsync(listadoForm);
                if (response.StatusCode == HttpStatusCode.Forbidden)
                {
                    await toast.Show("No tiene permisos para crear un listado maestro.", "warning");
                    return;
                }

                if (!response.IsSuccessStatusCode)
                {
                    await toast.Show("No se pudo crear el listado maestro.", "error");
                    return;
                }

                var created = await response.Content.ReadFromJsonAsync<ListadoMaestroDto>(new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (created is null)
                {
                    await toast.Show("No se pudo crear el listado maestro.", "error");
                    return;
                }

                listados.Add(created);
                selectedListadoId = created.Id;
                await toast.Show("Listado maestro creado correctamente.");
            }

            listadoForm = new CreateListadoMaestroDto();
            showListadoModal = false;
            await Filtrar();
        }
        finally
        {
            guardandoListado = false;
        }
    }

    private static readonly System.Text.Json.JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    private async Task ExportListado()
    {
        if (!selectedListadoId.HasValue)
            return;

        var response = await ControlDocumentalApi.ExportListadoAsync(selectedListadoId.Value);
        if (!response.IsSuccessStatusCode)
        {
            await toast.Show("No se pudo exportar el listado.", "error");
            return;
        }

        var bytes = await response.Content.ReadAsByteArrayAsync();
        var fileName = response.Content.Headers.ContentDisposition?.FileNameStar
            ?? response.Content.Headers.ContentDisposition?.FileName
            ?? $"listado-{selectedListadoId.Value}.xlsx";
        fileName = fileName.Trim('"');

        await JS.InvokeVoidAsync("descargarArchivo", Convert.ToBase64String(bytes), fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task OnArchivoListadoSeleccionado(InputFileChangeEventArgs e)
    {
        importingListado = true;

        try
        {
            var file = e.File;
            if (file is null)
            {
                return;
            }

            await using var stream = file.OpenReadStream(maxAllowedSize: 10_485_760);
            using var content = new MultipartFormDataContent();
            using var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new MediaTypeHeaderValue("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            content.Add(streamContent, "file", file.Name);

            var response = await ControlDocumentalApi.ImportListadoAsync(content);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                await toast.Show($"Error importando listado: {error}", "error");
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<ListadoMaestroDto>(JsonOptions);
            if (created is not null)
            {
                listados = await ControlDocumentalApi.GetListadosMaestrosAsync() ?? [];
                selectedListadoId = created.Id;
                await toast.Show("Listado importado correctamente.");
                await LoadListadoCamposAsync(created.Id);
                await Filtrar();
            }
        }
        catch (Exception ex)
        {
            await toast.Show($"Error importando listado: {ex.Message}", "error");
        }
        finally
        {
            importingListado = false;
        }
    }

    private async Task EliminarListadoSeleccionado()
    {
        if (!selectedListadoId.HasValue)
        {
            return;
        }

        var confirm = await JS.InvokeAsync<bool>("confirm", "¿Estás seguro de que deseas eliminar este listado maestro? Esta acción ocultará el listado y sus documentos.");
        if (!confirm)
        {
            return;
        }

        var response = await ControlDocumentalApi.DeleteListadoMaestroAsync(selectedListadoId.Value);
        if (response.StatusCode == HttpStatusCode.Forbidden)
        {
            await toast.Show("No tiene permisos para eliminar este listado maestro.", "warning");
            return;
        }

        if (response.StatusCode == HttpStatusCode.NotFound)
        {
            await toast.Show("Listado maestro no encontrado.", "error");
            return;
        }

        if (!response.IsSuccessStatusCode)
        {
            await toast.Show("No se pudo eliminar el listado maestro.", "error");
            return;
        }

        var removed = listados.FirstOrDefault(l => l.Id == selectedListadoId.Value);
        if (removed is not null)
        {
            listados.Remove(removed);
        }

        selectedListadoId = listados.FirstOrDefault()?.Id;
        if (selectedListadoId.HasValue)
        {
            await LoadListadoCamposAsync(selectedListadoId.Value);
        }
        else
        {
            listadoCampos = GetDefaultCampoPlantilla();
            documentos = [];
        }

        await Filtrar();
        await toast.Show("Listado maestro eliminado correctamente.");
    }

