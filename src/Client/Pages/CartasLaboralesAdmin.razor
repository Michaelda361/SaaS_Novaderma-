@page "/cartas/admin"
@attribute [PageTitle("Administración de cartas")]
@attribute [Authorize]
@inject PlantillaDocumentoApiService ApiService
@inject AreaApiService AreaApi
@inject ColaboradorApiService ColaboradorApi
@inject AuthInfoService AuthInfo
@inject NotificacionesService Notificaciones
@inject IJSRuntime JS
@implements IAsyncDisposable

<Toast @ref="toast" />
<ConfirmDialog Visible="showConfirm"
               Message="@confirmMsg"
               OnConfirm="EliminarConfirmado"
               OnCancel="() => showConfirm = false" />

@if (cargando)
{
    <div class="loading"><div class="spinner"></div> Cargando...</div>
}
else if (AuthInfo.EsSoloColaborador)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔒</div>
        <h3>Acceso restringido</h3>
        <p>Esta sección es solo para administradores y jefes de área.</p>
        <a href="cartas" class="btn btn-primary" style="margin-top:1rem;">Ir a mis cartas</a>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h2 class="page-title">Cartas Laborales — Administración</h2>
            <p class="page-subtitle">
                @if (AuthInfo.EsJefe || AuthInfo.EsAdmin) { <span>Gestiona plantillas y aprueba solicitudes</span> }
                else { <span>Revisa y aprueba las solicitudes de cartas laborales</span> }
            </p>
        </div>
        @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
        {
            <div class="flex gap-2">
                <button class="btn btn-primary" @onclick="AbrirNueva">+ Nueva plantilla</button>
            </div>
        }
    </div>

    <!-- Tabs: plantillas solo para Jefe/Admin, pendientes e historial para todos los no-colaboradores -->
    <div class="admin-tabs">
        @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
        {
            <button class="admin-tab @(tabActiva == "plantillas" ? "admin-tab--active" : "")"
                    @onclick='() => tabActiva = "plantillas"'>
                📄 Plantillas <span class="admin-tab-count">@plantillas.Count</span>
            </button>
        }
        <button class="admin-tab @(tabActiva == "pendientes" ? "admin-tab--active" : "")"
                @onclick='() => { tabActiva = "pendientes"; _ = CargarPendientes(); }'>
            ⏳ Pendientes
            @if (countPendientes > 0)
            {
                <span class="admin-tab-count admin-tab-count--alert">@countPendientes</span>
            }
        </button>
        <button class="admin-tab @(tabActiva == "historial" ? "admin-tab--active" : "")"
                @onclick='() => { tabActiva = "historial"; _ = CargarHistorial(); }'>
            📋 Historial
            @if (solicitudes.Any())
            {
                <span class="admin-tab-count">@solicitudes.Count</span>
            }
        </button>
    </div>

    @if (tabActiva == "plantillas")
    {
        @if (!plantillas.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📄</div>
                <h3>Sin plantillas</h3>
                <p>Crea la primera plantilla para que los colaboradores puedan descargar sus cartas.</p>
                <button class="btn btn-primary" style="margin-top:1rem;" @onclick="AbrirNueva">+ Nueva plantilla</button>
            </div>
        }
        else
        {
            <div class="card">
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Plantilla</th>
                                <th>Firmante</th>
                                <th>Disponible para</th>
                                <th>Tipo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in plantillas)
                            {
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="carta-admin-icon">@(p.TipoPlantilla == "docx" ? "📝" : "📄")</div>
                                            <div>
                                                <div class="user-name">@p.Nombre</div>
                                                @if (!string.IsNullOrWhiteSpace(p.Descripcion))
                                                {
                                                    <div class="user-email">@p.Descripcion</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-sm">
                                        @if (!string.IsNullOrWhiteSpace(p.NombreFirmante))
                                        {
                                            <div>@p.NombreFirmante</div>
                                            @if (!string.IsNullOrWhiteSpace(p.CargoFirmante))
                                            {
                                                <div class="text-muted text-xs">@p.CargoFirmante</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (p.AplicaTodasAreas)
                                        {
                                            <span class="badge badge-success">Todas las áreas</span>
                                        }
                                        else
                                        {
                                            <div style="display:flex;flex-wrap:wrap;gap:.25rem;">
                                                @foreach (var nombre in p.AreaNombres)
                                                {
                                                    <span class="badge badge-info">@nombre</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (p.TipoPlantilla == "docx")
                                        {
                                            <span class="badge badge-purple">Word</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-gray">HTML</span>
                                        }
                                        @if (p.VariablesEditables.Any())
                                        {
                                            <span class="badge badge-warning" style="margin-left:.25rem;">✏️ Editable</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="flex gap-2">
                                            <button class="btn btn-ghost btn-sm"
                                                    @onclick="() => MostrarVariables(p)">
                                                Variables
                                            </button>
                                            <button class="btn btn-primary btn-sm"
                                                    @onclick="() => AbrirGenerarPara(p)"
                                                    title="Generar carta para un colaborador">
                                                ⬇ Generar
                                            </button>
                                            <button class="btn btn-ghost btn-sm btn-icon"
                                                    @onclick="() => AbrirEditar(p)" title="Editar">✏️</button>
                                            <button class="btn btn-danger btn-sm btn-icon"
                                                    @onclick="() => PedirConfirmacion(p)" title="Eliminar">🗑️</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else if (tabActiva == "pendientes")
    {
        @if (cargandoPendientes)
        {
            <div class="loading"><div class="spinner"></div> Cargando...</div>
        }
        else if (!pendientes.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">✅</div>
                <h3>Sin solicitudes pendientes</h3>
                <p>Todas las solicitudes han sido resueltas.</p>
            </div>
        }
        else
        {
            <div class="card">
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr><th>Colaborador</th><th>Documento</th><th>Fecha</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in pendientes)
                            {
                                var sid = s.Id;
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="avatar avatar-sm">@Iniciales(s.ColaboradorNombre)</div>
                                            <div>
                                                <div class="user-name">@s.ColaboradorNombre</div>
                                                <div class="user-email">@s.ColaboradorEmail</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-sm">@s.PlantillaNombre</td>
                                    <td class="text-muted text-sm">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => AbrirAprobar(s)" title="Revisar solicitud">
                                            👁 Revisar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <!-- Historial de solicitudes -->
        @if (cargandoHistorial)
        {
            <div class="loading"><div class="spinner"></div> Cargando historial...</div>
        }
        else if (!solicitudes.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📋</div>
                <h3>Sin solicitudes aún</h3>
                <p>Aquí aparecerán todas las solicitudes de los colaboradores.</p>
            </div>
        }
        else
        {
            <div class="card">
                <div class="filter-bar">
                    <div class="search-input-wrap">
                        <span class="search-icon">🔍</span>
                        <input type="text" placeholder="Buscar colaborador o plantilla..."
                               @bind="filtroHistorial" @bind:event="oninput" />
                    </div>
                    <div style="display:flex;align-items:center;gap:.75rem;">
                        <span class="text-muted text-sm">@SolicitudesFiltradas.Count() solicitud(es)</span>
                        @if (historialCargadoEn.HasValue)
                        {
                            <span class="text-xs text-muted">Actualizado @historialCargadoEn.Value.ToString("HH:mm")</span>
                        }
                        <button class="btn btn-ghost btn-sm btn-icon" title="Recargar historial"
                                @onclick="RecargarHistorial">🔄</button>
                    </div>
                </div>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr><th>Colaborador</th><th>Documento</th><th>Fecha</th><th>Estado</th><th>Comentario</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in SolicitudesFiltradas.Take(100))
                            {
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="avatar avatar-sm">@Iniciales(s.ColaboradorNombre)</div>
                                            <span class="user-name">@s.ColaboradorNombre</span>
                                        </div>
                                    </td>
                                    <td class="text-sm">@s.PlantillaNombre</td>
                                    <td class="text-muted text-sm">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (s.Estado == "Pendiente")      { <span class="badge badge-warning">⏳ Pendiente</span> }
                                        else if (s.Estado == "Aprobada")   { <span class="badge badge-success">✅ Aprobada</span> }
                                        else                               { <span class="badge badge-danger">❌ Rechazada</span> }
                                    </td>
                                    <td class="text-sm text-muted">
                                        @if (!string.IsNullOrWhiteSpace(s.ComentarioAdmin))
                                        {
                                            <span style="font-style:italic;">@s.ComentarioAdmin</span>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}

<!-- Modal generar para colaborador (admin) -->
@if (showGenerarPara && plantillaGenerarPara is not null)
{
    <div class="modal-backdrop" @onclick="() => showGenerarPara = false">
        <div class="modal" style="max-width:480px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Generar carta — @plantillaGenerarPara.Nombre</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => showGenerarPara = false">✕</button>
            </div>
            <div class="modal-body">
                <p class="text-sm text-muted" style="margin-bottom:1rem;">
                    Selecciona el colaborador para quien deseas generar la carta. El PDF se descargará directamente con sus datos.
                </p>
                <div class="form-group">
                    <label>Colaborador</label>
                    <div class="search-input-wrap" style="margin-bottom:.5rem;">
                        <span class="search-icon">🔍</span>
                        <input type="search" placeholder="Buscar colaborador..."
                               @bind="busquedaColaboradorGenerar" @bind:event="oninput" />
                    </div>
                    <div style="max-height:240px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius);">
                        @foreach (var c in ColaboradoresFiltradosGenerar)
                        {
                            var col = c;
                            <div class="@(colaboradorGenerarId == col.Id ? "colaborador-item colaborador-item--selected" : "colaborador-item")"
                                 @onclick="() => colaboradorGenerarId = col.Id"
                                 style="padding:.6rem .875rem;cursor:pointer;display:flex;align-items:center;gap:.75rem;border-bottom:1px solid var(--border);background:@(colaboradorGenerarId == col.Id ? "var(--primary-light, rgba(99,102,241,.08))" : "transparent")">
                                <div class="avatar avatar-sm">@Iniciales($"{col.Nombre} {col.Apellido}")</div>
                                <div>
                                    <div class="text-sm font-medium">@col.NombreCompleto</div>
                                    <div class="text-xs text-muted">@col.AreaNombre · @col.CargoNombre · @ColaboradorGeneroUi.Etiqueta(col.Genero)</div>
                                </div>
                                @if (colaboradorGenerarId == col.Id)
                                {
                                    <span style="margin-left:auto;color:var(--primary);">✓</span>
                                }
                            </div>
                        }
                        @if (!ColaboradoresFiltradosGenerar.Any())
                        {
                            <div class="text-sm text-muted" style="padding:.75rem;text-align:center;">Sin resultados</div>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="() => showGenerarPara = false">Cancelar</button>
                <button class="btn btn-primary"
                        disabled="@(colaboradorGenerarId == 0 || generandoPdf)"
                        @onclick="DescargarParaColaborador">
                    @if (generandoPdf)
                    {
                        <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></span>
                    }
                    @(generandoPdf ? "Generando..." : "⬇ Descargar PDF")
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal variables -->
@if (showVariables && plantillaVariables is not null)
{
    <div class="modal-backdrop" @onclick="() => showVariables = false">
        <div class="modal" style="max-width:560px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Variables — @plantillaVariables.Nombre</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => showVariables = false">✕</button>
            </div>
            <div class="modal-body">
                <p class="text-muted text-sm" style="margin-bottom:.75rem;">
                    Estas variables se reemplazan automáticamente con los datos del colaborador al generar el documento.
                    <strong>{{genero}}</strong> usa el género cargado en RRHH (tratamiento «el señor» / «la señora» / neutro); no debe incluirse en «campos editables».
                </p>
                <div class="variables-grid">
                    @foreach (var v in Variables)
                    {
                        var usada = plantillaVariables.TipoPlantilla == "html" &&
                                    (plantillaVariables.ContenidoHtml?.Contains(v.Key) ?? false);
                        <div class="variable-item @(usada ? "variable-item--usada" : "")">
                            <code class="variable-tag">@v.Key</code>
                            <span class="text-muted text-sm">@v.Value</span>
                            @if (usada) { <span class="variable-usada-badge">✓ en uso</span> }
                        </div>
                    }
                </div>

                @if (plantillaVariables.VariablesEditables.Any())
                {
                    <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--border);">
                        <p class="text-sm" style="margin-bottom:.5rem;font-weight:500;">
                            ✏️ Campos que el colaborador completa
                        </p>
                        <p class="text-muted text-xs" style="margin-bottom:.5rem;">
                            Recomendado: solo <code>{{destinatario}}</code> para cartas a terceros. Use <code>{{destinatario}}</code> en el cuerpo y marque «destinatario» abajo al crear la plantilla.
                        </p>
                        <div class="variables-grid">
                            @foreach (var key in plantillaVariables.VariablesEditables)
                            {
                                var label = VariablesEditablesOpciones.TryGetValue(key, out var l) ? l : key.Replace("_", " ");
                                <div class="variable-item variable-item--editable">
                                    <code class="variable-tag">@("{{" + key + "}}")</code>
                                    <span class="text-muted text-sm">@label</span>
                                    <span class="variable-editable-badge">editable</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Modal crear/editar -->
@if (showModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal plantilla-modal" style="max-width: 820px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editandoId.HasValue ? "Editar plantilla" : "Nueva plantilla")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <EditForm Model="form" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <div class="modal-body" style="padding: 1.5rem;">
                    <div style="display: grid; grid-template-columns: 1.6fr 1fr; gap: 1.5rem; align-items: start;">
                        <!-- Columna Principal: Formulario -->
                        <div class="plantilla-form-main" style="display: flex; flex-direction: column; gap: 1.25rem;">
                            <!-- Tarjeta 1: Información Básica -->
                            <div class="card" style="padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface);">
                                <h4 style="margin-top: 0; margin-bottom: 0.75rem; font-size: 0.95rem; font-weight: 600;">📝 Información básica</h4>
                                <div class="form-group" style="margin-bottom: 0.75rem;">
                                    <label style="font-size: 0.85rem; font-weight: 500; display: block; margin-bottom: 0.25rem;">Nombre *</label>
                                    <InputText @bind-Value="form.Nombre" placeholder="Ej: Carta de certificación laboral" />
                                    <ValidationMessage For="() => form.Nombre" />
                                </div>
                                <div class="form-group" style="margin-bottom: 0;">
                                    <label style="font-size: 0.85rem; font-weight: 500; display: block; margin-bottom: 0.25rem;">Descripción</label>
                                    <InputText @bind-Value="form.Descripcion" placeholder="Descripción breve (opcional)" />
                                </div>
                            </div>

                            <!-- Tarjeta 2: Documento Word -->
                            <div class="card" style="padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface);">
                                <h4 style="margin-top: 0; margin-bottom: 0.75rem; font-size: 0.95rem; font-weight: 600;">📎 Archivo de plantilla</h4>
                                <div class="instructivo-box" style="margin-bottom: 0.75rem;">
                                    <button type="button" class="instructivo-toggle" style="font-size: 0.8rem; padding: 0.25rem 0.5rem;"
                                            @onclick="() => showInstructivoDocx = !showInstructivoDocx">
                                        <span>💡 ¿Cómo preparar el archivo Word?</span>
                                        <span>@(showInstructivoDocx ? "▲" : "▼")</span>
                                    </button>
                                    @if (showInstructivoDocx)
                                    {
                                        <div class="instructivo-body" style="font-size: 0.78rem; padding: 0.5rem; line-height: 1.4;">
                                            <ol class="instructivo-steps" style="margin: 0; padding-left: 1.2rem;">
                                                <li>Escribe las variables con doble llave: <code>&#123;&#123;nombre_variable&#125;&#125;</code></li>
                                                <li>Escribe cada variable de un solo trazo sin interrupciones.</li>
                                                <li>Guarda como <strong>.docx</strong> y súbelo abajo.</li>
                                            </ol>
                                        </div>
                                    }
                                </div>
                                <div class="form-group" style="margin-bottom: 0;">
                                    <label style="font-size: 0.85rem; font-weight: 500; display: block; margin-bottom: 0.25rem;">Archivo Word (.docx) *</label>
                                    <InputFile OnChange="OnDocxSeleccionado" accept=".docx" />
                                    @if (!string.IsNullOrWhiteSpace(form.ArchivoDocxBase64))
                                    {
                                        <div class="alert alert-success" style="margin-top:.5rem;padding:.35rem .5rem; font-size: 0.8rem;">
                                            ✅ Archivo cargado correctamente
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Tarjeta 3: Disponible para -->
                            <div class="card" style="padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface);">
                                <h4 style="margin-top: 0; margin-bottom: 0.75rem; font-size: 0.95rem; font-weight: 600;">🏢 Áreas permitidas</h4>
                                <div class="form-group" style="margin-bottom: 0;">
                                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;margin-bottom:.5rem; font-size: 0.85rem;">
                                        <input type="checkbox" @bind="form.AplicaTodasAreas" />
                                        Todas las áreas
                                    </label>
                                    @if (!form.AplicaTodasAreas)
                                    {
                                        <div class="areas-check-list" style="max-height: 120px; overflow-y: auto; border: 1px solid var(--border); padding: 0.5rem; border-radius: var(--radius); display: grid; grid-template-columns: 1fr 1fr; gap: 0.4rem;">
                                            @foreach (var area in areas)
                                            {
                                                var areaId = area.Id;
                                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer; font-size: 0.8rem;">
                                                    <input type="checkbox"
                                                           checked="@form.AreaIds.Contains(areaId)"
                                                           @onchange="e => ToggleArea(areaId, (bool)e.Value!)" />
                                                    @area.Nombre
                                                </label>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Tarjeta 4: Campos que completará el colaborador -->
                            <div class="card" style="padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); border-left: 4px solid #3b82f6;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                                    <h4 style="margin: 0; font-size: 0.95rem; font-weight: 600; color: #1e3a8a;">👥 Datos que completa el colaborador</h4>
                                    <button type="button" class="btn btn-primary btn-sm" @onclick='() => AbrirAgregarCampo("Colaborador")' style="font-size: 0.78rem; padding: 0.25rem 0.5rem; background-color: #3b82f6; border-color: #3b82f6;">
                                        ➕ Agregar Variable
                                    </button>
                                </div>
                                <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0; margin-bottom: 0.75rem;">
                                    Configura las preguntas o datos que el solicitante debe completar en su formulario al crear la solicitud.
                                </p>

                                <div class="table-wrapper" style="border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;">
                                    <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                        <thead>
                                            <tr style="background: var(--bg); border-bottom: 1px solid var(--border);">
                                                <th style="padding: 0.5rem; text-align: left; font-weight: 600;">Campo Visible</th>
                                                <th style="padding: 0.5rem; text-align: left; font-weight: 600;">Tipo</th>
                                                <th style="padding: 0.5rem; text-align: center; font-weight: 600;">Obligatorio</th>
                                                <th style="padding: 0.5rem; text-align: right; font-weight: 600;">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (form.CamposFormulario == null || !form.CamposFormulario.Any(c => c.DiligenciadoPor != "Aprobador"))
                                            {
                                                <tr>
                                                    <td colspan="4" style="padding: 1rem; text-align: center; color: var(--text-muted); font-size: 0.8rem;">
                                                        No hay variables del colaborador configuradas. Haz clic en "Agregar Variable".
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                @for (int i = 0; i < form.CamposFormulario.Count; i++)
                                                {
                                                    var index = i;
                                                    var campo = form.CamposFormulario[i];
                                                    if (campo.DiligenciadoPor != "Aprobador")
                                                    {
                                                        <tr style="border-bottom: 1px solid var(--border);">
                                                            <td style="padding: 0.5rem; font-weight: 500;">@campo.Nombre</td>
                                                            <td style="padding: 0.5rem;"><span class="badge badge-gray" style="font-size: 0.75rem;">@campo.Tipo</span></td>
                                                            <td style="padding: 0.5rem; text-align: center;">@(campo.Obligatorio ? "Sí" : "No")</td>
                                                            <td style="padding: 0.5rem; text-align: right;">
                                                                <div style="display: flex; gap: 0.25rem; justify-content: flex-end;">
                                                                    <button type="button" class="btn btn-ghost btn-sm" @onclick="() => AbrirEditarCampo(index)" style="padding: 0.15rem 0.35rem; font-size: 0.75rem;" title="Editar">✏️</button>
                                                                    <button type="button" class="btn btn-ghost btn-sm text-danger" @onclick="() => EliminarCampo(index)" style="padding: 0.15rem 0.35rem; font-size: 0.75rem;" title="Eliminar">🗑️</button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Tarjeta 5: Campos que completará el aprobador -->
                            <div class="card" style="padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); border-left: 4px solid #f97316; margin-top: 1rem;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                                    <h4 style="margin: 0; font-size: 0.95rem; font-weight: 600; color: #7c2d12;">🛡️ Datos que completa el aprobador</h4>
                                    <button type="button" class="btn btn-primary btn-sm" @onclick='() => AbrirAgregarCampo("Aprobador")' style="font-size: 0.78rem; padding: 0.25rem 0.5rem; background-color: #f97316; border-color: #f97316;">
                                        ➕ Agregar Variable
                                    </button>
                                </div>
                                <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0; margin-bottom: 0.75rem;">
                                    Configura los datos que Recursos Humanos o el aprobador debe rellenar al momento de revisar y autorizar la carta.
                                </p>

                                <div class="table-wrapper" style="border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;">
                                    <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                        <thead>
                                            <tr style="background: var(--bg); border-bottom: 1px solid var(--border);">
                                                <th style="padding: 0.5rem; text-align: left; font-weight: 600;">Campo Visible</th>
                                                <th style="padding: 0.5rem; text-align: left; font-weight: 600;">Tipo</th>
                                                <th style="padding: 0.5rem; text-align: center; font-weight: 600;">Obligatorio</th>
                                                <th style="padding: 0.5rem; text-align: right; font-weight: 600;">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (form.CamposFormulario == null || !form.CamposFormulario.Any(c => c.DiligenciadoPor == "Aprobador"))
                                            {
                                                <tr>
                                                    <td colspan="4" style="padding: 1rem; text-align: center; color: var(--text-muted); font-size: 0.8rem;">
                                                        No hay variables del aprobador configuradas. Haz clic en "Agregar Variable".
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                @for (int i = 0; i < form.CamposFormulario.Count; i++)
                                                {
                                                    var index = i;
                                                    var campo = form.CamposFormulario[i];
                                                    if (campo.DiligenciadoPor == "Aprobador")
                                                    {
                                                        <tr style="border-bottom: 1px solid var(--border);">
                                                            <td style="padding: 0.5rem; font-weight: 500;">@campo.Nombre</td>
                                                            <td style="padding: 0.5rem;"><span class="badge badge-gray" style="font-size: 0.75rem;">@campo.Tipo</span></td>
                                                            <td style="padding: 0.5rem; text-align: center;">@(campo.Obligatorio ? "Sí" : "No")</td>
                                                            <td style="padding: 0.5rem; text-align: right;">
                                                                <div style="display: flex; gap: 0.25rem; justify-content: flex-end;">
                                                                    <button type="button" class="btn btn-ghost btn-sm" @onclick="() => AbrirEditarCampo(index)" style="padding: 0.15rem 0.35rem; font-size: 0.75rem;" title="Editar">✏️</button>
                                                                    <button type="button" class="btn btn-ghost btn-sm text-danger" @onclick="() => EliminarCampo(index)" style="padding: 0.15rem 0.35rem; font-size: 0.75rem;" title="Eliminar">🗑️</button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Columna Derecha: Variables Disponibles -->
                        <div class="plantilla-form-sidebar" style="position: sticky; top: 0; display: flex; flex-direction: column; gap: 1rem;">
                            <div class="card" style="padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg);">
                                <h4 style="margin-top: 0; margin-bottom: 0.5rem; font-size: 0.9rem; font-weight: 600; color: var(--text);">📋 Variables disponibles</h4>
                                <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0; margin-bottom: 0.75rem; line-height: 1.3;">
                                    Copia estas variables con doble llave e insértalas directamente en tu documento Word.
                                </p>

                                <div style="font-weight: 600; font-size: 0.78rem; text-transform: uppercase; color: var(--text-subtle); margin-bottom: 0.4rem;">Datos de RRHH (Automáticos)</div>
                                <div style="display: flex; flex-direction: column; gap: 0.35rem; max-height: 160px; overflow-y: auto; padding-right: 0.2rem; margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">
                                    @foreach (var v in Variables.Where(x => x.Key != "{{destinatario}}"))
                                    {
                                        var key = v.Key;
                                        <div style="display: flex; align-items: center; justify-content: space-between; background: var(--surface); border: 1px solid var(--border); padding: 0.25rem 0.4rem; border-radius: 4px;">
                                            <code style="font-size: 0.75rem; color: var(--primary); font-weight: bold; cursor: pointer;" @onclick="() => CopiarAlPortapapeles(key)" title="Haga clic para copiar">@key</code>
                                            <button type="button" class="btn btn-ghost btn-sm" @onclick="() => CopiarAlPortapapeles(key)" style="font-size: 0.7rem; padding: 0.1rem 0.25rem;" title="Copiar">📋</button>
                                        </div>
                                    }
                                </div>

                                <div style="font-weight: 600; font-size: 0.78rem; text-transform: uppercase; color: #3b82f6; margin-bottom: 0.4rem;">👥 Variables del Colaborador</div>
                                <div style="display: flex; flex-direction: column; gap: 0.35rem; max-height: 140px; overflow-y: auto; margin-bottom: 1rem; border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">
                                    @if (form.CamposFormulario == null || !form.CamposFormulario.Any(c => c.DiligenciadoPor != "Aprobador"))
                                    {
                                        <div style="font-size: 0.75rem; color: var(--text-muted); text-align: center; padding: 0.25rem 0;">
                                            No hay variables del colaborador.
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (var campo in form.CamposFormulario.Where(c => c.DiligenciadoPor != "Aprobador"))
                                        {
                                            var key = "{{" + campo.Variable + "}}";
                                            <div style="display: flex; align-items: center; justify-content: space-between; background: var(--surface); border: 1px solid var(--border); padding: 0.25rem 0.4rem; border-radius: 4px;">
                                                <code style="font-size: 0.75rem; color: #3b82f6; font-weight: bold; cursor: pointer;" @onclick="() => CopiarAlPortapapeles(key)" title="Haga clic para copiar">@key</code>
                                                <span class="text-xs text-muted" style="margin-left:auto; margin-right: 0.5rem;" title="@campo.Nombre">@campo.Nombre</span>
                                                <button type="button" class="btn btn-ghost btn-sm" @onclick="() => CopiarAlPortapapeles(key)" style="font-size: 0.7rem; padding: 0.1rem 0.25rem;" title="Copiar">📋</button>
                                            </div>
                                        }
                                    }
                                </div>

                                <div style="font-weight: 600; font-size: 0.78rem; text-transform: uppercase; color: #f97316; margin-bottom: 0.4rem;">🛡️ Variables del Aprobador</div>
                                <div style="display: flex; flex-direction: column; gap: 0.35rem; max-height: 140px; overflow-y: auto;">
                                    @if (form.CamposFormulario == null || !form.CamposFormulario.Any(c => c.DiligenciadoPor == "Aprobador"))
                                    {
                                        <div style="font-size: 0.75rem; color: var(--text-muted); text-align: center; padding: 0.25rem 0;">
                                            No hay variables del aprobador.
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (var campo in form.CamposFormulario.Where(c => c.DiligenciadoPor == "Aprobador"))
                                        {
                                            var key = "{{" + campo.Variable + "}}";
                                            <div style="display: flex; align-items: center; justify-content: space-between; background: var(--surface); border: 1px solid var(--border); padding: 0.25rem 0.4rem; border-radius: 4px;">
                                                <code style="font-size: 0.75rem; color: #f97316; font-weight: bold; cursor: pointer;" @onclick="() => CopiarAlPortapapeles(key)" title="Haga clic para copiar">@key</code>
                                                <span class="text-xs text-muted" style="margin-left:auto; margin-right: 0.5rem;" title="@campo.Nombre">@campo.Nombre</span>
                                                <button type="button" class="btn btn-ghost btn-sm" @onclick="() => CopiarAlPortapapeles(key)" style="font-size: 0.7rem; padding: 0.1rem 0.25rem;" title="Copiar">📋</button>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @if (guardando)
                        {
                            <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></span>
                        }
                        @(guardando ? "Guardando..." : (editandoId.HasValue ? "Guardar cambios" : "Crear plantilla"))
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

<!-- Sub-modal para agregar/editar campos dinámicos -->
@if (showSubModal)
{
    <div class="modal-backdrop" style="z-index: 2000;" @onclick="() => showSubModal = false">
        <div class="modal" style="max-width: 420px; z-index: 2010;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(subModalEditandoIndex.HasValue ? "Editar Campo" : "Agregar Campo")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => showSubModal = false">✕</button>
            </div>
            <div class="modal-body" style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                    <label style="font-size: 0.85rem; font-weight: 500; display: block; margin-bottom: 0.25rem;">Nombre del campo *</label>
                    <input type="text" class="form-control" placeholder="Ej: Motivo de la carta"
                           @bind="subModalNombre" @bind:event="oninput" />
                    <small class="text-muted" style="display: block; margin-top: 0.2rem;">
                        Nombre visible que el colaborador completará en el formulario.
                    </small>
                </div>

                <div class="form-group">
                    <label style="font-size: 0.85rem; font-weight: 500; display: block; margin-bottom: 0.25rem;">Tipo de campo</label>
                    <select class="form-control" @bind="subModalTipo" style="width: 100%; padding: 0.4rem; border: 1px solid var(--border); border-radius: var(--radius);">
                        <option value="Texto corto">Texto corto</option>
                        <option value="Texto largo">Texto largo</option>
                        <option value="Número">Número</option>
                        <option value="Fecha">Fecha</option>
                        <option value="Correo electrónico">Correo electrónico</option>
                        <option value="Selección única">Selección única</option>
                        <option value="Selección múltiple">Selección múltiple</option>
                    </select>
                </div>

                <div class="form-group">
                    <label style="font-size: 0.85rem; font-weight: 500; display: block; margin-bottom: 0.25rem;">Quién completa la información</label>
                    <select class="form-control" @bind="subModalDiligenciadoPor" style="width: 100%; padding: 0.4rem; border: 1px solid var(--border); border-radius: var(--radius);">
                        <option value="Colaborador">Colaborador (Solicitante)</option>
                        <option value="Aprobador">Aprobador (Administración)</option>
                    </select>
                </div>

                @if (subModalTipo == "Selección única" || subModalTipo == "Selección múltiple")
                {
                    <div class="form-group">
                        <label style="font-size: 0.85rem; font-weight: 500; display: block; margin-bottom: 0.25rem;">Opciones (separadas por comas) *</label>
                        <input type="text" class="form-control" placeholder="Ej: Opción A, Opción B, Opción C"
                               @bind="subModalOpciones" />
                    </div>
                }

                <div class="form-group">
                    <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size: 0.85rem; margin-top: 0.5rem;">
                        <input type="checkbox" @bind="subModalObligatorio" />
                        Campo obligatorio
                    </label>
                </div>

                @if (!string.IsNullOrWhiteSpace(subModalNombre))
                {
                    <div style="background: var(--bg); border: 1px solid var(--border); padding: 0.6rem; border-radius: var(--radius); font-size: 0.8rem; margin-top: 0.5rem;">
                        <strong>Variable interna autogenerada:</strong>
                        <div style="margin-top: 0.25rem; font-family: monospace; color: #6d28d9; font-weight: bold; font-size: 0.95rem;">
                            @{
                                var variableGen = GenerarVariableInterna(subModalNombre);
                                @("{{" + variableGen + "}}")
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ghost" @onclick="() => showSubModal = false">Cancelar</button>
                <button type="button" class="btn btn-primary"
                        disabled="@string.IsNullOrWhiteSpace(subModalNombre)"
                        @onclick="GuardarCampo">
                    Guardar Campo
                </button>
            </div>
        </div>
    </div>
}
<!-- Modal aprobar/rechazar con vista previa del PDF -->
@if (solicitudResolviendo is not null)
{
    <div class="modal-backdrop" @onclick="CerrarModalResolucion">
        <div class="modal revision-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <span class="modal-title">Revisar solicitud</span>
                    <div class="revision-time">
                        <strong>@solicitudResolviendo.ColaboradorNombre</strong>
                        · @solicitudResolviendo.PlantillaNombre
                        · @TiempoRelativo(solicitudResolviendo.FechaSolicitud)
                    </div>
                </div>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModalResolucion">✕</button>
            </div>

            <div class="revision-modal-body">
                <!-- Vista previa del PDF -->
                <div class="revision-pdf-panel">
                    @if (cargandoPdfPreview)
                    {
                        <div class="revision-pdf-empty">
                            <div class="spinner"></div>
                            <span class="text-sm">Cargando documento...</span>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(pdfPreviewBase64))
                    {
                        <iframe src="data:application/pdf;base64,@pdfPreviewBase64"
                                class="revision-pdf-frame"
                                title="Vista previa del documento"></iframe>
                    }
                    else
                    {
                        <div class="revision-pdf-empty">
                            <span class="revision-pdf-empty-icon">📄</span>
                            <span class="text-sm">Sin vista previa disponible</span>
                            <span class="text-xs text-muted">La solicitud no tiene PDF adjunto</span>
                        </div>
                    }
                </div>

                <!-- Panel de decisión -->
                <div class="revision-decision-panel">
                    <p class="revision-decision-hint">Revisa el documento y decide si apruebas o rechazas la solicitud.</p>

                    <!-- Datos ingresados por el colaborador -->
                    <div class="revision-data-box" style="margin-bottom:1.25rem;padding:.75rem;background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);max-height: 200px; overflow-y: auto;">
                        <div style="font-weight:600;font-size:.875rem;margin-bottom:.5rem;color:var(--text);">📋 Datos Ingresados:</div>
                        @if (solicitudResolviendo.VariablesCompletadas is { Count: > 0 })
                        {
                            <ul style="list-style:none;padding:0;margin:0;font-size:.85rem;display:flex;flex-direction:column;gap:.35rem;">
                                @foreach (var (key, value) in solicitudResolviendo.VariablesCompletadas)
                                {
                                    var label = EtiquetaVariableFriendly(key);
                                    <li><strong>@label:</strong> <span class="text-muted">@value</span></li>
                                }
                            </ul>
                        }
                        else
                        {
                            <span class="text-xs text-muted">No se registraron variables específicas.</span>
                        }
                    </div>

                    <!-- Variables del aprobador a completar -->
                    @{
                        var camposAprobador = ObtenerCamposAprobador();
                    }
                    @if (camposAprobador.Any())
                    {
                        <div class="card" style="margin-bottom: 1.25rem; padding: 1rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); border-left: 4px solid #f97316;">
                            <div style="font-weight:600;font-size:.875rem;margin-bottom:.75rem;color:var(--text); display: flex; align-items: center; gap: 0.35rem;">
                                <span>🛡️ Variables del Aprobador</span>
                                <span class="badge badge-warning" style="font-size: 0.7rem;">Requerido antes de aprobar</span>
                            </div>
                            
                            @foreach (var campo in camposAprobador)
                            {
                                var c = campo;
                                var key = c.Variable;
                                <div class="form-group" style="margin-bottom: 0.85rem;">
                                    <label style="font-size: 0.8rem; font-weight: 500; display: block; margin-bottom: 0.25rem; color: var(--text);">
                                        @c.Nombre @(c.Obligatorio ? "*" : "")
                                    </label>
                                    
                                    @if (c.Tipo == "Texto largo")
                                    {
                                        <textarea class="form-control"
                                                  style="font-size:.85rem;padding:.4rem .6rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);height:60px;resize:none;"
                                                  value="@variablesAprobadorModel.GetValueOrDefault(key, "")"
                                                  placeholder="Escribe aquí..."
                                                  @oninput="e => OnVariablesAprobadorInput(key, e.Value?.ToString() ?? string.Empty)"></textarea>
                                    }
                                    else if (c.Tipo == "Número")
                                    {
                                        <input type="number" class="form-control"
                                               style="font-size:.85rem;padding:.4rem .6rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                               value="@variablesAprobadorModel.GetValueOrDefault(key, "")"
                                               placeholder="Ej: 123"
                                               @oninput="e => OnVariablesAprobadorInput(key, e.Value?.ToString() ?? string.Empty)" />
                                    }
                                    else if (c.Tipo == "Fecha")
                                    {
                                        <input type="date" class="form-control"
                                               style="font-size:.85rem;padding:.4rem .6rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                               value="@variablesAprobadorModel.GetValueOrDefault(key, "")"
                                               @onchange="e => OnVariablesAprobadorInput(key, e.Value?.ToString() ?? string.Empty)" />
                                    }
                                    else if (c.Tipo == "Correo electrónico")
                                    {
                                        <input type="email" class="form-control"
                                               style="font-size:.85rem;padding:.4rem .6rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                               value="@variablesAprobadorModel.GetValueOrDefault(key, "")"
                                               placeholder="Ej: admin@novaderma.com"
                                               @oninput="e => OnVariablesAprobadorInput(key, e.Value?.ToString() ?? string.Empty)" />
                                    }
                                    else if (c.Tipo == "Selección única")
                                    {
                                        var opciones = c.Opciones?.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(o => o.Trim()).ToList() ?? [];
                                        <select class="form-control"
                                                style="font-size:.85rem;padding:.4rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                                value="@variablesAprobadorModel.GetValueOrDefault(key, "")"
                                                @onchange="e => OnVariablesAprobadorInput(key, e.Value?.ToString() ?? string.Empty)">
                                            <option value="">-- Seleccionar --</option>
                                            @foreach (var opt in opciones)
                                            {
                                                <option value="@opt">@opt</option>
                                            }
                                        </select>
                                    }
                                    else if (c.Tipo == "Selección múltiple")
                                    {
                                        var opciones = c.Opciones?.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(o => o.Trim()).ToList() ?? [];
                                        var currentVal = variablesAprobadorModel.GetValueOrDefault(key, string.Empty);
                                        var selectedItems = currentVal.Split(new[] { ", " }, StringSplitOptions.RemoveEmptyEntries).ToList();
                                        <div style="display:flex; flex-direction:column; gap:0.3rem; padding: 0.4rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg); max-height: 100px; overflow-y: auto;">
                                            @foreach (var opt in opciones)
                                            {
                                                var optionVal = opt;
                                                <label style="display:flex; align-items:center; gap:0.35rem; cursor:pointer; font-size:0.8rem; margin:0;">
                                                    <input type="checkbox"
                                                           checked="@selectedItems.Contains(optionVal)"
                                                           @onchange="e => ToggleAprobadorCheckOption(key, optionVal, (bool)e.Value!)" />
                                                    @optionVal
                                                </label>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        // Texto corto (default)
                                        <input type="text" class="form-control"
                                               style="font-size:.85rem;padding:.4rem .6rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                               value="@variablesAprobadorModel.GetValueOrDefault(key, "")"
                                               placeholder="Escribe aquí..."
                                               @oninput="e => OnVariablesAprobadorInput(key, e.Value?.ToString() ?? string.Empty)" />
                                    }
                                </div>
                            }
                        </div>
                    }

                    <div class="form-group">
                        <label>Comentario de resolución (motivo de rechazo obligatorio)</label>
                        <textarea class="revision-comment-area"
                                  placeholder="Escribe un comentario o motivo de rechazo..."
                                  @bind="comentarioResolucion"></textarea>
                    </div>

                    <div class="revision-actions">
                        <button class="btn btn-primary"
                                disabled="@resolviendo"
                                @onclick="AprobarSolicitud">
                            @if (resolviendo && accionResolucion == "aprobar")
                            {
