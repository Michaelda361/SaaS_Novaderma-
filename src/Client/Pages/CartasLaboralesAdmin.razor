    private void AbrirEditarCampo(int index)
    {
        if (index < 0 || index >= form.CamposFormulario.Count) return;
        var campo = form.CamposFormulario[index];
        subModalNombre = campo.Nombre;
        subModalTipo = campo.Tipo;
        subModalObligatorio = campo.Obligatorio;
        subModalOpciones = campo.Opciones ?? string.Empty;
        subModalDiligenciadoPor = campo.DiligenciadoPor ?? "Colaborador";
        subModalEditandoIndex = index;
        showSubModal = true;
    }

    private async Task GuardarCampo()
    {
        if (string.IsNullOrWhiteSpace(subModalNombre)) return;

        var variableKey = GenerarVariableInterna(subModalNombre);
        if (string.IsNullOrWhiteSpace(variableKey)) return;

        // Validar que la variable no se duplique
        var existe = form.CamposFormulario
            .Select((c, idx) => new { c.Variable, Index = idx })
            .Any(x => x.Variable.Equals(variableKey, StringComparison.OrdinalIgnoreCase) && x.Index != subModalEditandoIndex);

        if (existe)
        {
            await toast.Show("⚠️ Ya existe una variable interna con este nombre.", "warning");
            return;
        }

        var campo = new CampoFormularioDto
        {
            Nombre = subModalNombre.Trim(),
            Tipo = subModalTipo,
            Obligatorio = subModalObligatorio,
            Variable = variableKey,
            Opciones = (subModalTipo == "Selección única" || subModalTipo == "Selección múltiple") ? subModalOpciones : null,
            DiligenciadoPor = subModalDiligenciadoPor
        };

        if (subModalEditandoIndex.HasValue)
        {
            form.CamposFormulario[subModalEditandoIndex.Value] = campo;
        }
        else
        {
            form.CamposFormulario.Add(campo);
        }

        // Sincronizar variables editables
        form.VariablesEditables = form.CamposFormulario.Select(c => c.Variable).ToList();

        showSubModal = false;
    }

    private void EliminarCampo(int index)
    {
        if (index < 0 || index >= form.CamposFormulario.Count) return;
        form.CamposFormulario.RemoveAt(index);
        form.VariablesEditables = form.CamposFormulario.Select(c => c.Variable).ToList();
    }

