@page "/cartas/admin"
@attribute [Authorize]
@inject PlantillaDocumentoApiService ApiService
@inject AreaApiService AreaApi
@inject AuthInfoService AuthInfo
@inject NotificacionesService Notificaciones
@inject IJSRuntime JS
@implements IAsyncDisposable

<Toast @ref="toast" />
<ConfirmDialog Visible="showConfirm"
               Message="@confirmMsg"
               OnConfirm="EliminarConfirmado"
               OnCancel="() => showConfirm = false" />

@if (cargando)
{
    <div class="loading"><div class="spinner"></div> Cargando...</div>
}
else if (AuthInfo.EsSoloColaborador)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔒</div>
        <h3>Acceso restringido</h3>
        <p>Esta sección es solo para administradores y jefes de área.</p>
        <a href="cartas" class="btn btn-primary" style="margin-top:1rem;">Ir a mis cartas</a>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h2 class="page-title">Cartas Laborales — Administración</h2>
            <p class="page-subtitle">
                @if (AuthInfo.EsJefe || AuthInfo.EsAdmin) { <span>Gestiona plantillas y aprueba solicitudes</span> }
                else { <span>Revisa y aprueba las solicitudes de cartas laborales</span> }
            </p>
        </div>
        @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
        {
            <div class="flex gap-2">
                <a href="cartas" class="btn btn-ghost btn-sm">👁 Ver como colaborador</a>
                <button class="btn btn-primary" @onclick="AbrirNueva">+ Nueva plantilla</button>
            </div>
        }
    </div>

    <!-- Tabs: plantillas solo para Jefe/Admin, pendientes e historial para todos los no-colaboradores -->
    <div class="admin-tabs">
        @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
        {
            <button class="admin-tab @(tabActiva == "plantillas" ? "admin-tab--active" : "")"
                    @onclick='() => tabActiva = "plantillas"'>
                📄 Plantillas <span class="admin-tab-count">@plantillas.Count</span>
            </button>
        }
        <button class="admin-tab @(tabActiva == "pendientes" ? "admin-tab--active" : "")"
                @onclick='() => { tabActiva = "pendientes"; _ = CargarPendientes(); }'>
            ⏳ Pendientes
            @if (countPendientes > 0)
            {
                <span class="admin-tab-count admin-tab-count--alert">@countPendientes</span>
            }
        </button>
        <button class="admin-tab @(tabActiva == "historial" ? "admin-tab--active" : "")"
                @onclick='() => { tabActiva = "historial"; _ = CargarHistorial(); }'>
            📋 Historial
            @if (solicitudes.Any())
            {
                <span class="admin-tab-count">@solicitudes.Count</span>
            }
        </button>
    </div>

    @if (tabActiva == "plantillas")
    {
        @if (!plantillas.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📄</div>
                <h3>Sin plantillas</h3>
                <p>Crea la primera plantilla para que los colaboradores puedan descargar sus cartas.</p>
                <button class="btn btn-primary" style="margin-top:1rem;" @onclick="AbrirNueva">+ Nueva plantilla</button>
            </div>
        }
        else
        {
            <div class="card">
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Plantilla</th>
                                <th>Firmante</th>
                                <th>Disponible para</th>
                                <th>Tipo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in plantillas)
                            {
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="carta-admin-icon">@(p.TipoPlantilla == "docx" ? "📝" : "📄")</div>
                                            <div>
                                                <div class="user-name">@p.Nombre</div>
                                                @if (!string.IsNullOrWhiteSpace(p.Descripcion))
                                                {
                                                    <div class="user-email">@p.Descripcion</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-sm">
                                        @if (!string.IsNullOrWhiteSpace(p.NombreFirmante))
                                        {
                                            <div>@p.NombreFirmante</div>
                                            @if (!string.IsNullOrWhiteSpace(p.CargoFirmante))
                                            {
                                                <div class="text-muted text-xs">@p.CargoFirmante</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (p.AplicaTodasAreas)
                                        {
                                            <span class="badge badge-success">Todas las áreas</span>
                                        }
                                        else
                                        {
                                            <div style="display:flex;flex-wrap:wrap;gap:.25rem;">
                                                @foreach (var nombre in p.AreaNombres)
                                                {
                                                    <span class="badge badge-info">@nombre</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (p.TipoPlantilla == "docx")
                                        {
                                            <span class="badge badge-purple">Word</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-gray">HTML</span>
                                        }
                                        @if (p.VariablesEditables.Any())
                                        {
                                            <span class="badge badge-warning" style="margin-left:.25rem;">✏️ Editable</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="flex gap-2">
                                            <button class="btn btn-ghost btn-sm"
                                                    @onclick="() => MostrarVariables(p)">
                                                Variables
                                            </button>
                                            <button class="btn btn-ghost btn-sm btn-icon"
                                                    @onclick="() => AbrirEditar(p)" title="Editar">✏️</button>
                                            <button class="btn btn-danger btn-sm btn-icon"
                                                    @onclick="() => PedirConfirmacion(p)" title="Eliminar">🗑️</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else if (tabActiva == "pendientes")
    {
        @if (cargandoPendientes)
        {
            <div class="loading"><div class="spinner"></div> Cargando...</div>
        }
        else if (!pendientes.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">✅</div>
                <h3>Sin solicitudes pendientes</h3>
                <p>Todas las solicitudes han sido resueltas.</p>
            </div>
        }
        else
        {
            <div class="card">
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr><th>Colaborador</th><th>Documento</th><th>Fecha</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in pendientes)
                            {
                                var sid = s.Id;
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="avatar avatar-sm">@Iniciales(s.ColaboradorNombre)</div>
                                            <div>
                                                <div class="user-name">@s.ColaboradorNombre</div>
                                                <div class="user-email">@s.ColaboradorEmail</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-sm">@s.PlantillaNombre</td>
                                    <td class="text-muted text-sm">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => AbrirAprobar(s)" title="Revisar solicitud">
                                            👁 Revisar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <!-- Historial de solicitudes -->
        @if (cargandoHistorial)
        {
            <div class="loading"><div class="spinner"></div> Cargando historial...</div>
        }
        else if (!solicitudes.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📋</div>
                <h3>Sin solicitudes aún</h3>
                <p>Aquí aparecerán todas las solicitudes de los colaboradores.</p>
            </div>
        }
        else
        {
            <div class="card">
                <div class="filter-bar">
                    <div class="search-input-wrap">
                        <span class="search-icon">🔍</span>
                        <input type="text" placeholder="Buscar colaborador o plantilla..."
                               @bind="filtroHistorial" @bind:event="oninput" />
                    </div>
                    <div style="display:flex;align-items:center;gap:.75rem;">
                        <span class="text-muted text-sm">@SolicitudesFiltradas.Count() solicitud(es)</span>
                        @if (historialCargadoEn.HasValue)
                        {
                            <span class="text-xs text-muted">Actualizado @historialCargadoEn.Value.ToString("HH:mm")</span>
                        }
                        <button class="btn btn-ghost btn-sm btn-icon" title="Recargar historial"
                                @onclick="RecargarHistorial">🔄</button>
                    </div>
                </div>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr><th>Colaborador</th><th>Documento</th><th>Fecha</th><th>Estado</th><th>Comentario</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in SolicitudesFiltradas.Take(100))
                            {
                                <tr>
                                    <td>
                                        <div class="user-cell">
                                            <div class="avatar avatar-sm">@Iniciales(s.ColaboradorNombre)</div>
                                            <span class="user-name">@s.ColaboradorNombre</span>
                                        </div>
                                    </td>
                                    <td class="text-sm">@s.PlantillaNombre</td>
                                    <td class="text-muted text-sm">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (s.Estado == "Pendiente")      { <span class="badge badge-warning">⏳ Pendiente</span> }
                                        else if (s.Estado == "Aprobada")   { <span class="badge badge-success">✅ Aprobada</span> }
                                        else                               { <span class="badge badge-danger">❌ Rechazada</span> }
                                    </td>
                                    <td class="text-sm text-muted">
                                        @if (!string.IsNullOrWhiteSpace(s.ComentarioAdmin))
                                        {
                                            <span style="font-style:italic;">@s.ComentarioAdmin</span>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}

<!-- Modal variables -->
@if (showVariables && plantillaVariables is not null)
{
    <div class="modal-backdrop" @onclick="() => showVariables = false">
        <div class="modal" style="max-width:560px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Variables — @plantillaVariables.Nombre</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => showVariables = false">✕</button>
            </div>
            <div class="modal-body">
                <p class="text-muted text-sm" style="margin-bottom:.75rem;">
                    Estas variables se reemplazan automáticamente con los datos del colaborador al generar el documento.
                </p>
                <div class="variables-grid">
                    @foreach (var v in Variables)
                    {
                        var usada = plantillaVariables.TipoPlantilla == "html" &&
                                    (plantillaVariables.ContenidoHtml?.Contains(v.Key) ?? false);
                        <div class="variable-item @(usada ? "variable-item--usada" : "")">
                            <code class="variable-tag">@v.Key</code>
                            <span class="text-muted text-sm">@v.Value</span>
                            @if (usada) { <span class="variable-usada-badge">✓ en uso</span> }
                        </div>
                    }
                </div>

                @if (plantillaVariables.VariablesEditables.Any())
                {
                    <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--border);">
                        <p class="text-sm" style="margin-bottom:.5rem;font-weight:500;">
                            ✏️ Campos que el colaborador completa
                        </p>
                        <div class="variables-grid">
                            @foreach (var key in plantillaVariables.VariablesEditables)
                            {
                                var label = VariablesEditablesOpciones.TryGetValue(key, out var l) ? l : key.Replace("_", " ");
                                <div class="variable-item variable-item--editable">
                                    <code class="variable-tag">@("{{" + key + "}}")</code>
                                    <span class="text-muted text-sm">@label</span>
                                    <span class="variable-editable-badge">editable</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Modal crear/editar -->
@if (showModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal plantilla-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editandoId.HasValue ? "Editar plantilla" : "Nueva plantilla")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <EditForm Model="form" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-group">
                        <label>Nombre *</label>
                        <InputText @bind-Value="form.Nombre" placeholder="Ej: Carta de certificación laboral" />
                        <ValidationMessage For="() => form.Nombre" />
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <InputText @bind-Value="form.Descripcion" placeholder="Descripción breve (opcional)" />
                    </div>

                    <div class="plantilla-divider"></div>

                    <div class="form-group">
                        <label>Tipo de plantilla</label>
                        <div class="tipo-selector">
                            <label class="tipo-option @(form.TipoPlantilla == "html" ? "tipo-option--active" : "")">
                                <input type="radio" name="tipo" value="html"
                                       checked="@(form.TipoPlantilla == "html")"
                                       @onchange='() => form.TipoPlantilla = "html"' />
                                <span class="tipo-icon">📄</span>
                                <div>
                                    <div class="tipo-label">Editor HTML</div>
                                    <div class="tipo-desc">Escribe directamente con formato</div>
                                </div>
                            </label>
                            <label class="tipo-option @(form.TipoPlantilla == "docx" ? "tipo-option--active" : "")">
                                <input type="radio" name="tipo" value="docx"
                                       checked="@(form.TipoPlantilla == "docx")"
                                       @onchange='() => form.TipoPlantilla = "docx"' />
                                <span class="tipo-icon">📝</span>
                                <div>
                                    <div class="tipo-label">Archivo Word</div>
                                    <div class="tipo-desc">Sube un .docx con variables</div>
                                </div>
                            </label>
                        </div>
                    </div>

                    @if (form.TipoPlantilla == "html")
                    {
                        <div class="instructivo-box">
                            <button type="button" class="instructivo-toggle"
                                    @onclick="() => showInstructivoHtml = !showInstructivoHtml">
                                <span>💡 ¿Cómo usar variables?</span>
                                <span>@(showInstructivoHtml ? "▲" : "▼")</span>
                            </button>
                            @if (showInstructivoHtml)
                            {
                                <div class="instructivo-body">
                                    <p>Escribe el contenido normalmente. Donde quieras insertar un dato del colaborador, usa <code>&#123;&#123;nombre_variable&#125;&#125;</code>. Haz clic en cualquier variable del panel derecho del editor para insertarla.</p>
                                    <div class="instructivo-ejemplo">
                                        <div class="instructivo-ejemplo-label">Ejemplo:</div>
                                        <code>La empresa certifica que <strong>&#123;&#123;nombre_completo&#125;&#125;</strong> se desempeña como <strong>&#123;&#123;cargo&#125;&#125;</strong> desde el <strong>&#123;&#123;fecha_ingreso&#125;&#125;</strong>.</code>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="form-group">
                            <label>Contenido de la carta</label>
                            <EditorPlantilla @bind-HtmlContent="form.ContenidoHtml" />
                        </div>
                    }
                    else
                    {
                        <div class="instructivo-box">
                            <button type="button" class="instructivo-toggle"
                                    @onclick="() => showInstructivoDocx = !showInstructivoDocx">
                                <span>💡 ¿Cómo preparar el archivo Word?</span>
                                <span>@(showInstructivoDocx ? "▲" : "▼")</span>
                            </button>
                            @if (showInstructivoDocx)
                            {
                                <div class="instructivo-body">
                                    <ol class="instructivo-steps">
                                        <li>Abre tu documento Word y escribe las variables con doble llave: <code>&#123;&#123;nombre_variable&#125;&#125;</code></li>
                                        <li>Escribe cada variable de un solo trazo sin interrupciones para que Word no las fragmente.</li>
                                        <li>Guarda como <strong>.docx</strong> y súbelo aquí.</li>
                                    </ol>
                                    <div class="instructivo-ejemplo">
                                        <div class="instructivo-ejemplo-label">Variables disponibles:</div>
                                        <div style="display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.4rem;">
                                            @foreach (var v in Variables)
                                            {
                                                <span style="background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:.1rem .35rem;font-size:.75rem;"><code>@v.Key</code></span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="form-group">
                            <label>Archivo Word (.docx) *</label>
                            <InputFile OnChange="OnDocxSeleccionado" accept=".docx" />
                            @if (!string.IsNullOrWhiteSpace(form.ArchivoDocxBase64))
                            {
                                <div class="alert alert-success" style="margin-top:.5rem;padding:.5rem .75rem;">
                                    ✅ Archivo cargado correctamente
                                </div>
                            }
                        </div>
                    }

                    <div class="plantilla-divider"></div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Nombre del firmante</label>
                            <InputText @bind-Value="form.NombreFirmante" placeholder="Ej: Francy Gutiérrez" />
                        </div>
                        <div class="form-group">
                            <label>Cargo del firmante</label>
                            <InputText @bind-Value="form.CargoFirmante" placeholder="Ej: Directora de RRHH" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Imagen de firma</label>
                        <InputFile OnChange="OnFirmaSeleccionada" accept="image/*" />
                        @if (!string.IsNullOrWhiteSpace(form.FirmaImagenBase64))
                        {
                            <div style="margin-top:.5rem;display:flex;align-items:center;gap:.75rem;">
                                <img src="@form.FirmaImagenBase64" alt="Firma"
                                     style="max-height:64px;border:1px solid var(--border);border-radius:4px;padding:4px;" />
                                <button type="button" class="btn btn-ghost btn-sm"
                                        @onclick="() => form.FirmaImagenBase64 = null">
                                    Quitar
                                </button>
                            </div>
                        }
                    </div>

                    <div class="plantilla-divider"></div>

                    <div class="form-group">
                        <label>Disponible para</label>
                        <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;margin-bottom:.5rem;">
                            <input type="checkbox" @bind="form.AplicaTodasAreas" />
                            Todas las áreas
                        </label>
                        @if (!form.AplicaTodasAreas)
                        {
                            <div class="areas-check-list">
                                @foreach (var area in areas)
                                {
                                    var areaId = area.Id;
                                    <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                        <input type="checkbox"
                                               checked="@form.AreaIds.Contains(areaId)"
                                               @onchange="e => ToggleArea(areaId, (bool)e.Value!)" />
                                        @area.Nombre
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class="plantilla-divider"></div>

                    <div class="form-group">
                        <label>
                            Campos editables por el colaborador
                            <span class="text-muted text-sm" style="font-weight:400;margin-left:.25rem;">— el colaborador puede personalizar estos valores antes de descargar</span>
                        </label>
                        <div class="areas-check-list">
                            @foreach (var v in VariablesEditablesOpciones)
                            {
                                var key = v.Key;
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                    <input type="checkbox"
                                           checked="@form.VariablesEditables.Contains(key)"
                                           @onchange="e => ToggleVariableEditable(key, (bool)e.Value!)" />
                                    <code style="font-size:.8rem;">@("{{" + key + "}}")</code>
                                    <span class="text-muted text-sm">@v.Value</span>
                                </label>
                            }
                        </div>
                        @foreach (var custom in form.VariablesEditables.Where(k => !VariablesEditablesOpciones.ContainsKey(k)))
                        {
                            var customKey = custom;
                            <div style="display:flex;align-items:center;gap:.4rem;margin-top:.35rem;">
                                <input type="checkbox" checked disabled />
                                <code style="font-size:.8rem;">@("{{" + customKey + "}}")</code>
                                <span class="text-muted text-sm">Variable personalizada</span>
                                <button type="button" class="btn btn-ghost btn-sm btn-icon"
                                        style="margin-left:auto;"
                                        @onclick="() => form.VariablesEditables.Remove(customKey)">✕</button>
                            </div>
                        }
                        <div style="display:flex;gap:.5rem;margin-top:.6rem;align-items:center;">
                            <input type="text" class="form-control" style="font-size:.8rem;max-width:200px;"
                                   placeholder="nombre_variable"
                                   @bind="nuevaVariableCustom" @bind:event="oninput"
                                   @onkeydown="OnNuevaVariableKeyDown" />
                            <button type="button" class="btn btn-ghost btn-sm"
                                    disabled="@string.IsNullOrWhiteSpace(nuevaVariableCustom)"
                                    @onclick="AgregarVariableCustom">
                                + Agregar
                            </button>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(errorVariableCustom))
                        {
                            <small class="text-danger">@errorVariableCustom</small>
                        }
                        <small class="text-muted" style="display:block;margin-top:.35rem;">
                            Las variables del perfil se rellenan automáticamente. Las personalizadas las completa el colaborador.
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @if (guardando)
                        {
                            <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></span>
                        }
                        @(guardando ? "Guardando..." : (editandoId.HasValue ? "Guardar cambios" : "Crear plantilla"))
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}
<!-- Modal aprobar/rechazar con vista previa del PDF -->
@if (solicitudResolviendo is not null)
{
    <div class="modal-backdrop" @onclick="CerrarModalResolucion">
        <div class="modal revision-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <span class="modal-title">Revisar solicitud</span>
                    <div class="revision-time">
                        <strong>@solicitudResolviendo.ColaboradorNombre</strong>
                        · @solicitudResolviendo.PlantillaNombre
                        · @TiempoRelativo(solicitudResolviendo.FechaSolicitud)
                    </div>
                </div>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModalResolucion">✕</button>
            </div>

            <div class="revision-modal-body">
                <!-- Vista previa del PDF -->
                <div class="revision-pdf-panel">
                    @if (cargandoPdfPreview)
                    {
                        <div class="revision-pdf-empty">
                            <div class="spinner"></div>
                            <span class="text-sm">Cargando documento...</span>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(pdfPreviewBase64))
                    {
                        <iframe src="data:application/pdf;base64,@pdfPreviewBase64"
                                class="revision-pdf-frame"
                                title="Vista previa del documento"></iframe>
                    }
                    else
                    {
                        <div class="revision-pdf-empty">
                            <span class="revision-pdf-empty-icon">📄</span>
                            <span class="text-sm">Sin vista previa disponible</span>
                            <span class="text-xs text-muted">La solicitud no tiene PDF adjunto</span>
                        </div>
                    }
                </div>

                <!-- Panel de decisión -->
                <div class="revision-decision-panel">
                    <p class="revision-decision-hint">Revisa el documento y decide si apruebas o rechazas la solicitud.</p>

                    <div class="form-group">
                        <label>Comentario (opcional)</label>
                        <textarea class="revision-comment-area"
                                  placeholder="Mensaje opcional para el colaborador..."
                                  @bind="comentarioResolucion"></textarea>
                    </div>

                    <div class="revision-actions">
                        <button class="btn btn-primary"
                                disabled="@resolviendo"
                                @onclick="AprobarSolicitud">
                            @if (resolviendo && accionResolucion == "aprobar")
                            {
                                <div class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></div>
                            }
                            <span>✅ Aprobar</span>
                        </button>
                        <button class="btn btn-danger"
                                disabled="@resolviendo"
                                @onclick="RechazarSolicitud">
                            @if (resolviendo && accionResolucion == "rechazar")
                            {
                                <div class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></div>
                            }
                            <span>❌ Rechazar</span>
                        </button>
                        <button class="btn btn-ghost" @onclick="CerrarModalResolucion">Cancelar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Toast toast = null!;
    private List<PlantillaDocumentoDto> plantillas = [];
    private List<AreaDto> areas = [];
    private List<SolicitudDocumentoDto> solicitudes = [];
    private List<SolicitudDocumentoDto> pendientes = [];
    private bool cargando = true;
    private bool cargandoHistorial = false;
    private bool cargandoPendientes = false;
    private bool historialCargado = false;
    private DateTime? historialCargadoEn;
    private bool showModal = false;
    private bool showVariables = false;
    private bool showConfirm = false;
    private bool guardando = false;
    private bool showInstructivoHtml = false;
    private bool showInstructivoDocx = true;
    private string tabActiva = "plantillas";
    private string filtroHistorial = string.Empty;
    private int? editandoId;
    private string confirmMsg = string.Empty;
    private PlantillaDocumentoDto? aEliminar;
    private PlantillaDocumentoDto? plantillaVariables;
    private string nuevaVariableCustom = string.Empty;
    private string errorVariableCustom = string.Empty;
    private int countPendientes = 0;
    private SolicitudDocumentoDto? solicitudResolviendo;
    private string accionResolucion = "aprobar";
    private string comentarioResolucion = string.Empty;
    private bool resolviendo = false;
    private bool cargandoPdfPreview = false;
    private string? pdfPreviewBase64;

    private CreatePlantillaDocumentoDto form = new();

    private IEnumerable<SolicitudDocumentoDto> SolicitudesFiltradas =>
        string.IsNullOrWhiteSpace(filtroHistorial)
            ? solicitudes
            : solicitudes.Where(s =>
                s.ColaboradorNombre.Contains(filtroHistorial, StringComparison.OrdinalIgnoreCase) ||
                s.PlantillaNombre.Contains(filtroHistorial, StringComparison.OrdinalIgnoreCase));

    private static readonly Dictionary<string, string> Variables = new()
    {
        ["{{nombre_completo}}"]  = "Nombre y apellido",
        ["{{nombre}}"]           = "Nombre",
        ["{{apellido}}"]         = "Apellido",
        ["{{cedula}}"]           = "Cédula",
        ["{{cargo}}"]            = "Cargo actual",
        ["{{area}}"]             = "Área / departamento",
        ["{{fecha_ingreso}}"]    = "Fecha de ingreso",
        ["{{tipo_contrato}}"]    = "Tipo de contrato",
        ["{{sueldo_basico}}"]    = "Sueldo básico",
        ["{{ciudad}}"]           = "Ciudad",
        ["{{fecha_expedicion}}"] = "Fecha de hoy",
        ["{{nombre_firmante}}"]  = "Nombre del firmante",
        ["{{cargo_firmante}}"]   = "Cargo del firmante",
    };

    private static readonly Dictionary<string, string> VariablesEditablesOpciones = new()
    {
        ["destinatario"]     = "A quién va dirigida la carta",
        ["motivo"]           = "Motivo o propósito",
        ["entidad"]          = "Entidad o empresa destinataria",
        ["nombre_completo"]  = "Nombre completo (si el colaborador quiere ajustarlo)",
        ["cargo"]            = "Cargo (si difiere del perfil)",
        ["ciudad"]           = "Ciudad de expedición",
        ["fecha_expedicion"] = "Fecha de expedición",
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthInfo.LoadAsync();
        if (!AuthInfo.EsSoloColaborador)
        {
            if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
            {
                var t1 = ApiService.GetAllAsync();
                var t2 = AreaApi.GetAllAsync();
                var t3 = ApiService.CountPendientesAsync();
                await Task.WhenAll(t1, t2, t3);
                plantillas = t1.Result ?? [];
                areas = t2.Result ?? [];
                countPendientes = t3.Result;
                if (countPendientes > 0)
                {
                    tabActiva = "pendientes";
                    pendientes = await ApiService.GetPendientesAsync();
                }
            }
            else
            {
                tabActiva = "pendientes";
                pendientes = await ApiService.GetPendientesAsync();
                countPendientes = pendientes.Count;
            }

            await Notificaciones.ConectarAsync();
            await Notificaciones.UnirseGrupoAdminAsync();
            Notificaciones.OnNuevaSolicitud += OnNuevaSolicitud;
        }
        cargando = false;
    }

    private void OnNuevaSolicitud(SolicitudDocumentoDto s)
    {
        countPendientes++;
        if (tabActiva == "pendientes") pendientes.Insert(0, s);
        InvokeAsync(async () =>
        {
            StateHasChanged();
            await toast.Show($"📥 Nueva solicitud de {s.ColaboradorNombre} — {s.PlantillaNombre}");
        });
    }

    private async Task CargarPendientes()
    {
        cargandoPendientes = true;
        StateHasChanged();
        try
        {
            pendientes = await ApiService.GetPendientesAsync();
            countPendientes = pendientes.Count;
        }
        catch
        {
            pendientes = [];
            countPendientes = 0;
        }
        finally
        {
            cargandoPendientes = false;
            StateHasChanged();
        }
    }

    private async Task AbrirAprobar(SolicitudDocumentoDto s)
    {
        solicitudResolviendo = s;
        accionResolucion = "aprobar";
        comentarioResolucion = string.Empty;
        StateHasChanged();
        await CargarPdfPreviewAsync(s);
    }

    private async Task AbrirRechazar(SolicitudDocumentoDto s)
    {
        solicitudResolviendo = s;
        accionResolucion = "rechazar";
        comentarioResolucion = string.Empty;
        StateHasChanged();
        await CargarPdfPreviewAsync(s);
    }

    private async Task AprobarSolicitud()
    {
        accionResolucion = "aprobar";
        await ConfirmarResolucion();
    }

    private async Task RechazarSolicitud()
    {
        accionResolucion = "rechazar";
        await ConfirmarResolucion();
    }

    private static string TiempoRelativo(DateTime fecha)
    {
        var diff = DateTime.UtcNow - fecha.ToUniversalTime();
        if (diff.TotalMinutes < 1)   return "hace un momento";
        if (diff.TotalMinutes < 60)  return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24)    return $"hace {(int)diff.TotalHours} h";
        if (diff.TotalDays < 7)      return $"hace {(int)diff.TotalDays} día(s)";
        return fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

    private async Task CargarPdfPreviewAsync(SolicitudDocumentoDto s)
    {
        if (!s.TienePdf) return;
        cargandoPdfPreview = true;
        pdfPreviewBase64 = null;
        StateHasChanged();
        pdfPreviewBase64 = await ApiService.GetPdfSolicitudBase64Async(s.Id);
        cargandoPdfPreview = false;
        StateHasChanged();
    }

    private void CerrarModalResolucion()
    {
        solicitudResolviendo = null;
        comentarioResolucion = string.Empty;
        pdfPreviewBase64 = null;
        cargandoPdfPreview = false;
    }

    private async Task ConfirmarResolucion()
    {
        if (solicitudResolviendo is null) return;
        resolviendo = true;
        StateHasChanged();

        var dto = new ResolverSolicitudDto { Comentario = comentarioResolucion };
        var resultado = accionResolucion == "aprobar"
            ? await ApiService.AprobarAsync(solicitudResolviendo.Id, dto)
            : await ApiService.RechazarAsync(solicitudResolviendo.Id, dto);

        resolviendo = false;

        if (resultado is null)
        {
            await toast.Show("Error al procesar la solicitud.", "error");
            StateHasChanged();
            return;
        }

        pendientes.RemoveAll(s => s.Id == resultado.Id);
        countPendientes = pendientes.Count;
        CerrarModalResolucion();
        await toast.Show(accionResolucion == "aprobar" ? "Solicitud aprobada." : "Solicitud rechazada.");
    }

    public async ValueTask DisposeAsync()
    {
        Notificaciones.OnNuevaSolicitud -= OnNuevaSolicitud;
        await Notificaciones.SalirGrupoAdminAsync();
        await Notificaciones.DisposeAsync();
    }

    private async Task CargarHistorial()
    {
        if (historialCargado) return;
        cargandoHistorial = true;
        StateHasChanged();
        try
        {
            solicitudes = await ApiService.GetTodasSolicitudesAsync();
            historialCargado = true;
            historialCargadoEn = DateTime.Now;
        }
        catch
        {
            solicitudes = [];
        }
        finally
        {
            cargandoHistorial = false;
            StateHasChanged();
        }
    }

    private async Task RecargarHistorial()
    {
        historialCargado = false;
        await CargarHistorial();
    }

    private void AbrirNueva()
    {
        form = new CreatePlantillaDocumentoDto();
        editandoId = null;
        showInstructivoHtml = false;
        showInstructivoDocx = true;
        showModal = true;
    }

    private void AbrirEditar(PlantillaDocumentoDto p)
    {
        form = new CreatePlantillaDocumentoDto
        {
            Nombre = p.Nombre,
            Descripcion = p.Descripcion,
            TipoPlantilla = p.TipoPlantilla,
            ContenidoHtml = p.ContenidoHtml,
            FirmaImagenBase64 = p.FirmaImagenBase64,
            NombreFirmante = p.NombreFirmante,
            CargoFirmante = p.CargoFirmante,
            AplicaTodasAreas = p.AplicaTodasAreas,
            AreaIds = [..p.AreaIds],
            VariablesEditables = [..p.VariablesEditables],
        };
        editandoId = p.Id;
        showModal = true;
    }

    private void CerrarModal()
    {
        showModal = false;
        form = new();
        editandoId = null;
        nuevaVariableCustom = string.Empty;
        errorVariableCustom = string.Empty;
    }

    private async Task Guardar()
    {
        guardando = true;
        bool ok;
        if (editandoId.HasValue)
            ok = await ApiService.UpdateAsync(editandoId.Value, form) is not null;
        else
            ok = await ApiService.CreateAsync(form) is not null;
        guardando = false;

        if (ok)
        {
            CerrarModal();
            plantillas = await ApiService.GetAllAsync() ?? [];
            await toast.Show(editandoId.HasValue ? "Plantilla actualizada." : "Plantilla creada.");
        }
        else
        {
            await toast.Show("Error al guardar la plantilla.", "error");
        }
    }

    private void PedirConfirmacion(PlantillaDocumentoDto p)
    {
        aEliminar = p;
        confirmMsg = $"¿Eliminar la plantilla \"{p.Nombre}\"? Esta acción no se puede deshacer.";
        showConfirm = true;
    }

    private async Task EliminarConfirmado()
    {
        showConfirm = false;
        if (aEliminar is null) return;
        var ok = await ApiService.DeleteAsync(aEliminar.Id);
        if (ok)
        {
            plantillas = await ApiService.GetAllAsync() ?? [];
            await toast.Show("Plantilla eliminada.");
        }
        else
        {
            await toast.Show("Error al eliminar.", "error");
        }
        aEliminar = null;
    }

    private async Task OnFirmaSeleccionada(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 2 * 1024 * 1024) { await toast.Show("La imagen no debe superar 2 MB.", "error"); return; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(ms);
        form.FirmaImagenBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private async Task OnDocxSeleccionado(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!file.Name.EndsWith(".docx", StringComparison.OrdinalIgnoreCase)) { await toast.Show("Solo se aceptan archivos .docx", "error"); return; }
        if (file.Size > 5 * 1024 * 1024) { await toast.Show("El archivo no debe superar 5 MB.", "error"); return; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);
        form.ArchivoDocxBase64 = Convert.ToBase64String(ms.ToArray());
    }

    private void ToggleArea(int areaId, bool checked_)
    {
        if (checked_) form.AreaIds.Add(areaId);
        else form.AreaIds.Remove(areaId);
    }

    private void ToggleVariableEditable(string key, bool checked_)
    {
        if (checked_) { if (!form.VariablesEditables.Contains(key)) form.VariablesEditables.Add(key); }
        else form.VariablesEditables.Remove(key);
    }

    private void MostrarVariables(PlantillaDocumentoDto p) { plantillaVariables = p; showVariables = true; }

    private void AgregarVariableCustom()
    {
        errorVariableCustom = string.Empty;
        var key = nuevaVariableCustom.Trim().ToLower().Replace(" ", "_");
        if (string.IsNullOrWhiteSpace(key)) return;
        if (!System.Text.RegularExpressions.Regex.IsMatch(key, @"^[a-z0-9_]+$"))
        {
            errorVariableCustom = "Solo letras, números y guión bajo.";
            return;
        }
        if (form.VariablesEditables.Contains(key))
        {
            errorVariableCustom = "Esa variable ya está en la lista.";
            return;
        }
        form.VariablesEditables.Add(key);
        nuevaVariableCustom = string.Empty;
    }

    private void OnNuevaVariableKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AgregarVariableCustom();
    }

    private static string Iniciales(string nombre)
    {
        var partes = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return partes.Length >= 2
            ? $"{partes[0][0]}{partes[1][0]}".ToUpper()
            : nombre.Length > 0 ? nombre[0].ToString().ToUpper() : "?";
    }
}
