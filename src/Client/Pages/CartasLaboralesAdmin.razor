            : nombre.Length > 0 ? nombre[0].ToString().ToUpper() : "?";
    }

    private static string EtiquetaVariableFriendly(string key)
    {
        var cleanKey = key.Trim().TrimStart('{').TrimEnd('}').Trim().ToLowerInvariant();
        return cleanKey switch
        {
            "destinatario"     => "Destinatario",
            "motivo"           => "Motivo",
            "entidad"          => "Entidad/Empresa",
