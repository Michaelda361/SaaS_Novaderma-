        busquedaColaboradorGenerar = string.Empty;
        if (!todosColaboradores.Any())
            todosColaboradores = await ColaboradorApi.GetAllAsync() ?? [];
        showGenerarPara = true;
    }

    private async Task DescargarParaColaborador()
    {
        if (plantillaGenerarPara is null || colaboradorGenerarId == 0) return;
        generandoPdf = true;
        StateHasChanged();

        var (bytes, fileName) = await ApiService.GenerarParaColaboradorAsync(
            plantillaGenerarPara.Id, colaboradorGenerarId);

        generandoPdf = false;

        if (bytes is null || bytes.Length == 0)
        {
            await toast.Show("Error al generar el PDF.", "error");
            StateHasChanged();
            return;
        }

        await JS.InvokeVoidAsync("descargarArchivo",
            Convert.ToBase64String(bytes), fileName, "application/pdf");
        showGenerarPara = false;
        await toast.Show("PDF generado y descargado.");
    }
}
