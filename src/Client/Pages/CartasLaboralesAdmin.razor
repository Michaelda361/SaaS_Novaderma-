            "cedula"           => "Cédula",
            "cargo"            => "Cargo",
            "area"             => "Área",
            "ciudad"           => "Ciudad",
            "fecha_expedicion" => "Fecha expedición",
            "tipo_contrato"    => "Tipo contrato",
            "fecha_ingreso"    => "Fecha ingreso",
            "sueldo_basico"    => "Sueldo básico",
            "genero"           => "Tratamiento género",
            "rol"              => "Rol",
            _                  => key.Replace("_", " "),
        };
    }

