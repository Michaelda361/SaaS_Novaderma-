@page "/cartas/admin"
@attribute [Authorize]
@inject PlantillaDocumentoApiService ApiService
@inject AreaApiService AreaApi

<Toast @ref="toast" />
<ConfirmDialog Visible="showConfirm"
               Message="@confirmMsg"
               OnConfirm="EliminarConfirmado"
               OnCancel="() => showConfirm = false" />

<div class="page-header">
    <div>
        <h2 class="page-title">Plantillas de Cartas Laborales</h2>
        <p class="page-subtitle">Gestiona las plantillas disponibles para los colaboradores</p>
    </div>
    <div class="flex gap-2">
        <a href="cartas" class="btn btn-ghost btn-sm">👁 Ver como colaborador</a>
        <button class="btn btn-primary" @onclick="AbrirNueva">+ Nueva plantilla</button>
    </div>
</div>

@if (cargando)
{
    <div class="loading"><div class="spinner"></div> Cargando...</div>
}
else if (!plantillas.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">📄</div>
        <h3>Sin plantillas</h3>
        <p>Crea la primera plantilla para que los colaboradores puedan descargar sus cartas.</p>
    </div>
}
else
{
    <div class="card">
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Firmante</th>
                        <th>Áreas</th>
                        <th>Variables disponibles</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in plantillas)
                    {
                        <tr>
                            <td>
                                <strong>@p.Nombre</strong>
                                @if (!string.IsNullOrWhiteSpace(p.Descripcion))
                                {
                                    <div class="text-muted text-sm">@p.Descripcion</div>
                                }
                            </td>
                            <td class="text-sm">
                                @(p.NombreFirmante ?? "—")
                                @if (!string.IsNullOrWhiteSpace(p.CargoFirmante))
                                {
                                    <div class="text-muted">@p.CargoFirmante</div>
                                }
                            </td>
                            <td>
                                @if (p.AplicaTodasAreas)
                                {
                                    <span class="badge badge-success">Todas</span>
                                }
                                else
                                {
                                    @foreach (var nombre in p.AreaNombres)
                                    {
                                        <span class="badge badge-info" style="margin:.1rem;">@nombre</span>
                                    }
                                }
                            </td>
                            <td>
                                <button class="btn btn-ghost btn-sm"
                                        @onclick="() => MostrarVariables()">
                                    Ver variables
                                </button>
                            </td>
                            <td>
                                <div class="flex gap-2">
                                    <button class="btn btn-ghost btn-sm btn-icon"
                                            @onclick="() => AbrirEditar(p)" title="Editar">✏️</button>
                                    <button class="btn btn-danger btn-sm btn-icon"
                                            @onclick="() => PedirConfirmacion(p)" title="Eliminar">🗑️</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal variables -->
@if (showVariables)
{
    <div class="modal-backdrop" @onclick="() => showVariables = false">
        <div class="modal" style="max-width:480px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Variables disponibles</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => showVariables = false">✕</button>
            </div>
            <div class="modal-body">
                <p class="text-muted" style="margin-bottom:1rem;">
                    Usa estas variables en el contenido HTML de la plantilla. Se reemplazarán automáticamente con los datos del colaborador.
                </p>
                <div class="variables-grid">
                    @foreach (var v in Variables)
                    {
                        <div class="variable-item">
                            <code class="variable-tag">@v.Key</code>
                            <span class="text-muted text-sm">@v.Value</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal crear/editar -->
@if (showModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal" style="max-width:720px;" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editandoId.HasValue ? "Editar plantilla" : "Nueva plantilla")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <EditForm Model="form" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-group">
                        <label>Nombre *</label>
                        <InputText @bind-Value="form.Nombre" placeholder="Ej: Carta de certificación laboral" />
                        <ValidationMessage For="() => form.Nombre" />
                    </div>
                    <div class="form-group">
                        <label>Descripción</label>
                        <InputText @bind-Value="form.Descripcion" placeholder="Descripción breve (opcional)" />
                    </div>
                    <div class="form-group">
                        <label>Tipo de plantilla</label>
                        <div class="flex gap-2">
                            <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                <input type="radio" name="tipo" value="html"
                                       checked="@(form.TipoPlantilla == "html")"
                                       @onchange='() => form.TipoPlantilla = "html"' />
                                Escribir en HTML
                            </label>
                            <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                <input type="radio" name="tipo" value="docx"
                                       checked="@(form.TipoPlantilla == "docx")"
                                       @onchange='() => form.TipoPlantilla = "docx"' />
                                Subir archivo Word (.docx)
                            </label>
                        </div>
                    </div>

                    @if (form.TipoPlantilla == "html")
                    {
                        <!-- Instructivo HTML -->
                        <div class="instructivo-box">
                            <button type="button" class="instructivo-toggle"
                                    @onclick="() => showInstructivoHtml = !showInstructivoHtml">
                                <span>💡 ¿Cómo usar variables en el editor HTML?</span>
                                <span>@(showInstructivoHtml ? "▲" : "▼")</span>
                            </button>
                            @if (showInstructivoHtml)
                            {
                                <div class="instructivo-body">
                                    <p>Escribe el contenido de la carta normalmente. Donde quieras insertar un dato del colaborador, usa una <strong>variable</strong> con el formato <code>&#123;&#123;nombre_variable&#125;&#125;</code>.</p>
                                    <p style="margin-top:.5rem;">Puedes hacer clic en cualquier variable del panel derecho del editor para insertarla en la posición del cursor.</p>
                                    <div class="instructivo-ejemplo">
                                        <div class="instructivo-ejemplo-label">Ejemplo de uso en el texto:</div>
                                        <code>
                                            La empresa certifica que <strong>&#123;&#123;nombre_completo&#125;&#125;</strong> identificado con cédula
                                            <strong>&#123;&#123;cedula&#125;&#125;</strong>, se desempeña en el cargo de <strong>&#123;&#123;cargo&#125;&#125;</strong>
                                            desde el <strong>&#123;&#123;fecha_ingreso&#125;&#125;</strong>.
                                        </code>
                                    </div>
                                    <p style="margin-top:.5rem;color:var(--text-muted);font-size:.8rem;">
                                        Al generar el PDF, cada variable se reemplaza automáticamente con los datos del perfil del colaborador que solicita la carta.
                                    </p>
                                </div>
                            }
                        </div>

                        <div class="form-group">
                            <label>Contenido de la carta</label>
                            <EditorPlantilla @bind-HtmlContent="form.ContenidoHtml" />
                        </div>
                    }
                    else
                    {
                        <!-- Instructivo DOCX -->
                        <div class="instructivo-box">
                            <button type="button" class="instructivo-toggle"
                                    @onclick="() => showInstructivoDocx = !showInstructivoDocx">
                                <span>💡 ¿Cómo preparar el archivo Word con variables?</span>
                                <span>@(showInstructivoDocx ? "▲" : "▼")</span>
                            </button>
                            @if (showInstructivoDocx)
                            {
                                <div class="instructivo-body">
                                    <ol class="instructivo-steps">
                                        <li>Abre tu documento Word (.docx) normalmente.</li>
                                        <li>
                                            Donde quieras que aparezca un dato del colaborador, escribe la variable
                                            con doble llave: <code>&#123;&#123;nombre_variable&#125;&#125;</code>
                                        </li>
                                        <li>
                                            <strong>Importante:</strong> escribe la variable completa de un solo trazo,
                                            sin interrupciones. Si copias y pegas partes, Word puede dividirla en
                                            fragmentos internos y no se reemplazará correctamente.
                                        </li>
                                        <li>Guarda el archivo como <strong>.docx</strong> (no .doc ni .pdf).</li>
                                        <li>Sube el archivo aquí y el sistema reemplazará las variables al generar cada carta.</li>
                                    </ol>
                                    <div class="instructivo-ejemplo">
                                        <div class="instructivo-ejemplo-label">Variables disponibles para usar en Word:</div>
                                        <div style="display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.4rem;">
                                            @foreach (var v in Variables)
                                            {
                                                <span style="display:inline-flex;align-items:center;gap:.3rem;background:var(--bg-secondary);border:1px solid var(--border);border-radius:4px;padding:.15rem .4rem;font-size:.75rem;">
                                                    <code>@v.Key</code>
                                                    <span class="text-muted">@v.Value</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    <p style="margin-top:.75rem;color:var(--warning, #b45309);font-size:.8rem;background:var(--warning-bg, #fef3c7);padding:.5rem .75rem;border-radius:6px;">
                                        ⚠️ Si una variable no se reemplaza, verifica que esté escrita exactamente igual (incluyendo las llaves dobles y sin espacios extra).
                                    </p>
                                </div>
                            }
                        </div>

                        <div class="form-group">
                            <label>Archivo Word (.docx) *</label>
                            <InputFile OnChange="OnDocxSeleccionado" accept=".docx" />
                            @if (!string.IsNullOrWhiteSpace(form.ArchivoDocxBase64))
                            {
                                <small class="text-muted">✅ Archivo cargado correctamente</small>
                            }
                        </div>
                    }

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Nombre del firmante</label>
                            <InputText @bind-Value="form.NombreFirmante" placeholder="Ej: Francy Gutiérrez Ramírez" />
                        </div>
                        <div class="form-group">
                            <label>Cargo del firmante</label>
                            <InputText @bind-Value="form.CargoFirmante" placeholder="Ej: Director de Recursos Humanos" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Firma (imagen)</label>
                        <InputFile OnChange="OnFirmaSeleccionada" accept="image/*" />
                        @if (!string.IsNullOrWhiteSpace(form.FirmaImagenBase64))
                        {
                            <div style="margin-top:.5rem;">
                                <img src="@form.FirmaImagenBase64" alt="Firma"
                                     style="max-height:80px;border:1px solid var(--border);border-radius:4px;padding:4px;" />
                                <button type="button" class="btn btn-ghost btn-sm"
                                        @onclick="() => form.FirmaImagenBase64 = null">
                                    Quitar firma
                                </button>
                            </div>
                        }
                    </div>

                    <div class="form-group">
                        <label>Disponible para</label>
                        <div class="flex gap-2" style="margin-bottom:.5rem;">
                            <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                <input type="checkbox" @bind="form.AplicaTodasAreas" />
                                Todas las áreas
                            </label>
                        </div>
                        @if (!form.AplicaTodasAreas)
                        {
                            <div class="areas-check-list">
                                @foreach (var area in areas)
                                {
                                    var areaId = area.Id;
                                    <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                        <input type="checkbox"
                                               checked="@form.AreaIds.Contains(areaId)"
                                               @onchange="e => ToggleArea(areaId, (bool)e.Value!)" />
                                        @area.Nombre
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class="form-group">
                        <label>
                            Campos editables por el colaborador
                            <span class="text-muted text-sm" style="font-weight:400;margin-left:.25rem;">
                                — el colaborador podrá personalizar estos valores antes de descargar
                            </span>
                        </label>
                        <div class="areas-check-list">
                            @foreach (var v in VariablesEditablesOpciones)
                            {
                                var key = v.Key;
                                <label style="display:flex;align-items:center;gap:.4rem;cursor:pointer;">
                                    <input type="checkbox"
                                           checked="@form.VariablesEditables.Contains(key)"
                                           @onchange="e => ToggleVariableEditable(key, (bool)e.Value!)" />
                                    <code style="font-size:.8rem;">@("{{" + key + "}}")</code>
                                    <span class="text-muted text-sm">@v.Value</span>
                                </label>
                            }
                        </div>
                        <small class="text-muted">
                            Las variables no marcadas se rellenan automáticamente con los datos del perfil.
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private Toast toast = null!;
    private List<PlantillaDocumentoDto> plantillas = [];
    private List<AreaDto> areas = [];
    private bool cargando = true;
    private bool showModal = false;
    private bool showVariables = false;
    private bool showConfirm = false;
    private bool guardando = false;
    private bool showInstructivoHtml = false;
    private bool showInstructivoDocx = true; // abierto por defecto en docx
    private int? editandoId;
    private string confirmMsg = string.Empty;
    private PlantillaDocumentoDto? aEliminar;

    private CreatePlantillaDocumentoDto form = new();

    private static readonly Dictionary<string, string> Variables = new()
    {
        ["{{nombre_completo}}"]  = "Nombre y apellido del colaborador",
        ["{{nombre}}"]           = "Nombre",
        ["{{apellido}}"]         = "Apellido",
        ["{{cedula}}"]           = "Número de cédula",
        ["{{cargo}}"]            = "Cargo actual",
        ["{{area}}"]             = "Área / departamento",
        ["{{fecha_ingreso}}"]    = "Fecha de ingreso (texto)",
        ["{{tipo_contrato}}"]    = "Tipo de contrato",
        ["{{sueldo_basico}}"]    = "Sueldo básico formateado",
        ["{{ciudad}}"]           = "Ciudad",
        ["{{fecha_expedicion}}"] = "Fecha de hoy (texto)",
        ["{{nombre_firmante}}"]  = "Nombre del firmante",
        ["{{cargo_firmante}}"]   = "Cargo del firmante",
    };

    // Variables que el admin puede marcar como editables por el colaborador
    private static readonly Dictionary<string, string> VariablesEditablesOpciones = new()
    {
        ["destinatario"]     = "A quién va dirigida la carta",
        ["motivo"]           = "Motivo o propósito de la carta",
        ["entidad"]          = "Entidad o empresa destinataria",
        ["nombre_completo"]  = "Nombre completo (si el colaborador quiere ajustarlo)",
        ["cargo"]            = "Cargo (si difiere del perfil)",
        ["ciudad"]           = "Ciudad de expedición",
        ["fecha_expedicion"] = "Fecha de expedición",
    };

    protected override async Task OnInitializedAsync()
    {
        var t1 = ApiService.GetAllAsync();
        var t2 = AreaApi.GetAllAsync();
        await Task.WhenAll(t1, t2);
        plantillas = t1.Result ?? [];
        areas = t2.Result ?? [];
        cargando = false;
    }

    private void AbrirNueva()
    {
        form = new CreatePlantillaDocumentoDto();
        editandoId = null;
        showInstructivoHtml = false;
        showInstructivoDocx = true;
        showModal = true;
    }

    private void AbrirEditar(PlantillaDocumentoDto p)
    {
        form = new CreatePlantillaDocumentoDto
        {
            Nombre = p.Nombre,
            Descripcion = p.Descripcion,
            TipoPlantilla = p.TipoPlantilla,
            ContenidoHtml = p.ContenidoHtml,
            FirmaImagenBase64 = p.FirmaImagenBase64,
            NombreFirmante = p.NombreFirmante,
            CargoFirmante = p.CargoFirmante,
            AplicaTodasAreas = p.AplicaTodasAreas,
            AreaIds = [..p.AreaIds],
            VariablesEditables = [..p.VariablesEditables],
        };
        editandoId = p.Id;
        showModal = true;
    }

    private void CerrarModal()
    {
        showModal = false;
        form = new();
        editandoId = null;
    }

    private async Task Guardar()
    {
        guardando = true;
        bool ok;
        if (editandoId.HasValue)
            ok = await ApiService.UpdateAsync(editandoId.Value, form) is not null;
        else
            ok = await ApiService.CreateAsync(form) is not null;
        guardando = false;

        if (ok)
        {
            CerrarModal();
            plantillas = await ApiService.GetAllAsync() ?? [];
            await toast.Show(editandoId.HasValue ? "Plantilla actualizada." : "Plantilla creada.");
        }
        else
        {
            await toast.Show("Error al guardar la plantilla.", "error");
        }
    }

    private void PedirConfirmacion(PlantillaDocumentoDto p)
    {
        aEliminar = p;
        confirmMsg = $"¿Eliminar la plantilla \"{p.Nombre}\"?";
        showConfirm = true;
    }

    private async Task EliminarConfirmado()
    {
        showConfirm = false;
        if (aEliminar is null) return;
        var ok = await ApiService.DeleteAsync(aEliminar.Id);
        if (ok)
        {
            plantillas = await ApiService.GetAllAsync() ?? [];
            await toast.Show("Plantilla eliminada.");
        }
        else
        {
            await toast.Show("Error al eliminar.", "error");
        }
        aEliminar = null;
    }

    private async Task OnFirmaSeleccionada(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 2 * 1024 * 1024)
        {
            await toast.Show("La imagen no debe superar 2 MB.", "error");
            return;
        }
        using var ms = new MemoryStream();
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        form.FirmaImagenBase64 = $"data:{file.ContentType};base64,{base64}";
    }

    private async Task OnDocxSeleccionado(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!file.Name.EndsWith(".docx", StringComparison.OrdinalIgnoreCase))
        {
            await toast.Show("Solo se aceptan archivos .docx", "error");
            return;
        }
        if (file.Size > 5 * 1024 * 1024)
        {
            await toast.Show("El archivo no debe superar 5 MB.", "error");
            return;
        }
        using var ms = new MemoryStream();
        await file.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);
        form.ArchivoDocxBase64 = Convert.ToBase64String(ms.ToArray());
    }

    private void ToggleArea(int areaId, bool checked_)
    {
        if (checked_) form.AreaIds.Add(areaId);
        else form.AreaIds.Remove(areaId);
    }

    private void ToggleVariableEditable(string key, bool checked_)
    {
        if (checked_) { if (!form.VariablesEditables.Contains(key)) form.VariablesEditables.Add(key); }
        else form.VariablesEditables.Remove(key);
    }

    private void MostrarVariables() => showVariables = true;
}
