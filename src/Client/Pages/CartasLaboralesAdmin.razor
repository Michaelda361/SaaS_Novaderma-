            if (missingFields.Any())
            {
                await toast.Show($"⚠️ Falta completar variables obligatorias: {string.Join(", ", missingFields)}", "warning");
                return;
            }
        }

        resolviendo = true;
        StateHasChanged();

        var dto = new ResolverSolicitudDto 
        { 
            Comentario = comentarioResolucion,
            VariablesAprobador = variablesAprobadorModel
        };
        var resultado = accionResolucion == "aprobar"
            ? await ApiService.AprobarAsync(solicitudResolviendo.Id, dto)
            : await ApiService.RechazarAsync(solicitudResolviendo.Id, dto);

        resolviendo = false;

        if (resultado is null)
