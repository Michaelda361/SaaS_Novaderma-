    private string GenerarVariableInterna(string nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return string.Empty;
        
        // Normalizar y remover acentos
        var normalized = nombre.Normalize(System.Text.NormalizationForm.FormD);
        var sb = new System.Text.StringBuilder();
        foreach (var c in normalized)
        {
            var unicodeCategory = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c);
            if (unicodeCategory != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                sb.Append(c);
            }
        }
        var clean = sb.ToString();
        
        // Separar por espacios, guiones bajos o medios, y capitalizar cada palabra
        var parts = clean.Split(new[] { ' ', '_', '-' }, StringSplitOptions.RemoveEmptyEntries);
        var result = new System.Text.StringBuilder();
        foreach (var part in parts)
        {
            if (part.Length > 0)
            {
                result.Append(char.ToUpper(part[0]));
                if (part.Length > 1)
                {
                    var cleanPart = new string(part.Skip(1).Where(char.IsLetterOrDigit).ToArray());
                    result.Append(cleanPart);
                }
            }
        }
        
        var finalStr = result.ToString();
        finalStr = new string(finalStr.Where(char.IsLetterOrDigit).ToArray());
        return finalStr;
    }

    private void AbrirAgregarCampo(string diligenciadoPor)
    {
        subModalNombre = string.Empty;
        subModalTipo = "Texto corto";
        subModalObligatorio = true;
        subModalOpciones = string.Empty;
        subModalDiligenciadoPor = diligenciadoPor;
        subModalEditandoIndex = null;
        showSubModal = true;
