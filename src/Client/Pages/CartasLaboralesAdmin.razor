    private static string TiempoRelativo(DateTime fecha)
    {
        var diff = DateTime.UtcNow - fecha.ToUniversalTime();
        if (diff.TotalMinutes < 1)   return "hace un moment";
        if (diff.TotalMinutes < 60)  return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24)    return $"hace {(int)diff.TotalHours} h";
        if (diff.TotalDays < 7)      return $"hace {(int)diff.TotalDays} día(s)";
        return fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

