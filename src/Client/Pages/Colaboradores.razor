@page "/colaboradores"
@attribute [PageTitle("Colaboradores")]
@attribute [Authorize]
@using TalentManagement.Client.Components
@inject ColaboradorApiService ApiService
@inject ColaboradorCampoApiService CampoApiService
@inject AreaApiService AreaService
@inject CargoApiService CargoService
@inject AuthInfoService AuthInfo

<Toast @ref="toast" />
<ConfirmDialog Visible="confirmVisible"
               Message="@confirmMensaje"
               OnConfirm="ConfirmarEliminar"
               OnCancel="CancelarEliminar" />

<!-- Pestañas: Colaboradores | Áreas | Cargos -->
<div style='display:flex;gap:.5rem;margin-bottom:1rem;align-items:center;'>
    <button class='btn btn-sm @(activeTab == "colaboradores" ? "btn-primary" : "btn-ghost")' @onclick='() => SelectTab("colaboradores")'>Colaboradores</button>
    @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
    {
        <button class='btn btn-sm @(activeTab == "areas" ? "btn-primary" : "btn-ghost")' @onclick='() => SelectTab("areas")'>Áreas</button>
        <button class='btn btn-sm @(activeTab == "cargos" ? "btn-primary" : "btn-ghost")' @onclick='() => SelectTab("cargos")'>Cargos</button>
    }
    @if (AuthInfo.EsAdmin)
    {
        <button class='btn btn-sm @(activeTab == "campos" ? "btn-primary" : "btn-ghost")' @onclick='() => SelectTab("campos")'>Ficha</button>
    }
</div>

@if (activeTab == "areas")
{
    <AreasManagement />
}
else if (activeTab == "cargos")
{
    <CargosManagement />
}
else if (activeTab == "campos")
{
    <ColaboradorFieldConfig />
}
else
{
<div class="card">
    <div class="card-header">
        <span class="card-title">Colaboradores</span>
        @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
        {
            <button class="btn btn-primary btn-sm" @onclick="AbrirModal">+ Nuevo colaborador</button>
        }
    </div>

    <!-- Tabs activos / inactivos -->
    <div style="display:flex;gap:.5rem;padding:.75rem 1rem .25rem;border-bottom:1px solid var(--border);">
        <button class="btn btn-sm @(mostrarInactivos ? "btn-ghost" : "btn-primary")"
                @onclick="() => { mostrarInactivos = false; }">
            Activos @(colaboradores is not null ? $"({colaboradores.Count})" : "")
        </button>
        <button class="btn btn-sm @(mostrarInactivos ? "btn-primary" : "btn-ghost")"
                @onclick="CargarInactivos">
            🗑 Inactivos @(inactivos is not null ? $"({inactivos.Count})" : "")
        </button>
    </div>

    <!-- Search bar -->
    <div class="filter-bar">
        <div class="search-input-wrap">
            <span class="search-icon">🔍</span>
            <input type="search" placeholder="Buscar por nombre o email..."
                   @bind="busqueda" @bind:event="oninput" />
        </div>
        <select @bind="filtroAreaId" style="min-width:160px;">
            <option value="0">Todas las áreas</option>
            @foreach (var a in areas ?? [])
            {
                <option value="@a.Id">@a.Nombre</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(busqueda) || filtroAreaId > 0)
        {
            <span class="text-sm text-muted">@ColaboradoresFiltrados.Count resultado(s)</span>
            <button class="btn btn-ghost btn-sm" @onclick="LimpiarFiltros">✕ Limpiar</button>
        }
    </div>

    @if (mostrarInactivos)
    {
        @if (cargandoInactivos)
        {
            <div class="loading"><div class="spinner"></div> Cargando...</div>
        }
        else if (!inactivos?.Any() ?? true)
        {
            <div class="empty-state">
                <div class="empty-state-icon">✅</div>
                <h3>Sin inactivos</h3>
                <p>No hay colaboradores eliminados.</p>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr><th>Colaborador</th><th>Cargo</th><th>Área</th><th>Género</th><th>Salida</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in inactivos!)
                        {
                            var cid = c.Id;
                            <tr style="opacity:.7;">
                                <td>
                                    <div class="user-cell">
                                        <div class="avatar">@Iniciales(c.Nombre, c.Apellido)</div>
                                        <div>
                                            <div class="user-name">@c.NombreCompleto</div>
                                            <div class="user-email">@c.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-sm">@c.CargoNombre</td>
                                <td><span class="badge badge-gray">@c.AreaNombre</span></td>
                                <td class="text-sm text-muted">@ColaboradorGeneroUi.Etiqueta(c.Genero)</td>
                                <td class="text-muted text-sm">@c.FechaSalida?.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <button class="btn btn-ghost btn-sm"
                                            @onclick="() => RestaurarColaborador(cid)">
                                        ♻️ Restaurar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {

    @if (cargando)
    {
        <div class="loading"><div class="spinner"></div> Cargando...</div>
    }
    else if (colaboradores is null || colaboradores.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">👥</div>
            <h3>Sin colaboradores</h3>
            <p>Agrega el primer colaborador para comenzar.</p>
        </div>
    }
    else if (ColaboradoresFiltrados.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">🔍</div>
            <h3>Sin resultados</h3>
            <p>No hay colaboradores que coincidan con los filtros aplicados.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Colaborador</th>
                        <th>Cargo</th>
                        <th>Área</th>
                        <th>Género</th>
                        <th>Ingreso</th>
                        <th>Rol</th>
                        @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
                        {
                            <th></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in ColaboradoresFiltrados)
                    {
                        var cid = c.Id;
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="avatar">@Iniciales(c.Nombre, c.Apellido)</div>
                                    <div>
                                        <div class="user-name">@c.NombreCompleto</div>
                                        <div class="user-email">@c.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-sm">@c.CargoNombre</td>
                            <td><span class="badge badge-info">@c.AreaNombre</span></td>
                            <td class="text-sm text-muted">@ColaboradorGeneroUi.Etiqueta(c.Genero)</td>
                            <td class="text-muted text-sm">@c.FechaIngreso.ToString("dd/MM/yyyy")</td>
                            <td>
                                <select class="rol-selector rol-selector--@c.Rol.ToLower()"
                                        value="@c.Rol"
                                        disabled="@(!AuthInfo.EsAdmin)"
                                        @onchange="async e => await CambiarRol(cid, e.Value?.ToString() ?? c.Rol)">
                                    <option value="Colaborador">👤 Colaborador</option>
                                    <option value="Jefe">👔 Jefe</option>
                                    <option value="Admin">🔑 Admin</option>
                                </select>
                            </td>
                            @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
                            {
                                <td>
                                    <div class="flex gap-2">
                                        <button class="btn btn-ghost btn-sm btn-icon"
                                                @onclick="() => AbrirEditar(c)" title="Editar">✏️</button>
                                        <button class="btn btn-danger btn-sm btn-icon"
                                                @onclick="() => PedirConfirmacion(c)" title="Eliminar">🗑️</button>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    } @* cierre else (activos) *@
</div>

}

@if (mostrarModal)
{
    <div class="modal-backdrop">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editandoId.HasValue ? "Editar colaborador" : "Nuevo colaborador")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <EditForm Model="form" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-grid">
                        @foreach (var campo in GetMergedCampos())
                        {
                            if (campo.CampoClave == "FechaSalida" && !editandoId.HasValue) continue;
                            if (campo.CampoClave == "AuxMediosTransporte" || campo.CampoClave == "ComisionVentas" || campo.CampoClave == "ComisionCobros") continue;
                            <div class="form-group">
                                <label>@campo.Nombre@if (campo.Requerido) { <span class="text-danger">*</span> }</label>

                                @if (campo.CampoClave == "Nombre")
                                {
                                    <InputText @bind-Value="form.Nombre" />
                                    <ValidationMessage For="() => form.Nombre" class="validation-message" />
                                }
                                else if (campo.CampoClave == "Apellido")
                                {
                                    <InputText @bind-Value="form.Apellido" />
                                    <ValidationMessage For="() => form.Apellido" class="validation-message" />
                                }
                                else if (campo.CampoClave == "Email")
                                {
                                    <InputText @bind-Value="form.Email" />
                                    <ValidationMessage For="() => form.Email" class="validation-message" />
                                }
                                else if (campo.CampoClave == "FechaIngreso")
                                {
                                    <InputDate @bind-Value="form.FechaIngreso" />
                                }
                                else if (campo.CampoClave == "Cedula")
                                {
                                    <InputText @bind-Value="form.Cedula" />
                                }
                                else if (campo.CampoClave == "FechaExpedicion")
                                {
                                    <InputDate @bind-Value="form.FechaExpedicion" />
                                }
                                else if (campo.CampoClave == "FechaNacimiento")
                                {
                                    <InputDate @bind-Value="form.FechaNacimiento" />
                                }
                                else if (campo.CampoClave == "LugarNacimiento")
                                {
                                    <InputText @bind-Value="form.LugarNacimiento" />
                                }
                                else if (campo.CampoClave == "TipoContrato")
                                {
                                    <InputSelect @bind-Value="form.TipoContrato">
                                        <option value="">-- Selecciona --</option>
                                        <option value="término indefinido">Término indefinido</option>
                                        <option value="término fijo">Término fijo</option>
                                        <option value="obra o labor">Obra o labor</option>
                                        <option value="prestación de servicios">Prestación de servicios</option>
                                    </InputSelect>
                                }
                                else if (campo.CampoClave == "SueldoBasico")
                                {
                                    <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.SueldoBasico)" @onchange="@(e => form.SueldoBasico = NumberFormatHelper.ParseDecimal(e.Value?.ToString()))" />
                                }
                                else if (campo.CampoClave == "SubTransporte")
                                {
                                    <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.SubTransporte)" @onchange="@(e => form.SubTransporte = NumberFormatHelper.ParseDecimal(e.Value?.ToString()))" />
                                }
                                else if (campo.CampoClave == "AuxMediosTransporte")
                                {
                                    <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.AuxMediosTransporte)" disabled />
                                }
                                else if (campo.CampoClave == "AuxTransporte")
                                {
                                    <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.AuxTransporte)" @onchange="@(e => form.AuxTransporte = NumberFormatHelper.ParseDecimal(e.Value?.ToString()))" />
                                }
                                else if (campo.CampoClave == "ComisionVentas")
                                {
                                    <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.ComisionVentas)" disabled />
                                }
                                else if (campo.CampoClave == "ComisionCobros")
                                {
                                    <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.ComisionCobros)" disabled />
                                }
                                else if (campo.CampoClave == "TotalSalario")
                                {
                                     var total = (form.SueldoBasico ?? 0m) + (form.SubTransporte ?? 0m) + (form.AuxMediosTransporte ?? 0m) + (form.ComisionVentas ?? 0m) + (form.ComisionCobros ?? 0m);
                                    <input type="text" class="form-control" value="@total.ToString("C0", new System.Globalization.CultureInfo("es-CO"))" disabled style="font-weight:600;" />
                                }
                                else if (campo.CampoClave == "FechaSalida")
                                {
                                    <input type="date" class="form-control" value="@form.FechaSalida?.ToString("yyyy-MM-dd")" disabled />
                                }
                                else if (campo.CampoClave == "Genero")
                                {
                                    <InputSelect @bind-Value="form.Genero">
                                        <option value="NoInformado">Sin especificar</option>
                                        <option value="Masculino">Masculino</option>
                                        <option value="Femenino">Femenino</option>
                                        <option value="OtroOPrefieroNoDecir">Otro / Prefiero no decir</option>
                                    </InputSelect>
                                }
                                else if (campo.CampoClave == "AreaNombre")
                                {
                                    <InputSelect @bind-Value="form.AreaId" @bind-Value:after="OnAreaChanged">
                                        <option value="0">-- Selecciona un área --</option>
                                        @foreach (var a in areas ?? [])
                                        {
                                            <option value="@a.Id">@a.Nombre</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => form.AreaId" class="validation-message" />
                                }
                                else if (campo.CampoClave == "CargoNombre")
                                {
                                    <InputSelect @bind-Value="form.CargoId">
                                        <option value="0">-- Selecciona un cargo --</option>
                                        @foreach (var c in cargosFiltrados ?? [])
                                        {
                                            <option value="@c.Id">@c.Nombre</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="() => form.CargoId" class="validation-message" />
                                }
                                else
                                {
                                    @* Dynamic custom field *@
                                    @if (campo.Tipo == "Seleccion")
                                    {
                                        <select class="form-control" value="@GetCampoValor(campo.CampoClave)" @onchange="@(e => SetCampoValor(campo.CampoClave, e.Value?.ToString()))">
                                            <option value="">-- Selecciona --</option>
                                            @foreach (var opcion in campo.Opciones?.Split(',').Select(o => o.Trim()).Where(o => !string.IsNullOrWhiteSpace(o)) ?? Enumerable.Empty<string>())
                                            {
                                                <option value="@opcion">@opcion</option>
                                            }
                                        </select>
                                    }
                                    else if (campo.Tipo == "Fecha")
                                    {
                                        <input type="date" class="form-control" value="@GetCampoValor(campo.CampoClave)" @onchange="@(e => SetCampoValor(campo.CampoClave, e.Value?.ToString()))" />
                                    }
                                    else if (campo.Tipo == "Numero")
                                    {
                                        <input type="text" class="form-control" value="@NumberFormatHelper.FormatDynamicNumber(GetCampoValor(campo.CampoClave))" @onchange="@(e => SetCampoValor(campo.CampoClave, NumberFormatHelper.CleanDynamicNumber(e.Value?.ToString())))" />
                                    }
                                    else
                                    {
                                        <input type="text" class="form-control" value="@GetCampoValor(campo.CampoClave)" @onchange="@(e => SetCampoValor(campo.CampoClave, e.Value?.ToString()))" />
                                    }
                                }

                            </div>
                        }
                    </div>

                    <div style="margin-top: 1.5rem; padding: 1.25rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); border-left: 4px solid #10b981;">
                        <h4 style="margin-top: 0; margin-bottom: 0.75rem; font-size: 0.95rem; font-weight: 600; color: #065f46;">💰 Cobros Especiales (Bloqueados en Ficha)</h4>
                        <div class="form-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 0;">
                            <div class="form-group" style="margin-bottom: 0;">
                                <label>Auxilio de medios de transporte</label>
                                <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.AuxMediosTransporte)" disabled />
                            </div>
                            <div class="form-group" style="margin-bottom: 0;">
                                <label>Comisión de ventas</label>
                                <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.ComisionVentas)" disabled />
                            </div>
                            <div class="form-group" style="margin-bottom: 0;">
                                <label>Comisión de cobros</label>
                                <input type="text" class="form-control" value="@NumberFormatHelper.FormatDecimal(form.ComisionCobros)" disabled />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<ColaboradorDto>? colaboradores;
    private string activeTab = "colaboradores";
    private List<AreaDto>? areas;
    private List<CargoDto>? todosLosCargos;
    private List<ColaboradorCampoDto>? camposDefinidos;
    private List<CargoDto>? cargosFiltrados;
    private bool cargando = true;
    private bool mostrarModal = false;
    private bool guardando = false;
    private int? editandoId = null;
    private string busqueda = string.Empty;
    private int filtroAreaId = 0;
    private Toast toast = default!;

    // Inactivos
    private List<ColaboradorDto>? inactivos;
    private bool mostrarInactivos = false;
    private bool cargandoInactivos = false;

    // Confirm dialog state
    private bool confirmVisible = false;
    private int eliminandoId;
    private string eliminandoNombre = string.Empty;
    private string confirmMensaje = string.Empty;

    private CreateColaboradorDto form = new();

    private List<ColaboradorDto> ColaboradoresFiltrados =>
        (colaboradores ?? [])
            .Where(c => filtroAreaId == 0 || c.AreaId == filtroAreaId)
            .Where(c => string.IsNullOrWhiteSpace(busqueda) ||
                        c.NombreCompleto.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
                        c.Email.Contains(busqueda, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private void LimpiarFiltros()
    {
        busqueda = string.Empty;
        filtroAreaId = 0;
    }

    private void SelectTab(string tab) => activeTab = tab;

    protected override async Task OnInitializedAsync()
    {
        var t1 = ApiService.GetAllAsync();
        var t2 = AreaService.GetAllAsync();
        var t3 = CargoService.GetAllAsync();
        var t4 = CampoApiService.GetAllAsync();
        await Task.WhenAll(t1, t2, t3, t4);
        colaboradores = t1.Result;
        areas = t2.Result;
        todosLosCargos = t3.Result;
        camposDefinidos = t4.Result;
        cargando = false;
    }

    private async Task Cargar()
    {
        cargando = true;
        var t1 = ApiService.GetAllAsync();
        var t2 = CampoApiService.GetAllAsync();
        await Task.WhenAll(t1, t2);
        colaboradores = t1.Result;
        camposDefinidos = t2.Result;
        cargando = false;
    }

    private readonly (string Clave, string Nombre, int Orden)[] standardCampos = new[] {
        ("Nombre", "Nombre", 10),
        ("Apellido", "Apellido", 20),
        ("Email", "Email", 30),
        ("FechaIngreso", "Fecha de ingreso", 40),
        ("Cedula", "Cédula", 50),
        ("FechaExpedicion", "Fecha de expedición", 60),
        ("FechaNacimiento", "Fecha de nacimiento", 70),
        ("LugarNacimiento", "Lugar de nacimiento", 80),
        ("TipoContrato", "Tipo de contrato", 90),
        ("SueldoBasico", "Salario", 110),
        ("SubTransporte", "Subsidio de transporte", 120),
        ("AuxMediosTransporte", "Auxilio de medios de transporte", 130),
        ("ComisionVentas", "Comisión de ventas", 140),
        ("ComisionCobros", "Comisión de cobros", 150),
        ("TotalSalario", "Total salario", 155),
        ("FechaSalida", "Fecha de salida", 160),
        ("Genero", "Género", 170),
        ("AreaNombre", "Área", 180),
        ("CargoNombre", "Cargo", 190)
    };

    private List<ColaboradorCampoDto> GetMergedCampos()
    {
        var definiciones = camposDefinidos ?? new List<ColaboradorCampoDto>();
        var merged = new List<ColaboradorCampoDto>();
        foreach (var s in standardCampos)
        {
            var existing = definiciones.FirstOrDefault(d => string.Equals(d.CampoClave, s.Clave, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
                merged.Add(existing);
            else
                merged.Add(new ColaboradorCampoDto { Id = 0, CampoClave = s.Clave, Nombre = s.Nombre, Tipo = "Texto", Requerido = false, Orden = s.Orden });
        }

        var custom = definiciones.Where(d => !standardCampos.Any(s => string.Equals(s.Clave, d.CampoClave, StringComparison.OrdinalIgnoreCase)))
                                .OrderBy(d => d.Orden);
        merged.AddRange(custom);
        return merged.OrderBy(c => c.Orden).ToList();
    }

    private async Task OnAreaChanged()
    {
        cargosFiltrados = form.AreaId > 0
            ? await CargoService.GetByAreaAsync(form.AreaId)
            : todosLosCargos;
        form.CargoId = 0;
    }

    private void InicializarCamposAdicionales()
    {
        if (form.CamposAdicionales is null)
            form.CamposAdicionales = new Dictionary<string, string?>();

        if (camposDefinidos is null) return;
        foreach (var campo in camposDefinidos)
        {
            if (!form.CamposAdicionales.ContainsKey(campo.CampoClave))
                form.CamposAdicionales[campo.CampoClave] = null;
        }
    }

    private void AbrirModal()
    {
        form = new CreateColaboradorDto { FechaIngreso = DateTime.Today, CamposAdicionales = new Dictionary<string, string?>() };
        cargosFiltrados = todosLosCargos;
        editandoId = null;
        InicializarCamposAdicionales();
        mostrarModal = true;
    }

    private async Task AbrirEditar(ColaboradorDto c)
    {
        var collaborator = await ApiService.GetByIdAsync(c.Id);
        if (collaborator is null) return;

        form = new CreateColaboradorDto
        {
            Nombre = collaborator.Nombre,
            Apellido = collaborator.Apellido,
            Email = collaborator.Email,
            FechaIngreso = collaborator.FechaIngreso,
            AreaId = collaborator.AreaId,
            CargoId = collaborator.CargoId,
            Cedula = collaborator.Cedula,
            FechaExpedicion = collaborator.FechaExpedicion,
            FechaNacimiento = collaborator.FechaNacimiento,
            LugarNacimiento = collaborator.LugarNacimiento,
            TipoContrato = collaborator.TipoContrato,
            SueldoBasico = collaborator.SueldoBasico,
            SubTransporte = collaborator.SubTransporte,
            AuxMediosTransporte = collaborator.AuxMediosTransporte,
            ComisionVentas = collaborator.ComisionVentas,
            ComisionCobros = collaborator.ComisionCobros,
            FechaSalida = collaborator.FechaSalida,
            Genero = collaborator.Genero,
            CamposAdicionales = collaborator.CamposAdicionales ?? new Dictionary<string, string?>()
        };

        cargosFiltrados = todosLosCargos?.Where(x => x.AreaId == collaborator.AreaId).ToList() ?? todosLosCargos;
        editandoId = c.Id;
        InicializarCamposAdicionales();
        mostrarModal = true;
    }

    private string? GetCampoValor(string clave)
    {
        if (form.CamposAdicionales is null) return null;
        return form.CamposAdicionales.TryGetValue(clave, out var valor) ? valor : null;
    }

    private void SetCampoValor(string clave, string? valor)
    {
        if (form.CamposAdicionales is null)
            form.CamposAdicionales = new Dictionary<string, string?>();

        form.CamposAdicionales[clave] = valor;
    }

    private void CerrarModal() => mostrarModal = false;

    private async Task Guardar()
    {
        guardando = true;
        try
        {
            bool ok;
            if (editandoId.HasValue)
            {
                var dto = new UpdateColaboradorDto
                {
                    Nombre = form.Nombre,
                    Apellido = form.Apellido,
                    Email = form.Email,
                    AreaId = form.AreaId,
                    CargoId = form.CargoId,
                    Cedula = form.Cedula,
                    FechaExpedicion = form.FechaExpedicion,
                    FechaNacimiento = form.FechaNacimiento,
                    LugarNacimiento = form.LugarNacimiento,
                    TipoContrato = form.TipoContrato,
                    SueldoBasico = form.SueldoBasico,
                    SubTransporte = form.SubTransporte,
                    AuxMediosTransporte = form.AuxMediosTransporte,
                    ComisionVentas = form.ComisionVentas,
                    ComisionCobros = form.ComisionCobros,
                    Genero = form.Genero,
                    CamposAdicionales = form.CamposAdicionales
                };
                ok = await ApiService.UpdateAsync(editandoId.Value, dto) is not null;
            }
            else
            {
                ok = await ApiService.CreateAsync(form) is not null;
            }

            if (ok)
            {
                CerrarModal();
                await Cargar();
                await toast.Show(editandoId.HasValue ? "Colaborador actualizado." : "Colaborador creado.");
            }
            else
            {
                await toast.Show("Error al guardar. Verifica los datos.", "error");
            }
        }
        catch (InvalidOperationException ex)
        {
            await toast.Show(ex.Message, "error");
        }
        finally
        {
            guardando = false;
        }
    }

    private void PedirConfirmacion(ColaboradorDto c)
    {
        eliminandoId = c.Id;
        eliminandoNombre = c.NombreCompleto;
        confirmMensaje = $"¿Seguro que deseas eliminar a {c.NombreCompleto}? Esta acción no se puede deshacer.";
        confirmVisible = true;
    }

    private async Task ConfirmarEliminar()
    {
        confirmVisible = false;
        if (await ApiService.DeleteAsync(eliminandoId))
        {
            await Cargar();
            await toast.Show("Colaborador eliminado.");
        }
        else
        {
            await toast.Show("No se pudo eliminar.", "error");
        }
    }

    private void CancelarEliminar() => confirmVisible = false;

    private async Task CambiarRol(int id, string nuevoRol)
    {
        var resultado = await ApiService.CambiarRolAsync(id, nuevoRol);
        if (resultado is not null)
        {
            var idx = colaboradores.FindIndex(c => c.Id == id);
            if (idx >= 0) colaboradores[idx] = resultado;
            await toast.Show($"Rol actualizado a {nuevoRol}.");
        }
        else
            await toast.Show("No se pudo cambiar el rol.", "error");
    }

    private static string Iniciales(string nombre, string apellido) =>
        $"{(nombre.Length > 0 ? nombre[0] : ' ')}{(apellido.Length > 0 ? apellido[0] : ' ')}".ToUpper();

    private async Task CargarInactivos()
    {
        mostrarInactivos = true;
        if (inactivos is not null) return;
        cargandoInactivos = true;
        inactivos = await ApiService.GetInactivosAsync() ?? [];
        cargandoInactivos = false;
    }

    private async Task RestaurarColaborador(int id)
    {
        if (await ApiService.RestaurarAsync(id))
        {
            inactivos = null; // invalidar caché para forzar recarga la próxima vez
            mostrarInactivos = false; // volver a la vista de activos
            await Cargar();
            await toast.Show("Colaborador restaurado.");
        }
        else
        {
            await toast.Show("No se pudo restaurar.", "error");
        }
    }

}
