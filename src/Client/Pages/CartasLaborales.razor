@page "/cartas"
@attribute [Authorize]
@inject PlantillaDocumentoApiService ApiService
@inject IJSRuntime JS

<Toast @ref="toast" />

<div class="page-header">
    <div>
        <h2 class="page-title">Mis Cartas Laborales</h2>
        <p class="page-subtitle">Descarga tus documentos laborales al instante</p>
    </div>
    <a href="cartas/admin" class="btn btn-ghost btn-sm">⚙️ Gestionar plantillas</a>
</div>

@if (cargando)
{
    <div class="cartas-skeleton">
        @for (int i = 0; i < 3; i++)
        {
            <div class="skeleton-card" style="height:100px;"></div>
        }
    </div>
}
else if (!plantillas.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">📄</div>
        <h3>Sin documentos disponibles</h3>
        <p>No hay cartas laborales disponibles para tu área en este momento.</p>
    </div>
}
else
{
    <div class="cartas-grid">
        @foreach (var p in plantillas)
        {
            var plantilla = p;
            <div class="carta-card @(plantillaSeleccionada?.Id == p.Id ? "carta-card--active" : "")">
                <div class="carta-card-icon">
                    <span>@(p.TipoPlantilla == "docx" ? "📝" : "📄")</span>
                </div>
                <div class="carta-card-body">
                    <div class="carta-card-nombre">@p.Nombre</div>
                    @if (!string.IsNullOrWhiteSpace(p.Descripcion))
                    {
                        <div class="carta-card-desc">@p.Descripcion</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(p.NombreFirmante))
                    {
                        <div class="carta-card-firmante">
                            <span class="carta-firmante-icon">✍️</span>
                            @p.NombreFirmante
                            @if (!string.IsNullOrWhiteSpace(p.CargoFirmante))
                            { <span class="text-muted"> · @p.CargoFirmante</span> }
                        </div>
                    }
                    @if (p.VariablesEditables.Any())
                    {
                        <div class="carta-card-badge">
                            <span class="badge badge-info">✏️ Personalizable</span>
                        </div>
                    }
                </div>
                <div class="carta-card-actions">
                    <button class="btn btn-primary btn-sm"
                            disabled="@(cargandoPreview && plantillaSeleccionada?.Id == p.Id)"
                            @onclick="() => AbrirPreview(plantilla)">
                        @if (cargandoPreview && plantillaSeleccionada?.Id == p.Id)
                        {
                            <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;"></span>
                        }
                        else
                        {
                            <span>👁 Ver y descargar</span>
                        }
                    </button>
                </div>
            </div>
        }
    </div>
}

@if (solicitudes.Any())
{
    <div class="card" style="margin-top:1.5rem;">
        <div class="card-header">
            <span class="card-title">📋 Mis descargas recientes</span>
        </div>
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Documento</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in solicitudes.Take(10))
                    {
                        <tr>
                            <td>@s.PlantillaNombre</td>
                            <td class="text-muted text-sm">
                                @s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal de vista previa + descarga -->
@if (plantillaSeleccionada is not null)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal carta-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:.625rem;">
                    <span style="font-size:1.25rem;">📄</span>
                    <span class="modal-title">@plantillaSeleccionada.Nombre</span>
                </div>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>

            <div class="carta-modal-body">
                <!-- Panel izquierdo: campos editables -->
                @if (plantillaSeleccionada.VariablesEditables.Any())
                {
                    <div class="carta-modal-sidebar">
                        <div class="carta-modal-sidebar-title">
                            <span>✏️ Personalizar carta</span>
                        </div>
                        <p class="carta-modal-sidebar-hint">
                            Completa los campos para personalizar tu carta antes de descargarla.
                        </p>
                        @foreach (var key in plantillaSeleccionada.VariablesEditables)
                        {
                            <div class="form-group" style="margin-bottom:.75rem;">
                                <label style="font-size:.8rem;">@EtiquetaVariable(key)</label>
                                <input class="form-control" type="text"
                                       style="font-size:.875rem;"
                                       value="@(extrasActuales.GetValueOrDefault(key, ""))"
                                       placeholder="@PlaceholderVariable(key)"
                                       @oninput="async e => { extrasActuales[key] = e.Value?.ToString() ?? string.Empty; await RefrescarPreviewAsync(); }" />
                            </div>
                        }
                    </div>
                }

                <!-- Panel derecho: preview -->
                <div class="carta-modal-preview">
                    @if (cargandoPreview)
                    {
                        <div class="loading" style="min-height:300px;">
                            <div class="spinner"></div>
                            <span>Generando vista previa...</span>
                        </div>
                    }
                    else if (preview is null)
                    {
                        <div class="carta-preview-error">
                            <span>⚠️</span>
                            <p>No se pudo cargar la vista previa. Verifica que tu perfil tenga todos los datos completos.</p>
                        </div>
                    }
                    else
                    {
                        <iframe @ref="iframeRef"
                                class="carta-preview-iframe"
                                title="Vista previa del documento"></iframe>
                    }
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CerrarModal">Cerrar</button>
                <button class="btn btn-primary"
                        disabled="@(descargando || preview is null)"
                        @onclick="DescargarDesdeModal">
                    @if (descargando)
                    {
                        <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></span>
                        <span>Generando PDF...</span>
                    }
                    else
                    {
                        <span>⬇ Descargar PDF</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private Toast toast = null!;
    private List<PlantillaDocumentoDto> plantillas = [];
    private List<SolicitudDocumentoDto> solicitudes = [];
    private bool cargando = true;
    private bool descargando = false;
    private bool cargandoPreview = false;

    private PlantillaDocumentoDto? plantillaSeleccionada;
    private Dictionary<string, string> extrasActuales = [];
    private PrevisualizarDto? preview;
    private ElementReference iframeRef;
    private string? htmlPendiente;
    private CancellationTokenSource? _debounce;

    protected override async Task OnInitializedAsync()
    {
        var t1 = ApiService.GetDisponiblesAsync();
        var t2 = ApiService.GetMisSolicitudesAsync();
        await Task.WhenAll(t1, t2);
        plantillas = t1.Result;
        solicitudes = t2.Result;
        cargando = false;
    }

    private async Task AbrirPreview(PlantillaDocumentoDto p)
    {
        plantillaSeleccionada = p;
        extrasActuales = p.VariablesEditables.ToDictionary(k => k, _ => string.Empty);
        preview = null;
        await CargarPreviewAsync();
    }

    private void CerrarModal()
    {
        plantillaSeleccionada = null;
        preview = null;
        extrasActuales = [];
        _debounce?.Cancel();
    }

    private async Task CargarPreviewAsync()
    {
        if (plantillaSeleccionada is null) return;
        cargandoPreview = true;
        htmlPendiente = null;
        StateHasChanged();

        var dto = new GenerarPdfDto { Extras = new(extrasActuales) };
        preview = await ApiService.PrevisualizarAsync(plantillaSeleccionada.Id, dto);

        cargandoPreview = false;
        if (preview is not null)
            htmlPendiente = BuildPreviewHtml(preview);

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (htmlPendiente is not null)
        {
            var html = htmlPendiente;
            htmlPendiente = null;
            await JS.InvokeVoidAsync("setIframeContent", iframeRef, html);
        }
    }

    private async Task RefrescarPreviewAsync()
    {
        _debounce?.Cancel();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        try
        {
            await Task.Delay(600, token);
            if (!token.IsCancellationRequested)
                await CargarPreviewAsync();
        }
        catch (TaskCanceledException) { }
    }

    private async Task DescargarDesdeModal()
    {
        if (plantillaSeleccionada is null) return;
        descargando = true;
        StateHasChanged();

        var (bytes, fileName) = await ApiService.GenerarPdfAsync(
            plantillaSeleccionada.Id,
            extrasActuales.Count > 0 ? extrasActuales : null);

        descargando = false;

        if (bytes is null)
        {
            await toast.Show("No se pudo generar el documento. Verifica que tu perfil tenga todos los datos completos.", "error");
            StateHasChanged();
            return;
        }

        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("descargarPdf", base64, fileName ?? $"{plantillaSeleccionada.Nombre}.pdf");

        CerrarModal();
        solicitudes = await ApiService.GetMisSolicitudesAsync();
        await toast.Show("Documento descargado correctamente.");
    }

    private static string BuildPreviewHtml(PrevisualizarDto p)
    {
        var imgTag = !string.IsNullOrWhiteSpace(p.FirmaImagenBase64)
            ? $"<img src=\"{p.FirmaImagenBase64}\" style=\"max-height:70px;display:block;margin-bottom:6px;\" />"
            : string.Empty;

        var cargoTag = !string.IsNullOrWhiteSpace(p.CargoFirmante)
            ? $"<div style=\"font-size:9pt;color:#555;\">{p.CargoFirmante}</div>"
            : string.Empty;

        var firma = !string.IsNullOrWhiteSpace(p.NombreFirmante)
            ? $"<div style=\"margin-top:3rem;\">{imgTag}<div style=\"border-top:1px solid #555;padding-top:4px;width:220px;\"><strong style=\"font-size:10pt;\">{p.NombreFirmante}</strong>{cargoTag}</div></div>"
            : string.Empty;

        const string css =
            "html,body{margin:0;padding:0}" +
            "body{font-family:Arial,Helvetica,sans-serif;font-size:11pt;line-height:1.6;color:#111;background:#fff;padding:2cm 2.5cm;}" +
            "p,div{margin:0 0 .4em 0}" +
            "b,strong{font-weight:bold}" +
            "i,em{font-style:italic}" +
            "u{text-decoration:underline}" +
            "ul{list-style:disc;margin-left:1.5em;margin-bottom:.5em}" +
            "ol{list-style:decimal;margin-left:1.5em;margin-bottom:.5em}" +
            "li{margin-bottom:.2em}";

        return "<!DOCTYPE html><html lang=\"es\"><head><meta charset=\"utf-8\"/>"
             + $"<style>{css}</style></head><body>"
             + p.Html
             + firma
             + "</body></html>";
    }

    private static string EtiquetaVariable(string key) => key switch
    {
        "destinatario"     => "¿A quién va dirigida?",
        "motivo"           => "Motivo de la carta",
        "entidad"          => "Entidad o empresa destinataria",
        "nombre_completo"  => "Nombre completo",
        "cargo"            => "Cargo",
        "ciudad"           => "Ciudad de expedición",
        "fecha_expedicion" => "Fecha de expedición",
        _                  => key.Replace("_", " "),
    };

    private static string PlaceholderVariable(string key) => key switch
    {
        "destinatario"     => "Ej: Banco de Bogotá",
        "motivo"           => "Ej: Solicitud de crédito",
        "entidad"          => "Ej: Ministerio de Educación",
        "ciudad"           => "Ej: Bogotá",
        "fecha_expedicion" => "Ej: 8 de abril de 2026",
        _                  => string.Empty,
    };
}
