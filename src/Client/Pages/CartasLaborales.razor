@page "/cartas"
@attribute [PageTitle("Mis cartas laborales")]
@attribute [Authorize]
@inject PlantillaDocumentoApiService ApiService
@inject NotificacionesService Notificaciones
@inject AuthInfoService AuthInfo
@inject IJSRuntime JS
@implements IAsyncDisposable

<Toast @ref="toast" />

<div class="page-header">
    <div>
        <h2 class="page-title">Mis Cartas Laborales</h2>
        <p class="page-subtitle">Solicita y descarga tus documentos laborales</p>
    </div>
    @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
    {
        <a href="cartas/admin" class="btn btn-ghost btn-sm">⚙️ Administrar</a>
    }
</div>

@if (cargando)
{
    <div class="cartas-skeleton">
        @for (int i = 0; i < 3; i++) { <div class="skeleton-card" style="height:100px;"></div> }
    </div>
}
else if (!plantillas.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">📄</div>
        <h3>Sin documentos disponibles</h3>
        <p>No hay cartas laborales disponibles para tu área en este momento.</p>
    </div>
}
else
{
    <div class="cartas-grid">
        @foreach (var p in plantillas)
        {
            var plantilla = p;
            <div class="carta-card @(plantillaSeleccionada?.Id == p.Id ? "carta-card--active" : "")">
                <div class="carta-card-icon">
                    <span>@(p.TipoPlantilla == "docx" ? "📝" : "📄")</span>
                </div>
                <div class="carta-card-body">
                    <div class="carta-card-nombre">@p.Nombre</div>
                    @if (!string.IsNullOrWhiteSpace(p.Descripcion))
                    {
                        <div class="carta-card-desc">@p.Descripcion</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(p.NombreFirmante))
                    {
                        <div class="carta-card-firmante">
                            <span class="carta-firmante-icon">✍️</span>
                            @p.NombreFirmante
                            @if (!string.IsNullOrWhiteSpace(p.CargoFirmante))
                            { <span class="text-muted"> · @p.CargoFirmante</span> }
                        </div>
                    }
                    <div style="display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.35rem;">
                        @if (p.VariablesEditables.Any())
                        {
                            <span class="badge badge-info">✏️ Personalizable</span>
                        }
                        @if (p.TipoPlantilla == "docx")
                        {
                            <span class="badge badge-purple">Word</span>
                        }
                    </div>
                </div>
                <div class="carta-card-actions">
                    @{
                        var tienePendiente = solicitudes.Any(s =>
                            s.PlantillaDocumentoId == p.Id && s.Estado == "Pendiente");
                    }
                    @if (tienePendiente)
                    {
                        <span class="badge badge-warning" style="font-size:.75rem;padding:.35rem .75rem;">⏳ Solicitud pendiente</span>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm"
                                @onclick="() => AbrirFormulario(plantilla)">
                            <span>📥 Solicitar</span>
                        </button>
                    }
                </div>
            </div>
        }
    </div>
}

@* Banner de novedades — solicitudes resueltas no vistas *@
@if (!cargando && solicitudes.Any(s => s.TieneNovedad))
{
    <div class="novedad-banner">
        <span class="novedad-banner-icon">🔔</span>
        <div>
            <div class="font-medium text-sm">Tienes novedades en tus solicitudes</div>
            <div class="text-xs" style="margin-top:.1rem;opacity:.85;">
                @{
                    var aprobadas = solicitudes.Count(s => s.TieneNovedad && s.Estado == "Aprobada");
                    var rechazadas = solicitudes.Count(s => s.TieneNovedad && s.Estado == "Rechazada");
                }
                @if (aprobadas > 0) { <span>✅ @aprobadas aprobada(s) </span> }
                @if (rechazadas > 0) { <span>❌ @rechazadas rechazada(s)</span> }
            </div>
        </div>
    </div>
}

@* Tabla de solicitudes *@
@if (solicitudes.Any())
{
    <div class="card" style="margin-top:1.5rem;">
        <div class="card-header">
            <span class="card-title">📋 Mis solicitudes</span>
            <span class="text-muted text-sm">@solicitudes.Count solicitud(es)</span>
        </div>
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr><th>Documento</th><th>Fecha</th><th>Estado</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var s in solicitudes.Take(20))
                    {
                        <tr>
                            <td class="font-medium">@s.PlantillaNombre</td>
                            <td class="text-muted text-sm">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (s.Estado == "Pendiente")    { <span class="badge badge-warning">⏳ Pendiente</span> }
                                else if (s.Estado == "Aprobada") { <span class="badge badge-success">✅ Aprobada</span> }
                                else                             { <span class="badge badge-danger">❌ Rechazada</span> }
                            </td>
                            <td>
                                @if (s.Estado == "Aprobada")
                                {
                                    @if (s.Descargado)
                                    {
                                        <span class="badge badge-gray" style="font-size:.75rem;padding:.35rem .75rem;opacity:.75;">⬇ Descargada</span>
                                    }
                                    else
                                    {
                                        <button class="btn btn-primary btn-sm" @onclick="() => DescargarAprobada(s.Id)">
                                            ⬇ Descargar
                                        </button>
                                    }
                                }
                                else if (s.Estado == "Rechazada")
                                {
                                    <div style="display:flex;flex-direction:column;gap:.25rem;align-items:flex-start;">
                                        @if (!string.IsNullOrWhiteSpace(s.ComentarioAdmin))
                                        {
                                            <span class="text-sm text-muted" style="font-style:italic;">
                                                💬 "@s.ComentarioAdmin"
                                            </span>
                                        }
                                        <button class="btn btn-ghost btn-sm"
                                                @onclick="() => ReSolicitar(s.PlantillaDocumentoId)">
                                            🔄 Volver a solicitar
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-xs text-muted">En revisión</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* Modal de solicitud simplificado (sin previsualización) *@
@if (plantillaSeleccionada is not null)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal" style="max-width:500px;" @onclick:stopPropagation>

            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:.625rem;">
                    <span style="font-size:1.25rem;">📄</span>
                    <div>
                        <span class="modal-title">@plantillaSeleccionada.Nombre</span>
                    </div>
                </div>
                <div style="display:flex;gap:.5rem;align-items:center;">
                    <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
                </div>
            </div>

            @if (plantillaSeleccionada.CamposFormulario != null && plantillaSeleccionada.CamposFormulario.Any(c => c.DiligenciadoPor != "Aprobador"))
            {
                <div class="modal-body" style="padding:1.5rem; max-height: 55vh; overflow-y: auto;">
                    <div style="font-weight:600;font-size:1.1rem;margin-bottom:.5rem;color:var(--text);">✏️ Personalizar</div>
                    <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:1.25rem;">
                        Por favor, completa la siguiente información requerida por la plantilla.
                    </p>
                    @foreach (var campo in plantillaSeleccionada.CamposFormulario.Where(c => c.DiligenciadoPor != "Aprobador"))
                    {
                        var c = campo;
                        var key = c.Variable;
                        <div class="form-group" style="margin-bottom:1.25rem;">
                            <label style="font-size:.875rem;font-weight:500;margin-bottom:.35rem;display:block;color:var(--text);">
                                @c.Nombre @(c.Obligatorio ? "*" : "")
                            </label>

                            @if (c.Tipo == "Texto largo")
                            {
                                <textarea class="form-control"
                                          style="font-size:.9rem;padding:.5rem .75rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);height:80px;resize:none;"
                                          value="@extrasActuales.GetValueOrDefault(key, "")"
                                          placeholder="Escribe aquí..."
                                          @oninput="e => OnCampoInput(key, e.Value?.ToString() ?? string.Empty)"></textarea>
                            }
                            else if (c.Tipo == "Número")
                            {
                                <input type="text" class="form-control"
                                       style="font-size:.9rem;padding:.5rem .75rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                       value="@NumberFormatHelper.FormatDynamicNumber(extrasActuales.GetValueOrDefault(key, ""))"
                                       placeholder="Ej: 1.859.928"
                                       @onchange="@(e => OnCampoInput(key, NumberFormatHelper.CleanDynamicNumber(e.Value?.ToString()) ?? string.Empty))" />
                            }
                            else if (c.Tipo == "Fecha")
                            {
                                <input type="date" class="form-control"
                                       style="font-size:.9rem;padding:.5rem .75rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                       value="@extrasActuales.GetValueOrDefault(key, "")"
                                       @onchange="e => OnCampoInput(key, e.Value?.ToString() ?? string.Empty)" />
                            }
                            else if (c.Tipo == "Correo electrónico")
                            {
                                <input type="email" class="form-control"
                                       style="font-size:.9rem;padding:.5rem .75rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                       value="@extrasActuales.GetValueOrDefault(key, "")"
                                       placeholder="Ej: colaborador@empresa.com"
                                       @oninput="e => OnCampoInput(key, e.Value?.ToString() ?? string.Empty)" />
                            }
                            else if (c.Tipo == "Selección única")
                            {
                                var opciones = c.Opciones?.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(o => o.Trim()).ToList() ?? [];
                                <select class="form-control"
                                        style="font-size:.9rem;padding:.5rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                        value="@extrasActuales.GetValueOrDefault(key, "")"
                                        @onchange="e => OnCampoInput(key, e.Value?.ToString() ?? string.Empty)">
                                    <option value="">-- Seleccionar --</option>
                                    @foreach (var opt in opciones)
                                    {
                                        <option value="@opt">@opt</option>
                                    }
                                </select>
                            }
                            else if (c.Tipo == "Selección múltiple")
                            {
                                var opciones = c.Opciones?.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries).Select(o => o.Trim()).ToList() ?? [];
                                var currentVal = extrasActuales.GetValueOrDefault(key, string.Empty);
                                var selectedItems = currentVal.Split(new[] { ", " }, StringSplitOptions.RemoveEmptyEntries).ToList();
                                <div style="display:flex; flex-direction:column; gap:0.4rem; padding: 0.5rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--bg); max-height: 120px; overflow-y: auto;">
                                    @foreach (var opt in opciones)
                                    {
                                        var optionVal = opt;
                                        <label style="display:flex; align-items:center; gap:0.4rem; cursor:pointer; font-size:0.85rem; margin:0;">
                                            <input type="checkbox"
                                                   checked="@selectedItems.Contains(optionVal)"
                                                   @onchange="e => ToggleCheckOption(key, optionVal, (bool)e.Value!)" />
                                            @optionVal
                                        </label>
                                    }
                                </div>
                            }
                            else
                            {
                                // Texto corto (default)
                                <input type="text" class="form-control"
                                       style="font-size:.9rem;padding:.5rem .75rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                       value="@extrasActuales.GetValueOrDefault(key, "")"
                                       placeholder="Escribe aquí..."
                                       @oninput="e => OnCampoInput(key, e.Value?.ToString() ?? string.Empty)" />
                            }
                        </div>
                    }
                </div>
            }
            else if (plantillaSeleccionada.VariablesEditables.Any())
            {
                // FALLBACK: Legacy
                <div class="modal-body" style="padding:1.5rem; max-height: 55vh; overflow-y: auto;">
                    <div style="font-weight:600;font-size:1.1rem;margin-bottom:.5rem;color:var(--text);">✏️ Personalizar</div>
                    <p style="font-size:.85rem;color:var(--text-muted);margin-bottom:1.25rem;">
                        Por favor, completa la siguiente información requerida por la plantilla de la carta laboral.
                    </p>
                    @foreach (var key in plantillaSeleccionada.VariablesEditables)
                    {
                        var k = key;
                        <div class="form-group" style="margin-bottom:1rem;">
                            <label style="font-size:.875rem;font-weight:500;margin-bottom:.25rem;display:block;color:var(--text);">@EtiquetaVariable(k)</label>
                            <input @key="k" type="text"
                                   class="form-control"
                                   style="font-size:.9rem;padding:.5rem .75rem;width:100%;border:1px solid var(--border);border-radius:var(--radius);"
                                   value="@(k == "sueldo_basico" ? NumberFormatHelper.FormatDynamicNumber(extrasActuales.GetValueOrDefault(k, "")) : extrasActuales.GetValueOrDefault(k, ""))"
                                   placeholder="@PlaceholderVariable(k)"
                                   @onchange="@(e => OnCampoInput(k, k == "sueldo_basico" ? (NumberFormatHelper.CleanDynamicNumber(e.Value?.ToString()) ?? string.Empty) : (e.Value?.ToString() ?? string.Empty)))" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="modal-body" style="padding:2.5rem 1.5rem;text-align:center;">
                    <span style="font-size:3rem;display:block;margin-bottom:1rem;">📄</span>
                    <p style="font-size:.95rem;color:var(--text);margin-bottom:.5rem;font-weight:500;">Esta plantilla no requiere datos adicionales.</p>
                    <p style="font-size:.85rem;color:var(--text-muted);">¿Deseas enviar la solicitud para su revisión directa?</p>
                </div>
            }

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CerrarModal">Cerrar</button>
                <button class="btn btn-primary"
                        disabled="@enviando"
                        @onclick="EnviarSolicitud">
                    @if (enviando)
                    {
                        <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;margin-right:.5rem;"></span>
                        <span>Enviando...</span>
                    }
                    else { <span>📤 Enviar solicitud</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private Toast toast = null!;
    private List<PlantillaDocumentoDto> plantillas = [];
    private List<SolicitudDocumentoDto> solicitudes = [];
    private bool cargando = true;
    private bool enviando = false;

    private PlantillaDocumentoDto? plantillaSeleccionada;
    private Dictionary<string, string> extrasActuales = [];
    private Dictionary<string, string> valoresPerfil = [];

    protected override async Task OnInitializedAsync()
    {
        var t1 = ApiService.GetDisponiblesAsync();
        var t2 = ApiService.GetMisSolicitudesAsync();
        var t3 = ApiService.GetValoresPerfilAsync();
        await Task.WhenAll(t1, t2, t3);
        plantillas = t1.Result;
        solicitudes = t2.Result;
        valoresPerfil = t3.Result ?? [];
        cargando = false;

        // Si hay novedades no vistas, marcarlas como vistas en background
        if (solicitudes.Any(s => s.TieneNovedad))
            _ = ApiService.MarcarSolicitudesVistasAsync();

        // La conexión ya fue iniciada por MainLayout
        Notificaciones.OnSolicitudResuelta += OnSolicitudResuelta;
    }

    private void OnSolicitudResuelta(SolicitudDocumentoDto s)
    {
        var idx = solicitudes.FindIndex(x => x.Id == s.Id);
        if (idx >= 0) solicitudes[idx] = s;
        else solicitudes.Insert(0, s);

        var msg = s.Estado == "Aprobada"
            ? $"✅ Tu solicitud de \"{s.PlantillaNombre}\" fue aprobada. Ya puedes descargarla."
            : $"❌ Tu solicitud de \"{s.PlantillaNombre}\" fue rechazada.{(string.IsNullOrWhiteSpace(s.ComentarioAdmin) ? "" : $" Motivo: {s.ComentarioAdmin}")}";

        InvokeAsync(async () =>
        {
            StateHasChanged();
            await toast.Show(msg, s.Estado == "Aprobada" ? "success" : "error");
        });
    }

    private async Task EnviarSolicitud()
    {
        if (plantillaSeleccionada is null) return;

        // Validaciones de obligatoriedad
        if (plantillaSeleccionada.CamposFormulario != null && plantillaSeleccionada.CamposFormulario.Any(c => c.DiligenciadoPor != "Aprobador"))
        {
            foreach (var campo in plantillaSeleccionada.CamposFormulario.Where(c => c.DiligenciadoPor != "Aprobador"))
            {
                var val = extrasActuales.GetValueOrDefault(campo.Variable, string.Empty);
                if (campo.Obligatorio && string.IsNullOrWhiteSpace(val))
                {
                    await toast.Show($"⚠️ El campo '{campo.Nombre}' es obligatorio.", "warning");
                    return;
                }
            }
        }
        else
        {
            foreach (var key in plantillaSeleccionada.VariablesEditables)
            {
                var val = extrasActuales.GetValueOrDefault(key, string.Empty);
                if (string.IsNullOrWhiteSpace(val))
                {
                    await toast.Show($"⚠️ El campo '{EtiquetaVariable(key)}' es obligatorio.", "warning");
                    return;
                }
            }
        }

        enviando = true;
        StateHasChanged();

        try
        {
            // Bug #1 fix: usar todos los campos de extrasActuales (CamposFormulario modernos
            // + VariablesEditables legacy). El servidor filtra internamente las variables
            // permitidas, por lo que no hay riesgo de inyectar campos no autorizados.
            var extrasEnvio = extrasActuales.Count > 0
                ? new Dictionary<string, string>(extrasActuales)
                : [];

            var resultado = await ApiService.EnviarSolicitudAsync(plantillaSeleccionada.Id,
                new EnviarSolicitudDto { Extras = extrasEnvio });
            enviando = false;

            if (resultado is null)
            {
                await toast.Show("No se pudo enviar la solicitud. Intenta de nuevo.", "error");
                StateHasChanged();
                return;
            }

            solicitudes.Insert(0, resultado);
            CerrarModal();
            await toast.Show("✅ Solicitud enviada. Recibirás una notificación cuando sea revisada.");
        }
        catch (InvalidOperationException ex)
        {
            enviando = false;
            await toast.Show(ex.Message, "warning");
            StateHasChanged();
        }
    }

    private async Task DescargarAprobada(int solicitudId)
    {
        var (bytes, fileName) = await ApiService.DescargarAprobadaAsync(solicitudId);
        if (bytes is null) 
        { 
            await toast.Show("No se pudo descargar el documento. Puede que ya haya sido descargado.", "error"); 
            var sList = await ApiService.GetMisSolicitudesAsync();
            if (sList is not null) solicitudes = sList;
            StateHasChanged();
            return; 
        }
        await JS.InvokeVoidAsync("descargarArchivo", Convert.ToBase64String(bytes),
            fileName ?? "carta.pdf", "application/pdf");
        await toast.Show("Documento descargado.");

        var sol = solicitudes.FirstOrDefault(x => x.Id == solicitudId);
        if (sol is not null)
        {
            sol.Descargado = true;
        }
        StateHasChanged();
    }

    private async Task ReSolicitar(int plantillaId)
    {
        var p = plantillas.FirstOrDefault(x => x.Id == plantillaId);
        if (p is not null) AbrirFormulario(p);
    }

    public async ValueTask DisposeAsync()
    {
        Notificaciones.OnSolicitudResuelta -= OnSolicitudResuelta;
        await Notificaciones.DisposeAsync();
    }

    private void ToggleCheckOption(string variable, string opcion, bool checked_)
    {
        var currentVal = extrasActuales.GetValueOrDefault(variable, string.Empty);
        var items = currentVal.Split(new[] { ", " }, StringSplitOptions.RemoveEmptyEntries).ToList();
        if (checked_)
        {
            if (!items.Contains(opcion)) items.Add(opcion);
        }
        else
        {
            items.Remove(opcion);
        }
        extrasActuales[variable] = string.Join(", ", items);
    }

    private void AbrirFormulario(PlantillaDocumentoDto p)
    {
        plantillaSeleccionada = p;
        extrasActuales = [];

        if (p.VariablesEditables != null)
        {
            foreach (var key in p.VariablesEditables)
            {
                extrasActuales[key] = valoresPerfil.GetValueOrDefault(key, string.Empty);
            }
        }

        if (p.CamposFormulario != null)
        {
            foreach (var campo in p.CamposFormulario.Where(c => c.DiligenciadoPor != "Aprobador"))
            {
                if (!extrasActuales.ContainsKey(campo.Variable))
                {
                    extrasActuales[campo.Variable] = valoresPerfil.GetValueOrDefault(campo.Variable, string.Empty);
                }
            }
        }
    }

    private void CerrarModal()
    {
        plantillaSeleccionada = null;
        extrasActuales = [];
    }

    private void OnCampoInput(string key, string valor)
    {
        extrasActuales[key] = valor;
    }

    private static string EtiquetaVariable(string key) => key switch
    {
        "destinatario"     => "¿A quién va dirigida?",
        "motivo"           => "Motivo de la carta",
        "entidad"          => "Entidad o empresa destinataria",
        "nombre_completo"  => "Nombre completo",
        "nombre"           => "Nombre",
        "apellido"         => "Apellido",
        "email"            => "Correo electrónico",
        "telefono"         => "Teléfono",
        "cedula"           => "Cédula",
        "cargo"            => "Cargo",
        "area"             => "Área",
        "ciudad"           => "Ciudad de expedición",
        "fecha_expedicion" => "Fecha de expedición",
        "tipo_contrato"    => "Tipo de contrato",
        "fecha_ingreso"    => "Fecha de ingreso",
        "sueldo_basico"    => "Sueldo básico",
        "genero"           => "Tratamiento de género",
        "rol"              => "Rol",
        _                  => key.Replace("_", " "),
    };

    private static string PlaceholderVariable(string key) => key switch
    {
        "destinatario"     => "Ej: Banco de Bogotá",
        "motivo"           => "Ej: Solicitud de crédito",
        "entidad"          => "Ej: Ministerio de Educación",
        "ciudad"           => "Ej: Bogotá",
        "fecha_expedicion" => "Ej: 8 de abril de 2026",
        "fecha_ingreso"    => "Ej: 1 de enero de 2025",
        "tipo_contrato"    => "Ej: Término Indefinido",
        "sueldo_basico"    => "Ej: $2.500.000",
        "genero"           => "Ej: el señor / la señora",
        "email"            => "Ej: colaborador@novaderma.com",
        "telefono"         => "Ej: 3001234567",
        _                  => string.Empty,
    };
}
