@page "/cartas"
@attribute [Authorize]
@inject PlantillaDocumentoApiService ApiService
@inject NotificacionesService Notificaciones
@inject AuthInfoService AuthInfo
@inject IJSRuntime JS
@implements IAsyncDisposable

<Toast @ref="toast" />

<div class="page-header">
    <div>
        <h2 class="page-title">Mis Cartas Laborales</h2>
        <p class="page-subtitle">Solicita y descarga tus documentos laborales</p>
    </div>
    @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
    {
        <a href="cartas/admin" class="btn btn-ghost btn-sm">⚙️ Administrar</a>
    }
</div>

@if (cargando)
{
    <div class="cartas-skeleton">
        @for (int i = 0; i < 3; i++) { <div class="skeleton-card" style="height:100px;"></div> }
    </div>
}
else if (!plantillas.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">📄</div>
        <h3>Sin documentos disponibles</h3>
        <p>No hay cartas laborales disponibles para tu área en este momento.</p>
    </div>
}
else
{
    <div class="cartas-grid">
        @foreach (var p in plantillas)
        {
            var plantilla = p;
            <div class="carta-card @(plantillaSeleccionada?.Id == p.Id ? "carta-card--active" : "")">
                <div class="carta-card-icon">
                    <span>@(p.TipoPlantilla == "docx" ? "📝" : "📄")</span>
                </div>
                <div class="carta-card-body">
                    <div class="carta-card-nombre">@p.Nombre</div>
                    @if (!string.IsNullOrWhiteSpace(p.Descripcion))
                    {
                        <div class="carta-card-desc">@p.Descripcion</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(p.NombreFirmante))
                    {
                        <div class="carta-card-firmante">
                            <span class="carta-firmante-icon">✍️</span>
                            @p.NombreFirmante
                            @if (!string.IsNullOrWhiteSpace(p.CargoFirmante))
                            { <span class="text-muted"> · @p.CargoFirmante</span> }
                        </div>
                    }
                    <div style="display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.35rem;">
                        @if (p.VariablesEditables.Any())
                        {
                            <span class="badge badge-info">✏️ Personalizable</span>
                        }
                        @if (p.TipoPlantilla == "docx")
                        {
                            <span class="badge badge-purple">Word</span>
                        }
                    </div>
                </div>
                <div class="carta-card-actions">
                    @{
                        var tienePendiente = solicitudes.Any(s =>
                            s.PlantillaDocumentoId == p.Id && s.Estado == "Pendiente");
                    }
                    @if (tienePendiente)
                    {
                        <span class="badge badge-warning" style="font-size:.75rem;padding:.35rem .75rem;">⏳ Solicitud pendiente</span>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm"
                                disabled="@(cargandoPreview && plantillaSeleccionada?.Id == p.Id)"
                                @onclick="() => AbrirPreview(plantilla)">
                            @if (cargandoPreview && plantillaSeleccionada?.Id == p.Id)
                            {
                                <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;"></span>
                            }
                            else { <span>👁 Ver y solicitar</span> }
                        </button>
                    }
                </div>
            </div>
        }
    </div>
}

@* Banner de novedades — solicitudes resueltas no vistas *@
@if (!cargando && solicitudes.Any(s => s.TieneNovedad))
{
    <div class="novedad-banner">
        <span class="novedad-banner-icon">🔔</span>
        <div>
            <div class="font-medium text-sm">Tienes novedades en tus solicitudes</div>
            <div class="text-xs" style="margin-top:.1rem;opacity:.85;">
                @{
                    var aprobadas = solicitudes.Count(s => s.TieneNovedad && s.Estado == "Aprobada");
                    var rechazadas = solicitudes.Count(s => s.TieneNovedad && s.Estado == "Rechazada");
                }
                @if (aprobadas > 0) { <span>✅ @aprobadas aprobada(s) </span> }
                @if (rechazadas > 0) { <span>❌ @rechazadas rechazada(s)</span> }
            </div>
        </div>
    </div>
}

@* Tabla de solicitudes *@
@if (solicitudes.Any())
{
    <div class="card" style="margin-top:1.5rem;">
        <div class="card-header">
            <span class="card-title">📋 Mis solicitudes</span>
            <span class="text-muted text-sm">@solicitudes.Count solicitud(es)</span>
        </div>
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr><th>Documento</th><th>Fecha</th><th>Estado</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var s in solicitudes.Take(20))
                    {
                        <tr>
                            <td class="font-medium">@s.PlantillaNombre</td>
                            <td class="text-muted text-sm">@s.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (s.Estado == "Pendiente")    { <span class="badge badge-warning">⏳ Pendiente</span> }
                                else if (s.Estado == "Aprobada") { <span class="badge badge-success">✅ Aprobada</span> }
                                else                             { <span class="badge badge-danger">❌ Rechazada</span> }
                            </td>
                            <td>
                                @if (s.Estado == "Aprobada")
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => DescargarAprobada(s.Id)">
                                        ⬇ Descargar
                                    </button>
                                }
                                else if (s.Estado == "Rechazada")
                                {
                                    <div style="display:flex;flex-direction:column;gap:.25rem;align-items:flex-start;">
                                        @if (!string.IsNullOrWhiteSpace(s.ComentarioAdmin))
                                        {
                                            <span class="text-sm text-muted" style="font-style:italic;">
                                                💬 "@s.ComentarioAdmin"
                                            </span>
                                        }
                                        <button class="btn btn-ghost btn-sm"
                                                @onclick="() => ReSolicitar(s.PlantillaDocumentoId)">
                                            🔄 Volver a solicitar
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-xs text-muted">En revisión</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* Modal de vista previa + solicitud *@
@if (plantillaSeleccionada is not null)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal carta-modal"
             @onclick:stopPropagation>

            <div class="modal-header">
                <div style="display:flex;align-items:center;gap:.625rem;">
                    <span style="font-size:1.25rem;">📄</span>
                    <div>
                        <span class="modal-title">@plantillaSeleccionada.Nombre</span>
                    </div>
                </div>
                <div style="display:flex;gap:.5rem;align-items:center;">
                    <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
                </div>
            </div>

            <div class="carta-modal-body @(!plantillaSeleccionada.VariablesEditables.Any() ? "carta-modal-body--full" : "")">
                @if (plantillaSeleccionada.VariablesEditables.Any())
                {
                    <div class="carta-modal-sidebar">
                        <div class="carta-modal-sidebar-title">✏️ Personalizar</div>
                        <p class="carta-modal-sidebar-hint">
                            Solo puedes completar los datos indicados; el cuerpo de la carta lo define RRHH.
                        </p>
                        @foreach (var key in plantillaSeleccionada.VariablesEditables)
                        {
                            var k = key;
                            <div class="form-group" style="margin-bottom:.75rem;">
                                <label style="font-size:.8rem;">@EtiquetaVariable(k)</label>
                                <input @key="k" type="text"
                                       style="font-size:.875rem;"
                                       value="@extrasActuales.GetValueOrDefault(k, "")"
                                       placeholder="@PlaceholderVariable(k)"
                                       @oninput="e => OnCampoInput(k, e.Value?.ToString() ?? string.Empty)" />
                            </div>
                        }
                    </div>
                }
                <div class="carta-modal-preview">
                    @if (cargandoPreview)
                    {
                        <div class="loading carta-preview-loading">
                            <div class="spinner"></div>
                            <span>Generando vista previa...</span>
                        </div>
                    }
                    else if (preview is null)
                    {
                        <div class="carta-preview-error">
                            <span>⚠️</span>
                            <p>No se pudo cargar la vista previa.</p>
                            <button class="btn btn-ghost btn-sm" style="margin-top:.5rem;"
                                    @onclick="CargarPreviewAsync">🔄 Reintentar</button>
                        </div>
                    }
                    else
                    {
                        <iframe @ref="iframeRef"
                                class="carta-preview-iframe"
                                title="Vista previa del documento"></iframe>
                    }
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CerrarModal">Cerrar</button>
                <button class="btn btn-primary"
                        disabled="@(enviando || cargandoPreview || preview is null)"
                        @onclick="EnviarSolicitud">
                    @if (enviando)
                    {
                        <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></span>
                        <span>Enviando...</span>
                    }
                    else { <span>📤 Enviar solicitud</span> }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private Toast toast = null!;
    private List<PlantillaDocumentoDto> plantillas = [];
    private List<SolicitudDocumentoDto> solicitudes = [];
    private bool cargando = true;
    private bool enviando = false;
    private bool cargandoPreview = false;
    private bool primeraVez = true;

    private PlantillaDocumentoDto? plantillaSeleccionada;
    private Dictionary<string, string> extrasActuales = [];
    private PrevisualizarDto? preview;
    private ElementReference iframeRef;
    private string? iframePendiente;
    private CancellationTokenSource? _debounce;

    protected override async Task OnInitializedAsync()
    {
        var t1 = ApiService.GetDisponiblesAsync();
        var t2 = ApiService.GetMisSolicitudesAsync();
        await Task.WhenAll(t1, t2);
        plantillas = t1.Result;
        solicitudes = t2.Result;
        cargando = false;

        // Si hay novedades no vistas, marcarlas como vistas en background
        if (solicitudes.Any(s => s.TieneNovedad))
            _ = ApiService.MarcarSolicitudesVistasAsync();

        // La conexión ya fue iniciada por MainLayout
        Notificaciones.OnSolicitudResuelta += OnSolicitudResuelta;
    }

    private void OnSolicitudResuelta(SolicitudDocumentoDto s)
    {
        var idx = solicitudes.FindIndex(x => x.Id == s.Id);
        if (idx >= 0) solicitudes[idx] = s;
        else solicitudes.Insert(0, s);

        var msg = s.Estado == "Aprobada"
            ? $"✅ Tu solicitud de \"{s.PlantillaNombre}\" fue aprobada. Ya puedes descargarla."
            : $"❌ Tu solicitud de \"{s.PlantillaNombre}\" fue rechazada.{(string.IsNullOrWhiteSpace(s.ComentarioAdmin) ? "" : $" Motivo: {s.ComentarioAdmin}")}";

        InvokeAsync(async () =>
        {
            StateHasChanged();
            await toast.Show(msg, s.Estado == "Aprobada" ? "success" : "error");
        });
    }

    private async Task EnviarSolicitud()
    {
        if (plantillaSeleccionada is null) return;
        enviando = true;
        StateHasChanged();

        try
        {
            var extrasEnvio = plantillaSeleccionada.VariablesEditables
                .Where(k => extrasActuales.ContainsKey(k))
                .ToDictionary(k => k, k => extrasActuales[k]);

            var resultado = await ApiService.EnviarSolicitudAsync(plantillaSeleccionada.Id,
                new EnviarSolicitudDto { Extras = extrasEnvio });
            enviando = false;

            if (resultado is null)
            {
                await toast.Show("No se pudo enviar la solicitud. Intenta de nuevo.", "error");
                StateHasChanged();
                return;
            }

            solicitudes.Insert(0, resultado);
            CerrarModal();
            await toast.Show("✅ Solicitud enviada. Recibirás una notificación cuando sea revisada.");
        }
        catch (InvalidOperationException ex)
        {
            enviando = false;
            await toast.Show(ex.Message, "warning");
            StateHasChanged();
        }
    }

    private async Task DescargarAprobada(int solicitudId)
    {
        var (bytes, fileName) = await ApiService.DescargarAprobadaAsync(solicitudId);
        if (bytes is null) { await toast.Show("No se pudo descargar el documento.", "error"); return; }
        await JS.InvokeVoidAsync("descargarArchivo", Convert.ToBase64String(bytes),
            fileName ?? "carta.pdf", "application/pdf");
        await toast.Show("Documento descargado.");
    }

    private async Task ReSolicitar(int plantillaId)
    {
        var p = plantillas.FirstOrDefault(x => x.Id == plantillaId);
        if (p is not null) await AbrirPreview(p);
    }

    public async ValueTask DisposeAsync()
    {
        Notificaciones.OnSolicitudResuelta -= OnSolicitudResuelta;
        await Notificaciones.DisposeAsync();
    }

    private async Task AbrirPreview(PlantillaDocumentoDto p)
    {
        plantillaSeleccionada = p;
        extrasActuales = p.VariablesEditables.ToDictionary(k => k, _ => string.Empty);
        preview = null;
        primeraVez = true;
        await CargarPreviewAsync();
    }

    private void CerrarModal()
    {
        plantillaSeleccionada = null;
        preview = null;
        extrasActuales = [];
        iframePendiente = null;
        primeraVez = true;
        _debounce?.Cancel();
    }

    private async Task CargarPreviewAsync()
    {
        if (plantillaSeleccionada is null) return;
        cargandoPreview = true;
        iframePendiente = null;

        if (primeraVez)
        {
            StateHasChanged();
            var dto0 = new GenerarPdfDto { Extras = new(extrasActuales) };
            preview = await ApiService.PrevisualizarAsync(plantillaSeleccionada.Id, dto0);

            if (preview is not null && preview.ValoresPerfil.Count > 0)
            {
                foreach (var key in extrasActuales.Keys.ToList())
                {
                    if (string.IsNullOrEmpty(extrasActuales[key]) &&
                        preview.ValoresPerfil.TryGetValue(key, out var valorPerfil) &&
                        !string.IsNullOrEmpty(valorPerfil))
                        extrasActuales[key] = valorPerfil;
                }
            }
            primeraVez = false;
        }

        cargandoPreview = false;

        if (preview is not null)
        {
            if (preview.TipoPlantilla == "docx")
            {
                var pdfBase64 = await ApiService.PrevisualizarDocxBase64Async(
                    plantillaSeleccionada.Id,
                    extrasActuales.Count > 0 ? extrasActuales : null);
                if (pdfBase64 is not null)
                    iframePendiente = $"data:application/pdf;base64,{pdfBase64}";
            }
            else
            {
                var dto = new GenerarPdfDto { Extras = new(extrasActuales) };
                var actualizado = await ApiService.PrevisualizarAsync(plantillaSeleccionada.Id, dto);
                if (actualizado is not null)
                {
                    preview = actualizado;
                    iframePendiente = BuildPreviewHtml(preview);
                }
            }
        }

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (iframePendiente is not null)
        {
            var content = iframePendiente;
            iframePendiente = null;
            if (content.StartsWith("data:application/pdf"))
                await JS.InvokeVoidAsync("setPdfIframeSrc", iframeRef, content);
            else
                await JS.InvokeVoidAsync("setIframeContent", iframeRef, content);
        }
    }

    private void OnCampoInput(string key, string valor)
    {
        extrasActuales[key] = valor;
        _ = RefrescarPreviewAsync();
    }

    private async Task RefrescarPreviewAsync()
    {
        _debounce?.Cancel();
        _debounce = new CancellationTokenSource();
        var token = _debounce.Token;
        try
        {
            await Task.Delay(800, token);
            if (!token.IsCancellationRequested) await CargarPreviewAsync();
        }
        catch (TaskCanceledException) { }
    }

    private static string BuildPreviewHtml(PrevisualizarDto p)
    {
        var imgTag = !string.IsNullOrWhiteSpace(p.FirmaImagenBase64)
            ? $"<img src=\"{p.FirmaImagenBase64}\" style=\"max-height:70px;display:block;margin-bottom:6px;\" />"
            : string.Empty;
        var cargoTag = !string.IsNullOrWhiteSpace(p.CargoFirmante)
            ? $"<div style=\"font-size:9pt;color:#555;\">{p.CargoFirmante}</div>"
            : string.Empty;
        var firma = !string.IsNullOrWhiteSpace(p.NombreFirmante)
            ? $"<div style=\"margin-top:3rem;\">{imgTag}<div style=\"border-top:1px solid #555;padding-top:4px;width:220px;\"><strong style=\"font-size:10pt;\">{p.NombreFirmante}</strong>{cargoTag}</div></div>"
            : string.Empty;
        const string css =
            "html,body{margin:0;padding:0}" +
            "body{font-family:Arial,Helvetica,sans-serif;font-size:11pt;line-height:1.6;color:#111;background:#fff;padding:2cm 2.5cm;}" +
            "p,div{margin:0 0 .4em 0}b,strong{font-weight:bold}i,em{font-style:italic}u{text-decoration:underline}" +
            "ul{list-style:disc;margin-left:1.5em;margin-bottom:.5em}ol{list-style:decimal;margin-left:1.5em;margin-bottom:.5em}li{margin-bottom:.2em}";
        return "<!DOCTYPE html><html lang=\"es\"><head><meta charset=\"utf-8\"/>"
             + $"<style>{css}</style></head><body>" + p.Html + firma + "</body></html>";
    }

    private static string EtiquetaVariable(string key) => key switch
    {
        "destinatario"     => "¿A quién va dirigida?",
        "motivo"           => "Motivo de la carta",
        "entidad"          => "Entidad o empresa destinataria",
        "nombre_completo"  => "Nombre completo",
        "cargo"            => "Cargo",
        "ciudad"           => "Ciudad de expedición",
        "fecha_expedicion" => "Fecha de expedición",
        _                  => key.Replace("_", " "),
    };

    private static string PlaceholderVariable(string key) => key switch
    {
        "destinatario"     => "Ej: Banco de Bogotá",
        "motivo"           => "Ej: Solicitud de crédito",
        "entidad"          => "Ej: Ministerio de Educación",
        "ciudad"           => "Ej: Bogotá",
        "fecha_expedicion" => "Ej: 8 de abril de 2026",
        _                  => string.Empty,
    };
}
