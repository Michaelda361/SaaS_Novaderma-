@page "/areas"
@attribute [PageTitle("Áreas")]
@attribute [Authorize]
@inject AreaApiService AreaService
@inject NavigationManager Nav

<Toast @ref="toast" />
<ConfirmDialog Visible="confirmVisible"
               Message="@confirmMensaje"
               OnConfirm="ConfirmarEliminar"
               OnCancel="() => confirmVisible = false" />

<div class="card">
    <div class="card-header">
        <span class="card-title">Áreas</span>
        <button class="btn btn-primary btn-sm" @onclick="AbrirModal">+ Nueva área</button>
    </div>

    <div class="filter-bar">
        <div class="search-input-wrap">
            <span class="search-icon">🔍</span>
            <input type="search" placeholder="Buscar área..." @bind="busqueda" @bind:event="oninput" />
        </div>
        @if (!string.IsNullOrEmpty(busqueda))
        {
            <span class="text-sm text-muted">@Filtradas.Count resultado(s)</span>
        }
    </div>

    @if (cargando)
    {
        <div class="loading"><div class="spinner"></div> Cargando...</div>
    }
    else if (areas is null || areas.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">🏢</div>
            <h3>Sin áreas</h3>
            <p>Crea la primera área organizacional.</p>
        </div>
    }
    else if (Filtradas.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">🔍</div>
            <h3>Sin resultados</h3>
            <p>No hay áreas que coincidan con "@busqueda".</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Cargos</th>
                        <th>Colaboradores</th>
                        <th>Jefe</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Filtradas)
                    {
                        <tr>
                            <td><strong>@a.Nombre</strong></td>
                            <td class="text-muted text-sm">@(a.Descripcion ?? "—")</td>
                            <td><span class="badge badge-info">@a.TotalCargos</span></td>
                            <td><span class="badge badge-success">@a.TotalColaboradores</span></td>
                            <td>
                                @if (a.JefeId.HasValue)
                                {
                                    <span class="badge badge-purple text-sm">@a.JefeNombre</span>
                                }
                                else
                                {
                                    <span class="text-muted text-sm">Sin jefe</span>
                                }
                            </td>
                            <td>
                                <div class="flex gap-2">
                                    <button class="btn btn-ghost btn-sm" @onclick='() => Nav.NavigateTo($"areas/{a.Id}")' title="Ver detalle">👁️</button>
                                    <button class="btn btn-ghost btn-sm btn-icon" @onclick="() => AbrirEditar(a)" title="Editar">✏️</button>
                                    <button class="btn btn-danger btn-sm btn-icon" @onclick="() => PedirConfirmacion(a)" title="Eliminar">🗑️</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editandoId.HasValue ? "Editar área" : "Nueva área")</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <EditForm Model="form" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />
                <div class="modal-body">
                    <div class="form-group">
                        <label>Nombre</label>
                        <InputText @bind-Value="form.Nombre" placeholder="Ej: Recursos Humanos" />
                        <ValidationMessage For="() => form.Nombre" class="validation-message" />
                    </div>
                    <div class="form-group">
                        <label>Descripción (opcional)</label>
                        <InputText @bind-Value="form.Descripcion" placeholder="Descripción del área" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@guardando">
                        @(guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<AreaDto>? areas;
    private bool cargando = true;
    private bool mostrarModal = false;
    private bool guardando = false;
    private int? editandoId = null;
    private string busqueda = string.Empty;
    private Toast toast = default!;
    private bool confirmVisible = false;
    private int eliminandoId;
    private string confirmMensaje = string.Empty;
    private CreateAreaDto form = new();

    private List<AreaDto> Filtradas =>
        string.IsNullOrWhiteSpace(busqueda)
            ? areas ?? []
            : (areas ?? []).Where(a => a.Nombre.Contains(busqueda, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        cargando = true;
        areas = await AreaService.GetAllAsync();
        cargando = false;
    }

    private void AbrirModal() { form = new(); editandoId = null; mostrarModal = true; }

    private void AbrirEditar(AreaDto a)
    {
        form = new CreateAreaDto { Nombre = a.Nombre, Descripcion = a.Descripcion };
        editandoId = a.Id;
        mostrarModal = true;
    }

    private void CerrarModal() => mostrarModal = false;

    private async Task Guardar()
    {
        guardando = true;
        bool ok = editandoId.HasValue
            ? await AreaService.UpdateAsync(editandoId.Value, form) is not null
            : await AreaService.CreateAsync(form) is not null;
        guardando = false;

        if (ok) { CerrarModal(); await Cargar(); await toast.Show(editandoId.HasValue ? "Área actualizada." : "Área creada."); }
        else await toast.Show("Error al guardar.", "error");
    }

    private void PedirConfirmacion(AreaDto a)
    {
        eliminandoId = a.Id;
        confirmMensaje = $"¿Eliminar el área \"{a.Nombre}\"? Se eliminarán también sus cargos asociados.";
        confirmVisible = true;
    }

    private async Task ConfirmarEliminar()
    {
        confirmVisible = false;
        if (await AreaService.DeleteAsync(eliminandoId)) { await Cargar(); await toast.Show("Área eliminada."); }
        else await toast.Show("No se pudo eliminar.", "error");
    }
}
