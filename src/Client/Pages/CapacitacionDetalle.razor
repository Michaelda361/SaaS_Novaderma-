@page "/capacitaciones/{Id:int}"
@attribute [PageTitle("Detalle de capacitación")]
@attribute [Authorize]
@inject InscripcionApiService InscripcionService
@inject CapacitacionApiService CapacitacionService
@inject ColaboradorApiService ColaboradorService
@inject RecursoApiService RecursoService
@inject CuestionarioApiService CuestionarioService
@inject AuthInfoService AuthInfo
@inject NavigationManager Nav
<Toast @ref="toast" />

<div class="page-header" style="margin-bottom:1.5rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;">
    <button class="btn btn-ghost btn-sm" @onclick='() => Nav.NavigateTo("/capacitaciones")'>← Volver</button>
    <h2 style="margin:0;font-size:1.25rem;font-weight:600;">
        @(capacitacion?.Nombre ?? "Cargando...")
    </h2>
    @if (capacitacion is not null)
    {
        <span class="badge badge-info">@capacitacion.DuracionHoras h</span>
        <span class="text-sm text-muted">@capacitacion.FechaInicio.ToString("dd/MM/yyyy") — @capacitacion.FechaFin.ToString("dd/MM/yyyy")</span>
        @if (capacitacion.AreaId.HasValue)
        {
            <span class="badge badge-info">🏢 @capacitacion.AreaNombre</span>
        }
        else if (capacitacion.ColaboradorId.HasValue)
        {
            <span class="badge badge-warning">👤 @capacitacion.ColaboradorNombre</span>
        }
        @if (PuedeGestionar)
        {
            @if (capacitacion.Publicada)
            {
                <span class="badge badge-success">✅ Publicada</span>
                <button class="btn btn-ghost btn-sm" @onclick="Despublicar" disabled="@publicando">
                    Despublicar
                </button>
            }
            else
            {
                <span class="badge badge-warning">📝 Borrador</span>
                <button class="btn btn-primary btn-sm" @onclick="Publicar" disabled="@publicando">
                    @(publicando ? "Publicando..." : "🚀 Publicar")
                </button>
            }
        }
    }
</div>

<!-- RECURSOS -->
<div class="card" style="margin-bottom:1.5rem;">
    <div class="card-header">
        <span class="card-title">📎 Materiales y recursos (@recursos.Count)</span>
        @if (PuedeGestionar)
        {
            <button class="btn btn-primary btn-sm" @onclick="AbrirModalRecurso">+ Agregar recurso</button>
        }
    </div>

    @if (cargandoRecursos)
    {
        <div class="loading"><div class="spinner"></div> Cargando recursos...</div>
    }
    else if (recursos.Count == 0)
    {
        <div class="empty-state" style="padding:1.5rem;">
            <div class="empty-state-icon">📂</div>
            <h3>Sin materiales</h3>
            <p>Agrega videos, documentos o enlaces para esta capacitación.</p>
        </div>
    }
    else
    {
        <div style="padding:1rem;display:flex;flex-direction:column;gap:0.75rem;">
            @foreach (var r in recursos.OrderBy(x => x.Orden))
            {
                <div class="recurso-item">
                    <span class="recurso-icon">@IconoTipo(r.Tipo)</span>
                    <div class="recurso-info">
                        <span class="font-medium">@r.Titulo</span>
                        @if (!string.IsNullOrEmpty(r.Descripcion))
                        {
                            <span class="text-sm text-muted">@r.Descripcion</span>
                        }
                    </div>
                    <div class="flex gap-2" style="margin-left:auto;">
                        <a href="@r.Url" target="_blank" class="btn btn-primary btn-sm">Abrir →</a>
                        @if (PuedeGestionar)
                        {
                            <button class="btn btn-ghost btn-sm btn-icon"
                                    @onclick="() => AbrirEditarRecurso(r)" title="Editar">✏️</button>
                            <button class="btn btn-danger btn-sm btn-icon"
                                    @onclick="() => EliminarRecurso(r.Id)" title="Eliminar">🗑️</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- INSCRITOS -->
@if (PuedeGestionar)
{
<div class="card">
    <div class="card-header">
        <span class="card-title">👥 Inscritos (@inscripciones.Count)</span>
        @if (PuedeGestionar)
        {
            <button class="btn btn-primary btn-sm" @onclick="AbrirModal">+ Inscribir colaborador</button>
        }
    </div>

    @if (cargando)
    {
        <div class="loading"><div class="spinner"></div> Cargando...</div>
    }
    else if (inscripciones.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">👥</div>
            <h3>Sin inscritos</h3>
            <p>Inscribe colaboradores a esta capacitación.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Colaborador</th>
                        <th>Área</th>
                        <th>Cargo</th>
                        <th>Fecha inscripción</th>
                        <th>Asistió</th>
                        <th>Calificación</th>
                        <th>Cuestionario</th>
                        <th>Observaciones</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in inscripciones)
                    {
                        var aprobado = resultadosInscritos.TryGetValue(i.Id, out var res) && res.Aprobado;
                        var respondio = resultadosInscritos.ContainsKey(i.Id);
                        <tr style="@(aprobado ? "background:var(--success-bg, rgba(34,197,94,.06));" : "")">
                            <td class="font-medium">@i.ColaboradorNombre</td>
                            <td class="text-sm text-muted">@i.ColaboradorArea</td>
                            <td class="text-sm text-muted">@i.ColaboradorCargo</td>
                            <td class="text-sm">@i.FechaInscripcion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (editandoId == i.Id)
                                {
                                    <input type="checkbox" @bind="editForm.Asistio" />
                                }
                                else
                                {
                                    <span class="badge @(i.Asistio ? "badge-success" : "badge-gray")">
                                        @(i.Asistio ? "Sí" : "No")
                                    </span>
                                }
                            </td>
                            <td>
                                @if (editandoId == i.Id)
                                {
                                    <input type="number" step="0.01" min="0" max="10"
                                           style="width:70px" @bind="editForm.Calificacion" />
                                }
                                else
                                {
                                    <span class="@(i.Calificacion >= 7 ? "text-success" : i.Calificacion.HasValue ? "text-danger" : "")">
                                        @(i.Calificacion.HasValue ? i.Calificacion.Value.ToString("0.##") : "-")
                                    </span>
                                }
                            </td>
                            <td>
                                @if (respondio && res is not null)
                                {
                                    <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
                                        <span class="badge @(res.Aprobado ? "badge-success" : "badge-danger")">
                                            @(res.Aprobado ? "✅ Aprobó" : "❌ No aprobó")
                                        </span>
                                        <span class="text-xs text-muted">@res.Puntaje.ToString("0.#")%</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted text-sm">Sin responder</span>
                                }
                            </td>
                            <td>
                                @if (editandoId == i.Id)
                                {
                                    <input type="text" @bind="editForm.Observaciones"
                                           placeholder="Observaciones..." style="width:150px" />
                                }
                                else
                                {
                                    <span class="text-sm text-muted">@(i.Observaciones ?? "-")</span>
                                }
                            </td>
                            <td>
                                <div class="flex gap-2">
                                    @if (PuedeGestionar && !aprobado)
                                    {
                                        @if (editandoId == i.Id)
                                        {
                                            <button class="btn btn-primary btn-sm btn-icon"
                                                    @onclick="() => GuardarEdicion(i.Id)" title="Guardar">💾</button>
                                            <button class="btn btn-ghost btn-sm btn-icon"
                                                    @onclick="CancelarEdicion" title="Cancelar">✕</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-ghost btn-sm btn-icon"
                                                    @onclick="() => IniciarEdicion(i)" title="Editar">✏️</button>
                                            <button class="btn btn-danger btn-sm btn-icon"
                                                    @onclick="() => Desinscribir(i.Id)" title="Eliminar">🗑️</button>
                                        }
                                    }
                                    @if (aprobado)
                                    {
                                        <span class="text-xs text-muted" style="font-style:italic;">Completado</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
}

<!-- CUESTIONARIO -->
<div class="card" style="margin-bottom:1.5rem;margin-top:1.5rem;">
    <div class="card-header">
        <span class="card-title">📝 Cuestionario</span>
        @if (PuedeGestionar)
        {
            @if (cuestionario is null)
            {
                <button class="btn btn-primary btn-sm" @onclick="AbrirModalCuestionario">+ Crear cuestionario</button>
            }
            else
            {
                <div class="flex gap-2">
                    <button class="btn btn-ghost btn-sm" @onclick="AbrirModalCuestionario">✏️ Editar</button>
                    <button class="btn btn-danger btn-sm" @onclick="EliminarCuestionario">🗑️</button>
                </div>
            }
        }
    </div>

    @if (cuestionario is null)
    {
        @if (cargandoCuestionario)
        {
            <div class="loading"><div class="spinner"></div> Cargando cuestionario...</div>
        }
        else
        {
            <div class="empty-state" style="padding:1.5rem;">
                <div class="empty-state-icon">📝</div>
                <h3>Sin cuestionario</h3>
                <p>@(PuedeGestionar ? "Crea un cuestionario para evaluar a los inscritos." : "Esta capacitación no tiene cuestionario aún.")</p>
            </div>
        }
    }
    else if (resultadoPropio is not null)
    {
        <!-- Ya respondió — mostrar resultado -->
        <div class="cuest-resultado">
            <div class="cuest-resultado-emoji">@(resultadoPropio.Aprobado ? "🎉" : "😔")</div>
            <div class="cuest-resultado-puntaje @(resultadoPropio.Aprobado ? "cuest-resultado-puntaje--ok" : "cuest-resultado-puntaje--fail")">
                @resultadoPropio.Puntaje.ToString("0.#")%
            </div>
            <div class="text-muted text-sm" style="margin-top:.35rem;">
                @resultadoPropio.Correctas de @resultadoPropio.TotalPreguntas correctas · Mínimo: @resultadoPropio.PuntajeAprobacion%
            </div>
            <div style="margin-top:.875rem;">
                <span class="badge @(resultadoPropio.Aprobado ? "badge-success" : "badge-danger")" style="font-size:.875rem;padding:.35rem .875rem;">
                    @(resultadoPropio.Aprobado ? "✅ Aprobado" : "❌ No aprobado")
                </span>
            </div>
        </div>
        @if (PuedeGestionar)
        {
            <div style="padding:.75rem 1.5rem;border-top:1px solid var(--border);background:var(--bg);">
                <p class="text-xs text-muted">📊 @cuestionario.Titulo · @cuestionario.Preguntas.Count pregunta(s) · Mínimo @cuestionario.PuntajeAprobacion%</p>
            </div>
        }
    }
    else if (inscripcionPropia is not null)
    {
        <!-- Cualquier usuario inscrito puede responder -->
        <div style="padding:1rem;">
            @if (PuedeGestionar)
            {
                <div class="alert alert-warning" style="margin-bottom:1rem;padding:.6rem .875rem;font-size:.8125rem;">
                    ℹ️ Estás inscrito en esta capacitación — puedes responder el cuestionario como participante.
                </div>
            }
            @if (!respondiendo)
            {
                <div class="cuest-info-card">
                    <div class="cuest-info-icon">📝</div>
                    <div>
                        <div class="font-medium">@cuestionario.Titulo</div>
                        @if (!string.IsNullOrWhiteSpace(cuestionario.Descripcion))
                        {
                            <div class="text-sm text-muted" style="margin-top:.2rem;">@cuestionario.Descripcion</div>
                        }
                        <div class="text-sm text-muted" style="margin-top:.35rem;">
                            @cuestionario.Preguntas.Count pregunta(s) · Mínimo @cuestionario.PuntajeAprobacion% para aprobar
                        </div>
                    </div>
                    <button class="btn btn-primary" @onclick="IniciarCuestionario">Comenzar →</button>
                </div>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:1.25rem;">
                    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;">
                        <span class="text-sm text-muted">
                            @respuestasColaborador.Count de @cuestionario.Preguntas.Count respondidas
                        </span>
                        <div style="display:flex;gap:.25rem;">
                            @for (int qi = 0; qi < cuestionario.Preguntas.Count; qi++)
                            {
                                var qId = cuestionario.Preguntas[qi].Id;
                                <div class="cuest-dot @(respuestasColaborador.ContainsKey(qId) ? "cuest-dot--done" : "")"></div>
                            }
                        </div>
                    </div>

                    @for (int qi = 0; qi < cuestionario.Preguntas.Count; qi++)
                    {
                        var pregunta = cuestionario.Preguntas[qi];
                        var pIdx = qi;
                        <div class="cuest-pregunta">
                            <div class="cuest-pregunta-num">@(pIdx + 1)</div>
                            <div style="flex:1;">
                                <div class="font-medium" style="margin-bottom:.75rem;line-height:1.5;">
                                    @pregunta.Enunciado
                                </div>
                                <div style="display:flex;flex-direction:column;gap:.5rem;">
                                    @foreach (var opcion in pregunta.Opciones)
                                    {
                                        var op = opcion;
                                        var seleccionada = respuestasColaborador.TryGetValue(pregunta.Id, out var sel) && sel == op.Id;
                                        <button type="button"
                                                class="cuest-opcion @(seleccionada ? "cuest-opcion--seleccionada" : "")"
                                                @onclick="() => SeleccionarOpcion(pregunta.Id, op.Id)">
                                            <div class="cuest-opcion-radio @(seleccionada ? "cuest-opcion-radio--activo" : "")">
                                                @if (seleccionada) { <span>●</span> }
                                            </div>
                                            <span>@op.Texto</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="flex gap-2" style="padding-top:.5rem;border-top:1px solid var(--border);">
                        <button class="btn btn-primary"
                                @onclick="EnviarCuestionario"
                                disabled="@(enviandoCuestionario || respuestasColaborador.Count < cuestionario.Preguntas.Count)">
                            @if (enviandoCuestionario)
                            {
                                <span class="spinner" style="width:.9rem;height:.9rem;border-width:2px;border-color:rgba(255,255,255,.3);border-top-color:#fff;"></span>
                            }
                            @(enviandoCuestionario ? "Enviando..." : $"Enviar ({respuestasColaborador.Count}/{cuestionario.Preguntas.Count})")
                        </button>
                        <button class="btn btn-ghost" @onclick="() => respondiendo = false">Cancelar</button>
                    </div>
                </div>
            }
        </div>
    }
    else if (PuedeGestionar)
    {
        <!-- Admin ve resumen del cuestionario -->
        <div style="padding:1rem;">
            <p class="text-sm text-muted">@cuestionario.Titulo · @cuestionario.Preguntas.Count pregunta(s) · Mínimo @cuestionario.PuntajeAprobacion%</p>
        </div>
    }
    else
    {
        <!-- Colaborador no inscrito — no puede responder -->
        <div class="empty-state" style="padding:1.5rem;">
            <div class="empty-state-icon">🔒</div>
            <h3>No estás inscrito</h3>
            <p>Debes estar inscrito en esta capacitación para responder el cuestionario.</p>
        </div>
    }
</div>


<!-- CERTIFICADO (solo Jefe/Admin) -->
@if (PuedeGestionar && capacitacion is not null)
{
<div class="card" style="margin-bottom:1.5rem;">
    <div class="card-header">
        <span class="card-title">🏆 Certificado al aprobar</span>
        @if (!editandoCertificado)
        {
            <button class="btn btn-ghost btn-sm" @onclick="AbrirEditarCertificado">✏️ Configurar</button>
        }
    </div>
    @if (!editandoCertificado)
    {
        <div style="padding:1rem;">
            @if (capacitacion.EmiteCertificado)
            {
                <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
                    <span class="badge badge-success">✅ Activo</span>
                    @if (!string.IsNullOrWhiteSpace(capacitacion.PlantillaNombreCertificado))
                    {
                        <span class="text-sm text-muted">Plantilla: <code style="background:var(--bg);padding:.1rem .3rem;border-radius:3px;">@capacitacion.PlantillaNombreCertificado</code></span>
                    }
                    @if (capacitacion.TienePlantillaDocx)
                    {
                        <span class="badge badge-purple">
                            @(capacitacion.TipoArchivoCertificado == "application/pdf" ? "PDF" : capacitacion.TipoArchivoCertificado == "application/vnd.openxmlformats-officedocument.presentationml.presentation" ? "PPTX" : "DOCX")
                        </span>
                    }
                </div>
            }
            else
            {
                <div style="display:flex;align-items:center;gap:.75rem;">
                    <span class="badge badge-gray">Inactivo</span>
                    <span class="text-sm text-muted">No se emite certificado al aprobar el cuestionario.</span>
                </div>
            }
        </div>
    }
    else
    {
        <div style="padding:1rem;display:flex;flex-direction:column;gap:.875rem;">
            <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-weight:500;">
                <input type="checkbox" @bind="certForm.EmiteCertificado" />
                Emitir certificado automaticamente al aprobar el cuestionario
            </label>
            @if (certForm.EmiteCertificado)
            {
                <div>
                    <label style="font-size:.85rem;font-weight:500;">Tipo de plantilla</label>
                    <div class="tipo-selector" style="margin-top:.35rem;">
                        <label class="tipo-option @(tipoCertificado == "docx" ? "tipo-option--active" : "")">
                            <input type="radio" name="tipoCert" value="docx"
                                   checked="@(tipoCertificado == "docx")"
                                   @onchange='() => tipoCertificado = "docx"' />
                            <span class="tipo-icon"></span>
                            <div><div class="tipo-label">Archivo Word</div><div class="tipo-desc">Sube un .docx con variables</div></div>
                        </label>
                        <label class="tipo-option @(tipoCertificado == "pptx" ? "tipo-option--active" : "")">
                            <input type="radio" name="tipoCert" value="pptx"
                                   checked="@(tipoCertificado == "pptx")"
                                   @onchange='() => tipoCertificado = "pptx"' />
                            <span class="tipo-icon"></span>
                            <div><div class="tipo-label">Presentacion PowerPoint</div><div class="tipo-desc">Sube un .pptx con variables</div></div>
                        </label>
                        <label class="tipo-option @(tipoCertificado == "pdf" ? "tipo-option--active" : "")">
                            <input type="radio" name="tipoCert" value="pdf"
                                   checked="@(tipoCertificado == "pdf")"
                                   @onchange='() => tipoCertificado = "pdf"' />
                            <span class="tipo-icon"></span>
                            <div><div class="tipo-label">Plantilla PDF</div><div class="tipo-desc">Sube un .pdf con variables o campos de formulario</div></div>
                        </label>
                    </div>
                </div>

                <div>
                    <label style="font-size:.85rem;font-weight:500;">
                        Nombre del certificado
                        <span class="text-muted" style="font-weight:400;"> — usa variables para personalizar</span>
                    </label>
                    <input class="form-control" style="margin-top:.35rem;"
                           @bind="certForm.PlantillaNombreCertificado"
                           placeholder="Ej: Certificado de {{capacitacion}} — {{nombre_completo}}" />
                    <div style="margin-top:.4rem;display:flex;flex-wrap:wrap;gap:.3rem;">
                        @foreach (var vari in variablesCertificado)
                        {
                            var v = vari;
                            <button type="button" class="btn btn-ghost btn-sm"
                                    style="font-size:.75rem;padding:.2rem .5rem;font-family:monospace;"
                                    @onclick="() => InsertarVariable(v)">@v</button>
                        }
                    </div>
                </div>

                    <div>
                        <label style="font-size:.85rem;font-weight:500;">@(tipoCertificado == "pptx" ? "Presentacion PowerPoint (.pptx)" : tipoCertificado == "pdf" ? "Plantilla PDF (.pdf)" : "Archivo Word (.docx)")</label>
                        @if (capacitacion.TienePlantillaDocx && string.IsNullOrWhiteSpace(certForm.ArchivoDocxBase64))
                        {
                            <div style="margin-top:.35rem;display:flex;align-items:center;gap:.75rem;">
                                <span class="badge badge-success">✅ Plantilla cargada</span>
                                <button type="button" class="btn btn-ghost btn-sm"
                                        @onclick="() => certForm.EliminarDocx = true">Quitar</button>
                            </div>
                        }
                        @if (!capacitacion.TienePlantillaDocx || certForm.EliminarDocx)
                        {
                            <InputFile OnChange="OnArchivoCertificadoSeleccionado" accept="@(tipoCertificado == "pptx" ? ".pptx" : tipoCertificado == "pdf" ? ".pdf" : ".docx")" style="margin-top:.35rem;" />
                            @if (!string.IsNullOrWhiteSpace(certForm.ArchivoDocxBase64))
                            {
                                <div class="alert alert-success" style="margin-top:.35rem;padding:.4rem .75rem;font-size:.8rem;">
                                    ✅ Archivo cargado — se guardara al hacer clic en Guardar
                                </div>
                            }
                            <p class="text-xs text-muted" style="margin-top:.3rem;">
                                Sube un @(tipoCertificado == "pptx" ? ".pptx" : tipoCertificado == "pdf" ? ".pdf" : ".docx") con variables {{nombre_completo}}, {{cargo}}, {{capacitacion}}, etc.
                            </p>
                        }
                    </div>
                }
            }
            <div class="flex gap-2">
                <button class="btn btn-primary btn-sm" @onclick="GuardarCertificado" disabled="@guardandoCertificado">
                    @(guardandoCertificado ? "Guardando..." : "Guardar")
                </button>
                <button class="btn btn-ghost btn-sm" @onclick="() => editandoCertificado = false">Cancelar</button>
            </div>
        </div>
    }
</div>
}
<!-- MODAL INSCRIBIR -->
@if (mostrarModal)
{
    <div class="modal-backdrop" @onclick="CerrarModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Inscribir colaborador</span>
                <button class="btn btn-ghost btn-sm btn-icon" @onclick="CerrarModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Colaborador</label>
                    <select @bind="nuevaInscripcion.ColaboradorId" class="form-select">
                        <option value="0">-- Seleccionar --</option>
                        @foreach (var col in colaboradoresDisponibles)
                        {
                            <option value="@col.Id">@col.Nombre @col.Apellido — @ColaboradorGeneroUi.Etiqueta(col.Genero) · @col.AreaNombre</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Fecha de inscripción</label>
                    <input type="date" @bind="nuevaInscripcion.FechaInscripcion" @bind:format="yyyy-MM-dd" />
                </div>
                @if (!string.IsNullOrEmpty(errorInscripcion))
                {
                    <p class="validation-message">@errorInscripcion</p>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CerrarModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Inscribir" disabled="@inscribiendo">
                    @(inscribiendo ? "Inscribiendo..." : "Inscribir")
                </button>
            </div>
        </div>
    </div>
}

