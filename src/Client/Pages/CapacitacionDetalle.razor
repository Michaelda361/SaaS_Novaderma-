    protected override async Task OnInitializedAsync()
    {
        await AuthInfo.LoadAsync();
        try
        {
            capacitacion = await CapacitacionService.GetByIdAsync(Id);
        }
        catch (System.UnauthorizedAccessException)
        {
            accessDenied = true;
            return;
        }

        if (accessDenied) return;

        try
        {
            camposFicha = await CampoApiService.GetAllAsync() ?? [];
        }
        catch { }

        if (PuedeGestionar)
        {
            // Cargar cuestionario primero — Cargar() lo necesita para obtener resultados
            await CargarCuestionario();
            await Task.WhenAll(Cargar(), CargarRecursos());
        }
        else
        {
            // Colaborador: solo recursos y cuestionario (sin inscripciones del grupo)
            cargando = false;
            await Task.WhenAll(CargarRecursos(), CargarCuestionario());
        }
    }

    private async Task Cargar()
    {
        cargando = true;
        inscripciones = await InscripcionService.GetByCapacitacionAsync(Id);

        // Si hay cuestionario, cargar resultados de todos los inscritos en paralelo
        if (cuestionario is not null && inscripciones.Count > 0)
        {
            var tareas = inscripciones.Select(async insc =>
            {
                try
                {
                    var resultado = await CuestionarioService.GetResultadoAsync(cuestionario.Id, insc.Id);
                    return (InscripcionId: insc.Id, Resultado: resultado);
                }
                catch { return (InscripcionId: insc.Id, Resultado: (ResultadoCuestionarioDto?)null); }
            });
            var resultados = await Task.WhenAll(tareas);
            resultadosInscritos = resultados
                .Where(x => x.Resultado is not null)
                .ToDictionary(x => x.InscripcionId, x => x.Resultado!);
        }

        cargando = false;
    }

