    private async Task OnArchivoCertificadoSeleccionado(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var expectedExt = ".pptx";

        if (!file.Name.EndsWith(expectedExt, StringComparison.OrdinalIgnoreCase))
        { await toast.Show($"Solo se aceptan archivos {expectedExt}", "warning"); return; }
        if (file.Size > 5 * 1024 * 1024)
        { await toast.Show("El archivo no puede superar 5 MB.", "warning"); return; }
        
        nombreArchivoSeleccionado = file.Name;
        certForm.CopiarPlantillaDesdeId = null;
        copiandoDesdeNombre = null;
        previewCertificadoBase64Temp = null;

        using var ms = new System.IO.MemoryStream();
        await file.OpenReadStream(5 * 1024 * 1024).CopyToAsync(ms);
        certForm.ArchivoDocxBase64 = Convert.ToBase64String(ms.ToArray());
        certForm.TipoArchivoCertificado = "application/vnd.openxmlformats-officedocument.presentationml.presentation";
        certForm.EliminarDocx = false;

        // Guardado automático para generar y mostrar la vista previa sin cerrar la edición
        await AutoGuardarPlantillaParaPreview();
    }

    private async Task AutoGuardarPlantillaParaPreview()
    {
        guardandoCertificado = true;
        
        bool tienePlantilla = !string.IsNullOrWhiteSpace(certForm.ArchivoDocxBase64)
            || (capacitacion?.TienePlantillaDocx == true && !certForm.EliminarDocx)
            || certForm.CopiarPlantillaDesdeId.HasValue;
            
        bool tieneNombre = !string.IsNullOrWhiteSpace(certForm.PlantillaNombreCertificado);
        certForm.EmiteCertificado = tienePlantilla || tieneNombre;

        var result = await CapacitacionService.ConfigurarCertificadoAsync(Id, certForm);
        guardandoCertificado = false;
        
        if (result is not null)
        {
            capacitacion = result;
            previewCertificadoBase64Temp = result.PreviewCertificadoBase64;
            
            // Preservar la firma si ya estaba configurada en el servidor y no la hemos tocado localmente
            if (result.FirmaImagenBase64 is not null && string.IsNullOrWhiteSpace(certForm.FirmaImagenBase64) && !certForm.EliminarFirma)
            {
                certForm.FirmaImagenBase64 = result.FirmaImagenBase64;
            }

            // Limpiar el base64 local ya que está guardado en el servidor
            certForm.ArchivoDocxBase64 = null;
            
            await toast.Show("Nueva plantilla subida y procesada con éxito.");
        }
        else
        {
            await toast.Show("Error al procesar la plantilla en el servidor.", "error");
        }
    }

    private async Task OnCopiarDesdeSeleccionado(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        if (int.TryParse(val, out var selectedId))
        {
            var selectedCap = capacitacionesConPlantilla.FirstOrDefault(c => c.Id == selectedId);
            if (selectedCap is not null)
            {
                certForm.CopiarPlantillaDesdeId = selectedCap.Id;
                if (string.IsNullOrWhiteSpace(certForm.PlantillaNombreCertificado))
                {
                    certForm.PlantillaNombreCertificado = selectedCap.PlantillaNombreCertificado;
                }
                copiandoDesdeNombre = selectedCap.Nombre;
                certForm.ArchivoDocxBase64 = null;
                certForm.TipoArchivoCertificado = null;
                certForm.EliminarDocx = false;
                nombreArchivoSeleccionado = null;
                
                // Copiar la vista previa inmediatamente para que se visualice
                previewCertificadoBase64Temp = selectedCap.PreviewCertificadoBase64;
                
                // Copiar también la firma y sus coordenadas si existen
                if (!string.IsNullOrWhiteSpace(selectedCap.FirmaImagenBase64))
                {
                    certForm.FirmaImagenBase64 = selectedCap.FirmaImagenBase64;
                    certForm.FirmaX = selectedCap.FirmaX ?? 70;
                    certForm.FirmaY = selectedCap.FirmaY ?? 70;
                    certForm.FirmaAncho = selectedCap.FirmaAncho ?? 20;
                    certForm.FirmaAlto = selectedCap.FirmaAlto ?? 15;
                    certForm.EliminarFirma = false;
                }

                await AutoGuardarCertificadoSilencioso();
                await toast.Show("Plantilla copiada y guardada.");
            }
        }
        else
        {
            certForm.CopiarPlantillaDesdeId = null;
            copiandoDesdeNombre = null;
            
            // Restaurar la vista previa y firma originales al deseleccionar
            previewCertificadoBase64Temp = capacitacion?.PreviewCertificadoBase64;
            certForm.FirmaImagenBase64 = capacitacion?.FirmaImagenBase64;
            certForm.FirmaX = capacitacion?.FirmaX ?? 70;
            certForm.FirmaY = capacitacion?.FirmaY ?? 70;
            certForm.FirmaAncho = capacitacion?.FirmaAncho ?? 20;
            certForm.FirmaAlto = capacitacion?.FirmaAlto ?? 15;
            certForm.EliminarFirma = false;

            await AutoGuardarCertificadoSilencioso();
        }
    }

    private async Task GuardarCertificado()
    {
        guardandoCertificado = true;
        
        bool tienePlantilla = (capacitacion?.TienePlantillaDocx == true && !certForm.EliminarDocx) 
            || !string.IsNullOrWhiteSpace(certForm.ArchivoDocxBase64)
            || certForm.CopiarPlantillaDesdeId.HasValue;
            
        bool tieneNombre = !string.IsNullOrWhiteSpace(certForm.PlantillaNombreCertificado);
        certForm.EmiteCertificado = tienePlantilla || tieneNombre;

        var result = await CapacitacionService.ConfigurarCertificadoAsync(Id, certForm);
        guardandoCertificado = false;
        if (result is not null)
        {
            capacitacion = result;
            previewCertificadoBase64Temp = result.PreviewCertificadoBase64;
            editandoCertificado = false;
            await toast.Show("Configuración de certificado guardada.");
        }
        else await toast.Show("Error al guardar la configuración.", "error");
    }

    private async Task OnFirmaSeleccionada(InputFileChangeEventArgs e)
    {
        var file = e.File;
        var expectedExt = ".png";

        if (!file.Name.EndsWith(expectedExt, StringComparison.OrdinalIgnoreCase))
        {
            await toast.Show($"Solo se aceptan archivos {expectedExt}", "warning");
            return;
        }
        if (file.Size > 2 * 1024 * 1024)
        {
            await toast.Show("La firma no puede superar 2 MB.", "warning");
            return;
        }

        using var ms = new System.IO.MemoryStream();
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(ms);
        certForm.FirmaImagenBase64 = Convert.ToBase64String(ms.ToArray());
        certForm.EliminarFirma = false;
        
        // Asignar valores por defecto si no existen
        certForm.FirmaX ??= 70;
        certForm.FirmaY ??= 70;
        certForm.FirmaAncho ??= 20;
        certForm.FirmaAlto ??= 15;

        // Guardado automático de la firma subida
        await AutoGuardarCertificadoSilencioso();
        await toast.Show("Firma subida y guardada con éxito.");
    }

    private async Task RestablecerFirma()
    {
        certForm.FirmaX = 70;
        certForm.FirmaY = 70;
        certForm.FirmaAncho = 20;
        certForm.FirmaAlto = 15;
        await AutoGuardarCertificadoSilencioso();
        await toast.Show("Posición y tamaño de firma restablecidos.");
    }

    private async Task QuitarFirma()
    {
        certForm.EliminarFirma = true;
        certForm.FirmaImagenBase64 = null;
        await AutoGuardarCertificadoSilencioso();
        await toast.Show("Firma quitada y guardada.");
    }

    private async Task QuitarPlantilla()
    {
        certForm.EliminarDocx = true;
        certForm.CopiarPlantillaDesdeId = null;
        copiandoDesdeNombre = null;
        nombreArchivoSeleccionado = null;
        previewCertificadoBase64Temp = null;
        await AutoGuardarCertificadoSilencioso();
        await toast.Show("Plantilla quitada y guardada.");
    }

    private async Task AutoGuardarCertificadoSilencioso()
    {
        bool tienePlantilla = !string.IsNullOrWhiteSpace(certForm.ArchivoDocxBase64)
            || (capacitacion?.TienePlantillaDocx == true && !certForm.EliminarDocx)
            || certForm.CopiarPlantillaDesdeId.HasValue;
            
        bool tieneNombre = !string.IsNullOrWhiteSpace(certForm.PlantillaNombreCertificado);
        certForm.EmiteCertificado = tienePlantilla || tieneNombre;

        var result = await CapacitacionService.ConfigurarCertificadoAsync(Id, certForm);
        if (result is not null)
        {
            capacitacion = result;
            previewCertificadoBase64Temp = result.PreviewCertificadoBase64;
            
            // Preservar la firma
            if (result.FirmaImagenBase64 is not null && string.IsNullOrWhiteSpace(certForm.FirmaImagenBase64) && !certForm.EliminarFirma)
            {
                certForm.FirmaImagenBase64 = result.FirmaImagenBase64;
            }
        }
    }

    private bool RecursoVisto(int recursoId)
    {
        if (inscripcionPropia is null || string.IsNullOrEmpty(inscripcionPropia.RecursosVistos))
            return false;

        var vistos = inscripcionPropia.RecursosVistos.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(int.Parse)
            .ToHashSet();

        return vistos.Contains(recursoId);
    }

    private bool TodosRecursosVistos()
    {
        if (recursos == null || recursos.Count == 0) return true;
        if (inscripcionPropia == null) return false;
        if (string.IsNullOrEmpty(inscripcionPropia.RecursosVistos)) return false;

        var vistos = inscripcionPropia.RecursosVistos.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(int.Parse)
            .ToHashSet();

        return recursos.All(r => vistos.Contains(r.Id));
    }

    private async Task AbrirRecurso(RecursoDto r)
    {
        if (inscripcionPropia is not null)
        {
            var result = await InscripcionService.MarcarRecursoVistoAsync(inscripcionPropia.Id, r.Id);
            if (result is not null)
            {
                inscripcionPropia = result;
            }
        }
        await JS.InvokeVoidAsync("open", r.Url, "_blank");
    }

    private DotNetObjectReference<CapacitacionDetalle>? objectRef;

    [JSInvokable]
    public async Task SetCoords(double x, double y)
    {
        certForm.FirmaX = Math.Round(x, 2);
        certForm.FirmaY = Math.Round(y, 2);
        StateHasChanged();
        await AutoGuardarCertificadoSilencioso();
    }

    [JSInvokable]
    public async Task SetSize(double w, double h)
    {
        certForm.FirmaAncho = Math.Round(w, 2);
        certForm.FirmaAlto = Math.Round(h, 2);
        StateHasChanged();
        await AutoGuardarCertificadoSilencioso();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objectRef = DotNetObjectReference.Create(this);
        }

        if (editandoCertificado && !string.IsNullOrWhiteSpace(certForm.FirmaImagenBase64) && !certForm.EliminarFirma)
        {
            try
            {
                await JS.InvokeVoidAsync("initSignatureEditor", "firma-canvas", "firma-imagen", "firma-handle", objectRef);
            }
            catch { }
        }
    }

    public void Dispose()
    {
        objectRef?.Dispose();
    }
}

