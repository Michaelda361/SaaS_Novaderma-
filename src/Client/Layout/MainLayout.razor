@inherits LayoutComponentBase
@using System.Reflection
@inject ThemeService Theme
@inject PlantillaDocumentoApiService CartasApi
@inject NavigationManager Nav
@inject AuthInfoService AuthInfo
@inject NotificacionesService Notificaciones
@implements IDisposable

<CascadingValue Value="AuthInfo.EsMicrosoftUser" Name="EsMicrosoftUser">
<CascadingValue Value="AuthInfo.EsSoloColaborador" Name="EsSoloColaborador">
<div class="app-layout @(sidebarOpen ? "sidebar-open" : "")">
    <Toast @ref="layoutToast" />
    @if (sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseSidebar" aria-hidden="true"></div>
    }
    <aside id="app-sidebar" class="sidebar" role="navigation" aria-label="Menú principal">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <img src="logo.png" alt="NovaHub" class="sidebar-logo" />
            </div>
            <div class="sidebar-brand-text">
                <h1>NovaHub</h1>
                <span>Gestion de Talento</span>
            </div>
            <button type="button" class="sidebar-close-btn" @onclick="CloseSidebar" aria-label="Cerrar menú">x</button>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Principal</span>
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg></span> Dashboard
            </NavLink>

            <span class="nav-section-label">Gestion</span>

            @if (!AuthInfo.EsSoloColaborador)
            {
                <NavLink class="nav-link" href="colaboradores">
                    <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg></span> Colaboradores
                </NavLink>
            }
            <NavLink class="nav-link" href="capacitaciones">
                <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg></span> Capacitaciones
            </NavLink>
            @if (AuthInfo.EsSoloColaborador)
            {
                <NavLink class="nav-link" href="mi-historial">
                    <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg></span> Mi Historial
                </NavLink>
            }

            <NavLink class="nav-link" href="certificados">
                <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg></span> Certificados
            </NavLink>

            <NavLink class="nav-link" href="control-documental">
                <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2a4 4 0 014-4h3m-7 6h7a2 2 0 002-2v-5a2 2 0 00-2-2h-3.5a2 2 0 01-1.414-.586L10 3H5a2 2 0 00-2 2v11a2 2 0 002 2h4z"/></svg></span> Control Documental
            </NavLink>



            <NavLink class="nav-link" href="cartas">
                <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></span> Cartas Laborales
            </NavLink>

            @if (AuthInfo.PuedeResolverSolicitudes)

            {
                <NavLink class="nav-link" href="cartas/admin?tab=pendientes">
                    <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></span> Aprobar Cartas
                </NavLink>
            }

            @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
            {
                <NavLink class="nav-link" href="cartas/admin?tab=plantillas">
                    <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg></span> Configurar Plantillas
                </NavLink>
            }
            @if (AuthInfo.EsAdmin)
            {
                <span class="nav-section-label">Configuracion</span>
                <NavLink class="nav-link" href="auditoria">
                    <span class="nav-icon"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></span> Auditoría
                </NavLink>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="avatar avatar-sm avatar--sidebar">@AuthInfo.Iniciales</div>
                <div class="sidebar-user-info">
                    <div class="sidebar-user-name">@AuthInfo.Nombre</div>
                    <div class="sidebar-user-role">
                        <span class="sidebar-rol-badge sidebar-rol-badge--@AuthInfo.Rol.ToLower()">
                            @RolLabel(AuthInfo.Rol)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </aside>
    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <button type="button" class="hamburger-btn" @onclick="OpenSidebar" title="Abrir menú"
                        aria-label="Abrir menú de navegación" aria-expanded="@sidebarOpen" aria-controls="app-sidebar">☰</button>
                <span class="topbar-title">@GetPageTitle()</span>
            </div>
            <div class="topbar-right">
                <button type="button" class="theme-toggle" @onclick="ToggleTheme"
                        aria-label="@(Theme.IsDark ? "Activar modo claro" : "Activar modo oscuro")"
                        aria-pressed="@Theme.IsDark">
                    <span aria-hidden="true" style="width: 1.25rem; height: 1.25rem; display: inline-block;">
                        @if (Theme.IsDark) { <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg> }
                        else { <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg> }
                    </span>
                </button>
                <CampanaNotificaciones />
                <LoginDisplay />
            </div>
        </header>
        <main class="page-body" id="main-content" tabindex="-1">
            @Body
        </main>
    </div>
</div>
</CascadingValue>
</CascadingValue>

@code {
    [CascadingParameter] private RouteData? RouteData { get; set; }
    private bool sidebarOpen = false;
    private Toast layoutToast = default!;
    private void OpenSidebar() => sidebarOpen = true;
    private void CloseSidebar() => sidebarOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthInfo.LoadAsync();
        VerificarColaborador();
    }

    protected override void OnParametersSet()
    {
        VerificarColaborador();
    }

    private void VerificarColaborador()
    {
        var uri = Nav.Uri.ToLower();
        if (uri.Contains("/authentication/") || uri.Contains("/landing") || uri.Contains("/sin-registro"))
        {
            return;
        }

        if (AuthInfo.EsColaborador == false && !string.IsNullOrWhiteSpace(AuthInfo.Email))
        {
            Nav.NavigateTo("sin-registro");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Theme.OnChange += StateHasChanged;
            await Theme.InitAsync();
            await AuthInfo.LoadAsync();
        }

        // Reconectar el hub si se desconectó (server reiniciado, etc.)
        if (!Notificaciones.Conectado && !string.IsNullOrWhiteSpace(AuthInfo.Email))
        {
            var esAdminOJefe = AuthInfo.EsJefe || AuthInfo.EsAdmin;

            // IniciarAsync ya maneja el join al grupo admin internamente cuando esAdmin=true
            await Notificaciones.IniciarAsync(AuthInfo.Email, AuthInfo.ColaboradorId, esAdmin: esAdminOJefe);

            // Esperar conexión (máx 2s)
            for (int i = 0; i < 10; i++)
            {
                if (Notificaciones.Conectado) break;
                await Task.Delay(200);
            }

            if (firstRender && esAdminOJefe)
                Notificaciones.OnCuestionarioRespondido += OnCuestionarioRespondido;

            StateHasChanged();
        }
    }

    private void OnCuestionarioRespondido(TalentManagement.Shared.DTOs.Cuestionarios.CuestionarioRespondidoDto n)
    {
        var estado = n.Aprobado ? "✅ Aprobó" : "❌ No aprobó";
        var msg = $"📝 {n.ColaboradorNombre} completó \"{n.CapacitacionNombre}\" — {estado} ({n.Puntaje:0.#}%)";
        InvokeAsync(async () => { StateHasChanged(); if (layoutToast is not null) await layoutToast.Show(msg, n.Aprobado ? "success" : "warning"); });
    }

    private async Task ToggleTheme() => await Theme.ToggleAsync();

    public void Dispose()
    {
        Theme.OnChange -= StateHasChanged;
        Notificaciones.OnCuestionarioRespondido -= OnCuestionarioRespondido;
    }

    private static string RolLabel(string rol) => rol switch
    {
        "Admin"       => "🔑 Admin",
        "Jefe"        => "👔 Jefe",
        "Colaborador" => "👤 Colaborador",
        _             => rol
    };

    private string GetPageTitle()
    {
        var pageType = RouteData?.PageType;
        if (pageType is null) return "NovaHub";
        var attr = pageType.GetCustomAttribute<PageTitleAttribute>();
        return string.IsNullOrWhiteSpace(attr?.Title) ? "NovaHub" : attr.Title;
    }
}