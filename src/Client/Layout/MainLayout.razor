@inherits LayoutComponentBase
@inject ThemeService Theme
@inject DocumentoApiService DocumentoApi
@inject PlantillaDocumentoApiService CartasApi
@inject NavigationManager Nav
@inject AuthInfoService AuthInfo
@inject NotificacionesService Notificaciones
@implements IDisposable

<CascadingValue Value="AuthInfo.EsMicrosoftUser" Name="EsMicrosoftUser">
<CascadingValue Value="AuthInfo.EsSoloColaborador" Name="EsSoloColaborador">
<div class="app-layout @(sidebarOpen ? "sidebar-open" : "")">
    <Toast @ref="layoutToast" />
    @if (sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseSidebar"></div>
    }
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <img src="logo.png" alt="NovaHub" class="sidebar-logo" />
            </div>
            <div class="sidebar-brand-text">
                <h1>NovaHub</h1>
                <span>Gestion de Talento</span>
            </div>
            <button class="sidebar-close-btn" @onclick="CloseSidebar">x</button>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Principal</span>
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span> Dashboard
            </NavLink>

            <span class="nav-section-label">Gestion</span>

            @if (!AuthInfo.EsSoloColaborador)
            {
                <NavLink class="nav-link" href="colaboradores">
                    <span class="nav-icon">👥</span> Colaboradores
                </NavLink>
            }
            <NavLink class="nav-link" href="capacitaciones">
                <span class="nav-icon">📚</span> Capacitaciones
            </NavLink>
            @if (AuthInfo.EsSoloColaborador)
            {
                <NavLink class="nav-link" href="mi-historial">
                    <span class="nav-icon">📋</span> Mi Historial
                </NavLink>
            }

            <NavLink class="nav-link" href="certificados">
                <span class="nav-icon">🏆</span> Certificados
            </NavLink>

            @if (!AuthInfo.EsSoloColaborador)
            {
                <NavLink class="nav-link" href="documentos">
                    <span class="nav-icon">📄</span> Documentos
                    @if (propuestasPendientes > 0)
                    {
                        <span class="badge badge-warning badge-pill">@propuestasPendientes</span>
                    }
                </NavLink>
            }

            <NavLink class="nav-link" href="cartas">
                <span class="nav-icon">📋</span> Mis Cartas
            </NavLink>

            @if (AuthInfo.PuedeResolverSolicitudes)
            {
                <NavLink class="nav-link" href="cartas/admin">
                    <span class="nav-icon">✅</span> Aprobar Cartas
                    @if (cartasPendientes > 0)
                    {
                        <span class="badge badge-warning badge-pill">@cartasPendientes</span>
                    }
                </NavLink>
            }

            @if (AuthInfo.EsJefe || AuthInfo.EsAdmin)
            {
                <span class="nav-section-label">Configuracion</span>
                <NavLink class="nav-link" href="areas">
                    <span class="nav-icon">🏢</span> Areas
                </NavLink>
                <NavLink class="nav-link" href="cargos">
                    <span class="nav-icon">💼</span> Cargos
                </NavLink>
                <NavLink class="nav-link" href="cartas/admin">
                    <span class="nav-icon">⚙️</span> Plantillas de Cartas
                </NavLink>
            }
            @if (AuthInfo.EsAdmin)
            {
                <NavLink class="nav-link" href="auditoria">
                    <span class="nav-icon">🔍</span> Auditoría
                </NavLink>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="avatar avatar-sm" style="background:#312e81;color:#a5b4fc;">@AuthInfo.Iniciales</div>
                <div class="sidebar-user-info">
                    <div class="sidebar-user-name">@AuthInfo.Nombre</div>
                    <div class="sidebar-user-role">
                        <span class="sidebar-rol-badge sidebar-rol-badge--@AuthInfo.Rol.ToLower()">
                            @RolLabel(AuthInfo.Rol)
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </aside>
    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger-btn" @onclick="OpenSidebar" title="Abrir menu">☰</button>
                <span class="topbar-title">@GetPageTitle()</span>
            </div>
            <div class="topbar-right">
                <button class="theme-toggle" @onclick="ToggleTheme">
                    @(Theme.IsDark ? "☀️" : "🌙")
                </button>
                <CampanaNotificaciones />
                <LoginDisplay />
            </div>
        </header>
        <main class="page-body">
            @Body
        </main>
    </div>
</div>
</CascadingValue>
</CascadingValue>

@code {
    [CascadingParameter] private RouteData? RouteData { get; set; }
    private bool sidebarOpen = false;
    private int propuestasPendientes = 0;
    private int cartasPendientes = 0;
    private Toast layoutToast = default!;
    private void OpenSidebar() => sidebarOpen = true;
    private void CloseSidebar() => sidebarOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthInfo.LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Theme.OnChange += StateHasChanged;
            await Theme.InitAsync();
            await AuthInfo.LoadAsync();

            try { propuestasPendientes = await DocumentoApi.GetPropuestasPendientesCountAsync(); } catch { }
            if (AuthInfo.PuedeResolverSolicitudes)
                try { cartasPendientes = await CartasApi.CountPendientesAsync(); } catch { }
        }

        // Reconectar el hub si se desconectó (server reiniciado, etc.)
        if (!Notificaciones.Conectado && !string.IsNullOrWhiteSpace(AuthInfo.Email))
        {
            var esAdminOJefe = AuthInfo.EsJefe || AuthInfo.EsAdmin;

            // IniciarAsync ya maneja el join al grupo admin internamente cuando esAdmin=true
            await Notificaciones.IniciarAsync(AuthInfo.Email, AuthInfo.ColaboradorId, esAdmin: esAdminOJefe);

            // Esperar conexión (máx 2s)
            for (int i = 0; i < 10; i++)
            {
                if (Notificaciones.Conectado) break;
                await Task.Delay(200);
            }

            if (firstRender && esAdminOJefe)
                Notificaciones.OnCuestionarioRespondido += OnCuestionarioRespondido;

            StateHasChanged();
        }
    }

    private void OnCuestionarioRespondido(TalentManagement.Shared.DTOs.Cuestionarios.CuestionarioRespondidoDto n)
    {
        var estado = n.Aprobado ? "✅ Aprobó" : "❌ No aprobó";
        var msg = $"📝 {n.ColaboradorNombre} completó \"{n.CapacitacionNombre}\" — {estado} ({n.Puntaje:0.#}%)";
        InvokeAsync(async () => { StateHasChanged(); if (layoutToast is not null) await layoutToast.Show(msg, n.Aprobado ? "success" : "warning"); });
    }

    private async Task ToggleTheme() => await Theme.ToggleAsync();

    public void Dispose()
    {
        Theme.OnChange -= StateHasChanged;
        Notificaciones.OnCuestionarioRespondido -= OnCuestionarioRespondido;
    }

    private static string RolLabel(string rol) => rol switch
    {
        "Admin"       => "🔑 Admin",
        "Jefe"        => "👔 Jefe",
        "Colaborador" => "👤 Colaborador",
        _             => rol
    };

    private string GetPageTitle() => RouteData?.PageType?.Name switch
    {
        "Home"                 => "Dashboard",
        "Colaboradores"        => "Colaboradores",
        "Capacitaciones"       => "Capacitaciones",
        "CapacitacionDetalle"  => "Detalle de Capacitacion",
        "Certificados"         => "Certificados",
        "Areas"                => "Areas",
        "AreaDetalle"          => "Detalle de Area",
        "Cargos"               => "Cargos",
        "Documentos"           => "Documentos",
        "DocumentoDetalle"     => "Detalle de Documento",
        "DocumentosPropuestas" => "Propuestas Pendientes",
        "CartasLaborales"      => "Mis Cartas Laborales",
        "CartasLaboralesAdmin" => "Administracion de Cartas",
        "MiHistorial"          => "Mi Historial de Capacitaciones",
        "Auditoria"            => "Auditoría del Sistema",
        "Landing"              => "Bienvenido",
        _                      => "NovaHub"
    };
}