@inherits LayoutComponentBase
@inject ThemeService Theme
@inject DocumentoApiService DocumentoApi
@inject AuthenticationStateProvider AuthState
@inject IConfiguration Config
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthInfoService AuthInfo
@implements IDisposable

<CascadingValue Value="AuthInfo.EsMicrosoftUser" Name="EsMicrosoftUser">
<CascadingValue Value="AuthInfo.EsSoloColaborador" Name="EsSoloColaborador">
<div class="app-layout @(sidebarOpen ? "sidebar-open" : "")">
    <!-- Overlay para cerrar sidebar en móvil -->
    @if (sidebarOpen)
    {
        <div class="sidebar-overlay" @onclick="CloseSidebar"></div>
    }
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <img src="logo.png" alt="NovaHub" class="sidebar-logo" />
            </div>
            <div class="sidebar-brand-text">
                <h1>NovaHub</h1>
                <span>Gestión de Talento</span>
            </div>
            <button class="sidebar-close-btn" @onclick="CloseSidebar">✕</button>
        </div>

        <nav class="sidebar-nav">
            <span class="nav-section-label">Principal</span>
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">🏠</span> Dashboard
            </NavLink>

            <span class="nav-section-label">Gestión</span>
            <NavLink class="nav-link" href="colaboradores">
                <span class="nav-icon">👥</span> Colaboradores
            </NavLink>
            <NavLink class="nav-link" href="capacitaciones">
                <span class="nav-icon">📚</span> Capacitaciones
            </NavLink>
            <NavLink class="nav-link" href="certificados">
                <span class="nav-icon">🏆</span> Certificados
            </NavLink>
            <NavLink class="nav-link" href="documentos">
                <span class="nav-icon">📄</span> Documentos
                @if (propuestasPendientes > 0)
                {
                    <span class="badge badge-warning badge-pill">@propuestasPendientes</span>
                }
            </NavLink>
            <NavLink class="nav-link" href="cartas">
                <span class="nav-icon">📋</span> Cartas Laborales
            </NavLink>

            <span class="nav-section-label">Configuración</span>
            <NavLink class="nav-link" href="areas">
                <span class="nav-icon">🏢</span> Áreas
            </NavLink>
            <NavLink class="nav-link" href="cargos">
                <span class="nav-icon">💼</span> Cargos
            </NavLink>
            <NavLink class="nav-link" href="cartas/admin">
                <span class="nav-icon">⚙️</span> Plantillas de Cartas
            </NavLink>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="avatar avatar-sm" style="background:#312e81;color:#a5b4fc;">@userInitials</div>
                <div class="sidebar-user-info">
                    <div class="sidebar-user-name">@userName</div>
                    <div class="sidebar-user-role">@userEmail</div>
                </div>
            </div>
            @if (isDevMode)
            {
                <div style="margin-top:.5rem;">
                    <div style="font-size:.65rem;color:var(--text-muted);margin-bottom:.25rem;text-transform:uppercase;letter-spacing:.05em;">
                        🛠️ Usuario dev
                    </div>
                    <select style="width:100%;font-size:.75rem;padding:.25rem .4rem;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--text);"
                            value="@userEmail"
                            @onchange="CambiarUsuarioDevAsync">
                        <option value="">— cuenta Microsoft —</option>
                        <option value="dev.colaborador@test.local">Andrés Martínez (Colaborador)</option>
                        <option value="dev.jefe@test.local">Carlos Herrera (Jefe Tecnología)</option>
                        <option value="dev.jeferrhh@test.local">Francy Gutiérrez (Jefe RRHH)</option>
                    </select>
                </div>
            }
        </div>
    </aside>

    <div class="main-content">
        <header class="topbar">
            <div class="topbar-left">
                <button class="hamburger-btn" @onclick="OpenSidebar" title="Abrir menú">☰</button>
                <span class="topbar-title">@GetPageTitle()</span>
            </div>
            <div class="topbar-right">
                <button class="theme-toggle" @onclick="ToggleTheme" title="@(Theme.IsDark ? "Tema claro" : "Tema oscuro")">
                    @(Theme.IsDark ? "☀️" : "🌙")
                </button>
                <LoginDisplay />
            </div>
        </header>
        <main class="page-body">
            @Body
        </main>
    </div>
</div>
</CascadingValue>
</CascadingValue>

@code {
    [CascadingParameter] private RouteData? RouteData { get; set; }

    private bool sidebarOpen = false;
    private int propuestasPendientes = 0;
    private string userName = "Usuario";
    private string userEmail = "";
    private string userInitials = "U";
    private bool isDevMode;

    private void OpenSidebar() => sidebarOpen = true;
    private void CloseSidebar() => sidebarOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isDevMode = Config.GetValue<bool>("DevMode");
            Theme.OnChange += StateHasChanged;
            await Theme.InitAsync();
            await AuthInfo.LoadAsync();

            if (isDevMode)
            {
                try
                {
                    var devInfo = await Http.GetFromJsonAsync<DevUsuarioActivoDto>(
                        "api/v1/dev/usuario-activo");
                    if (devInfo?.Activo == true && !string.IsNullOrWhiteSpace(devInfo.Email))
                    {
                        userEmail = devInfo.Email;
                        userName = devInfo.Email switch
                        {
                            "dev.colaborador@test.local" => "Andrés Martínez",
                            "dev.jefe@test.local"        => "Carlos Herrera",
                            "dev.jeferrhh@test.local"    => "Francy Gutiérrez",
                            _                            => devInfo.Email.Split('@')[0]
                        };
                        var parts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        userInitials = parts.Length >= 2
                            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
                            : userName[0..1].ToUpper();
                    }
                }
                catch { /* silencioso */ }
            }
            else
            {
                var auth = await AuthState.GetAuthenticationStateAsync();
                var user = auth.User;
                if (user.Identity?.IsAuthenticated == true)
                {
                    var name = user.FindFirst("name")?.Value
                            ?? user.FindFirst("preferred_username")?.Value
                            ?? user.Identity.Name
                            ?? "Usuario";
                    userEmail = user.FindFirst("preferred_username")?.Value
                             ?? user.FindFirst("upn")?.Value
                             ?? "";
                    userName = name;
                    var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                    userInitials = parts.Length >= 2
                        ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
                        : name.Length > 0 ? name[0..1].ToUpper() : "U";
                }
            }

            try
            {
                propuestasPendientes = await DocumentoApi.GetPropuestasPendientesCountAsync();
            }
            catch (AccessTokenNotAvailableException ex)
            {
                if (!isDevMode) ex.Redirect();
                return;
            }
            catch { /* silencioso — no crítico */ }

            StateHasChanged();
        }
    }

    private async Task CambiarUsuarioDevAsync(ChangeEventArgs e)
    {
        try
        {
            var email = e.Value?.ToString();
            await Http.PostAsJsonAsync("api/v1/dev/usuario-activo", new { email });
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
        catch { /* silencioso */ }
    }

    private record DevUsuarioActivoDto(string? Email, bool Activo);

    private async Task ToggleTheme() => await Theme.ToggleAsync();

    public void Dispose() => Theme.OnChange -= StateHasChanged;

    private string GetPageTitle() => RouteData?.PageType?.Name switch
    {
        "Home"                    => "Dashboard",
        "Colaboradores"           => "Colaboradores",
        "Capacitaciones"          => "Capacitaciones",
        "CapacitacionDetalle"     => "Detalle de Capacitación",
        "Certificados"            => "Certificados",
        "Areas"                   => "Áreas",
        "AreaDetalle"             => "Detalle de Área",
        "Cargos"                  => "Cargos",
        "Documentos"              => "Documentos",
        "DocumentoDetalle"        => "Detalle de Documento",
        "DocumentosPropuestas"    => "Propuestas Pendientes",
        "CartasLaborales"         => "Mis Cartas Laborales",
        "CartasLaboralesAdmin"    => "Plantillas de Cartas",
        _                         => "NovaHub"
    };
}
